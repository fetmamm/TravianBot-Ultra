<Window x:Class="TbotUltra.Desktop.SavePageHtmlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Save page HTML"
        Height="400"
        Width="460"
        MinHeight="400"
        MinWidth="440"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Save current page HTML"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,8" />

        <TextBlock Grid.Row="1"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,12"
                   Text="Copies the raw HTML of the page the browser is currently on and saves it to a file in the DOM folder. The notes and the page address are written at the top of the file. Use it to capture pages for later analysis when building or changing functions." />

        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,0,0,10">
            <TextBlock Text="File name"
                       VerticalAlignment="Center"
                       Margin="0,0,0,4" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FileNameTextBox"
                         Grid.Column="0"
                         TextChanged="FileNameTextBox_TextChanged" />
                <TextBlock Grid.Column="1"
                           Text=".txt"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSubtleBrush}"
                           Margin="6,0,0,0" />
            </Grid>
        </StackPanel>

        <TextBlock Grid.Row="3"
                   Text="Notes (written at the top of the file)"
                   VerticalAlignment="Center"
                   Margin="0,0,0,4" />
        <TextBox x:Name="NotesTextBox"
                 Grid.Row="4"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 MinHeight="80"
                 Margin="0,0,0,12" />

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left">
            <Button x:Name="OpenFolderButton"
                    Padding="10,4"
                    Margin="0,0,8,0"
                    Content="Open folder"
                    ToolTip="Opens the folder where the HTML files are saved."
                    Click="OpenFolderButton_Click" />
            <Button x:Name="ClearFolderButton"
                    Padding="10,4"
                    Content="Clear folder"
                    ToolTip="Deletes all files in the DOM folder (asks for confirmation first)."
                    Click="ClearFolderButton_Click" />
            <TextBlock x:Name="StatusTextBlock"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource InfoBrush}"
                       Margin="10,0,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="SaveButton"
                    Width="100"
                    Margin="0,0,8,0"
                    Background="{DynamicResource AccentBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Content="Save HTML"
                    Click="SaveButton_Click" />
            <Button x:Name="BulkSaveButton"
                    Width="100"
                    Margin="0,0,8,0"
                    Content="Bulk save"
                    Click="BulkSaveButton_Click" />
            <Button Width="100"
                    Content="Close"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
