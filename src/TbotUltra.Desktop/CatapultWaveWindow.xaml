<Window x:Class="TbotUltra.Desktop.CatapultWaveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Catapult Waves"
        Height="650"
        Width="760"
        MinHeight="560"
        MinWidth="680"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="Catapult waves"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#111827" />
                <Border Width="14"
                        Height="14"
                        CornerRadius="7"
                        Background="#E5E7EB"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        Margin="8,3,0,0"
                        VerticalAlignment="Center"
                        ToolTipService.InitialShowDelay="0">
                    <Border.ToolTip>
                        <ToolTip MaxWidth="360">
                            <StackPanel Width="320">
                                <TextBlock Text="Catapult waves"
                                           FontWeight="SemiBold"
                                           Foreground="#F9FAFB"
                                           Margin="0,0,0,6" />
                                <TextBlock TextWrapping="Wrap"
                                           Text="Prepares one first attack and multiple normal attack waves. Catapult targets use Random automatically when catapults are included." />
                            </StackPanel>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock Text="i"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#4B5563"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center" />
                </Border>
            </StackPanel>
            <TextBlock x:Name="RallyPointLevelTextBlock"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       Foreground="#4B5563"
                       FontWeight="SemiBold"
                       Text="Rallypoint level: -" />
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="8"
                Background="#FFFFFF"
                Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="X" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox x:Name="XTextBox" Grid.Column="1" Text="0" TextChanged="Input_TextChanged" />
                        <TextBlock Grid.Column="2" Text="Y" VerticalAlignment="Center" Margin="14,0,8,0" />
                        <TextBox x:Name="YTextBox" Grid.Column="3" Text="0" TextChanged="Input_TextChanged" />
                        <TextBlock Grid.Column="4" Text="Waves" VerticalAlignment="Center" Margin="14,0,8,0" />
                        <TextBox x:Name="WaveCountTextBox" Grid.Column="5" Text="21" TextChanged="Input_TextChanged" />
                        <RadioButton x:Name="NormalAttackRadioButton"
                                     Grid.Column="6"
                                     Content="Normal"
                                     IsChecked="True"
                                     VerticalAlignment="Center"
                                     Margin="14,0,8,0" />
                        <RadioButton x:Name="RaidAttackRadioButton"
                                     Grid.Column="7"
                                     Content="Raid"
                                     VerticalAlignment="Center" />
                        <Button x:Name="RefreshButton"
                                Grid.Column="9"
                                Width="100"
                                Content="Refresh"
                                Click="RefreshButton_Click" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Background="#F9FAFB"
                                Padding="10">
                            <StackPanel>
                                <TextBlock Text="First attack"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           Margin="0,0,0,8" />
                                <Grid x:Name="FirstAttackTroopsGrid" />
                                <StackPanel Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="Target building:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <RadioButton Content="Random" IsChecked="True" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Target building:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <RadioButton Content="Random" IsChecked="True" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Background="#F9FAFB"
                                Padding="10">
                            <StackPanel>
                                <TextBlock Text="Waves"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           Margin="0,0,0,8" />
                                <Grid x:Name="WaveTroopsGrid" />
                                <StackPanel Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="Target building:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <RadioButton Content="Random" IsChecked="True" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Target building:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <RadioButton Content="Random" IsChecked="True" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Margin="0,16,0,0"
                            Padding="10"
                            BorderBrush="#D1D5DB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Background="#F9FAFB">
                        <TextBlock x:Name="StatusTextBlock"
                                   Foreground="#374151"
                                   TextWrapping="Wrap"
                                   Text="Troops loaded from Rally Point. Click a first attack amount in parentheses to fill the remaining available amount." />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="StartButton"
                    Width="100"
                    Margin="0,0,8,0"
                    Background="#111827"
                    BorderBrush="#111827"
                    Foreground="#F9FAFB"
                    FontWeight="SemiBold"
                    Content="Start"
                    Click="StartButton_Click" />
            <Button x:Name="CancelButton"
                    Width="100"
                    Content="Cancel"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
