<Window x:Class="TbotUltra.Desktop.BuildingDemolishTargetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Demolish building"
        Width="340"
        MinHeight="240"
        SizeToContent="Height"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#111827"
                   Margin="0,0,0,6" />

        <TextBlock x:Name="SubtitleTextBlock"
                   Grid.Row="1"
                   Foreground="#6B7280"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <Button Grid.Row="2"
                Content="Demolish whole building"
                Height="30"
                Margin="0,0,0,14"
                Background="#991B1B"
                Foreground="White"
                BorderBrush="#7F1D1D"
                Click="DemolishWholeButton_Click" />

        <StackPanel Grid.Row="3">
            <TextBlock Text="Demolish to level"
                       Foreground="#374151"
                       FontSize="12"
                       Margin="0,0,0,4" />
            <DockPanel>
                <ComboBox x:Name="TargetLevelComboBox"
                          Height="28"
                          MinWidth="96"
                          Margin="0,0,8,0" />
                <Button Content="Queue"
                        Width="88"
                        Height="28"
                        Click="QueueTargetButton_Click" />
            </DockPanel>
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Width="88"
                    Height="28"
                    Content="Cancel"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
