<Window x:Class="TbotUltra.Desktop.BulkMessagesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TbotUltra.Desktop.Views"
        Title="Bulk messages"
        Width="720"
        Height="680"
        MinWidth="620"
        MinHeight="600"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Bulk messages"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock x:Name="PlayersTextBlock"
                               Text="Players: -"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
                <Button x:Name="AnalyzeButton"
                        Grid.Column="1"
                        Content="Refresh analysis"
                        MinWidth="130"
                        Padding="10,4"
                        Click="AnalyzeButton_Click" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="6"
                            Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Send order" VerticalAlignment="Center" />
                            <ComboBox x:Name="SortOrderComboBox"
                                      Grid.Column="1"
                                      Width="190"
                                      HorizontalAlignment="Left"
                                      SelectionChanged="InputChanged" />

                            <TextBlock Grid.Column="2"
                                       Text="Max recipients"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center" />
                            <TextBox x:Name="MaxRecipientsTextBox"
                                     Grid.Row="1"
                                     Grid.Column="2"
                                     Width="120"
                                     Margin="12,8,0,0"
                                     HorizontalAlignment="Left"
                                     Text="5000"
                                     TextChanged="InputChanged" />

                            <TextBlock Grid.Row="1"
                                       Text="Cached sent"
                                       Margin="0,8,0,0"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Row="1"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Margin="0,8,0,0">
                                <Button x:Name="ClearCacheButton"
                                        Content="Clear players cache"
                                        Padding="10,4"
                                        Click="ClearCacheButton_Click" />
                                <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                                Margin="6,0,0,0"
                                                ToolTip="Clears the remembered players for this account and server only. Players already messaged can be selected again after clearing." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Margin="0,10,0,0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="6"
                            Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Subject" VerticalAlignment="Center" />
                            <TextBox x:Name="SubjectTextBox"
                                     Grid.Column="1"
                                     MaxLength="80"
                                     TextChanged="InputChanged" />

                            <TextBlock Grid.Row="1"
                                       Text="Message"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Top" />
                            <TextBox x:Name="MessageTextBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,10,0,0"
                                     MinHeight="150"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="InputChanged" />

                            <TextBlock Grid.Row="2"
                                       Text="Exclude players"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Top" />
                            <TextBox x:Name="ExcludePlayersTextBox"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="0,10,0,0"
                                     MinHeight="54"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="InputChanged" />

                            <TextBlock Grid.Row="3"
                                       Text="Exclude alliances"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Top" />
                            <TextBox x:Name="ExcludeAlliancesTextBox"
                                     Grid.Row="3"
                                     Grid.Column="1"
                                     Margin="0,10,0,0"
                                     MinHeight="54"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="InputChanged" />
                        </Grid>
                    </Border>

                    <TextBlock x:Name="ValidationTextBlock"
                               Margin="0,12,0,0"
                               Foreground="{DynamicResource WarningTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,14,0,0">
                <Button x:Name="SendButton"
                        Content="Send messages"
                        MinWidth="140"
                        Margin="0,0,8,0"
                        Click="SendButton_Click" />
                <Button Content="Close"
                        Width="100"
                        Click="CloseButton_Click" />
            </StackPanel>
        </Grid>

        <views:BusyOverlayControl x:Name="LoadingOverlay"
                                  Title="Bulk messages"
                                  Text="Preparing..."
                                  Cancelled="LoadingOverlay_Cancelled" />
    </Grid>
</Window>
