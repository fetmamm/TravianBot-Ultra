<Window x:Class="TbotUltra.Desktop.AccountsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Accounts"
        Height="520"
        Width="820"
        MinHeight="480"
        MinWidth="760"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Grid.Row="0" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6">
            <DockPanel Margin="8">
                <TextBlock DockPanel.Dock="Top" Text="Accounts" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ListBox x:Name="AccountsListBox" DisplayMemberPath="Name" SelectionChanged="AccountsListBox_SelectionChanged" />
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Grid.Row="0" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6">
            <Grid Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Account name" Margin="0,0,8,8" VerticalAlignment="Center" />
                <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Username" Margin="0,0,8,8" VerticalAlignment="Center" />
                <TextBox x:Name="UsernameTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Password" Margin="0,0,8,8" VerticalAlignment="Center" />
                <PasswordBox x:Name="PasswordBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Server" Margin="0,0,8,8" VerticalAlignment="Center" />
                <ComboBox x:Name="ServerComboBox"
                          Grid.Row="3"
                          Grid.Column="1"
                          Margin="0,0,0,8"
                          DisplayMemberPath="Name"
                          SelectionChanged="ServerComboBox_SelectionChanged" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Server URL" Margin="0,0,8,8" VerticalAlignment="Center" />
                <TextBox x:Name="ServerUrlTextBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" IsReadOnly="True" />

                <CheckBox x:Name="SetActiveCheckBox" Grid.Row="5" Grid.Column="1" Content="Set as active account" Margin="0,0,0,8" />

                <TextBlock x:Name="InfoTextBlock" Grid.Row="6" Grid.ColumnSpan="2" TextWrapping="Wrap" Foreground="#334155" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="NewButton" Content="New" Width="90" Margin="0,0,8,0" Click="NewButton_Click" />
            <Button x:Name="SaveButton" Content="Save" Width="90" Margin="0,0,8,0" Click="SaveButton_Click" />
            <Button x:Name="DeleteButton" Content="Delete" Width="90" Margin="0,0,8,0" Click="DeleteButton_Click" />
            <Button x:Name="SetActiveButton" Content="Set Active" Width="100" Margin="0,0,8,0" Click="SetActiveButton_Click" />
            <Button x:Name="CloseButtonControl" Content="Close" Width="90" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
