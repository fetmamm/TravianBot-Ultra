<Window x:Class="TbotUltra.Desktop.AccountsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Accounts"
        Height="520"
        Width="820"
        MinHeight="480"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Closing="AccountsWindow_Closing">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
            <DockPanel Margin="8">
                <TextBlock DockPanel.Dock="Top" Text="Accounts" FontWeight="SemiBold" Margin="0,0,0,8" />
                <Grid DockPanel.Dock="Top" Margin="6,0,6,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Account" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SlateTextBrush}" />
                    <TextBlock Grid.Column="1" Text="Server" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SlateTextBrush}" Margin="8,0,0,0" />
                </Grid>
                <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource ControlBackgroundBrush}" Margin="0,0,0,4" />
                <ListBox x:Name="AccountsListBox"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="AccountsListBox_SelectionChanged"
                         MouseDoubleClick="AccountsListBox_MouseDoubleClick">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Username}" TextTrimming="CharacterEllipsis" Margin="0,0,8,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ServerSpeedLabel}"
                                           Foreground="{DynamicResource SlateTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="8,0,0,0" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Username/email" Margin="0,0,8,8" VerticalAlignment="Center" />
                <TextBox x:Name="UsernameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" TextChanged="EditorField_Changed" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Password" Margin="0,0,8,8" VerticalAlignment="Center" />
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="70" />
                    </Grid.ColumnDefinitions>

                    <PasswordBox x:Name="PasswordBox"
                                 Grid.Column="0"
                                 Margin="0,0,8,0"
                                 PasswordChanged="PasswordBox_PasswordChanged" />
                    <TextBox x:Name="PasswordTextBox"
                             Grid.Column="0"
                             Margin="0,0,8,0"
                             Visibility="Collapsed"
                             TextChanged="PasswordTextBox_TextChanged" />
                    <Button x:Name="TogglePasswordButton"
                            Grid.Column="1"
                            Content="Show"
                            Click="TogglePasswordButton_Click" />
                </Grid>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Server" Margin="0,0,8,8" VerticalAlignment="Center" />
                <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="130" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="ServerComboBox"
                              Grid.Column="0"
                              Margin="0,0,8,0"
                              DisplayMemberPath="Name"
                              MaxDropDownHeight="420"
                              ScrollViewer.CanContentScroll="False"
                              SelectionChanged="ServerComboBox_SelectionChanged">
                        <ComboBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SlateTextBrush}"
                                                   Margin="4,6,0,2" />
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ComboBox.GroupStyle>
                    </ComboBox>
                    <Button x:Name="ServerListButton"
                            Grid.Column="1"
                            Content="Custom servers"
                            Click="ServerListButton_Click" />
                </Grid>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Selected URL" Margin="0,0,8,16" VerticalAlignment="Center" />
                <TextBlock x:Name="ServerUrlTextBlock" Grid.Row="3" Grid.Column="1" Margin="0,0,0,16" VerticalAlignment="Center" Foreground="{DynamicResource SlateTextBrush}" />

                <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="UseProxyCheckBox" Content="Use proxy" VerticalAlignment="Center"
                                  Checked="UseProxyCheckBox_Changed" Unchecked="UseProxyCheckBox_Changed" />
                        <ContentControl Style="{DynamicResource InfoTooltipIconStyle}" Margin="6,0,0,0"
                                        ToolTip="Routes this account's browser traffic through your proxy so it uses a different IP.&#10;Choose proxy type, then enter host/IP and port separately.&#10;Examples: SOCKS5 1.2.3.4 1080, HTTP 1.2.3.4 8080.&#10;Applies on next bot start." />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <CheckBox x:Name="NeverUseOwnIpCheckBox"
                                  Content="Never use own IP"
                                  VerticalAlignment="Center"
                                  Checked="NeverUseOwnIpCheckBox_Changed"
                                  Unchecked="NeverUseOwnIpCheckBox_Changed" />
                        <ContentControl Style="{DynamicResource InfoTooltipIconStyle}" Margin="6,0,0,0"
                                        ToolTip="Blocks browser startup unless this account has a valid working proxy configured.&#10;Use this to avoid exposing your own IP address to Travian." />
                    </StackPanel>
                    <Button x:Name="CheckProxyButton"
                            Content="Check proxy"
                            Margin="0,6,0,0"
                            MinWidth="105"
                            HorizontalAlignment="Left"
                            IsEnabled="False"
                            Click="CheckProxyButton_Click" />
                    <Button x:Name="CheckMyIpButton"
                            Content="Check my IP address"
                            Margin="0,6,0,0"
                            MinWidth="130"
                            HorizontalAlignment="Left"
                            Click="CheckMyIpButton_Click" />
                    <Button x:Name="FindBestProxyButton"
                            Content="Find best proxy…"
                            Margin="0,6,0,0"
                            MinWidth="130"
                            HorizontalAlignment="Left"
                            Click="FindBestProxyButton_Click" />
                </StackPanel>
                <Grid Grid.Row="4" Grid.Column="1" Margin="0,0,0,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="SAVED PROXIES"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SlateTextBrush}"
                               Margin="0,0,8,2" />

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="SavedProxyComboBox"
                                  Grid.Column="0"
                                  Margin="0,0,8,0"
                                  DisplayMemberPath="DisplayText"
                                  IsEnabled="False"
                                  SelectionChanged="SavedProxyComboBox_SelectionChanged" />
                        <Button x:Name="ProxyLibraryButton"
                                Grid.Column="1"
                                Content="Proxy list…"
                                Click="ProxyLibraryButton_Click" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="105" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="TYPE"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SlateTextBrush}"
                                   Margin="0,0,8,2" />
                        <TextBlock Grid.Column="1"
                                   Text="IP"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SlateTextBrush}"
                                   Margin="0,0,8,2" />
                        <TextBlock Grid.Column="2"
                                   Text="PORT"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SlateTextBrush}"
                                   Margin="0,0,0,2" />
                    </Grid>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="105" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ProxySchemeComboBox"
                                  Grid.Column="0"
                                  Margin="0,0,8,0"
                                  IsEnabled="False"
                                  SelectedValuePath="Tag"
                                  SelectionChanged="ProxySchemeComboBox_SelectionChanged">
                            <ComboBoxItem Content="SOCKS5" Tag="socks5" />
                            <ComboBoxItem Content="SOCKS4" Tag="socks4" />
                            <ComboBoxItem Content="HTTP" Tag="http" />
                        </ComboBox>
                        <TextBox x:Name="ProxyHostTextBox"
                                 Grid.Column="1"
                                 Margin="0,0,8,0"
                                 IsEnabled="False"
                                 TextChanged="EditorField_Changed"
                                 ToolTip="Proxy host or IP, for example 45.61.129.165" />
                        <TextBox x:Name="ProxyPortTextBox"
                                 Grid.Column="2"
                                 IsEnabled="False"
                                 TextChanged="EditorField_Changed"
                                 ToolTip="Proxy port, for example 9050" />
                    </Grid>
                </Grid>

                <Border Grid.Row="6"
                        Grid.ColumnSpan="2"
                        Margin="0,12,0,0"
                        Padding="10,8"
                        VerticalAlignment="Bottom"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock x:Name="InfoTextBlock"
                               MinHeight="16"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource IronTextBrush}" />
                </Border>
            </Grid>
        </Border>

        <DockPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0">
            <Button x:Name="ClearAccountsButton"
                    DockPanel.Dock="Left"
                    Content="Clear accounts"
                    Width="120"
                    Background="{DynamicResource PrimaryButtonBrush}"
                    BorderBrush="{DynamicResource PrimaryButtonBrush}"
                    Foreground="{DynamicResource TooltipForegroundBrush}"
                    FontWeight="SemiBold"
                    Click="ClearAccountsButton_Click" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="NewButton" Content="New" Width="90" Margin="0,0,8,0" Click="NewButton_Click" />
                <Button x:Name="SaveButton" Content="Save" Width="90" Margin="0,0,8,0" Click="SaveButton_Click" />
                <Button x:Name="UpdateButton" Content="Update" Width="90" Margin="0,0,8,0" Click="UpdateButton_Click" />
                <Button x:Name="DeleteButton" Content="Delete" Width="90" Margin="0,0,8,0" Click="DeleteButton_Click" />
                <Button x:Name="CloseButtonControl" Content="Close" Width="90" Click="CloseButton_Click" />
            </StackPanel>
        </DockPanel>

        <Border x:Name="ProxyCheckOverlay"
                Grid.RowSpan="2"
                Grid.ColumnSpan="3"
                Background="#B0000000"
                Visibility="Collapsed">
            <Border Width="440"
                    Padding="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock x:Name="ProxyCheckTitleTextBlock"
                               Text="Proxy check"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,8" />
                    <TextBlock x:Name="ProxyCheckStatusTextBlock"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SlateTextBrush}"
                               Margin="0,0,0,12" />
                    <Grid x:Name="ProxyCheckResultGrid"
                          Visibility="Collapsed"
                          Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="ProxyCheckRow0LabelTextBlock" Grid.Row="0" Grid.Column="0" Text="IP" FontWeight="SemiBold" Foreground="{DynamicResource SlateTextBrush}" Margin="0,0,12,7" />
                        <TextBlock x:Name="ProxyCheckIpTextBlock" Grid.Row="0" Grid.Column="1" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,7" />
                        <TextBlock x:Name="ProxyCheckRow1LabelTextBlock" Grid.Row="1" Grid.Column="0" Text="Location" FontWeight="SemiBold" Foreground="{DynamicResource SlateTextBrush}" Margin="0,0,12,7" />
                        <TextBlock x:Name="ProxyCheckLocationTextBlock" Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,7" />
                        <TextBlock x:Name="ProxyCheckRow2LabelTextBlock" Grid.Row="2" Grid.Column="0" Text="ISP" FontWeight="SemiBold" Foreground="{DynamicResource SlateTextBrush}" Margin="0,0,12,7" />
                        <TextBlock x:Name="ProxyCheckIspTextBlock" Grid.Row="2" Grid.Column="1" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,7" />
                        <TextBlock x:Name="ProxyCheckRow3LabelTextBlock" Grid.Row="3" Grid.Column="0" Text="Route" FontWeight="SemiBold" Foreground="{DynamicResource SlateTextBrush}" Margin="0,0,12,7" />
                        <TextBlock x:Name="ProxyCheckRouteTextBlock" Grid.Row="3" Grid.Column="1" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,7" />
                        <TextBlock x:Name="ProxyCheckRow4LabelTextBlock" Grid.Row="4" Grid.Column="0" Text="Latency" FontWeight="SemiBold" Foreground="{DynamicResource SlateTextBrush}" Margin="0,0,12,7" />
                        <TextBlock x:Name="ProxyCheckLatencyTextBlock" Grid.Row="4" Grid.Column="1" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,7" />
                        <TextBlock x:Name="ProxyCheckRow5LabelTextBlock" Grid.Row="5" Grid.Column="0" Text="Target" FontWeight="SemiBold" Foreground="{DynamicResource SlateTextBrush}" Margin="0,0,12,0" Visibility="Collapsed" />
                        <TextBlock x:Name="ProxyCheckTargetTextBlock" Grid.Row="5" Grid.Column="1" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Visibility="Collapsed" />
                    </Grid>
                    <Button x:Name="ProxyCheckOverlayButton"
                            Content="Cancel"
                            Width="120"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Right"
                            Background="{DynamicResource DangerBgBrush}"
                            BorderBrush="{DynamicResource DangerBorderBrush}"
                            Foreground="{DynamicResource DangerTextBrush}"
                            Click="ProxyCheckOverlayButton_Click" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
