<Window x:Class="TbotUltra.Desktop.AccountsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Accounts"
        Height="520"
        Width="820"
        MinHeight="480"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Closing="AccountsWindow_Closing">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Grid.Row="0" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6">
            <DockPanel Margin="8">
                <TextBlock DockPanel.Dock="Top" Text="Accounts" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ListBox x:Name="AccountsListBox"
                         SelectionChanged="AccountsListBox_SelectionChanged"
                         MouseDoubleClick="AccountsListBox_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Username}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#111827" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Foreground" Value="#16A34A" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Margin="8,0,0,0"
                                           Foreground="#475569"
                                           Text="{Binding AnalysisStatus, StringFormat=Analyzed: {0}}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Grid.Row="0" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6">
            <Grid Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Username" Margin="0,0,8,8" VerticalAlignment="Center" />
                <TextBox x:Name="UsernameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" TextChanged="EditorField_Changed" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Password" Margin="0,0,8,8" VerticalAlignment="Center" />
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="70" />
                    </Grid.ColumnDefinitions>

                    <PasswordBox x:Name="PasswordBox"
                                 Grid.Column="0"
                                 Margin="0,0,8,0"
                                 PasswordChanged="PasswordBox_PasswordChanged" />
                    <TextBox x:Name="PasswordTextBox"
                             Grid.Column="0"
                             Margin="0,0,8,0"
                             Visibility="Collapsed"
                             TextChanged="PasswordTextBox_TextChanged" />
                    <Button x:Name="TogglePasswordButton"
                            Grid.Column="1"
                            Content="Show"
                            Click="TogglePasswordButton_Click" />
                </Grid>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Server" Margin="0,0,8,8" VerticalAlignment="Center" />
                <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="130" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="ServerComboBox"
                              Grid.Column="0"
                              Margin="0,0,8,0"
                              DisplayMemberPath="Name"
                              SelectionChanged="ServerComboBox_SelectionChanged" />
                    <Button x:Name="ServerListButton"
                            Grid.Column="1"
                            Content="Server list"
                            Click="ServerListButton_Click" />
                </Grid>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Selected URL" Margin="0,0,8,8" VerticalAlignment="Center" />
                <TextBlock x:Name="ServerUrlTextBlock" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" VerticalAlignment="Center" Foreground="#475569" />

                <TextBlock x:Name="InfoTextBlock" Grid.Row="4" Grid.ColumnSpan="2" TextWrapping="Wrap" Foreground="#334155" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="NewButton" Content="New" Width="90" Margin="0,0,8,0" Click="NewButton_Click" />
            <Button x:Name="SaveButton" Content="Save" Width="90" Margin="0,0,8,0" Click="SaveButton_Click" />
            <Button x:Name="UpdateButton" Content="Update" Width="90" Margin="0,0,8,0" Click="UpdateButton_Click" />
            <Button x:Name="DeleteButton" Content="Delete" Width="90" Margin="0,0,8,0" Click="DeleteButton_Click" />
            <Button x:Name="CloseButtonControl" Content="Close" Width="90" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
