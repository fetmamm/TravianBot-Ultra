<Window x:Class="TbotUltra.Desktop.ProductionBonusSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="15% production bonus"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="15% production bonus"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Yellow (+25%): the gold +25% bonus is running."
                       FontSize="12"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,6,0,0" />
            <TextBlock Text="Purple (+15%): the free +15% video bonus is running."
                       FontSize="12"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,2,0,0" />
            <TextBlock Text="Yellow (+15%): +15% is on cooldown, waiting for the next run."
                       FontSize="12"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,2,0,0" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <!-- Two rows (25%, 15%) x four resource columns are built in code-behind into this grid. -->
            <Grid x:Name="TimersGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="0,14,0,0">
            <TextBlock Text="Delay:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBox x:Name="DelayMinTextBox"
                     Width="52"
                     Margin="8,0,0,0"
                     Padding="6,3"
                     VerticalAlignment="Center"
                     BorderBrush="{DynamicResource BorderSubtleBrush}"
                     LostFocus="DelaySetting_Changed" />
            <TextBlock Text="-"
                       VerticalAlignment="Center"
                       Margin="6,0,6,0"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBox x:Name="DelayMaxTextBox"
                     Width="52"
                     Padding="6,3"
                     VerticalAlignment="Center"
                     BorderBrush="{DynamicResource BorderSubtleBrush}"
                     LostFocus="DelaySetting_Changed" />
            <TextBlock Text="min"
                       VerticalAlignment="Center"
                       Margin="6,0,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="After the daily 09:00 server-time reset, the bot waits a random time within this range before watching the videos again.&#10;&#10;Example: reset is 09:00 and 40 min is picked at random — the bot runs about 09:40 server time, then watches every available video in a row." />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Daily reset time (server)"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="When the free +15% video re-enables each day (server time). Auto-learn watches when the video becomes available and remembers the hour, per account. Manual: set the whole hour yourself." />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
                <RadioButton x:Name="ResetAutoRadio"
                             GroupName="ProductionBonusReset"
                             Content="Auto-learn"
                             VerticalAlignment="Center"
                             Checked="ResetMode_Changed" />
                <TextBlock x:Name="LearnedResetTextBlock"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
                <RadioButton x:Name="ResetManualRadio"
                             GroupName="ProductionBonusReset"
                             Content="Manual"
                             VerticalAlignment="Center"
                             Checked="ResetMode_Changed" />
                <ComboBox x:Name="ManualResetHourComboBox"
                          Width="80"
                          Margin="8,0,0,0"
                          VerticalAlignment="Center"
                          SelectionChanged="ResetMode_Changed" />
            </StackPanel>
        </StackPanel>

        <DockPanel Grid.Row="4"
                   LastChildFill="False"
                   Margin="0,16,0,0">
            <Button x:Name="ClearTimersButton"
                    DockPanel.Dock="Left"
                    Width="120"
                    Height="30"
                    Content="Clear timers"
                    Background="{DynamicResource DangerBrush}"
                    Foreground="White"
                    BorderBrush="{DynamicResource DangerBrush}"
                    ToolTip="Clear all remembered production bonus timers (for testing)."
                    Click="ClearTimersButton_Click" />
            <Button DockPanel.Dock="Right"
                    Width="80"
                    Height="30"
                    Content="Close"
                    Click="CloseButton_Click" />
            <Button x:Name="ScanTimersButton"
                    DockPanel.Dock="Right"
                    Width="120"
                    Height="30"
                    Content="Scan timers"
                    Margin="0,0,8,0"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    BorderBrush="{DynamicResource AccentBrush}"
                    ToolTip="Read the Advantages tab now to refresh these timers (no video is watched). Runs even when the bot is paused or stopped."
                    Click="ScanTimersButton_Click" />
        </DockPanel>
    </Grid>
</Window>
