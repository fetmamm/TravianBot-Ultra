<Window x:Class="TbotUltra.Desktop.TravcoToolsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TbotUltra.Desktop.Views"
        Title="Travco inactive search"
        Width="1200"
        Height="680"
        MinWidth="980"
        MinHeight="520"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                    <Button x:Name="InactiveSearchButton"
                            MinWidth="120"
                            HorizontalAlignment="Left"
                            Content="Analyze Travco"
                            Background="{DynamicResource AccentBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            Foreground="White"
                            Click="InactiveSearchButton_Click" />
                    <Button x:Name="SaveListButton"
                            Margin="0,8,0,0"
                            MinWidth="135"
                            HorizontalAlignment="Left"
                            Content="Save page as list"
                            Click="SaveListButton_Click" />
                    <Button x:Name="SaveAllPagesButton"
                            Margin="0,8,0,0"
                            MinWidth="155"
                            HorizontalAlignment="Left"
                            Content="Save all pages as list"
                            Click="SaveAllPagesButton_Click" />
                    <Button x:Name="CalculateDistanceButton"
                            Margin="0,8,0,0"
                            MinWidth="155"
                            HorizontalAlignment="Left"
                            Content="Calculate distance"
                            Click="CalculateDistanceButton_Click" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Button x:Name="AnalyzeMapOasisButton"
                            Content="Analyze map oasis"
                            MinWidth="150"
                            Margin="0,0,0,10"
                            HorizontalAlignment="Right"
                            Background="{DynamicResource AccentBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            Foreground="White"
                            Click="AnalyzeMapOasisButton_Click" />
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Village" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                    <TextBlock Grid.Column="2" Text="Active days" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                    <TextBlock Grid.Column="4" Text="Order by" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                    <TextBlock Grid.Column="6" Text="List name" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />

                    <ComboBox Grid.Row="1"
                              Grid.Column="0"
                              ItemsSource="{Binding Villages}"
                              SelectedItem="{Binding SelectedVillage}"
                              DisplayMemberPath="NameWithCoords" />
                    <TextBox Grid.Row="1"
                             Grid.Column="2"
                             VerticalContentAlignment="Center"
                             Text="{Binding DaysInactiveText, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox Grid.Row="1"
                              Grid.Column="4"
                              ItemsSource="{Binding OrderByOptions}"
                              SelectedValue="{Binding SelectedOrderBy}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Label" />
                    <TextBox x:Name="ListNameTextBox"
                             Grid.Row="1"
                             Grid.Column="6"
                             MinWidth="220"
                             MaxWidth="420"
                             HorizontalAlignment="Left"
                             VerticalContentAlignment="Center"
                             Text="{Binding ListName, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Saved lists"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,8" />
                        <DataGrid x:Name="SavedListsListBox"
                                  Grid.Row="1"
                                  ItemsSource="{Binding SavedLists}"
                                  SelectedItem="{Binding SelectedSavedList}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Width="*" MinWidth="90" Binding="{Binding Name}" />
                                <DataGridTextColumn Header="Saved date" Width="145" Binding="{Binding SavedDateText}" />
                                <DataGridTextColumn Header="Villages" Width="75" Binding="{Binding VillageCount}" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Open" Click="OpenListButton_Click" />
                            <Button Grid.Column="1" Margin="6,0,0,0" Content="Edit" Click="EditListButton_Click" />
                            <Button x:Name="SaveEditedListButton"
                                    Grid.Column="2"
                                    Margin="6,0,0,0"
                                    Content="Save"
                                    IsEnabled="False"
                                    Click="SaveEditedListButton_Click" />
                            <Button Grid.Column="3" Margin="6,0,0,0" Content="Delete" Click="DeleteListButton_Click" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">
                    <DataGrid x:Name="ResultsDataGrid"
                              ItemsSource="{Binding Rows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Extended">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn x:Name="UseColumn"
                                                    IsReadOnly="True"
                                                    Header="Use"
                                                    Width="52"
                                                    Binding="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn x:Name="DistanceColumn" Header="Distance" Width="90" IsReadOnly="True" Binding="{Binding Distance, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <DataGridTextColumn x:Name="AccountColumn" Header="Account" Width="*" MinWidth="150" IsReadOnly="True" Binding="{Binding Account, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <DataGridTextColumn x:Name="VillageColumn" Header="Village" Width="*" MinWidth="150" IsReadOnly="True" Binding="{Binding Village, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <DataGridTextColumn x:Name="PopColumn" Header="Pop" Width="90" IsReadOnly="True" Binding="{Binding Pop, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <DataGridTextColumn x:Name="CoordinatesColumn" Header="Coordinates" Width="110" IsReadOnly="True" Binding="{Binding Coordinates, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,12,0" />
                <Button Grid.Column="1" Width="100" Content="Close" Click="CloseButton_Click" />
            </Grid>
        </Grid>

        <views:BusyOverlayControl x:Name="BusyOverlay"
                                  ShowCancel="False"
                                  Cancelled="BusyOverlay_Cancelled"
                                  Title="Travco inactive search"
                                  Text="Searching Travco..." />
    </Grid>
</Window>
