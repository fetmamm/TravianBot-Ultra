<Window x:Class="TbotUltra.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tbot Ultra"
        Height="760"
        Width="1100"
        MinHeight="640"
        MinWidth="900"
        Background="#F2F4F7">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Tbot Ultra" FontSize="36" FontWeight="SemiBold" Margin="0,0,20,0" />
                <TextBlock Text="Account" VerticalAlignment="Center" Foreground="#4B5563" Margin="0,0,8,0" />
                <Button x:Name="AccountsButton" Content="Accounts" MinWidth="92" Height="30" Margin="0,0,12,0" Click="AccountsButton_Click" />
                <Button x:Name="LoginButton" Content="Login" MinWidth="92" Height="30" Margin="0,0,8,0" Background="#2563EB" Foreground="White" Click="LoginButton_Click" />
                <Button x:Name="LogoutButton" Content="Logout" MinWidth="92" Height="30" Margin="0,0,12,0" Click="LogoutButton_Click" />
                <Button x:Name="CheckStatusButton" Content="Check village status" MinWidth="160" Height="30" Margin="0,0,10,0" Click="CheckStatusButton_Click" />
                <Button x:Name="StartLoopButton" Content=">" Width="34" Height="30" Margin="0,0,4,0" Click="StartLoopButton_Click" />
                <Button x:Name="StopLoopButton" Content="||" Width="34" Height="30" Margin="0,0,8,0" Click="StopLoopButton_Click" IsEnabled="False" />
                <Button x:Name="RunOnceButton" Content="!" Width="34" Height="30" Margin="0,0,4,0" Click="RunOnceButton_Click" />
                <Button x:Name="HelpButton" Content="?" Width="34" Height="30" Margin="0,0,4,0" Click="HelpButton_Click" />
                <Button x:Name="ReloadButton" Content="v" Width="34" Height="30" Margin="0,0,4,0" Click="ReloadButton_Click" />
                <Button x:Name="InstallButton" Content="i" Width="34" Height="30" Margin="0,0,4,0" Click="InstallButton_Click" />
                <Button x:Name="SettingsButton" Content="⚙" Width="34" Height="30" Click="SettingsButton_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="ServerComboBox"
                      Grid.Column="0"
                      Height="26"
                      Margin="0,0,14,0"
                      DisplayMemberPath="Name"
                      SelectionChanged="ServerComboBox_SelectionChanged" />
            <ComboBox x:Name="VillageComboBox" Grid.Column="1" Height="26" Margin="0,0,14,0" />
            <TextBlock x:Name="VillagesInfoTextBlock" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,14,0" Text="Villages: -" Foreground="#4B5563" />
            <TextBlock x:Name="TribeInfoTextBlock" Grid.Column="3" VerticalAlignment="Center" Margin="0,0,14,0" Text="Tribe: -" Foreground="#4B5563" />
            <TextBlock x:Name="LastScanInfoTextBlock" Grid.Column="4" VerticalAlignment="Center" Margin="0,0,14,0" Text="Last scan: -" Foreground="#4B5563" />
            <TextBlock x:Name="BrowserInfoTextBlock" Grid.Column="5" VerticalAlignment="Center" Margin="0,0,14,0" Text="Browser: idle" Foreground="#4B5563" />
            <TextBlock x:Name="ClockTextBlock" Grid.Column="6" VerticalAlignment="Center" Text="Time: -" Foreground="#374151" HorizontalAlignment="Right" />
        </Grid>

        <TabControl Grid.Row="2" Margin="0,0,0,8">
            <TabItem Header="Dashboard" />
            <TabItem Header="Resources" />
            <TabItem Header="Buildings" />
            <TabItem Header="Queue" />
        </TabControl>

        <Border Grid.Row="3" BorderThickness="1" BorderBrush="#C9CED6" Background="#F8FAFC" CornerRadius="4">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="ScanAllVillagesButton" Grid.Row="0" Grid.Column="0" Height="34" Margin="0,0,8,10" Content="Scan all villages" Background="#2563EB" Foreground="White" Click="ScanAllVillagesButton_Click" />
                <Button x:Name="OpenVerificationBrowserButton" Grid.Row="0" Grid.Column="1" Height="34" Margin="8,0,0,10" Content="Open verification browser" Click="OpenVerificationBrowserButton_Click" />

                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="Overview" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,8" />
                <TextBlock x:Name="SummaryTextBlock" Grid.Row="2" Grid.ColumnSpan="2" Text="Run Check village status to populate the views." Margin="0,0,0,10" Foreground="#1F2937" />

                <TextBox x:Name="LogTextBox"
                         Grid.Row="3"
                         Grid.ColumnSpan="2"
                         FontFamily="Consolas"
                         FontSize="13"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         AcceptsReturn="True" />
            </Grid>
        </Border>

        <StatusBar Grid.Row="4" Margin="0,8,0,0" Background="#E5E7EB">
            <StatusBarItem>
                <TextBlock Text="Status" FontWeight="SemiBold" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock" Text="Ready." />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="LoopStateTextBlock" Text="Loop: stopped" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
