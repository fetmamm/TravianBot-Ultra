                                    Content="Pop out"
                                    Width="92"
                                    Click="QueuePopoutButton_Click"
                                    Background="#FFFFFF"
                                    BorderBrush="#E5E7EB" />
                            <Button x:Name="QueueClearButton"
                                    DockPanel.Dock="Right"
                                    Content="Clear active queue"
                                    Width="120"
                                    Margin="0,0,8,0"
                                    Click="QueueClearButton_Click"
                                    Background="#FEE2E2"
                                    BorderBrush="#FCA5A5"
                                    Foreground="#991B1B" />
                            <TextBlock />
                        </DockPanel>

                        <StackPanel Grid.Row="1" Margin="2,0,2,12">
                            <TextBlock x:Name="BuildQueueStatusTextBlock" Visibility="Collapsed" />
                            <TextBlock Text="All queue groups are shown together below."
                                       Foreground="#6B7280"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <TabControl x:Name="QueueSectionTabControl"
                                    Grid.Row="2"
                                    Margin="2,0,2,2"
                                    SelectionChanged="QueueSectionTabControl_SelectionChanged">
                            <TabItem x:Name="ActiveQueueTabItem" Header="Active queue">
                                <Border Background="#FFFFFF"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <Ellipse Width="8" Height="8" Fill="#16A34A" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Text="Active queue"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="QueueRemoveButton" Content="Remove" Width="76" Click="QueueRemoveButton_Click" Background="#FFFFFF" BorderBrush="#E5E7EB" />
                                        <Rectangle Width="1" Fill="#E5E7EB" Margin="10,3,10,3" />
                                        <Button x:Name="QueueMoveUpButton" Content="↑" Width="36" Click="QueueMoveUpButton_Click" Background="#FFFFFF" BorderBrush="#E5E7EB" ToolTip="Move up" />
                                        <Button x:Name="QueueMoveDownButton" Content="↓" Width="36" Margin="6,0,0,0" Click="QueueMoveDownButton_Click" Background="#FFFFFF" BorderBrush="#E5E7EB" ToolTip="Move down" />
                                        <Rectangle Width="1" Fill="#E5E7EB" Margin="10,3,10,3" />
                                        <Button x:Name="QueueRefreshButton" Content="Refresh" Width="76" Click="QueueRefreshButton_Click" Background="#FFFFFF" BorderBrush="#E5E7EB" />
                                    </StackPanel>
                                </DockPanel>

                                <DataGrid x:Name="QueueDataGrid"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserReorderColumns="False"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#F3F4F6"
                                          RowBackground="#FFFFFF"
                                          AlternatingRowBackground="#FAFBFC"
                                          BorderBrush="#E5E7EB"
                                          BorderThickness="1"
                                          HeadersVisibility="Column"
                                          ColumnHeaderHeight="32"
                                          RowHeight="30"
                                          FontSize="12">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F9FAFB" />
                                            <Setter Property="Foreground" Value="#374151" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="FontSize" Value="11" />
                                            <Setter Property="Padding" Value="10,6" />
                                            <Setter Property="BorderBrush" Value="#E5E7EB" />
                                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="10,4" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Foreground" Value="#1F2937" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#EEF2FF" />
                                                    <Setter Property="Foreground" Value="#1F2937" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Group" Width="1.15*" Binding="{Binding GroupName}" />
                                        <DataGridTextColumn Header="Task" Width="2.4*" Binding="{Binding DisplayName}" />
                                        <DataGridTemplateColumn Header="Status" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Status}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#1F2937" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                        <Setter Property="Foreground" Value="#16A34A" />
                                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Retries" Width="0.9*" Binding="{Binding RetriesText}" />
                                        <DataGridTextColumn Header="Created" Width="1.5*" Binding="{Binding CreatedAtServer}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                            </TabItem>
                            <TabItem x:Name="HistoryQueueTabItem" Header="History">
                                <Border Background="#FFFFFF"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                    <Ellipse Width="8" Height="8" Fill="#9CA3AF" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="History"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <DataGrid x:Name="QueueHistoryDataGrid"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserReorderColumns="False"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#F3F4F6"
                                          RowBackground="#FFFFFF"
                                          AlternatingRowBackground="#FAFBFC"
                                          BorderBrush="#E5E7EB"
                                          BorderThickness="1"
                                          HeadersVisibility="Column"
                                          ColumnHeaderHeight="32"
                                          RowHeight="30"
                                          FontSize="12">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F9FAFB" />
                                            <Setter Property="Foreground" Value="#374151" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="FontSize" Value="11" />
                                            <Setter Property="Padding" Value="10,6" />
                                            <Setter Property="BorderBrush" Value="#E5E7EB" />
                                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="10,4" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Foreground" Value="#4B5563" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#F3F4F6" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Group" Width="1.15*" Binding="{Binding GroupName}" />
                                        <DataGridTextColumn Header="Completed task" Width="2.4*" Binding="{Binding DisplayName}" />
                                        <DataGridTemplateColumn Header="Status" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Status}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#4B5563" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                        <Setter Property="Foreground" Value="#16A34A" />
                                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Retries" Width="0.7*" Binding="{Binding Retries}" />
                                        <DataGridTextColumn Header="Created" Width="1.5*" Binding="{Binding CreatedAtServer}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>

                <TabItem x:Name="LogsTabItem" Header="Logs">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                            <TextBlock Text="Filter:" VerticalAlignment="Center" Foreground="#374151" FontWeight="SemiBold" Margin="0,0,8,0" />
                            <ComboBox x:Name="LogCategoryFilterComboBox"
                                      Width="140"
                                      Margin="0,0,12,0"
                                      VerticalAlignment="Center"
                                      SelectionChanged="LogCategoryFilterComboBox_SelectionChanged"
                                      ToolTip="Show only log lines for this task category." />
                            <CheckBox x:Name="LogCleanModeToggle"
                                      Content="Clean"
                                      VerticalAlignment="Center"
                                      Checked="LogCleanModeToggle_Changed"
                                      Unchecked="LogCleanModeToggle_Changed"
                                      ToolTip="Hide high-volume noise lines (full log is still kept in the session file)." />
                            <Border Width="14"
                                    Height="14"
                                    Margin="8,0,0,0"
                                    CornerRadius="7"
                                    Background="#E5E7EB"
                                    BorderBrush="#D1D5DB"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    ToolTipService.InitialShowDelay="0">
                                <Border.ToolTip>
                                    <ToolTip MaxWidth="360">
                                        <StackPanel Width="320">
                                            <TextBlock Text="Clean log"
                                                       FontWeight="SemiBold"
                                                       Foreground="#F9FAFB"
                                                       Margin="0,0,0,6" />
                                            <TextBlock TextWrapping="Wrap"
                                                       Text="Hides high-volume technical lines from the visible log, such as routine login checks, UI sync, resource-production updates, and repeated internal scans." />
                                            <TextBlock Margin="0,8,0,0"
                                                       TextWrapping="Wrap"
                                                       Text="Important queue events, waits, actions, hero status, errors, and alarms are still shown. The full raw session log is still saved to file." />
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Text="i"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#4B5563"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <TabControl x:Name="TerminalAlarmTabControl" Grid.Row="1" Margin="0,0,0,8">
                            <TabItem Header="Log">
                                <Border Background="#020617" Padding="8">
                                    <ListBox x:Name="TerminalListBox"
                                             Background="#020617"
                                             Foreground="#93C5FD"
                                             BorderThickness="0"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             SelectionMode="Extended"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </TabItem>
                            <TabItem x:Name="AlarmTabItem" Header="Alarms">
                                <TabItem.Resources>
                                    <ControlTemplate x:Key="ActiveAlarmTabTemplate" TargetType="TabItem">
                                        <Border x:Name="AlarmTabBorder"
                                                Background="#DC2626"
                                                BorderBrush="#B91C1C"
                                                BorderThickness="1"
                                                CornerRadius="3,3,0,0"
                                                Padding="8,3"
                                                Margin="0,0,2,0">
                                            <ContentPresenter ContentSource="Header"
                                                              RecognizesAccessKey="True"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="AlarmTabBorder" Property="BorderBrush" Value="#7F1D1D" />
                                                <Setter TargetName="AlarmTabBorder" Property="BorderThickness" Value="2,2,2,0" />
                                                <Setter TargetName="AlarmTabBorder" Property="Padding" Value="7,3,7,4" />
                                                <Setter Property="Panel.ZIndex" Value="100" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.56" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </TabItem.Resources>
                                <Border Background="#110D0D" Padding="8">
                                    <ListBox x:Name="AlarmListBox"
                                             Background="#110D0D"
                                             BorderThickness="0"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             SelectionMode="Extended"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#FCA5A5" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsAcknowledged}" Value="True">
                                                                    <Setter Property="Foreground" Value="#93C5FD" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </TabItem>
                        </TabControl>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="CopyFeedbackTextBlock"
                                       Text=""
                                       Foreground="#16A34A"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Visibility="Collapsed" />
                            <Button x:Name="PopoutLogsButton" Content="Pop out" Margin="0,0,8,0" Padding="10,4" Click="PopoutLogsButton_Click" />
                            <Button x:Name="CopyCurrentTabButton" Content="Copy" Margin="0,0,8,0" Padding="10,4" Click="CopyCurrentTabButton_Click" />
                            <Button x:Name="AcknowledgeAlarmButton" Content="Acknowledge alarms" Margin="0,0,8,0" Padding="10,4" Click="AcknowledgeAlarmButton_Click" />
                            <Button x:Name="ClearCurrentLogButton" Content="Clear" Padding="10,4" Click="ClearCurrentLogButton_Click" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem x:Name="InboxTabItem" Header="Inbox"
                         DataContext="{Binding InboxVm, ElementName=RootWindow}">
                    <views:InboxPanel x:Name="InboxPanelControl" />
                </TabItem>
                </TabControl>
                </Grid>
            </Border>

        </Grid>

        <views:BusyOverlayControl x:Name="BusyOverlay"
                                  Grid.Column="0" Grid.ColumnSpan="2"
                                  Cancelled="BusyOverlay_Cancelled" />

    </Grid>
</Window>




