<Window x:Class="TbotUltra.Desktop.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TbotUltra.Desktop"
        xmlns:views="clr-namespace:TbotUltra.Desktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tbot Ultra"
        Height="740"
        Width="1180"
        MinHeight="640"
        MinWidth="980"
        ShowInTaskbar="True"
        Background="#F3F4F6">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Buttons.xaml" />
                <ResourceDictionary Source="Themes/Badges.xaml" />
                <ResourceDictionary Source="Themes/Toggles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="0.88" ScaleY="0.88" />
        </Grid.LayoutTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#EFEFEF" BorderBrush="#D1D5DB" BorderThickness="0,0,1,0">
            <Grid Margin="10,8,10,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Tbot Ultra" FontSize="26" FontWeight="SemiBold" Foreground="#111827" />
                    <TextBlock x:Name="VersionTextBlock" Text="Version: -" Foreground="#6B7280" Margin="0,2,0,0" />
                </StackPanel>

                <Border Grid.Row="1" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="7" Margin="0,0,0,6">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Account" Foreground="#6B7280" VerticalAlignment="Center" />
                            <Button x:Name="AccountManageButton"
                                    DockPanel.Dock="Right"
                                    Content="Manage"
                                    Height="22"
                                    Width="72"
                                    Padding="8,1"
                                    Margin="6,0,0,0"
                                    HorizontalAlignment="Right"
                                    Click="AccountsButton_Click" />
                        </DockPanel>
                        <ComboBox x:Name="AccountComboBox"
                                  Height="30"
                                  DisplayMemberPath="PickerName"
                                  SelectionChanged="AccountComboBox_SelectionChanged" />
                        <TextBlock x:Name="ActiveAccountInfoTextBlock"
                                   Margin="0,6,0,0"
                                   Foreground="#4B5563"
                                    Text="Account: - | Server: -" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="7" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="LoginButton"
                                Grid.Column="0"
                                Margin="0,0,3,0"
                                Content="Login"
                                Background="#030826"
                                Foreground="White"
                                BorderBrush="#030826"
                                Click="LoginButton_Click" />
                        <Button x:Name="LogoutButton"
                                Grid.Column="1"
                                Margin="3,0,0,0"
                                Content="Logout"
                                Click="LogoutButton_Click" />
                    </Grid>
                </Border>

                <Border Grid.Row="3" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="7" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="Village" Foreground="#6B7280" Margin="0,0,0,5" />
                        <ComboBox x:Name="VillageComboBox" Height="28">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NameWithCoords}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#111827" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCapital}" Value="True">
                                                        <Setter Property="Foreground" Value="#D97706" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="4">
                    <Button x:Name="DashboardNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Dashboard" Tag="dashboard" Click="SidebarNavButton_Click" />
                    <Button x:Name="ResourcesNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Resources" Tag="resources" Click="SidebarNavButton_Click" />
                    <Button x:Name="BuildingsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Building" Tag="buildings" Click="SidebarNavButton_Click" />
                    <Button x:Name="HeroNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Hero / Adventures" Tag="hero" Click="SidebarNavButton_Click" />
                    <Button x:Name="FarmingNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Farming" Tag="farming" Click="SidebarNavButton_Click" />
                    <Button x:Name="TroopsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Troops" Tag="troops" Click="SidebarNavButton_Click" />
                    <Button x:Name="NpcTradeNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="NPC / Trade" Tag="npc_trade" Click="SidebarNavButton_Click" />
                    <Button x:Name="QueueNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Queue" Tag="queue" Click="SidebarNavButton_Click" />
                    <Button x:Name="LogsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Logs" Tag="logs" Click="SidebarNavButton_Click" />
                    <Button x:Name="InboxNavButton" Content="Messages / Reports" Tag="inbox" Click="SidebarNavButton_Click"
                            ToolTip="{Binding InboxVm.NavTooltip, ElementName=RootWindow}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InboxVm.HasUnreadMessages, ElementName=RootWindow}" Value="True">
                                        <Setter Property="Background" Value="#DC2626" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <Border Grid.Row="5" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="7">
                    <StackPanel>
                        <Border x:Name="LoopStateBadge"
                                Background="#6B7280"
                                CornerRadius="10"
                                Padding="8,2,8,2"
                                Margin="0,0,0,6"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="LoopStateTextBlock"
                                       Text="State: idle"
                                       Foreground="White"
                                       FontWeight="SemiBold" />
                        </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Continuous run"
                                           VerticalAlignment="Center"
                                           Foreground="#374151"
                                           FontWeight="SemiBold"
                                           Margin="0,0,8,0" />
						        <ToggleButton x:Name="ContinuousRunToggleButton"
                                              Style="{StaticResource ContinuousRunToggleStyle}"
                                              IsChecked="True"
                                              ToolTip="When enabled, Start/Pause/Stop controls continuous running."
                                              Unchecked="ContinuousRunToggleButton_Unchecked" />
                            </StackPanel>

						    <Grid Margin="0,0,0,6">
							    <Grid.ColumnDefinitions>
								    <ColumnDefinition Width="*" />
								    <ColumnDefinition Width="Auto" />
							    </Grid.ColumnDefinitions>
							    <Button x:Name="StartLoopButton" Grid.Column="0" Content="Start bot" Background="#030826" Foreground="White" BorderBrush="#030826" Click="StartLoopButton_Click" />
							    <Button x:Name="StopBotButton" Grid.Column="1" Content="&#9632;" Width="30" Padding="0" Margin="6,0,0,0" Click="StopBotButton_Click" ToolTip="Stop bot" />
						    </Grid>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="SettingsButton"
                                    Grid.Column="0"
                                    Content="Settings"
                                    Click="SettingsButton_Click"
                                    Margin="0,0,6,0" />
                            <Button x:Name="SupportButton"
                                    Grid.Column="1"
                                    Content="&#xE715;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Width="30"
                                    Padding="0"
                                    Margin="6,0,0,0"
                                    ToolTip="Support"
                                    Click="SupportButton_Click" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="12,8,12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                <DockPanel>
                    <TextBlock x:Name="BrowserInfoTextBlock" Text="Browser: idle" Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Left" />
                    <TextBlock x:Name="TribeInfoTextBlock" Text="Tribe: -" Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Right" />
                    <TextBlock Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Right">
                        <Run Text="Plus: " /><Run x:Name="PlusInfoTextBlock" Text="-" />
                    </TextBlock>
                    <TextBlock Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Right">
                        <Run Text="Goldclub: " /><Run x:Name="GoldClubInfoTextBlock" Text="-" />
                    </TextBlock>
                    <TextBlock x:Name="ServerResourcesTextBlock" Text="Gold: - | Silver: -" Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Right" />
                    <TextBlock x:Name="CaptchaStatsTextBlock" Text="Captchas solved: 0/0" Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Right" />
                    <TextBlock x:Name="ClockTextBlock" Text="Time: -" Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Left" />
                    <TextBlock x:Name="StatusTextBlock" Text="Ready." Visibility="Collapsed" />
                </DockPanel>
            </Border>

            <StatusBar Grid.Row="1" Margin="0,0,0,8" Background="#E5E7EB">
                <StatusBarItem>
                    <TextBlock Text="Status" FontWeight="SemiBold" />
                </StatusBarItem>
                <StatusBarItem>
                    <TextBlock x:Name="StatusMiniLogTextBlock" Text="Ready." Foreground="#1F2937" />
                </StatusBarItem>
            </StatusBar>

            <Border Grid.Row="2"
                    Margin="0,8,0,0"
                    Background="#F9FAFB"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            DataContext="{Binding ResourcesVm, ElementName=RootWindow}"
                            Background="#FFFFFF"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,8">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <Button x:Name="OpenResourceTestFunctionsButton"
                                        DockPanel.Dock="Right"
                                        Content="Test functions"
                                        Padding="10,4"
                                        Click="OpenResourceTestFunctionsButton_Click" />
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <TextBlock Text="Storage"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           VerticalAlignment="Center" />
                                <Button x:Name="StorageRefreshButton"
                                        Width="26"
                                        Height="26"
                                        Padding="0"
                                        Margin="8,0,8,0"
                                        FontFamily="Segoe MDL2 Assets"
                                        Content="&#xE72C;"
                                        ToolTip="Refresh storage from the current page"
                                        Click="StorageRefreshButton_Click" />
                                </StackPanel>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding StorageBars}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,8,0"
                                                Padding="8"
                                                CornerRadius="8"
                                                Background="#F9FAFB"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="1"
                                                ToolTipService.InitialShowDelay="500"
                                                ToolTip="{Binding TooltipText}">
                                            <StackPanel>
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left"
                                                               Text="{Binding DisplayName}"
                                                               Foreground="#374151"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding PercentText}"
                                                               Foreground="{Binding StatusBrush}"
                                                               FontWeight="SemiBold" />
                                                </DockPanel>
                                                <ProgressBar Height="10"
                                                             Margin="0,6,0,6"
                                                             Minimum="0"
                                                             Maximum="100"
                                                             Value="{Binding PercentValue}"
                                                             Foreground="{Binding BarBrush}"
                                                             Background="{Binding TrackBrush}" />
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left"
                                                               Text="{Binding CurrentMaxText}"
                                                               Foreground="#4B5563"
                                                               FontSize="11" />
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding TimeUntilFullText}"
                                                               Foreground="{Binding StatusBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold" />
                                                </DockPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <TabControl Grid.Row="1" x:Name="MainTabControl" Background="Transparent" BorderThickness="0">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Style>
                    </TabControl.ItemContainerStyle>

                <TabItem x:Name="DashboardTabItem" Header="Dashboard">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="Dashboard" FontSize="32" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right" x:Name="ResetProgramButton" Height="32" Content="Reset program" Background="#FCD34D" Foreground="#1F2937" BorderBrush="#F59E0B" VerticalAlignment="Center" Margin="12,0,0,0" Click="ResetProgramButton_Click"
                                    ToolTip="Restart the program: stops all running tasks, clears the queue, closes the browser session, and resets to the just-started state. Your saved login is kept — just press Login to start a new session." />
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,10" Visibility="Collapsed">
                            <TextBlock x:Name="VillagesInfoTextBlock" Text="Villages: -" />
                            <TextBlock x:Name="LastScanInfoTextBlock" Text="Last scan: -" />
                        </Grid>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="260" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,0,10,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                        <TextBlock DockPanel.Dock="Left" Text="Automation Loop" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                                        <Button x:Name="DashboardFunctionListButton"
                                                DockPanel.Dock="Right"
                                                Height="30"
                                                Content="Function list"
                                                MinWidth="70"
                                                Click="DashboardFunctionListButton_Click" />
                                        <StackPanel DockPanel.Dock="Right" Visibility="Collapsed">
                                            <Ellipse x:Name="AutomationLoopRunStateDot" Width="8" Height="8" Fill="#9CA3AF" />
                                            <TextBlock x:Name="AutomationLoopRunStateTextBlock" Text="Idle" />
                                        </StackPanel>
                                    </DockPanel>

                                    <ListBox x:Name="AutomationLoopListBox"
                                             Grid.Row="1"
                                             Margin="0,0,0,8"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             SelectionMode="Single"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             AllowDrop="True"
                                             PreviewMouseLeftButtonDown="AutomationLoopListBox_PreviewMouseLeftButtonDown"
                                             PreviewMouseMove="AutomationLoopListBox_PreviewMouseMove"
                                             DragOver="AutomationLoopListBox_DragOver"
                                             Drop="AutomationLoopListBox_Drop">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <local:VerticalFirstUniformGrid Columns="2" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,0,6,6" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="9" Padding="8" Background="#FFFFFF">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FFFFFF" />
                                                            <Setter Property="BorderBrush" Value="#D1D5DB" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                    <Setter Property="Background" Value="#F9FAFB" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                    <Setter Property="Background" Value="#DCFCE7" />
                                                                    <Setter Property="BorderBrush" Value="#16A34A" />
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0"
                                                                    Orientation="Vertical"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center"
                                                                    Margin="0,0,8,0">
                                                            <Border Width="24"
                                                                    Height="24"
                                                                    CornerRadius="12"
                                                                    Margin="0,0,0,6"
                                                                    Background="#2563EB">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#2563EB" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                                <Setter Property="Background" Value="#16A34A" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding Order}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <ToggleButton Style="{StaticResource ContinuousRunToggleStyle}"
                                                                          HorizontalAlignment="Center"
                                                                          IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                                          Click="AutomationLoopToggleButton_Click" />
                                                        </StackPanel>

                                                        <Border Grid.Column="1" BorderBrush="#2563EB" BorderThickness="3,0,0,0" Padding="8,0,0,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="BorderBrush" Value="#2563EB" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="#16A34A" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                            <Setter Property="BorderBrush" Value="#D1D5DB" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid VerticalAlignment="Center">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <StackPanel Grid.Column="0">
                                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="#111827" TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock Text="Running" Margin="8,0,0,0" Foreground="#16A34A" FontSize="12" FontWeight="SemiBold">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Description}" Foreground="#4B5563" FontSize="11" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding StateText}" Foreground="#1D4ED8" FontSize="11" FontWeight="SemiBold" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                                        <TextBlock Text="{Binding QueuedCount, StringFormat=Queued: {0}}" Foreground="#4B5563" FontSize="11" VerticalAlignment="Center" />
                                                                        <Border Margin="8,0,0,0"
                                                                                Padding="6,1"
                                                                                CornerRadius="5"
                                                                                BorderThickness="1"
                                                                                VerticalAlignment="Center">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background" Value="#F0FDF4" />
                                                                                    <Setter Property="BorderBrush" Value="#BBF7D0" />
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding TaskName}" Value="hero">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding HeroVm.AdventureCountText, ElementName=RootWindow}" Value="0">
                                                                                            <Setter Property="Background" Value="#F3F4F6" />
                                                                                            <Setter Property="BorderBrush" Value="#D1D5DB" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="Adv:" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Foreground" Value="#166534" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HeroVm.AdventureCountText, ElementName=RootWindow}" Value="0">
                                                                                                    <Setter Property="Foreground" Value="#6B7280" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                                <TextBlock Text="{Binding HeroVm.AdventureCountText, ElementName=RootWindow}"
                                                                                           FontWeight="SemiBold"
                                                                                           FontSize="12"
                                                                                           VerticalAlignment="Center">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Foreground" Value="#166534" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HeroVm.AdventureCountText, ElementName=RootWindow}" Value="0">
                                                                                                    <Setter Property="Foreground" Value="#6B7280" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding DetailText}" Foreground="#6B7280" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>

                                                                <ItemsControl Grid.Column="1"
                                                                              ItemsSource="{Binding TroopTrainingVm.Buildings, ElementName=RootWindow}"
                                                                              Margin="8,0,0,0"
                                                                              HorizontalAlignment="Left"
                                                                              VerticalAlignment="Center">
                                                                    <ItemsControl.Style>
                                                                        <Style TargetType="ItemsControl">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding TaskName}" Value="troop_training">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </ItemsControl.Style>
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <UniformGrid Columns="3" />
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <StackPanel Margin="0,0,4,0">
                                                                                <TextBlock Text="{Binding Title}"
                                                                                           FontSize="11"
                                                                                           FontWeight="SemiBold"
                                                                                           Foreground="#111827"
                                                                                           HorizontalAlignment="Left"
                                                                                           TextAlignment="Left" />
                                                                                <Border Margin="0,4,0,0"
                                                                                        HorizontalAlignment="Left"
                                                                                        Width="58"
                                                                                        Padding="5,2"
                                                                                        CornerRadius="6"
                                                                                        Background="{Binding QueueBadgeBackground}"
                                                                                        BorderBrush="{Binding QueueBadgeBorderBrush}"
                                                                                        BorderThickness="1">
                                                                                    <TextBlock Text="{Binding QueueTimerText}"
                                                                                               Foreground="{Binding QueueBadgeForeground}"
                                                                                               FontWeight="SemiBold"
                                                                                               FontSize="11"
                                                                                               HorizontalAlignment="Center"
                                                                                               TextAlignment="Center" />
                                                                                </Border>
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Grid>
                                                        </Border>

                                                        <StackPanel Grid.Column="2"
                                                                    Orientation="Vertical"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center">
                                                                    <Border Padding="8,3"
                                                                            CornerRadius="8"
                                                                            VerticalAlignment="Center"
                                                                            BorderThickness="1"
                                                                            MinWidth="70">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#DCFCE7" />
                                                                        <Setter Property="BorderBrush" Value="#22C55E" />
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                                                <Setter Property="Background" Value="#E5E7EB" />
                                                                                <Setter Property="BorderBrush" Value="#9CA3AF" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding HasTimer}" Value="True">
                                                                                <Setter Property="Background" Value="#FEF3C7" />
                                                                                <Setter Property="BorderBrush" Value="#F59E0B" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="{Binding BadgeText}" />
                                                                            <Setter Property="Foreground" Value="#15803D" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                                                    <Setter Property="Text" Value="{Binding BlockedText}" />
                                                                                    <Setter Property="Foreground" Value="#6B7280" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding HasTimer}" Value="True">
                                                                                    <Setter Property="Text" Value="{Binding TimerText}" />
                                                                                    <Setter Property="Foreground" Value="#B45309" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>

                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <TextBlock Grid.Row="2"
                                               x:Name="AutomationLoopSummaryTextBlock"
                                               Text="Loop cycles through enabled tasks continuously."
                                               HorizontalAlignment="Center"
                                               Foreground="#4B5563" />
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="9" Padding="12">
                                <StackPanel Grid.IsSharedSizeScope="True">
                                    <TextBlock Text="Villages" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6" />
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="VillagePopColumn" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="VillageCoordsColumn" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="VillageFlagColumn" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Village" FontWeight="SemiBold" Foreground="#111827" />
                                        <TextBlock Grid.Column="1" Text="Pop" FontWeight="SemiBold" Foreground="#111827" Margin="8,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="Coords" FontWeight="SemiBold" Foreground="#111827" Margin="8,0,0,0" />
                                    </Grid>
                                    <ItemsControl x:Name="DashboardVillageList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="VillagePopColumn" />
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="VillageCoordsColumn" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="VillageFlagColumn" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#374151" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding PopText}" Foreground="#374151" FontSize="13" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="2" Text="{Binding CoordsText}" Foreground="#374151" FontSize="13" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="4" Text="{Binding CapitalText}" Foreground="#D97706" FontSize="13" FontWeight="SemiBold" Margin="8,0,0,0" HorizontalAlignment="Right" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem x:Name="ResourcesTabItem" Header="Resources"
                         DataContext="{Binding ResourcesVm, ElementName=RootWindow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="Resources"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal">
                            <Button x:Name="LoadResourcesButton" Content="↻" Width="42" FontSize="16" Click="LoadResourcesButton_Click" ToolTip="Refresh resources" />
                            <TextBlock Text="Target level" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox x:Name="ResourceTargetLevelComboBox" Width="90" Margin="0,0,8,0" />
                            <Button x:Name="UpgradeAllResourcesButton" Content="Upgrade all to level" Width="160" Background="#030826" Foreground="White" BorderBrush="#030826" Click="UpgradeAllResourcesButton_Click"
                                    ToolTip="Queue upgrades for every resource field up to the target level selected on the left, following the chosen Build order (Lowest level first or Smart)." />
                            <Button x:Name="UpgradeAllResourcesToMaxButton" Content="Upgrade to max" Width="140" Margin="8,0,0,0" Background="#FCD34D" Foreground="#1F2937" BorderBrush="#F59E0B" Click="UpgradeAllResourcesToMaxButton_Click"
                                    ToolTip="Queue upgrades for every resource field up to its maximum level, following the chosen Build order (Lowest level first or Smart)." />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Build order:" VerticalAlignment="Center" Foreground="#374151" FontWeight="SemiBold" Margin="0,0,12,0" />
                                <RadioButton Content="Lowest level first"
                                             GroupName="ResourceBuildStrategy"
                                             VerticalAlignment="Center"
                                             Margin="0,0,16,0"
                                             IsChecked="{Binding IsBuildLowestFirst}"
                                             Click="ResourceBuildStrategyRadio_Click"
                                             ToolTip="When using 'Upgrade all', always upgrade the resource field with the lowest level first, so all fields rise evenly toward the target level." />
                                <RadioButton Content="Smart (least in storage)"
                                             GroupName="ResourceBuildStrategy"
                                             VerticalAlignment="Center"
                                             IsChecked="{Binding IsBuildSmart}"
                                             Click="ResourceBuildStrategyRadio_Click"
                                             ToolTip="When using 'Upgrade all', prioritize fields that produce the resource you currently have the least of in storage (wood/clay/iron/crop), re-evaluated each pass to balance your stockpile." />
                            </StackPanel>
                            <Border Background="#FFFFFF"
                                    BorderBrush="#D1D5DB"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="Production"
                                                   Foreground="#111827"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>
                                    <ItemsControl ItemsSource="{Binding StorageBars}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="4" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,8,0"
                                                        Padding="8"
                                                        CornerRadius="6"
                                                        Background="{Binding TrackBrush}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="#374151"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding ProductionText}"
                                                                   Foreground="#111827"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Border Grid.Row="1" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Background="#FFFFFF" Padding="12">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <Grid HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Width="190" Margin="0,0,8,0">
                                    <TextBlock Text="Woodcutter" Foreground="#0F766E" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding WoodFields}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#E4F2F1" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="#134E4A"
                                                                Background="#A5E1DA"
                                                                BorderBrush="#74CCC2"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Width="190" Margin="0,0,8,0">
                                    <TextBlock Text="Clay Pit" Foreground="#DC4C1D" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding ClayFields}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FDECE5" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="#7C2D12"
                                                                Background="#F9C9AF"
                                                                BorderBrush="#F2A57E"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Width="190" Margin="0,0,8,0">
                                    <TextBlock Text="Iron Mine" Foreground="#334155" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding IronFields}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#EAF0F4" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="#1E293B"
                                                                Background="#B7C7D4"
                                                                BorderBrush="#92ABC0"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel x:Name="CroplandColumnPanel" Grid.Column="3" Width="190" Margin="0,0,0,0">
                                    <TextBlock Text="Cropland" Foreground="#C47F00" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl x:Name="CroplandItemsControl" ItemsSource="{Binding CroplandFields}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="1" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FFF5DF" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="#7C5C0B"
                                                                Background="#F7E3A3"
                                                                BorderBrush="#EACD73"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                            </ScrollViewer>
                        </Border>
                        <DataGrid x:Name="ResourcesDataGrid" Visibility="Collapsed" />
                        <TextBlock x:Name="ResourcesInfoTextBlock" Visibility="Collapsed" Text="Resources not loaded yet." />
                    </Grid>
                </TabItem>

                <TabItem x:Name="BuildingsTabItem" Header="Buildings">
                    <Grid>
                        <views:BuildingsPanel />

                        <!-- Hidden compatibility controls used by existing building code-behind -->
                        <StackPanel Visibility="Collapsed">
                            <ComboBox x:Name="BuildingCategoryComboBox" />
                            <ComboBox x:Name="ConstructBuildingComboBox" />
                            <ComboBox x:Name="DemolishBuildingComboBox" />
                            <TextBox x:Name="ConstructSlotTextBox" Text="19" />
                            <TextBox x:Name="UpgradeSlotTextBox" Text="19" />
                            <TextBox x:Name="UpgradeTargetLevelTextBox" Text="2" />
                            <TextBox x:Name="DemolishTargetLevelTextBox" Text="0" />
                            <TextBlock x:Name="BuildingsInfoTextBlock" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem x:Name="HeroTabItem" Header="Hero / Adventures"
                         DataContext="{Binding HeroVm, ElementName=RootWindow}">
                    <!-- TabItem keeps the DataContext binding so the panel inherits the
                         HeroViewModel; all hero UI lives in Views/HeroPanel.xaml. -->
                    <views:HeroPanel />
                </TabItem>
                <TabItem x:Name="FarmingTabItem" Header="Farming">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Farming" FontSize="24" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,10" />
                        <Grid Grid.Row="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#FFFFFF"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,0,8,0">
                                    <Grid MaxWidth="560" HorizontalAlignment="Left">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="Farm List Management"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"
                                                   Margin="0,0,0,12" />

                                        <WrapPanel Grid.Row="1" Margin="0,0,0,12">
                                            <Button x:Name="AnalyzeFarmListsButton"
                                                    Content="Analyze Farmlists"
                                                    Background="#030826"
                                                    Foreground="White"
                                                    BorderBrush="#030826"
                                                    MinWidth="150"
                                                    Click="AnalyzeFarmListsButton_Click" />
                                            <Button x:Name="AddFarmsToListButton"
                                                    Content="Add Farms to List"
                                                    MinWidth="140"
                                                    Click="AddFarmsToListButton_Click" />
                                            <Button x:Name="CreateFarmListButton"
                                                    Content="Create Farmlist"
                                                    MinWidth="120"
                                                    Click="CreateFarmListButton_Click" />
                                        </WrapPanel>

                                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel>
                                                <TextBlock x:Name="FarmingStatusTextBlock"
                                                           Text="No farm lists loaded. Click Analyze Farmlists."
                                                           Foreground="#4B5563"
                                                           Margin="0,0,0,8" />

                                                <ItemsControl x:Name="FarmListsItemsControl">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="9" Padding="10" Margin="0,0,0,10" Background="#F9FAFB">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <ToggleButton Grid.Column="0"
                                                                                  Style="{StaticResource ContinuousRunToggleStyle}"
                                                                                  VerticalAlignment="Center"
                                                                                  Margin="0,0,10,0"
                                                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}" />

                                                                    <Border Grid.Column="1" BorderBrush="#2563EB" BorderThickness="3,0,0,0" Padding="10,0,0,0">
                                                                        <StackPanel VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#111827" />
                                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                                <TextBlock Text="{Binding FarmCountText}" Foreground="#4B5563" FontSize="12" Margin="0,0,8,0" />
                                                                                <ProgressBar Width="120"
                                                                                             Height="8"
                                                                                             VerticalAlignment="Center"
                                                                                             Minimum="0"
                                                                                             Maximum="100"
                                                                                             Value="{Binding FillPercent, Mode=OneWay}" />
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <Border Grid.Column="2"
                                                                            Margin="8,0,8,0"
                                                                            Padding="10,4"
                                                                            CornerRadius="8"
                                                                            VerticalAlignment="Center"
                                                                            BorderThickness="1">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="#DCFCE7" />
                                                                                <Setter Property="BorderBrush" Value="#22C55E" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasTimer}" Value="True">
                                                                                        <Setter Property="Background" Value="#FEF3C7" />
                                                                                        <Setter Property="BorderBrush" Value="#F59E0B" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="{Binding ReadyText}" />
                                                                                    <Setter Property="Foreground" Value="#15803D" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasTimer}" Value="True">
                                                                                            <Setter Property="Text" Value="{Binding TimerText}" />
                                                                                            <Setter Property="Foreground" Value="#B45309" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Border>

                                                                    <Button Grid.Column="3"
                                                                            Content="Send Now"
                                                                            MinWidth="90"
                                                                            Height="32"
                                                                            Background="#030826"
                                                                            Foreground="White"
                                                                            BorderBrush="#030826"
                                                                            VerticalAlignment="Center"
                                                                            Tag="{Binding}"
                                                                            IsEnabled="{Binding CanSendNow}"
                                                                            Click="FarmListSendNowButton_Click" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1" Margin="8,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Background="#FFFFFF"
                                            BorderBrush="#D1D5DB"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Manual farming"
                                                           FontSize="22"
                                                           FontWeight="SemiBold"
                                                           Foreground="#111827"
                                                           VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1"
                                                            HorizontalAlignment="Right">
                                                    <TextBlock Text="Farmlist executions"
                                                               Foreground="#6B7280"
                                                               FontSize="12"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock x:Name="ManualFarmingExecutionCountTextBlock"
                                                               Text="0"
                                                               Foreground="#111827"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="190" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Button x:Name="AnalyzeNatarsProfileButton"
                                                        Grid.Row="0"
                                                        Grid.Column="0"
                                                        Content="Analyze natars profile"
                                                        Width="170"
                                                        Margin="0,0,0,6"
                                                        Click="AnalyzeNatarsProfileButton_Click" />
                                                <Button x:Name="ShowNatarsListButton"
                                                        Grid.Row="1"
                                                        Grid.Column="0"
                                                        Content="Show natars list"
                                                        Width="170"
                                                        Margin="0,0,0,6"
                                                        Click="ShowNatarsListButton_Click" />
                                                <Button x:Name="StartManualFarmingButton"
                                                        Grid.Row="2"
                                                        Grid.Column="0"
                                                        Content="Start manual farming"
                                                        Width="170"
                                                        HorizontalAlignment="Center"
                                                        Click="StartManualFarmingButton_Click" />

                                                <StackPanel Grid.Row="0"
                                                            Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            Margin="10,0,0,6">
                                                    <TextBlock Text="Analyzed:"
                                                               VerticalAlignment="Center"
                                                               Foreground="#374151"
                                                               Margin="0,0,6,0" />
                                                    <Ellipse x:Name="NatarsProfileAnalyzedIndicator"
                                                             Width="14"
                                                             Height="14"
                                                             VerticalAlignment="Center"
                                                             Fill="#9CA3AF" />
                                                </StackPanel>

                                                <StackPanel Grid.Row="2"
                                                            Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            Margin="10,0,0,0">
                                                    <TextBlock x:Name="ManualFarmingStateTextBlock"
                                                               Text="State:"
                                                               Foreground="#6B7280"
                                                               Margin="0,0,8,0"
                                                               VerticalAlignment="Center" />
                                                    <Ellipse x:Name="ManualFarmingStateDot"
                                                             Width="12"
                                                             Height="12"
                                                             VerticalAlignment="Center"
                                                             Fill="#9CA3AF" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Background="#FFFFFF"
                                            BorderBrush="#D1D5DB"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Settings"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="#111827"
                                                       Margin="0,0,0,8" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem x:Name="TroopsTabItem" Header="Troops"
                         DataContext="{Binding TroopTrainingVm, ElementName=RootWindow}">
                    <!-- All troops UI lives in Views/TroopsPanel.xaml; the TabItem keeps the
                         DataContext binding so the panel inherits the TroopTrainingViewModel. -->
                    <views:TroopsPanel />
                </TabItem>

                <TabItem x:Name="NpcTradeTabItem" Header="NPC / Trade"
                         DataContext="{Binding TroopTrainingVm, ElementName=RootWindow}">
                    <Grid Background="#F3F4F6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border VerticalAlignment="Top"
                                    Background="#FFFFFF"
                                    BorderBrush="#D1D5DB"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="NPC Trade"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               Margin="0,0,0,12" />
                                    <TextBlock Text="Each NPC trade costs 3 gold. Allow gold spending must be enabled for NPC trade to run."
                                               Foreground="#6B7280"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,12" />
                                    <TextBlock Text="Troops"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               Margin="0,0,0,6" />
                                    <CheckBox Content="Enable NPC trade while building troops"
                                              IsChecked="{Binding NpcTradeEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Trade when a selected resource is at/above"
                                               Foreground="#6B7280"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,4" />
                                    <ComboBox Width="100"
                                              HorizontalAlignment="Left"
                                              SelectedValuePath="Tag"
                                              IsEnabled="{Binding NpcTradeEnabled}"
                                              SelectedValue="{Binding NpcTradeThresholdPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBoxItem Content="50%" Tag="50" />
                                        <ComboBoxItem Content="60%" Tag="60" />
                                        <ComboBoxItem Content="70%" Tag="70" />
                                        <ComboBoxItem Content="80%" Tag="80" />
                                        <ComboBoxItem Content="90%" Tag="90" />
                                        <ComboBoxItem Content="95%" Tag="95" />
                                        <ComboBoxItem Content="100%" Tag="100" />
                                    </ComboBox>
                                    <TextBlock Text="Analyze resources"
                                               Foreground="#6B7280"
                                               FontSize="12"
                                               Margin="0,12,0,4" />
                                    <WrapPanel>
                                        <CheckBox Content="Wood"
                                                  Width="90"
                                                  IsChecked="{Binding NpcTradeAnalyzeWood, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding NpcTradeEnabled}" />
                                        <CheckBox Content="Clay"
                                                  Width="90"
                                                  IsChecked="{Binding NpcTradeAnalyzeClay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding NpcTradeEnabled}" />
                                        <CheckBox Content="Iron"
                                                  Width="90"
                                                  Margin="0,6,0,0"
                                                  IsChecked="{Binding NpcTradeAnalyzeIron, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding NpcTradeEnabled}" />
                                        <CheckBox Content="Crop"
                                                  Width="90"
                                                  Margin="0,6,0,0"
                                                  IsChecked="{Binding NpcTradeAnalyzeCrop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding NpcTradeEnabled}" />
                                    </WrapPanel>

                                    <Border Height="1"
                                            Background="#E5E7EB"
                                            Margin="0,14,0,14" />

                                    <TextBlock Text="Buildings and resource fields"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               Margin="0,0,0,6" />
                                    <CheckBox Content="Enable NPC trade while upgrading buildings and resource fields"
                                              IsChecked="{Binding NpcTradeConstructionEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Text="When enabled, NPC trade is used only after the page says there are not enough resources for a building or resource field upgrade."
                                               Foreground="#6B7280"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,12,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Border VerticalAlignment="Top"
                                    Background="#FFFFFF"
                                    BorderBrush="#D1D5DB"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Trade"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Trade settings will appear here."
                                               Foreground="#6B7280"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    VerticalAlignment="Top"
                                    Background="#FFFFFF"
                                    BorderBrush="#D1D5DB"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Gold"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               Margin="0,0,0,12" />
                                    <CheckBox Content="Allow gold spending"
                                              Margin="0,0,0,12"
                                              IsChecked="{Binding AllowGoldSpending, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding GoldLimitText}"
                                               Foreground="#111827"
                                               Margin="0,0,0,4" />
                                    <Slider Minimum="0"
                                            Maximum="1000"
                                            TickFrequency="10"
                                            IsSnapToTickEnabled="True"
                                            IsEnabled="{Binding AllowGoldSpending}"
                                            Width="140"
                                            HorizontalAlignment="Left"
                                            Value="{Binding GoldLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Gold-spending features (e.g. NPC trade) will not run if spending would take gold below this limit."
                                               Foreground="#6B7280"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,12,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem x:Name="QueueTabItem" Header="Queue">
                    <Grid Background="#F3F4F6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <DockPanel Grid.Row="0" Margin="2,2,2,12">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Queue"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#111827" />
                                <TextBlock x:Name="QueueInfoTextBlock"
                                           Text="Queue loaded."
                                           Foreground="#6B7280"
                                           FontSize="12"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <Button x:Name="QueuePopoutButton"
                                    DockPanel.Dock="Right"
                                    Content="Pop out"
                                    Width="92"
                                    Click="QueuePopoutButton_Click"
                                    Background="#FFFFFF"
                                    BorderBrush="#E5E7EB" />
                            <Button x:Name="QueueClearButton"
                                    DockPanel.Dock="Right"
                                    Content="Clear active queue"
                                    Width="120"
                                    Margin="0,0,8,0"
                                    Click="QueueClearButton_Click"
                                    Background="#FEE2E2"
                                    BorderBrush="#FCA5A5"
                                    Foreground="#991B1B" />
                            <TextBlock />
                        </DockPanel>

                        <StackPanel Grid.Row="1" Margin="2,0,2,12">
                            <TextBlock x:Name="BuildQueueStatusTextBlock" Visibility="Collapsed" />
                            <TextBlock Text="All queue groups are shown together below."
                                       Foreground="#6B7280"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <TabControl x:Name="QueueSectionTabControl"
                                    Grid.Row="2"
                                    Margin="2,0,2,2"
                                    SelectionChanged="QueueSectionTabControl_SelectionChanged">
                            <TabItem x:Name="ActiveQueueTabItem" Header="Active queue">
                                <Border Background="#FFFFFF"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <Ellipse Width="8" Height="8" Fill="#16A34A" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Text="Active queue"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="QueueRemoveButton" Content="Remove" Width="76" Click="QueueRemoveButton_Click" Background="#FFFFFF" BorderBrush="#E5E7EB" />
                                        <Rectangle Width="1" Fill="#E5E7EB" Margin="10,3,10,3" />
                                        <Button x:Name="QueueMoveUpButton" Content="↑" Width="36" Click="QueueMoveUpButton_Click" Background="#FFFFFF" BorderBrush="#E5E7EB" ToolTip="Move up" />
                                        <Button x:Name="QueueMoveDownButton" Content="↓" Width="36" Margin="6,0,0,0" Click="QueueMoveDownButton_Click" Background="#FFFFFF" BorderBrush="#E5E7EB" ToolTip="Move down" />
                                        <Rectangle Width="1" Fill="#E5E7EB" Margin="10,3,10,3" />
                                        <Button x:Name="QueueRefreshButton" Content="Refresh" Width="76" Click="QueueRefreshButton_Click" Background="#FFFFFF" BorderBrush="#E5E7EB" />
                                    </StackPanel>
                                </DockPanel>

                                <DataGrid x:Name="QueueDataGrid"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserReorderColumns="False"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#F3F4F6"
                                          RowBackground="#FFFFFF"
                                          AlternatingRowBackground="#FAFBFC"
                                          BorderBrush="#E5E7EB"
                                          BorderThickness="1"
                                          HeadersVisibility="Column"
                                          ColumnHeaderHeight="32"
                                          RowHeight="30"
                                          FontSize="12">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F9FAFB" />
                                            <Setter Property="Foreground" Value="#374151" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="FontSize" Value="11" />
                                            <Setter Property="Padding" Value="10,6" />
                                            <Setter Property="BorderBrush" Value="#E5E7EB" />
                                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="10,4" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Foreground" Value="#1F2937" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#EEF2FF" />
                                                    <Setter Property="Foreground" Value="#1F2937" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Group" Width="1.15*" Binding="{Binding GroupName}" />
                                        <DataGridTextColumn Header="Task" Width="2.4*" Binding="{Binding DisplayName}" />
                                        <DataGridTemplateColumn Header="Status" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Status}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#1F2937" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                        <Setter Property="Foreground" Value="#16A34A" />
                                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Retries" Width="0.9*" Binding="{Binding RetriesText}" />
                                        <DataGridTextColumn Header="Created" Width="1.5*" Binding="{Binding CreatedAtServer}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                            </TabItem>
                            <TabItem x:Name="HistoryQueueTabItem" Header="History">
                                <Border Background="#FFFFFF"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                    <Ellipse Width="8" Height="8" Fill="#9CA3AF" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="History"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <DataGrid x:Name="QueueHistoryDataGrid"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserReorderColumns="False"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#F3F4F6"
                                          RowBackground="#FFFFFF"
                                          AlternatingRowBackground="#FAFBFC"
                                          BorderBrush="#E5E7EB"
                                          BorderThickness="1"
                                          HeadersVisibility="Column"
                                          ColumnHeaderHeight="32"
                                          RowHeight="30"
                                          FontSize="12">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F9FAFB" />
                                            <Setter Property="Foreground" Value="#374151" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="FontSize" Value="11" />
                                            <Setter Property="Padding" Value="10,6" />
                                            <Setter Property="BorderBrush" Value="#E5E7EB" />
                                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="10,4" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Foreground" Value="#4B5563" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#F3F4F6" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Group" Width="1.15*" Binding="{Binding GroupName}" />
                                        <DataGridTextColumn Header="Completed task" Width="2.4*" Binding="{Binding DisplayName}" />
                                        <DataGridTemplateColumn Header="Status" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Status}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#4B5563" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                        <Setter Property="Foreground" Value="#16A34A" />
                                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Retries" Width="0.7*" Binding="{Binding Retries}" />
                                        <DataGridTextColumn Header="Created" Width="1.5*" Binding="{Binding CreatedAtServer}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>

                <TabItem x:Name="LogsTabItem" Header="Logs">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                            <TextBlock Text="Filter:" VerticalAlignment="Center" Foreground="#374151" FontWeight="SemiBold" Margin="0,0,8,0" />
                            <ComboBox x:Name="LogCategoryFilterComboBox"
                                      Width="140"
                                      Margin="0,0,12,0"
                                      VerticalAlignment="Center"
                                      SelectionChanged="LogCategoryFilterComboBox_SelectionChanged"
                                      ToolTip="Show only log lines for this task category." />
                            <CheckBox x:Name="LogCleanModeToggle"
                                      Content="Clean"
                                      VerticalAlignment="Center"
                                      Checked="LogCleanModeToggle_Changed"
                                      Unchecked="LogCleanModeToggle_Changed"
                                      ToolTip="Hide high-volume noise lines (full log is still kept in the session file)." />
                        </StackPanel>
                        <TabControl x:Name="TerminalAlarmTabControl" Grid.Row="1" Margin="0,0,0,8">
                            <TabItem Header="Log">
                                <Border Background="#020617" Padding="8">
                                    <ListBox x:Name="TerminalListBox"
                                             Background="#020617"
                                             Foreground="#93C5FD"
                                             BorderThickness="0"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             SelectionMode="Extended"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </TabItem>
                            <TabItem Header="Alarms">
                                <Border Background="#110D0D" Padding="8">
                                    <ListBox x:Name="AlarmListBox"
                                             Background="#110D0D"
                                             BorderThickness="0"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             SelectionMode="Extended"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#FCA5A5" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsAcknowledged}" Value="True">
                                                                    <Setter Property="Foreground" Value="#93C5FD" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </TabItem>
                        </TabControl>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="CopyFeedbackTextBlock"
                                       Text=""
                                       Foreground="#16A34A"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Visibility="Collapsed" />
                            <Button x:Name="PopoutLogsButton" Content="Pop out" Margin="0,0,8,0" Padding="10,4" Click="PopoutLogsButton_Click" />
                            <Button x:Name="CopyCurrentTabButton" Content="Copy" Margin="0,0,8,0" Padding="10,4" Click="CopyCurrentTabButton_Click" />
                            <Button x:Name="AcknowledgeAlarmButton" Content="Acknowledge alarms" Margin="0,0,8,0" Padding="10,4" Click="AcknowledgeAlarmButton_Click" />
                            <Button x:Name="ClearCurrentLogButton" Content="Clear" Padding="10,4" Click="ClearCurrentLogButton_Click" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem x:Name="InboxTabItem" Header="Inbox"
                         DataContext="{Binding InboxVm, ElementName=RootWindow}">
                    <views:InboxPanel x:Name="InboxPanelControl" />
                </TabItem>
                </TabControl>
                </Grid>
            </Border>

        </Grid>

    </Grid>
</Window>




