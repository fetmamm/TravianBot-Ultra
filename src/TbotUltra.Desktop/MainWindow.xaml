<Window x:Class="TbotUltra.Desktop.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tbot Ultra"
        Height="740"
        Width="1180"
        MinHeight="640"
        MinWidth="980"
        Background="#F3F4F6">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="#E5E7EB" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Background" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#F3F4F6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ResourceLevelBadgeStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="MinWidth" Value="52" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMaxLevel}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Foreground" Value="#6B7280" />
                    <Setter Property="Background" Value="#E5E7EB" />
                    <Setter Property="BorderBrush" Value="#9CA3AF" />
                    <Setter Property="Opacity" Value="0.85" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ContinuousRunToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#9CA3AF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <Border x:Name="Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="12"
                                    BorderBrush="#6B7280"
                                    BorderThickness="1" />
                            <Ellipse x:Name="Thumb"
                                     Width="20"
                                     Height="20"
                                     Margin="2"
                                     Fill="#FFFFFF"
                                     Stroke="#E5E7EB"
                                     StrokeThickness="1"
                                     HorizontalAlignment="Left" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#16A34A" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#15803D" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="0.88" ScaleY="0.88" />
        </Grid.LayoutTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#EFEFEF" BorderBrush="#D1D5DB" BorderThickness="0,0,1,0">
            <Grid Margin="10,8,10,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Tbot Ultra" FontSize="26" FontWeight="SemiBold" Foreground="#111827" />
                    <TextBlock x:Name="VersionTextBlock" Text="Version: -" Foreground="#6B7280" Margin="0,2,0,0" />
                </StackPanel>

                <Border Grid.Row="1" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="7" Margin="0,0,0,6">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Account" Foreground="#6B7280" VerticalAlignment="Center" />
                            <Button x:Name="AccountManageButton"
                                    DockPanel.Dock="Right"
                                    Content="Manage"
                                    Height="22"
                                    Width="72"
                                    Padding="8,1"
                                    Margin="6,0,0,0"
                                    HorizontalAlignment="Right"
                                    Click="AccountsButton_Click" />
                        </DockPanel>
                        <ComboBox x:Name="AccountComboBox"
                                  Height="30"
                                  DisplayMemberPath="PickerName"
                                  SelectionChanged="AccountComboBox_SelectionChanged" />
                        <TextBlock x:Name="ActiveAccountInfoTextBlock"
                                   Margin="0,6,0,0"
                                   Foreground="#4B5563"
                                    Text="Account: - | Server: -" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="7" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="LoginButton"
                                Grid.Column="0"
                                Margin="0,0,3,0"
                                Content="Login"
                                Background="#030826"
                                Foreground="White"
                                BorderBrush="#030826"
                                Click="LoginButton_Click" />
                        <Button x:Name="LogoutButton"
                                Grid.Column="1"
                                Margin="3,0,0,0"
                                Content="Logout"
                                Click="LogoutButton_Click" />
                    </Grid>
                </Border>

                <Border Grid.Row="3" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="7" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="Village" Foreground="#6B7280" Margin="0,0,0,5" />
                        <ComboBox x:Name="VillageComboBox" Height="28" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="4">
                    <Button x:Name="DashboardNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Dashboard" Tag="dashboard" Click="SidebarNavButton_Click" />
                    <Button x:Name="ResourcesNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Resources" Tag="resources" Click="SidebarNavButton_Click" />
                    <Button x:Name="BuildingsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Building" Tag="buildings" Click="SidebarNavButton_Click" />
                    <Button x:Name="HeroNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Hero / Adventures" Tag="hero" Click="SidebarNavButton_Click" />
                    <Button x:Name="FarmingNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Farming" Tag="farming" Click="SidebarNavButton_Click" />
                    <Button x:Name="QueueNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Queue" Tag="queue" Click="SidebarNavButton_Click" />
                    <Button x:Name="LogsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Logs" Tag="logs" Click="SidebarNavButton_Click" />
                    <Button x:Name="InboxNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Messages / Reports" Tag="inbox" Click="SidebarNavButton_Click" />
                </StackPanel>

                <Border Grid.Row="5" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="7">
                    <StackPanel>
                        <Border x:Name="LoopStateBadge"
                                Background="#6B7280"
                                CornerRadius="10"
                                Padding="8,2,8,2"
                                Margin="0,0,0,6"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="LoopStateTextBlock"
                                       Text="State: idle"
                                       Foreground="White"
                                       FontWeight="SemiBold" />
                        </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Continuous run"
                                           VerticalAlignment="Center"
                                           Foreground="#374151"
                                           FontWeight="SemiBold"
                                           Margin="0,0,8,0" />
						        <ToggleButton x:Name="ContinuousRunToggleButton"
                                              Style="{StaticResource ContinuousRunToggleStyle}"
                                              ToolTip="When enabled, Start/Pause/Stop controls continuous running." />
                            </StackPanel>

						    <Grid Margin="0,0,0,6">
							    <Grid.ColumnDefinitions>
								    <ColumnDefinition Width="*" />
								    <ColumnDefinition Width="Auto" />
							    </Grid.ColumnDefinitions>
							    <Button x:Name="StartLoopButton" Grid.Column="0" Content="Start bot" Background="#030826" Foreground="White" BorderBrush="#030826" Click="StartLoopButton_Click" />
							    <Button x:Name="StopBotButton" Grid.Column="1" Content="&#9632;" Width="30" Padding="0" Margin="6,0,0,0" Click="StopBotButton_Click" ToolTip="Stop bot" />
						    </Grid>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="SettingsButton"
                                    Grid.Column="0"
                                    Content="Settings"
                                    Click="SettingsButton_Click"
                                    Margin="0,0,6,0" />
                            <Button x:Name="SupportButton"
                                    Grid.Column="1"
                                    Content="&#xE715;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Width="30"
                                    Padding="0"
                                    Margin="6,0,0,0"
                                    ToolTip="Support"
                                    Click="SupportButton_Click" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="12,8,12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                <DockPanel>
                    <TextBlock x:Name="BrowserInfoTextBlock" Text="Browser: idle" Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Left" />
                    <TextBlock x:Name="ServerResourcesTextBlock" Text="Gold: - | Silver: -" Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Right" />
                    <TextBlock x:Name="ClockTextBlock" Text="Time: -" Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Left" />
                    <TextBlock x:Name="StatusTextBlock" Text="Ready." Visibility="Collapsed" />
                </DockPanel>
            </Border>

            <StatusBar Grid.Row="1" Margin="0,0,0,8" Background="#E5E7EB">
                <StatusBarItem>
                    <TextBlock Text="Status" FontWeight="SemiBold" />
                </StatusBarItem>
                <StatusBarItem>
                    <TextBlock x:Name="StatusMiniLogTextBlock" Text="Ready." Foreground="#1F2937" />
                </StatusBarItem>
            </StatusBar>

            <Border Grid.Row="2"
                    Margin="0,56,0,0"
                    Background="#F9FAFB"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <TabControl x:Name="MainTabControl" Background="Transparent" BorderThickness="0">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Style>
                    </TabControl.ItemContainerStyle>

                <TabItem Header="Dashboard">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Dashboard" FontSize="32" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,10" />

                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="9" Padding="14" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Villages" Foreground="#4B5563" FontSize="20" />
                                    <TextBlock x:Name="VillagesInfoTextBlock" Margin="0,6,0,0" Text="Villages: -" FontSize="32" Foreground="#111827" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="9" Padding="14" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Population / Tribe" Foreground="#4B5563" FontSize="20" />
                                    <TextBlock x:Name="TribeInfoTextBlock" Margin="0,6,0,0" Text="Tribe: -" FontSize="32" Foreground="#111827" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="9" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Activity" Foreground="#4B5563" FontSize="20" />
                                    <TextBlock x:Name="LastScanInfoTextBlock" Margin="0,6,0,0" Text="Last scan: -" FontSize="32" Foreground="#111827" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <WrapPanel Grid.Row="2" Margin="0,0,0,8">
                            <Button x:Name="CheckStatusButton" Height="32" Content="Check village status" MinWidth="150" Click="CheckStatusButton_Click" />
                            <Button x:Name="ScanAllVillagesButton" Height="32" Content="Scan all villages" Background="#030826" Foreground="White" BorderBrush="#030826" Click="ScanAllVillagesButton_Click" />
                            <Button x:Name="ResetProgramButton" Height="32" Content="Reset program" Background="#FCD34D" Foreground="#1F2937" BorderBrush="#F59E0B" Click="ResetProgramButton_Click" />
                        </WrapPanel>

                        <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="9" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Overview" FontSize="20" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6" />
                                <TextBlock x:Name="SummaryTextBlock" Text="Run Check village status to populate the views." Foreground="#374151" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Resources">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="LoadResourcesButton" Content="↻" Width="42" FontSize="16" Click="LoadResourcesButton_Click" ToolTip="Refresh resources" />
                            <TextBlock Text="Target level" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox x:Name="ResourceTargetLevelComboBox" Width="90" Margin="0,0,8,0" />
                            <Button x:Name="UpgradeAllResourcesButton" Content="Upgrade all to level" Width="160" Click="UpgradeAllResourcesButton_Click" />
                        </StackPanel>
                        <Border Grid.Row="1" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Background="#FFFFFF" Padding="12">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <Grid HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Width="190" Margin="0,0,8,0">
                                    <TextBlock Text="Woodcutter" Foreground="#0F766E" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding WoodFields, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#E4F2F1" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="#134E4A"
                                                                Background="#A5E1DA"
                                                                BorderBrush="#74CCC2"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Width="190" Margin="0,0,8,0">
                                    <TextBlock Text="Clay Pit" Foreground="#DC4C1D" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding ClayFields, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FDECE5" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="#7C2D12"
                                                                Background="#F9C9AF"
                                                                BorderBrush="#F2A57E"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Width="190" Margin="0,0,8,0">
                                    <TextBlock Text="Iron Mine" Foreground="#334155" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding IronFields, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#EAF0F4" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="#1E293B"
                                                                Background="#B7C7D4"
                                                                BorderBrush="#92ABC0"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel x:Name="CroplandColumnPanel" Grid.Column="3" Width="190" Margin="0,0,0,0">
                                    <TextBlock Text="Cropland" Foreground="#C47F00" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl x:Name="CroplandItemsControl" ItemsSource="{Binding CroplandFields, ElementName=RootWindow}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="1" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FFF5DF" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="#7C5C0B"
                                                                Background="#F7E3A3"
                                                                BorderBrush="#EACD73"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                            </ScrollViewer>
                        </Border>
                        <DataGrid x:Name="ResourcesDataGrid" Visibility="Collapsed" />
                        <TextBlock x:Name="ResourcesInfoTextBlock" Grid.Row="2" Margin="0,8,0,0" Foreground="#065F46" Text="Resources not loaded yet." />
                    </Grid>
                </TabItem>

               <TabItem Header="Buildings">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="260" />
        </Grid.ColumnDefinitions>

        <!-- Vänster: slot-grid -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,4">
                <TextBlock Text="🏗 Buildings" FontSize="24" FontWeight="SemiBold" Foreground="#111827" />
                <TextBlock Text="Manage your village buildings. Click a slot to view and manage building details."
                           Foreground="#6B7280" Margin="0,2,0,8" />
            </StackPanel>

            <!-- Load-knapp -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="LoadBuildingsButton" Content="Load buildings" Width="130" Click="LoadBuildingsButton_Click" />
				
				<!-- Dolda kontroller för bakåtkompatibilitet med code-behind -->
				<ComboBox x:Name="BuildingCategoryComboBox" Visibility="Collapsed" />
				<ComboBox x:Name="ConstructBuildingComboBox" Visibility="Collapsed" />
				<ComboBox x:Name="DemolishBuildingComboBox" Visibility="Collapsed" />
				<TextBox x:Name="ConstructSlotTextBox" Visibility="Collapsed" Text="19" />
				<TextBox x:Name="UpgradeSlotTextBox" Visibility="Collapsed" Text="19" />
				<TextBox x:Name="UpgradeTargetLevelTextBox" Visibility="Collapsed" Text="2" />
				<TextBox x:Name="DemolishTargetLevelTextBox" Visibility="Collapsed" Text="0" />
				<TextBlock x:Name="BuildingsInfoTextBlock" Visibility="Collapsed" />
            </StackPanel>

            <!-- Slot-grid -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="BuildingSlotsItemsControl"
                              ItemsSource="{Binding BuildingSlots, ElementName=RootWindow}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Margin="3"
									Background="#FFFFFF"
									BorderBrush="#D1D5DB"
									BorderThickness="1"
									CornerRadius="6">
								<Border.Style>
									<Style TargetType="Border">
										<Style.Triggers>
											<DataTrigger Binding="{Binding HasPendingUpgrade}" Value="True">
												<Setter Property="BorderBrush" Value="#D97706" />
												<Setter Property="Background" Value="#FFFBEB" />
											</DataTrigger>
											<DataTrigger Binding="{Binding HasPendingConstruct}" Value="True">
												<Setter Property="BorderBrush" Value="#16A34A" />
												<Setter Property="Background" Value="#F0FDF4" />
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Border.Style>
								<Button Background="Transparent"
										BorderThickness="0"
										Padding="6,5"
										Tag="{Binding}"
										Click="BuildingSlotCircleButton_Click"
										HorizontalContentAlignment="Stretch"
										VerticalContentAlignment="Stretch">
									<StackPanel>
										<TextBlock Text="{Binding SlotLabel}"
												   FontSize="11"
												   Foreground="#9CA3AF"
												   HorizontalAlignment="Left" />
										<TextBlock Text="{Binding NameLabel}"
												   FontSize="12"
												   FontWeight="SemiBold"
												   Foreground="#111827"
												   TextWrapping="Wrap"
												   Margin="0,2,0,0" />
										<TextBlock Text="{Binding LevelStatusLabel}"
												   FontSize="11"
												   Foreground="#6B7280"
												   Margin="0,1,0,0" />
									</StackPanel>
								</Button>
							</Border>
						</DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Höger: detaljpanel -->
        <Border Grid.Column="1"
                Background="#FFFFFF"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14">
            <StackPanel>

                <!-- Selected building -->
                <TextBlock Text="Selected building"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Margin="0,0,0,10" />

                <Border Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock x:Name="SelectedBuildingNameTextBlock"
                                   Text="No building selected"
                                   FontWeight="SemiBold"
                                   Foreground="#374151" />
                        <TextBlock Text="Click a building slot to view details"
                                   Foreground="#9CA3AF"
                                   FontSize="11"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <!-- Building info -->
                <TextBlock Text="Building info"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Margin="0,0,0,6" />
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Level:" Foreground="#6B7280" Margin="0,2" />
                    <TextBlock x:Name="SelectedBuildingLevelTextBlock" Grid.Row="0" Grid.Column="1" Text="-" Foreground="#111827" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Upgrade time:" Foreground="#6B7280" Margin="0,2" />
                    <TextBlock x:Name="SelectedBuildingUpgradeTimeTextBlock" Grid.Row="1" Grid.Column="1" Text="-" Foreground="#111827" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Completion time:" Foreground="#6B7280" Margin="0,2" />
                    <TextBlock x:Name="SelectedBuildingCompletionTextBlock" Grid.Row="2" Grid.Column="1" Text="-" Foreground="#111827" />
                </Grid>

                <!-- Requirements -->
                <TextBlock Text="Requirements"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Margin="0,0,0,6" />
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="🪵 Wood:" Foreground="#6B7280" Margin="0,2" />
                    <TextBlock x:Name="ReqWoodTextBlock" Grid.Row="0" Grid.Column="1" Text="-" Foreground="#111827" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="🪨 Clay:" Foreground="#6B7280" Margin="0,2" />
                    <TextBlock x:Name="ReqClayTextBlock" Grid.Row="1" Grid.Column="1" Text="-" Foreground="#111827" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="⛏ Iron:" Foreground="#6B7280" Margin="0,2" />
                    <TextBlock x:Name="ReqIronTextBlock" Grid.Row="2" Grid.Column="1" Text="-" Foreground="#111827" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="🌾 Crop:" Foreground="#6B7280" Margin="0,2" />
                    <TextBlock x:Name="ReqCropTextBlock" Grid.Row="3" Grid.Column="1" Text="-" Foreground="#111827" />
                </Grid>

                <!-- Actions -->
                <TextBlock Text="Actions"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Margin="0,0,0,8" />
                <Button x:Name="QueueUpgradeBuildingButton"
                        Content="Upgrade"
                        Margin="0,0,0,6"
                        Background="#E5E7EB"
                        Foreground="#374151"
                        Click="QueueUpgradeBuildingButton_Click" />
                <Button x:Name="QueueDemolishButton"
                        Content="Demolish"
                        Margin="0,0,0,14"
                        Background="#030826"
                        Foreground="White"
                        BorderBrush="#030826"
                        Click="QueueDemolishButton_Click" />

                <!-- Tip -->
                <Border Background="#EFF6FF"
                        BorderBrush="#BFDBFE"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ℹ " Foreground="#2563EB" FontWeight="SemiBold" />
                        <TextBlock Text="Tip" FontWeight="SemiBold" Foreground="#1D4ED8" Margin="0,0,0,4" />
                    </StackPanel>
                </Border>
                <Border Background="#EFF6FF"
                        BorderBrush="#BFDBFE"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,-6,0,0">
                    <TextBlock Text="Click on any building slot to view details and options."
                               Foreground="#1D4ED8"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </Border>

            </StackPanel>
        </Border>

    </Grid>
</TabItem>

                <TabItem Header="Hero / Adventures">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Hero / Adventures" FontSize="24" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,10" />
                        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Hero min HP for adventure" />
                                <TextBox x:Name="HeroMinHpTextBox" Text="60" Margin="0,2,0,8" Width="120" />
                                <CheckBox x:Name="HeroAutoReviveCheckBox" Content="Auto revive" IsChecked="True" Margin="0,0,0,8" />
                                <TextBlock Text="Stat priority (csv)" />
                                <TextBox x:Name="HeroStatPriorityTextBox" Text="offense,resource,regeneration" Margin="0,2,0,8" />
                                <Button x:Name="QueueHeroManageButton" Content="Queue hero manage" Width="160" Click="QueueHeroManageButton_Click" />
                            </StackPanel>
                        </Border>
                        <TextBlock Grid.Row="2" Foreground="#334155" Text="Queue hero automation from here. The queue runner handles execution." />
                    </Grid>
                </TabItem>

                <TabItem Header="Farming">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Farming" FontSize="24" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,10" />
                        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12">
                            <TextBlock Foreground="#334155" TextWrapping="Wrap"
                                       Text="Farming controls are prepared in this section. Existing queue and status systems remain available while farming features evolve." />
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Queue">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,8,0">
                                <WrapPanel>
                                    <Button x:Name="QueueAddButton" Content="Add" Width="82" Click="QueueAddButton_Click" />
                                    <Button x:Name="QueueRemoveButton" Content="Remove" Width="82" Margin="0" Click="QueueRemoveButton_Click" />
                                </WrapPanel>
                            </Border>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,8,0">
                                <WrapPanel>
                                    <Button x:Name="QueueMoveUpButton" Content="Move up" Width="82" Click="QueueMoveUpButton_Click" />
                                    <Button x:Name="QueueMoveDownButton" Content="Move down" Width="82" Margin="0" Click="QueueMoveDownButton_Click" />
                                </WrapPanel>
                            </Border>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="4">
                                <WrapPanel>
                                    <Button x:Name="QueueRetryButton" Content="Retry" Width="82" Click="QueueRetryButton_Click" />
                                    <Button x:Name="QueueRefreshButton" Content="Refresh" Width="82" Click="QueueRefreshButton_Click" />
                                    <Button x:Name="QueueClearButton" Content="Clear queue" Width="92" Margin="0" Click="QueueClearButton_Click" />
                                    <Button x:Name="QueuePopoutButton" Content="Pop out" Width="82" Margin="6,0,0,0" Click="QueuePopoutButton_Click" />
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                        <DataGrid x:Name="QueueDataGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  BorderBrush="#D1D5DB"
                                  BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Task" Width="2*" Binding="{Binding TaskName}" />
                                <DataGridTextColumn Header="Priority" Width="*" Binding="{Binding Priority}" />
                                <DataGridTextColumn Header="Status" Width="*" Binding="{Binding Status}" />
                                <DataGridTextColumn Header="Retries" Width="*" Binding="{Binding Retries}" />
                                <DataGridTextColumn Header="Max retries" Width="*" Binding="{Binding MaxRetries}" />
                                <DataGridTextColumn Header="Next try (Server time)" Width="2*" Binding="{Binding NextAttemptAtServer}" />
                                <DataGridTextColumn Header="Created (Server time)" Width="2*" Binding="{Binding CreatedAtServer}" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <DataGrid x:Name="QueueHistoryDataGrid"
                                  Grid.Row="2"
                                  Margin="0,8,0,0"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  BorderBrush="#D1D5DB"
                                  BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Completed task" Width="2*" Binding="{Binding TaskName}" />
                                <DataGridTextColumn Header="Status" Width="*" Binding="{Binding Status}" />
                                <DataGridTextColumn Header="Retries" Width="*" Binding="{Binding Retries}" />
                                <DataGridTextColumn Header="Created (Server time)" Width="2*" Binding="{Binding CreatedAtServer}" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock x:Name="BuildQueueStatusTextBlock" Grid.Row="3" Margin="0,8,0,0" Foreground="#1F2937" Text="Build queue: -" />
                        <TextBlock x:Name="QueueInfoTextBlock" Grid.Row="4" Margin="0,4,0,0" Foreground="#334155" Text="Queue loaded." />
                    </Grid>
                </TabItem>

                <TabItem Header="Logs">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TabControl x:Name="TerminalAlarmTabControl" Grid.Row="0" Margin="0,0,0,8">
                            <TabItem Header="Log">
                                <Border Background="#020617" Padding="8">
                                    <ListBox x:Name="TerminalListBox"
                                             Background="#020617"
                                             Foreground="#93C5FD"
                                             BorderThickness="0"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             SelectionMode="Extended"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </TabItem>
                            <TabItem Header="Alarms">
                                <Border Background="#110D0D" Padding="8">
                                    <ListBox x:Name="AlarmListBox"
                                             Background="#110D0D"
                                             Foreground="#FCA5A5"
                                             BorderThickness="0"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             SelectionMode="Extended"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </TabItem>
                        </TabControl>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="CopyFeedbackTextBlock"
                                       Text=""
                                       Foreground="#16A34A"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Visibility="Collapsed" />
                            <Button x:Name="PopoutLogsButton" Content="Pop out" Margin="0,0,8,0" Padding="10,4" Click="PopoutLogsButton_Click" />
                            <Button x:Name="CopyCurrentTabButton" Content="Copy" Margin="0,0,8,0" Padding="10,4" Click="CopyCurrentTabButton_Click" />
                            <Button x:Name="AcknowledgeAlarmButton" Content="Acknowledge alarms" Margin="0,0,8,0" Padding="10,4" Click="AcknowledgeAlarmButton_Click" />
                            <Button x:Name="ClearCurrentLogButton" Content="Clear" Padding="10,4" Click="ClearCurrentLogButton_Click" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Inbox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Messages / Reports" FontSize="24" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,8" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Messages" FontSize="20" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6" />
                                    <TextBlock x:Name="MessageUnreadTextBlock" Text="Unread: -" Foreground="#374151" Margin="0,0,0,10" />
                                    <Button x:Name="MarkMessagesReadButton" Width="120" Margin="0" Content="Mark as read" Click="MarkMessagesReadButton_Click" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Reports" FontSize="20" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6" />
                                    <TextBlock x:Name="ReportsUnreadTextBlock" Text="Unread: -" Foreground="#374151" Margin="0,0,0,10" />
                                    <Button x:Name="MarkReportsReadButton" Width="120" Margin="0" Content="Mark as read" Click="MarkReportsReadButton_Click" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
                </TabControl>
            </Border>

        </Grid>

    </Grid>
</Window>




