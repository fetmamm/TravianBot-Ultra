<Window x:Class="TbotUltra.Desktop.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TbotUltra.Desktop"
        xmlns:views="clr-namespace:TbotUltra.Desktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tbot Ultra"
        Height="800"
        Width="1180"
        MinHeight="700"
        MinWidth="980"
        ShowInTaskbar="True"
        Icon="/Assets/icon_windows.ico"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="0.88" ScaleY="0.88" />
        </Grid.LayoutTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="10,8,10,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Image Source="/Assets/Tbot_ultra_appicon_2.png"
                           Width="56"
                           Height="56"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Tbot Ultra" FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock x:Name="VersionTextBlock" Text="Version: -" Foreground="{DynamicResource TextSubtleBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="1" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="7" Margin="0,0,0,6">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Account" Foreground="{DynamicResource TextSubtleBrush}" VerticalAlignment="Center" />
                            <Button x:Name="AccountManageButton"
                                    DockPanel.Dock="Right"
                                    Content="Manage"
                                    Height="22"
                                    Width="72"
                                    Padding="8,1"
                                    Margin="6,0,0,0"
                                    HorizontalAlignment="Right"
                                    Click="AccountsButton_Click" />
                        </DockPanel>
                        <ComboBox x:Name="AccountComboBox"
                                  Height="30"
                                  DisplayMemberPath="PickerName"
                                  SelectionChanged="AccountComboBox_SelectionChanged" />
                        <TextBlock x:Name="ActiveAccountInfoTextBlock"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                    Text="-" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="7" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="LoginButton"
                                Grid.Column="0"
                                Margin="0,0,3,0"
                                Content="Login"
                                Background="{DynamicResource SuccessBgBrush}"
                                Foreground="{DynamicResource SuccessTextBrush}"
                                BorderBrush="{DynamicResource SuccessBorderBrush}"
                                Click="LoginButton_Click" />
                        <Button x:Name="LogoutButton"
                                Grid.Column="1"
                                Margin="3,0,0,0"
                                Content="Logout"
                                Background="{DynamicResource ControlBackgroundBrush}"
                                Foreground="{DynamicResource TextSubtleBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Click="LogoutButton_Click" />
                    </Grid>
                </Border>

                <Border Grid.Row="3" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="7" Margin="0,0,0,6">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,5" LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="Village" Foreground="{DynamicResource TextSubtleBrush}" VerticalAlignment="Center" />
                            <!-- Switch village lives here (next to the dropdown) so the bot's working village can be
                                 changed from any UI page, not just the Dashboard. Compact to fit the side bar. -->
                            <Button DockPanel.Dock="Right" x:Name="SwitchVillageButton" Height="22" Padding="8,0" FontSize="11" Content="Switch to" VerticalAlignment="Center" Click="SwitchVillageButton_Click"
                                    ToolTip="Make the bot work in the village selected in the dropdown. Selecting a village in the list only changes the view/queue target; this button actually moves the bot there." />
                        </DockPanel>
                        <ComboBox x:Name="VillageComboBox" Height="28">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NameWithCoords}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCapital}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource CapitalBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="4">
                    <!-- Monochrome line icons (Segoe MDL2 Assets) per the reference; tinted with the
                         button's own foreground. Glyph codepoints can be swapped freely if one looks off. -->
                    <StackPanel.Resources>
                        <Style x:Key="NavIcon" TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="Width" Value="24" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                        <Style x:Key="NavText" TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </StackPanel.Resources>
                    <Button x:Name="DashboardNavButton" Style="{StaticResource SidebarNavButtonStyle}" Tag="dashboard" Click="SidebarNavButton_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource NavIcon}" Text="&#xE80F;" /><TextBlock Style="{StaticResource NavText}" Text="Dashboard" /></StackPanel>
                    </Button>
                    <Button x:Name="ResourcesNavButton" Style="{StaticResource SidebarNavButtonStyle}" Tag="resources" Click="SidebarNavButton_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource NavIcon}" Text="&#xE8F1;" /><TextBlock Style="{StaticResource NavText}" Text="Resources" /></StackPanel>
                    </Button>
                    <Button x:Name="BuildingsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Tag="buildings" Click="SidebarNavButton_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource NavIcon}" Text="&#xE825;" /><TextBlock Style="{StaticResource NavText}" Text="Buildings" /></StackPanel>
                    </Button>
                    <Button x:Name="HeroNavButton" Style="{StaticResource SidebarNavButtonStyle}" Tag="hero" Click="SidebarNavButton_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource NavIcon}" Text="&#xE77B;" /><TextBlock Style="{StaticResource NavText}" Text="Hero / Adventures" /></StackPanel>
                    </Button>
                    <Button x:Name="FarmingNavButton" Style="{StaticResource SidebarNavButtonStyle}" Tag="farming" Click="SidebarNavButton_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource NavIcon}" Text="&#xE7C1;" /><TextBlock Style="{StaticResource NavText}" Text="Farming" /></StackPanel>
                    </Button>
                    <Button x:Name="TroopsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Tag="troops" Click="SidebarNavButton_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource NavIcon}" Text="&#xE716;" /><TextBlock Style="{StaticResource NavText}" Text="Troops" /></StackPanel>
                    </Button>
                    <Button x:Name="ReinforcementsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Tag="reinforcements" Click="SidebarNavButton_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource NavIcon}" Text="&#xE724;" /><TextBlock Style="{StaticResource NavText}" Text="Send Troops" /></StackPanel>
                    </Button>
                    <Button x:Name="NpcTradeNavButton" Style="{StaticResource SidebarNavButtonStyle}" Tag="npc_trade" Click="SidebarNavButton_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource NavIcon}" Text="&#xE719;" /><TextBlock Style="{StaticResource NavText}" Text="NPC / Trade" /></StackPanel>
                    </Button>
                    <Button x:Name="QueueNavButton" Style="{StaticResource SidebarNavButtonStyle}" Tag="queue" Click="SidebarNavButton_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource NavIcon}" Text="&#xE8FD;" /><TextBlock Style="{StaticResource NavText}" Text="Queue" /></StackPanel>
                    </Button>
                    <Button x:Name="LogsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Tag="logs" Click="SidebarNavButton_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource NavIcon}" Text="&#xE7C3;" /><TextBlock Style="{StaticResource NavText}" Text="Logs" /></StackPanel>
                    </Button>
                    <Button x:Name="InboxNavButton" Tag="inbox" Click="SidebarNavButton_Click"
                            ToolTip="{Binding InboxVm.NavTooltip, ElementName=RootWindow}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InboxVm.HasUnreadMessages, ElementName=RootWindow}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource UnreadBrush}" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource NavIcon}" Text="&#xE715;" /><TextBlock Style="{StaticResource NavText}" Text="Messages / Reports" /></StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="5" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="7">
                    <StackPanel>
                        <Border x:Name="LoopStateBadge"
                                Background="{DynamicResource StateIdleBrush}"
                                CornerRadius="10"
                                Padding="8,2,8,2"
                                Margin="0,0,0,6"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="LoopStateTextBlock"
                                       Text="State: idle"
                                       Foreground="White"
                                       FontWeight="SemiBold" />
                        </Border>

						    <Grid Margin="0,0,0,6">
							    <Grid.ColumnDefinitions>
								    <ColumnDefinition Width="*" />
								    <ColumnDefinition Width="Auto" />
							    </Grid.ColumnDefinitions>
							    <Button x:Name="StartLoopButton" Grid.Column="0" Content="Start bot" Background="{DynamicResource AccentBrush}" Foreground="White" BorderBrush="{DynamicResource AccentBrush}" Click="StartLoopButton_Click" />
							    <Button x:Name="StopBotButton" Grid.Column="1" Content="&#9632;" Width="30" Padding="0" Margin="6,0,0,0" Background="{DynamicResource DangerBgBrush}" BorderBrush="{DynamicResource DangerBorderBrush}" Foreground="{DynamicResource DangerTextBrush}" Click="StopBotButton_Click" ToolTip="Stop bot" />
						    </Grid>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="SettingsButton"
                                    Grid.Column="0"
                                    Content="Settings"
                                    Click="SettingsButton_Click"
                                    Margin="0,0,6,0" />
                            <Button x:Name="SupportButton"
                                    Grid.Column="1"
                                    Content="&#xE715;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Width="30"
                                    Padding="0"
                                    Margin="6,0,0,0"
                                    ToolTip="Support"
                                    Click="SupportButton_Click" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="12,8,12,8">
            <Grid.Resources>
                <Style x:Key="MetricCard" TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CornerRadius" Value="8" />
                    <Setter Property="Padding" Value="11,6" />
                    <Setter Property="Margin" Value="0,0,8,0" />
                    <Setter Property="MinWidth" Value="78" />
                    <Setter Property="VerticalAlignment" Value="Stretch" />
                </Style>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Topbar: each metric in its own card (label on top, value below).
                 Session + Time stay left; the rest are right-aligned with a gap between. -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.Resources>
                    <Style x:Key="MetricLabel" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="Margin" Value="0,0,0,3" />
                    </Style>
                    <Style x:Key="MetricValue" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                        <Setter Property="FontSize" Value="15" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                    <!-- Icon before each value. Segoe MDL2 line glyphs (WPF renders color emoji as
                         monochrome/blank), tinted per metric for a crisp colored look. -->
                    <Style x:Key="MetricIcon" TargetType="TextBlock">
                        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="Margin" Value="0,0,6,0" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                    </Style>
                    <Style x:Key="DailyMetricLabel" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                        <Setter Property="FontSize" Value="10" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                    <Style x:Key="DailyMetricValue" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="HorizontalAlignment" Value="Right" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left group: Session + Time -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- Session pacing / Next sleep (background pulses via code) -->
                    <!-- Fixed width so the card does not resize as the status text/Run now button changes. -->
                    <Border x:Name="SessionPacingBorder" Style="{StaticResource MetricCard}" Width="176">
                        <StackPanel>
                            <TextBlock Text="Session" Style="{StaticResource MetricLabel}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE916;" Style="{StaticResource MetricIcon}" />
                                <TextBlock x:Name="SessionPacingStatusTextBlock"
                                           Text="Session pacing"
                                           Style="{StaticResource MetricValue}"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                                <!-- Compact play-glyph button (tooltip "Run now") so the card can stay narrow
                                     while still fitting the sleeping status text plus the wake action. -->
                                <Button x:Name="SessionPacingRunNowButton"
                                        Content="&#xE768;"
                                        FontFamily="Segoe MDL2 Assets"
                                        Margin="6,0,0,0"
                                        Padding="0"
                                        Width="22"
                                        Height="20"
                                        MinHeight="0"
                                        FontSize="11"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed"
                                        ToolTip="Run now"
                                        Click="SessionPacingRunNowButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="DailyPacingBorder" Style="{StaticResource MetricCard}" Width="141">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Online today" Style="{StaticResource DailyMetricLabel}" />
                                    <Button x:Name="DailyPacingDetailsButton"
                                            Content="&#xE713;"
                                            FontFamily="Segoe MDL2 Assets"
                                            Padding="0"
                                            Width="16"
                                            Height="16"
                                            MinHeight="0"
                                            FontSize="9"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="Daily details"
                                            Click="DailyPacingDetailsButton_Click" />
                                </StackPanel>
                                <TextBlock x:Name="DailyOnlineTextBlock" Grid.Row="0" Grid.Column="1" Text="00:00" Style="{StaticResource DailyMetricValue}" Margin="6,0,0,0" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Time left" Style="{StaticResource DailyMetricLabel}" />
                                <TextBlock x:Name="DailyLeftTextBlock" Grid.Row="1" Grid.Column="1" Text="-" Style="{StaticResource DailyMetricValue}" Margin="6,0,0,0" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Fixed width so the clock value does not jiggle the card as the time updates. -->
                    <Border Style="{StaticResource MetricCard}" Width="152">
                        <StackPanel>
                            <TextBlock Text="Time" Style="{StaticResource MetricLabel}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE823;" Style="{StaticResource MetricIcon}" />
                                <TextBlock x:Name="ClockTextBlock" Text="-" Style="{StaticResource MetricValue}" FontSize="13" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- The village the bot is currently working in (browser's village), so the user can see it
                         from any page in the UI. Set from SetActiveWorkingVillage. -->
                    <Border Style="{StaticResource MetricCard}" Width="130">
                        <StackPanel>
                            <TextBlock Text="Active village" Style="{StaticResource MetricLabel}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE707;" Style="{StaticResource MetricIcon}" />
                                <TextBlock x:Name="ActiveVillageTextBlock" Text="-" Style="{StaticResource MetricValue}" FontSize="13" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right group: everything else, right-aligned -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Gold spent" Style="{StaticResource MetricLabel}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="NpcTradeSessionStatsTextBlock" Text="0" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Captchas only relevant on SS-Travi; shown/hidden in code via UpdateCaptchaCardVisibility. -->
                    <Border x:Name="CaptchaStatsCard" Style="{StaticResource MetricCard}" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Captchas solved" Style="{StaticResource MetricLabel}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72E;" Style="{StaticResource MetricIcon}" />
                                <TextBlock x:Name="CaptchaStatsTextBlock" Text="0/0" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Gold" Style="{StaticResource MetricLabel}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ServerResourcesTextBlock" Text="-" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Silver" Style="{StaticResource MetricLabel}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="SilverInfoTextBlock" Text="-" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Goldclub" Style="{StaticResource MetricLabel}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="GoldClubInfoTextBlock" Text="-" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Plus" Style="{StaticResource MetricLabel}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="PlusInfoTextBlock" Text="-" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="Tribe" Style="{StaticResource MetricLabel}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TribeInfoTextBlock" Text="-" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Hidden compatibility controls referenced by existing code-behind. -->
                    <TextBlock x:Name="BrowserInfoTextBlock" Text="Browser: idle" Visibility="Collapsed" />
                    <TextBlock x:Name="StatusTextBlock" Text="Ready." Visibility="Collapsed" />
                </StackPanel>
            </Grid>

            <!-- Status + Next task styled as rounded cards matching the metric cards above. -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left half: status mini-log -->
                <Border Grid.Column="0" Style="{StaticResource MetricCard}" Margin="0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Status" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock x:Name="StatusMiniLogTextBlock" Text="Ready." Foreground="{DynamicResource DataGridCellTextBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Right half: what the bot will run next (read-only mirror of the loop selector). -->
                <Border Grid.Column="2" Style="{StaticResource MetricCard}" Margin="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Next task" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock x:Name="NextTaskTextBlock" Text="-" Foreground="{DynamicResource DataGridCellTextBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,8,0,0"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            DataContext="{Binding ResourcesVm, ElementName=RootWindow}"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,8">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <Button x:Name="OpenResourceTestFunctionsButton"
                                        DockPanel.Dock="Right"
                                        Content="Test functions"
                                        Padding="10,4"
                                        Click="OpenResourceTestFunctionsButton_Click" />
                                <Button x:Name="TroopSettingsButton"
                                        DockPanel.Dock="Right"
                                        Content="Troop settings"
                                        Padding="10,4"
                                        Margin="0,0,8,0"
                                        Click="TroopSettingsButton_Click"
                                        ToolTip="Open the per-village troop training overview (which buildings train and which troop). Available on every page." />
                                <Button x:Name="VillageSettingsButton"
                                        DockPanel.Dock="Right"
                                        Content="Village settings"
                                        Padding="10,4"
                                        Margin="0,0,8,0"
                                        Click="VillageSettingsButton_Click"
                                        ToolTip="Open per-village settings (hero resources, NPC, build/upgrade troops, farming)." />
                                <Button x:Name="AccountScanButton"
                                        DockPanel.Dock="Right"
                                        Content="Account scan"
                                        IsEnabled="False"
                                        Padding="10,4"
                                        Margin="0,0,8,0"
                                        Click="AccountScanButton_Click"
                                        ToolTip="Analyze dorf1, dorf2, construction queue and Smithy queue for every village. Active automation pauses and resumes automatically." />
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <TextBlock Text="Storage"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <Button x:Name="StorageRefreshButton"
                                        Width="26"
                                        Height="26"
                                        Padding="0"
                                        Margin="8,0,8,0"
                                        FontFamily="Segoe MDL2 Assets"
                                        Content="&#xE72C;"
                                        ToolTip="Refresh storage from the current page"
                                        Click="StorageRefreshButton_Click" />
                                </StackPanel>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding StorageBars}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,8,0"
                                                Padding="8"
                                                CornerRadius="8"
                                                Background="{DynamicResource SurfaceAltBrush}"
                                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                BorderThickness="1"
                                                ToolTipService.InitialShowDelay="500"
                                                ToolTip="{Binding TooltipText}">
                                            <StackPanel>
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left"
                                                               Text="{Binding DisplayName}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding PercentText}"
                                                               Foreground="{Binding StatusBrush}"
                                                               FontWeight="SemiBold" />
                                                </DockPanel>
                                                <ProgressBar Height="10"
                                                             Margin="0,6,0,6"
                                                             Minimum="0"
                                                             Maximum="100"
                                                             Value="{Binding PercentValue}"
                                                             Foreground="{Binding BarBrush}"
                                                             Background="{Binding TrackBrush}" />
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left"
                                                               Text="{Binding CurrentMaxText}"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               FontSize="11" />
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding TimeUntilFullText}"
                                                               Foreground="{Binding StatusBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold" />
                                                </DockPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <TabControl Grid.Row="1" x:Name="MainTabControl" Background="Transparent" BorderThickness="0">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Style>
                    </TabControl.ItemContainerStyle>

                <TabItem x:Name="DashboardTabItem" Header="Dashboard">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="Dashboard" FontSize="32" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right" x:Name="ResetProgramButton" Height="32" Content="Reset program" Background="{DynamicResource WarningButtonBgBrush}" Foreground="{DynamicResource OnWarningBrush}" BorderBrush="{DynamicResource WarningBorderBrush}" VerticalAlignment="Center" Margin="12,0,0,0" Click="ResetProgramButton_Click"
                                    ToolTip="Restart the browser session: stops running tasks and closes Chromium. Account, settings, queue, cached villages, and saved login are kept." />
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,10" Visibility="Collapsed">
                            <TextBlock x:Name="VillagesInfoTextBlock" Text="Villages: -" />
                            <TextBlock x:Name="LastScanInfoTextBlock" Text="Last scan: -" />
                        </Grid>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- LEFT column: Automation Loop, full height (so all group rows fit in one column). -->
                            <Border Grid.Column="0" Margin="0,0,10,0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="9" Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                            <TextBlock Text="Automation Loop" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <Border Width="14"
                                                    Height="14"
                                                    Margin="8,0,0,0"
                                                    CornerRadius="7"
                                                    Background="{DynamicResource ControlBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    VerticalAlignment="Center"
                                                    ToolTipService.InitialShowDelay="0">
                                                <Border.ToolTip>
                                                    <ToolTip MaxWidth="360">
                                                        <StackPanel Width="320">
                                                            <TextBlock Text="Automation Loop"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TooltipForegroundBrush}"
                                                                       Margin="0,0,0,6" />
                                                            <TextBlock TextWrapping="Wrap"
                                                                       Text="Runs the enabled task groups in the order shown. The loop checks the queue, runs ready tasks, and waits between passes while still reacting quickly to stop or pause." />
                                                            <TextBlock Margin="0,6,0,0"
                                                                       TextWrapping="Wrap"
                                                                       Text="Drag items to change order. Use each switch to enable or disable a task group." />
                                                        </StackPanel>
                                                    </ToolTip>
                                                </Border.ToolTip>
                                                <TextBlock Text="i"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center" />
                                            </Border>
                                        </StackPanel>
                                        <Button x:Name="DashboardClearTimersButton"
                                                DockPanel.Dock="Right"
                                                Height="30"
                                                Content="Clear timers"
                                                MinWidth="70"
                                                Click="DashboardClearTimersButton_Click" />
                                        <StackPanel DockPanel.Dock="Right" Visibility="Collapsed">
                                            <Ellipse x:Name="AutomationLoopRunStateDot" Width="8" Height="8" Fill="{DynamicResource BorderMutedBrush}" />
                                            <TextBlock x:Name="AutomationLoopRunStateTextBlock" Text="Idle" />
                                        </StackPanel>
                                    </DockPanel>

                                    <ListBox x:Name="AutomationLoopListBox"
                                             Grid.Row="1"
                                             Margin="0,0,0,8"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             SelectionMode="Single"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             AllowDrop="True"
                                             PreviewMouseLeftButtonDown="AutomationLoopListBox_PreviewMouseLeftButtonDown"
                                             PreviewMouseMove="AutomationLoopListBox_PreviewMouseMove"
                                             DragOver="AutomationLoopListBox_DragOver"
                                             Drop="AutomationLoopListBox_Drop">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,0,6,6" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="8" Padding="8,5" Margin="0,0,0,4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource SuccessBgBrush}" />
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Toggle -->
                                                        <ToggleButton Grid.Column="0"
                                                                      Style="{StaticResource AutomationToggleStyle}"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,10,0"
                                                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                                      Click="AutomationLoopToggleButton_Click" />

                                                        <!-- Name (+ description) -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>

                                                        <!-- Status -->
                                                        <Border Grid.Column="2"
                                                                Padding="8,3"
                                                                CornerRadius="8"
                                                                VerticalAlignment="Center"
                                                                BorderThickness="1"
                                                                MinWidth="64">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{DynamicResource SuccessBgBrush}" />
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBorderBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                                            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding HasTimer}" Value="True">
                                                                            <Setter Property="Background" Value="{DynamicResource WarningBgBrush}" />
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource WarningBorderBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="{Binding BadgeText}" />
                                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessTextBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                                                <Setter Property="Text" Value="{Binding BlockedText}" />
                                                                                <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                                <Setter Property="Text" Value="Disabled" />
                                                                                <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding HasTimer}" Value="True">
                                                                                <Setter Property="Text" Value="{Binding TimerText}" />
                                                                                <Setter Property="Foreground" Value="{DynamicResource WarningTextBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>

                            <!-- RIGHT column: Villages (row 0) + Auto settings (row 1, below). Villages no
                                 longer fills the whole height; the settings box sits beneath it. -->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                            <!-- Auto settings: rendered below the villages box via Grid.Row 1. -->
                            <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Text="Auto settings" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" />
                                    <!-- Each setting gets a trailing "i" info icon (SettingInfoIconStyle) describing it. -->
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox x:Name="AutoCollectTasksCheckBox" Content="Collect tasks"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  Checked="AutoCollectTasksSetting_Changed" Unchecked="AutoCollectTasksSetting_Changed" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}">
                                            <ContentControl.ToolTip>
                                                <ToolTip MaxWidth="320">
                                                    <TextBlock TextWrapping="Wrap"
                                                               Text="Official servers only. When the Questmaster has claimable task rewards, the bot opens the Tasks page, collects the rewards on both the village and general tabs, and returns to the village." />
                                                </ToolTip>
                                            </ContentControl.ToolTip>
                                        </ContentControl>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <CheckBox x:Name="AutoCollectDailyQuestsCheckBox" Content="Collect daily quests"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  Checked="AutoCollectDailyQuestsSetting_Changed" Unchecked="AutoCollectDailyQuestsSetting_Changed" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}">
                                            <ContentControl.ToolTip>
                                                <ToolTip MaxWidth="320">
                                                    <TextBlock TextWrapping="Wrap"
                                                               Text="Official servers only. When the daily quests icon shows an exclamation mark, the bot opens the dialog and collects available daily rewards." />
                                                </ToolTip>
                                            </ContentControl.ToolTip>
                                        </ContentControl>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <CheckBox x:Name="HeroResourceTransferCheckBox" Content="Use hero resources"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  VerticalAlignment="Center"
                                                  Checked="HeroResourceTransferSetting_Changed" Unchecked="HeroResourceTransferSetting_Changed" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}">
                                            <ContentControl.ToolTip>
                                                <ToolTip MaxWidth="320">
                                                    <TextBlock TextWrapping="Wrap"
                                                               Text="For the selected village. When enabled, allowed features may pull missing wood/clay/iron/crop from the hero's inventory." />
                                                </ToolTip>
                                            </ContentControl.ToolTip>
                                        </ContentControl>
                                        <Button x:Name="HeroInventorySettingsButton"
                                                Content="&#xE713;"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="13"
                                                Width="26"
                                                Height="22"
                                                Padding="0"
                                                Margin="6,0,0,0"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                ToolTip="Open per-village Hero resource settings"
                                                Click="HeroInventorySettingsButton_Click" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <CheckBox Content="Allow gold spending"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding TroopTrainingVm.AllowGoldSpending, ElementName=RootWindow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}">
                                            <ContentControl.ToolTip>
                                                <ToolTip MaxWidth="320">
                                                    <TextBlock TextWrapping="Wrap"
                                                               Text="Allows gold-spending features such as NPC trade. Spending still respects the gold limit configured on the NPC / Trade tab." />
                                                </ToolTip>
                                            </ContentControl.ToolTip>
                                        </ContentControl>
                                    </StackPanel>
                                    <!-- NPC trade master on/off. Detailed per-feature toggles and thresholds
                                         stay on the NPC / Trade tab, reachable via the gear button. -->
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <CheckBox Content="NPC trade"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding TroopTrainingVm.NpcTradeMasterEnabled, ElementName=RootWindow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}">
                                            <ContentControl.ToolTip>
                                                <ToolTip MaxWidth="320">
                                                    <TextBlock TextWrapping="Wrap"
                                                               Text="Enables NPC trade for both troop training and building/resource-field upgrades. Each NPC trade costs 3 gold and requires Allow gold spending. Open the settings for per-feature toggles, resources, and thresholds." />
                                                </ToolTip>
                                            </ContentControl.ToolTip>
                                        </ContentControl>
                                        <Button x:Name="GoldSpendingSettingsButton"
                                                Content="&#xE713;"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="13"
                                                Width="26"
                                                Height="22"
                                                Padding="0"
                                                Margin="6,0,0,0"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                ToolTip="Open NPC trade settings"
                                                Click="GoldSpendingSettingsButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Villages overview (top, row 0). Columns: Name, Buildings, Queue, Smithy,
                                 Troops, Hero, Pop, Coords. -->
                            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="9" Padding="12">
                                    <DockPanel>
                                        <!-- Title row doubles as the column header, aligned with the fixed-width data columns below. -->
                                        <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="44" />
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="84" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Village overview" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                            <TextBlock Grid.Column="1" Text="Buildings" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                                            <TextBlock Grid.Column="2" Text="Queue" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="2,0,0,0" />
                                            <TextBlock Grid.Column="3" Text="Smithy" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                                            <TextBlock Grid.Column="4" Text="Troops" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                                            <TextBlock Grid.Column="5" Text="Hero" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="2,0,0,0" />
                                            <TextBlock Grid.Column="6" Text="Pop" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                            <TextBlock Grid.Column="7" Text="Coords" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                        </Grid>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl x:Name="DashboardVillageList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                      <!-- Colored border marks the village the bot is currently working in
                                                           (the one open in the browser), distinct from the selected/viewed village. -->
                                                      <Border Margin="0,1" Padding="4,1" CornerRadius="6" BorderThickness="1">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActiveWorkingVillage}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource SuccessBgBrush}" />
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="72" />
                                                                <ColumnDefinition Width="40" />
                                                                <ColumnDefinition Width="56" />
                                                                <ColumnDefinition Width="92" />
                                                                <ColumnDefinition Width="44" />
                                                                <ColumnDefinition Width="56" />
                                                                <ColumnDefinition Width="84" />
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Capital villages get a gold box around the name instead of a
                                                                 separate "Capital" badge. Padding is kept on non-capital rows
                                                                 too (transparent box) so names stay vertically aligned. -->
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <!-- Enabled indicator: green = village is processed by the bot, grey = skipped. -->
                                                                <Ellipse Width="10" Height="10" Margin="2,0,6,0" VerticalAlignment="Center">
                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">
                                                                            <Setter Property="Fill" Value="{DynamicResource BorderMutedBrush}" />
                                                                            <Setter Property="ToolTip" Value="Village disabled (skipped by the bot)" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsEnabledForAutomation}" Value="True">
                                                                                    <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                                                                                    <Setter Property="ToolTip" Value="Village enabled (processed by the bot)" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>
                                                                </Ellipse>
                                                                <!-- Capital villages get a gold box around the name instead of a separate badge. -->
                                                                <Border HorizontalAlignment="Left"
                                                                    VerticalAlignment="Center"
                                                                    Padding="7,1"
                                                                    CornerRadius="6"
                                                                    BorderThickness="1"
                                                                    Background="Transparent"
                                                                    BorderBrush="Transparent">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="Transparent" />
                                                                        <Setter Property="BorderBrush" Value="Transparent" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCapital}" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource WarningBgBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource WarningBorderBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding Name}" FontSize="13" TextTrimming="CharacterEllipsis">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsCapital}" Value="True">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource WarningTextBrush}" />
                                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="6" Text="{Binding PopText}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="7" Text="{Binding CoordsText}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center" />

                                                            <!-- Buildings: one slot per construction queue position (2 normally, 3 for Romans).
                                                                 Dark = idle, green = building. -->
                                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding BuildingSlots}" VerticalAlignment="Center" Margin="4,0,0,0">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Width="18" Height="18" CornerRadius="4" Margin="2,0" ToolTip="{Binding Tooltip}">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                                                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}" />
                                                                                    <Setter Property="BorderThickness" Value="1" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                                                                            <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                                                            <Setter Property="BorderBrush" Value="{DynamicResource WarningBorderBrush}" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                                            <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                                                            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBorderBrush}" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                                                                                <Setter Property="Foreground" Value="{DynamicResource OnWarningBrush}" />
                                                                                            </DataTrigger>
                                                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                                                <Setter Property="Foreground" Value="White" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <!-- Troops: Barracks/Stable/Workshop. Dark = idle, green = training. -->
                                                            <ItemsControl Grid.Column="4" ItemsSource="{Binding TroopSlots}" VerticalAlignment="Center" Margin="4,0,0,0">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Width="18" Height="18" CornerRadius="4" Margin="2,0" ToolTip="{Binding Tooltip}">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                                                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}" />
                                                                                    <Setter Property="BorderThickness" Value="1" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                                                                            <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                                                            <Setter Property="BorderBrush" Value="{DynamicResource WarningBorderBrush}" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                                            <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                                                            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBorderBrush}" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="{Binding Label}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                                                                                <Setter Property="Foreground" Value="{DynamicResource OnWarningBrush}" />
                                                                                            </DataTrigger>
                                                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                                                <Setter Property="Foreground" Value="White" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <!-- Queue: green when the village has construction queued, grey (like the other icons) when empty. -->
                                                            <Border Grid.Column="2" Width="18" Height="18" CornerRadius="4" Margin="2,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}" />
                                                                        <Setter Property="BorderThickness" Value="1" />
                                                                        <Setter Property="ToolTip" Value="No construction queued here — consider queuing more" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasQueue}" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource SuccessBorderBrush}" />
                                                                                <Setter Property="ToolTip" Value="Construction queued in this village" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasQueue}" Value="True">
                                                                                    <Setter Property="Foreground" Value="White" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>

                                                            <!-- Smithy: two research slots, lit from the live per-village queue ([smithy-queue]); tooltip shows the remaining time. -->
                                                            <ItemsControl Grid.Column="3" ItemsSource="{Binding SmithySlots}" VerticalAlignment="Center" Margin="4,0,0,0">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Width="18" Height="18" CornerRadius="4" Margin="2,0" ToolTip="{Binding Tooltip}">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                                                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}" />
                                                                                    <Setter Property="BorderThickness" Value="1" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                                                                            <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                                                            <Setter Property="BorderBrush" Value="{DynamicResource WarningBorderBrush}" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                                            <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                                                            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBorderBrush}" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="&#xE70E;" FontFamily="Segoe MDL2 Assets" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                                                                                <Setter Property="Foreground" Value="{DynamicResource OnWarningBrush}" />
                                                                                            </DataTrigger>
                                                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                                                <Setter Property="Foreground" Value="White" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <!-- Hero: green = hero home in this village, yellow = home village but hero is away, dark = no hero. -->
                                                            <Border Grid.Column="5" Width="18" Height="18" CornerRadius="4" Margin="2,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}" />
                                                                        <Setter Property="BorderThickness" Value="1" />
                                                                        <Setter Property="ToolTip" Value="Hero is not based here" />
                                                                        <Style.Triggers>
                                                                            <!-- Green only when the hero is home AND present (not away, not dead). Using a
                                                                                 MultiDataTrigger keeps the states mutually exclusive so green can never render
                                                                                 on top of the away (yellow) / dead (red) states. -->
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding IsHeroHome}" Value="True" />
                                                                                    <Condition Binding="{Binding IsHeroAway}" Value="False" />
                                                                                    <Condition Binding="{Binding IsHeroReviving}" Value="False" />
                                                                                    <Condition Binding="{Binding IsHeroDead}" Value="False" />
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource SuccessBorderBrush}" />
                                                                                <Setter Property="ToolTip" Value="Hero home village (hero is here)" />
                                                                            </MultiDataTrigger>
                                                                            <DataTrigger Binding="{Binding IsHeroAway}" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource WarningBorderBrush}" />
                                                                                <Setter Property="ToolTip" Value="Hero home village (hero is away)" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsHeroReviving}" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource RevivingBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource RevivingBorderBrush}" />
                                                                                <Setter Property="ToolTip" Value="Hero home village (hero is reviving)" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsHeroDead}" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource DangerBorderBrush}" />
                                                                                <Setter Property="ToolTip" Value="Hero home village (hero is dead)" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsHeroHome}" Value="True">
                                                                                    <Setter Property="Foreground" Value="White" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </Grid>
                                                      </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem x:Name="ResourcesTabItem" Header="Resources"
                         DataContext="{Binding ResourcesVm, ElementName=RootWindow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="Resources"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal">
                            <Button x:Name="LoadResourcesButton" Content="↻" Width="42" FontSize="16" Click="LoadResourcesButton_Click" ToolTip="Refresh resources" IsEnabled="{Binding ActionsEnabled}" />
                            <TextBlock Text="Target level" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox x:Name="ResourceTargetLevelComboBox" Width="90" Margin="0,0,8,0" ItemsSource="{Binding TargetLevelOptions}" SelectedItem="{Binding SelectedTargetLevel}" IsEnabled="{Binding ActionsEnabled}" />
                            <Button x:Name="UpgradeAllResourcesButton" Content="Upgrade all to level" Width="160" Background="{DynamicResource AccentBrush}" Foreground="White" BorderBrush="{DynamicResource AccentBrush}" Click="UpgradeAllResourcesButton_Click" IsEnabled="{Binding ActionsEnabled}"
                                    ToolTip="Queue upgrades for every resource field up to the target level selected on the left, following the chosen Build order (Lowest level first or Smart)." />
                            <Button x:Name="UpgradeAllResourcesToMaxButton" Content="Upgrade to max" Width="140" Margin="8,0,0,0" Background="{DynamicResource WarningButtonBgBrush}" Foreground="{DynamicResource OnWarningBrush}" BorderBrush="{DynamicResource WarningBorderBrush}" Click="UpgradeAllResourcesToMaxButton_Click" IsEnabled="{Binding ActionsEnabled}"
                                    ToolTip="Queue upgrades for every resource field up to its maximum level, following the chosen Build order (Lowest level first or Smart)." />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Build order:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,12,0" />
                                <RadioButton Content="Lowest level first"
                                             GroupName="ResourceBuildStrategy"
                                             VerticalAlignment="Center"
                                             Margin="0,0,16,0"
                                             IsChecked="{Binding IsBuildLowestFirst}"
                                             Click="ResourceBuildStrategyRadio_Click"
                                             ToolTip="When using 'Upgrade all', always upgrade the resource field with the lowest level first, so all fields rise evenly toward the target level." />
                                <RadioButton Content="Smart"
                                             GroupName="ResourceBuildStrategy"
                                             VerticalAlignment="Center"
                                             IsChecked="{Binding IsBuildSmart}"
                                             Click="ResourceBuildStrategyRadio_Click"
                                             ToolTip="When using 'Upgrade all', prioritize fields that produce the resource you currently have the least of in storage (wood/clay/iron/crop), re-evaluated each pass to balance your stockpile." />
                                <Border Width="14"
                                        Height="14"
                                        Margin="6,0,0,0"
                                        CornerRadius="7"
                                        Background="{DynamicResource ControlBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTipService.InitialShowDelay="0">
                                    <Border.ToolTip>
                                        <ToolTip MaxWidth="340">
                                            <StackPanel Width="300">
                                                <TextBlock Text="Build order"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TooltipForegroundBrush}"
                                                           Margin="0,0,0,6" />
                                                <TextBlock TextWrapping="Wrap"
                                                           Text="Lowest level first upgrades the resource field with the lowest level so fields rise evenly." />
                                                <TextBlock Margin="0,6,0,0"
                                                           TextWrapping="Wrap"
                                                           Text="Smart prioritizes the resource you currently have the least of in storage and re-evaluates after each pass." />
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="i"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center" />
                                </Border>
                            </StackPanel>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="Production"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>
                                    <ItemsControl ItemsSource="{Binding StorageBars}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="4" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,8,0"
                                                        Padding="8"
                                                        CornerRadius="6"
                                                        Background="{Binding TrackBrush}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding ProductionText}"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Background="{DynamicResource SurfaceBrush}" Padding="12">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <Grid HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Width="190" Margin="0,0,8,0">
                                    <TextBlock Text="Woodcutter" Foreground="{DynamicResource WoodTextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding WoodFields}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource WoodCardBgBrush}" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="{DynamicResource WoodBadgeTextBrush}"
                                                                Background="{DynamicResource WoodBadgeBgBrush}"
                                                                BorderBrush="{DynamicResource WoodBadgeBorderBrush}"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Width="190" Margin="0,0,8,0">
                                    <TextBlock Text="Clay Pit" Foreground="{DynamicResource ClayTextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding ClayFields}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource ClayCardBgBrush}" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="{DynamicResource ClayBadgeTextBrush}"
                                                                Background="{DynamicResource ClayBadgeBgBrush}"
                                                                BorderBrush="{DynamicResource ClayBadgeBorderBrush}"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Width="190" Margin="0,0,8,0">
                                    <TextBlock Text="Iron Mine" Foreground="{DynamicResource IronTextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding IronFields}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource IronCardBgBrush}" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="{DynamicResource IronBadgeTextBrush}"
                                                                Background="{DynamicResource IronBadgeBgBrush}"
                                                                BorderBrush="{DynamicResource IronBadgeBorderBrush}"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel x:Name="CroplandColumnPanel" Grid.Column="3" Width="190" Margin="0,0,0,0">
                                    <TextBlock Text="Cropland" Foreground="{DynamicResource CropTextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl x:Name="CroplandItemsControl" ItemsSource="{Binding CroplandFields}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="1" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource CropCardBgBrush}" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="{DynamicResource CropBadgeTextBrush}"
                                                                Background="{DynamicResource CropBadgeBgBrush}"
                                                                BorderBrush="{DynamicResource CropBadgeBorderBrush}"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                            </ScrollViewer>
                        </Border>
                        <TextBlock Visibility="Collapsed" Text="{Binding InfoText}" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="BuildingsTabItem" Header="Buildings">
                    <Grid>
                        <views:BuildingsPanel />

                        <!-- Hidden compatibility controls used by existing building code-behind -->
                        <StackPanel Visibility="Collapsed">
                            <ComboBox x:Name="BuildingCategoryComboBox" />
                            <ComboBox x:Name="ConstructBuildingComboBox" />
                            <ComboBox x:Name="DemolishBuildingComboBox" />
                            <TextBox x:Name="ConstructSlotTextBox" Text="19" />
                            <TextBox x:Name="UpgradeSlotTextBox" Text="19" />
                            <TextBox x:Name="UpgradeTargetLevelTextBox" Text="2" />
                            <TextBox x:Name="DemolishTargetLevelTextBox" Text="0" />
                            <TextBlock x:Name="BuildingsInfoTextBlock" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem x:Name="HeroTabItem" Header="Hero / Adventures"
                         DataContext="{Binding HeroVm, ElementName=RootWindow}">
                    <!-- TabItem keeps the DataContext binding so the panel inherits the
                         HeroViewModel; all hero UI lives in Views/HeroPanel.xaml. -->
                    <views:HeroPanel />
                </TabItem>
                <TabItem x:Name="FarmingTabItem" Header="Farming">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Farming" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10" />
                        <Grid Grid.Row="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,0,8,0">
                                    <Grid MaxWidth="560" HorizontalAlignment="Left">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="Farm List Management"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,0,0,12" />

                                        <WrapPanel Grid.Row="1" Margin="0,0,0,12">
                                            <Button x:Name="AnalyzeFarmListsButton"
                                                    Content="Analyze Farmlists"
                                                    Background="{DynamicResource AccentBrush}"
                                                    Foreground="White"
                                                    BorderBrush="{DynamicResource AccentBrush}"
                                                    MinWidth="150"
                                                    Click="AnalyzeFarmListsButton_Click" />
                                            <Button x:Name="AddFarmsToListButton"
                                                    Content="Add Farms to List"
                                                    Background="{DynamicResource AccentBrush}"
                                                    Foreground="White"
                                                    BorderBrush="{DynamicResource AccentBrush}"
                                                    MinWidth="140"
                                                    Click="AddFarmsToListButton_Click" />
                                            <Button x:Name="CreateFarmListButton"
                                                    Content="Create Farmlist"
                                                    MinWidth="120"
                                                    Click="CreateFarmListButton_Click" />
                                        </WrapPanel>

                                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel>
                                                <TextBlock x:Name="FarmingStatusTextBlock"
                                                           Text="No farm lists loaded. Click Analyze Farmlists."
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           Margin="0,0,0,8" />

                                                <Button x:Name="FarmListSendAllNowButton"
                                                        Content="Send all Now"
                                                        MinWidth="110"
                                                        Height="32"
                                                        Margin="0,0,0,8"
                                                        HorizontalAlignment="Right"
                                                        Background="{DynamicResource AccentBrush}"
                                                        Foreground="White"
                                                        BorderBrush="{DynamicResource AccentBrush}"
                                                        IsEnabled="False"
                                                        Click="FarmListSendAllNowButton_Click" />

                                                <ItemsControl x:Name="FarmListsItemsControl">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border CornerRadius="9" Padding="10" Margin="0,0,0,10">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                                        <Setter Property="BorderThickness" Value="1" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource InfoBgBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource InfoBrush}" />
                                                                                <Setter Property="BorderThickness" Value="2" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <ToggleButton Grid.Column="0"
                                                                                  Style="{StaticResource AutomationToggleStyle}"
                                                                                  VerticalAlignment="Center"
                                                                                  Margin="0,0,10,0"
                                                                                  IsEnabled="{Binding HasFarmList}"
                                                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}" />

                                                                    <Border Grid.Column="1" BorderBrush="{DynamicResource InfoBrush}" BorderThickness="3,0,0,0" Padding="10,0,0,0">
                                                                        <StackPanel VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                                <TextBlock Text="{Binding FarmCountText}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,8,0" />
                                                                                <ProgressBar Width="120"
                                                                                             Height="8"
                                                                                             VerticalAlignment="Center"
                                                                                             Minimum="0"
                                                                                             Maximum="100"
                                                                                             Value="{Binding FillPercent, Mode=OneWay}" />
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <Border Grid.Column="2"
                                                                            Margin="8,0,8,0"
                                                                            Padding="10,4"
                                                                            CornerRadius="8"
                                                                            VerticalAlignment="Center"
                                                                            BorderThickness="1">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="{DynamicResource SuccessBgBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource SuccessBorderBrush}" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasTimer}" Value="True">
                                                                                        <Setter Property="Background" Value="{DynamicResource WarningBgBrush}" />
                                                                                        <Setter Property="BorderBrush" Value="{DynamicResource WarningBorderBrush}" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="{Binding ReadyText}" />
                                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessTextBrush}" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasTimer}" Value="True">
                                                                                            <Setter Property="Text" Value="{Binding TimerText}" />
                                                                                            <Setter Property="Foreground" Value="{DynamicResource WarningTextBrush}" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Border>

                                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                                        <Button Content="Send Now"
                                                                                MinWidth="90"
                                                                                Height="32"
                                                                                Background="{DynamicResource AccentBrush}"
                                                                                Foreground="White"
                                                                                BorderBrush="{DynamicResource AccentBrush}"
                                                                                Tag="{Binding}"
                                                                                IsEnabled="{Binding CanSendNow}"
                                                                                Click="FarmListSendNowButton_Click" />
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <!-- Floats in the bottom-right corner of the Farm List
                                             Management box while any farming operation (Analyze,
                                             Add Farms, Send Now, manual farming) is running, so the
                                             user can always cancel from a fixed location. -->
                                        <Button x:Name="CancelFarmingOperationButton"
                                                Grid.Row="2"
                                                Content="Cancel"
                                                Background="{DynamicResource DangerStrongBrush}"
                                                Foreground="White"
                                                BorderBrush="{DynamicResource DangerStrongBrush}"
                                                MinWidth="110"
                                                Height="36"
                                                Padding="14,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Margin="0,12,0,0"
                                                Panel.ZIndex="1000"
                                                Visibility="Collapsed"
                                                Click="CancelFarmingOperationButton_Click" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1" Margin="8,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Manual farming"
                                                           FontSize="22"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1"
                                                            HorizontalAlignment="Right">
                                                    <TextBlock Text="Farmlist executions"
                                                               Foreground="{DynamicResource TextSubtleBrush}"
                                                               FontSize="12"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock x:Name="ManualFarmingExecutionCountTextBlock"
                                                               Text="0"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="190" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Button x:Name="AnalyzeNatarsProfileButton"
                                                        Grid.Row="0"
                                                        Grid.Column="0"
                                                        Content="Analyze natars profile"
                                                        Width="170"
                                                        Margin="0,0,0,6"
                                                        ToolTip="Reads the Natars profile and saves the available farm villages for farming."
                                                        Click="AnalyzeNatarsProfileButton_Click" />
                                                <Button x:Name="ShowNatarsListButton"
                                                        Grid.Row="1"
                                                        Grid.Column="0"
                                                        Content="Show natars list"
                                                        Width="170"
                                                        Margin="0,0,0,6"
                                                        Click="ShowNatarsListButton_Click" />
                                                <Button x:Name="StartManualFarmingButton"
                                                        Grid.Row="2"
                                                        Grid.Column="0"
                                                        Content="Start manual farming"
                                                        Width="170"
                                                        HorizontalAlignment="Center"
                                                        IsEnabled="False"
                                                        ToolTip="Starts manual farming with the selected farming settings."
                                                        Click="StartManualFarmingButton_Click" />

                                                <StackPanel x:Name="NatarsAnalyzedPanel"
                                                            Grid.Row="0"
                                                            Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            Margin="10,0,0,6">
                                                    <TextBlock Text="Analyzed:"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Margin="0,0,6,0" />
                                                    <Ellipse x:Name="NatarsProfileAnalyzedIndicator"
                                                             Width="14"
                                                             Height="14"
                                                             VerticalAlignment="Center"
                                                             Fill="{DynamicResource BorderMutedBrush}" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Farm settings"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Margin="0,0,0,8" />
                                            <StackPanel Margin="0,0,0,10">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <RadioButton x:Name="FarmSendListPerListRadioButton"
                                                                 Content="Send list per list"
                                                                 GroupName="FarmSendMode"
                                                                 Margin="0,0,16,0"
                                                                 Checked="FarmingSettings_Changed" />
                                                    <RadioButton x:Name="FarmSendAllAtOnceRadioButton"
                                                                 Content="Send all lists at once"
                                                                 GroupName="FarmSendMode"
                                                                 Margin="0,0,8,0"
                                                                 Checked="FarmingSettings_Changed" />
                                                    <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                                    VerticalAlignment="Center"
                                                                    ToolTip="Choose whether continuous farming sends one selected farmlist per run or clicks Travian's start-all button for all farmlists at once." />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="Delay between farm sends"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               Margin="0,0,8,0" />
                                                    <ComboBox x:Name="FarmDispatchDelayComboBox"
                                                              Width="92"
                                                              Height="26"
                                                              SelectionChanged="FarmingSettings_Changed">
                                                        <ComboBoxItem Content="1 min" Tag="1" />
                                                        <ComboBoxItem Content="2 min" Tag="2" />
                                                        <ComboBoxItem Content="3 min" Tag="3" />
                                                        <ComboBoxItem Content="5 min" Tag="5" />
                                                        <ComboBoxItem Content="10 min" Tag="10" />
                                                        <ComboBoxItem Content="15 min" Tag="15" />
                                                        <ComboBoxItem Content="20 min" Tag="20" />
                                                        <ComboBoxItem Content="30 min" Tag="30" />
                                                        <ComboBoxItem Content="45 min" Tag="45" />
                                                        <ComboBoxItem Content="60 min" Tag="60" />
                                                        <ComboBoxItem Content="90 min" Tag="90" />
                                                    </ComboBox>
                                                    <ComboBox x:Name="FarmDispatchDelayVariationComboBox"
                                                              Width="70"
                                                              Height="26"
                                                              Margin="8,0,8,0"
                                                              SelectionChanged="FarmingSettings_Changed">
                                                        <ComboBoxItem Content="0%" Tag="0" />
                                                        <ComboBoxItem Content="5%" Tag="5" />
                                                        <ComboBoxItem Content="10%" Tag="10" />
                                                        <ComboBoxItem Content="20%" Tag="20" />
                                                        <ComboBoxItem Content="50%" Tag="50" />
                                                    </ComboBox>
                                                    <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                                    VerticalAlignment="Center"
                                                                    ToolTip="Adds random variation around the delay between farm sends. Example: 20 min with 20% becomes a random wait from 16 to 24 min." />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <CheckBox x:Name="DeactivateFarmLossesCheckBox"
                                                              Content="Deactivate red/yellow attacks"
                                                              Margin="0,0,8,0"
                                                              Checked="FarmingSettings_Changed"
                                                              Unchecked="FarmingSettings_Changed" />
                                                    <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                                    VerticalAlignment="Center"
                                                                    ToolTip="Before sending farmlists, disable targets whose last raid shows red or yellow losses." />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <CheckBox x:Name="DeactivateFarmOasisLossesCheckBox"
                                                              Content="Deactivate oasis with losses"
                                                              Margin="0,0,8,0"
                                                              Checked="FarmingSettings_Changed"
                                                              Unchecked="FarmingSettings_Changed" />
                                                    <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                                    VerticalAlignment="Center"
                                                                    ToolTip="When loss deactivation is enabled, also disable oasis targets that show losses." />
                                                </StackPanel>
                                            </StackPanel>
                                            <Button x:Name="TravcoInactiveSearchButton"
                                                    Content="Inactive / oasis analysis"
                                                    MinWidth="170"
                                                    HorizontalAlignment="Left"
                                                    Click="TravcoInactiveSearchButton_Click" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem x:Name="TroopsTabItem" Header="Troops"
                         DataContext="{Binding TroopTrainingVm, ElementName=RootWindow}">
                    <!-- All troops UI lives in Views/TroopsPanel.xaml; the TabItem keeps the
                         DataContext binding so the panel inherits the TroopTrainingViewModel. -->
                    <views:TroopsPanel />
                </TabItem>

                <TabItem x:Name="ReinforcementsTabItem" Header="Send Troops">
                    <Grid Background="{DynamicResource AppBackgroundBrush}">
                        <Border VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="1.4*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="Reinforcements"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <Border Width="14"
                                                Height="14"
                                                Margin="8,3,0,0"
                                                CornerRadius="7"
                                                Background="{DynamicResource ControlBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                VerticalAlignment="Top"
                                                ToolTipService.InitialShowDelay="0">
                                            <Border.ToolTip>
                                                <ToolTip MaxWidth="360">
                                                    <StackPanel Width="320">
                                                        <TextBlock Text="Reinforcements"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TooltipForegroundBrush}"
                                                                   Margin="0,0,0,6" />
                                                        <TextBlock TextWrapping="Wrap"
                                                                   Text="Sends selected troops from chosen source villages to the selected target village as reinforcements." />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   TextWrapping="Wrap"
                                                                   Text="Use the Troops button on each source village when different villages should send different troop types or amounts." />
                                                    </StackPanel>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Text="i"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1"
                                               Text="Target village"
                                               Foreground="{DynamicResource TextSubtleBrush}"
                                               FontSize="12"
                                               Margin="0,0,0,4" />
                                    <ComboBox Grid.Row="2"
                                              x:Name="ReinforcementTargetVillageComboBox"
                                              Height="30"
                                              DisplayMemberPath="DisplayName"
                                              SelectionChanged="ReinforcementSetting_SelectionChanged" />

                                    <Grid Grid.Row="3" Margin="0,12,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Row="0" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Source villages"
                                                   Foreground="{DynamicResource TextSubtleBrush}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center" />
                                        <Button x:Name="ReinforcementMarkAllTroopsButton"
                                                Grid.Column="1"
                                                Content="Mark all"
                                                Padding="8,2"
                                                Click="MarkAllReinforcementTroopsButton_Click" />
                                        </Grid>
                                    <Border Grid.Row="1"
                                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8"
                                            MinHeight="160">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="ReinforcementSourceVillagesItemsControl">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0"
                                                                      IsChecked="{Binding IsSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      IsEnabled="{Binding CanSelectAsSource}"
                                                                      VerticalAlignment="Center" />
                                                            <StackPanel Grid.Column="1"
                                                                        Margin="8,0,8,0"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                                <TextBlock Text="{Binding TroopSummaryText}"
                                                                           Foreground="{DynamicResource TextSubtleBrush}"
                                                                           FontSize="11"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            <Button Grid.Column="2"
                                                                    Content="Troops"
                                                                    Padding="8,2"
                                                                    Tag="{Binding}"
                                                                    Click="ChooseReinforcementVillageTroopsButton_Click" />
                                                            <TextBlock Grid.Column="3"
                                                                       Text="{Binding SourceStatusText}"
                                                                       Foreground="{DynamicResource BorderMutedBrush}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Margin="8,0,0,0"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="4"
                                               x:Name="ReinforcementTroopsSummaryTextBlock"
                                               Text="No troops selected."
                                               Foreground="{DynamicResource TextSubtleBrush}"
                                               FontSize="12"
                                               Margin="0,10,0,0"
                                               TextWrapping="Wrap" />
                                </Grid>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Send troop settings"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Margin="0,0,0,12" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="128" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Interval"
                                                   Foreground="{DynamicResource TextSubtleBrush}"
                                                   FontSize="12"
                                                   Margin="0,0,0,4" />
                                        <ComboBox Grid.Row="1"
                                                  Grid.Column="0"
                                                  x:Name="ReinforcementSendIntervalComboBox"
                                                  Height="28"
                                                  DisplayMemberPath="Label"
                                                  SelectionChanged="ReinforcementSetting_SelectionChanged" />
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="Variation"
                                                   Foreground="{DynamicResource TextSubtleBrush}"
                                                   FontSize="12"
                                                   Margin="0,0,0,4" />
                                        <ComboBox Grid.Row="1"
                                                  Grid.Column="2"
                                                  x:Name="ReinforcementSendVariationComboBox"
                                                  Height="28"
                                                  DisplayMemberPath="Label"
                                                  SelectionChanged="ReinforcementSetting_SelectionChanged" />
                                    </Grid>
                                    <TextBlock x:Name="ReinforcementTroopsDetailTextBlock"
                                               Text=""
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed" />
                                    <TextBlock x:Name="ReinforcementStatusTextBlock"
                                               Text=""
                                               Foreground="{DynamicResource WarningTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed" />
                                    <Button x:Name="ReinforcementQueueNowButton"
                                            Content="Queue now"
                                            Padding="10,4"
                                            HorizontalAlignment="Left"
                                            Margin="0,12,0,0"
                                            Click="QueueReinforcementsNowButton_Click" />

                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12"
                                            Margin="0,18,0,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Catapult waves"
                                                           FontSize="22"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="7"
                                                        Background="{DynamicResource ControlBackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        Margin="8,5,0,0"
                                                        VerticalAlignment="Center"
                                                        ToolTipService.InitialShowDelay="0">
                                                    <Border.ToolTip>
                                                        <ToolTip MaxWidth="360">
                                                            <StackPanel Width="320">
                                                                <TextBlock Text="Catapult waves"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource TooltipForegroundBrush}"
                                                                           Margin="0,0,0,6" />
                                                                <TextBlock TextWrapping="Wrap"
                                                                           Text="Reads available troops from Rally Point, prepares one first attack and multiple attack waves. Catapult targets use Random automatically when catapults are included." />
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                    <TextBlock Text="i"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center" />
                                                </Border>
                                            </StackPanel>
                                            <Button x:Name="StartCatapultWavesButton"
                                                    Content="Start catapult waves"
                                                    Width="180"
                                                    HorizontalAlignment="Left"
                                                    Background="{DynamicResource AccentBrush}"
                                                    Foreground="White"
                                                    BorderBrush="{DynamicResource AccentBrush}"
                                                    Click="StartCatapultWavesButton_Click" />
                                            <TextBlock x:Name="CatapultWavesStatusTextBlock"
                                                       Text="No catapult waves running."
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       Margin="0,10,0,0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem x:Name="NpcTradeTabItem" Header="NPC / Trade"
                         DataContext="{Binding TroopTrainingVm, ElementName=RootWindow}">
                    <Grid Background="{DynamicResource AppBackgroundBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border VerticalAlignment="Top"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="NPC Trade"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Margin="0,0,0,12" />
                                    <TextBlock Text="Each NPC trade costs 3 gold. Allow gold spending must be enabled for NPC trade to run."
                                               Foreground="{DynamicResource TextSubtleBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,12" />
                                    <TextBlock x:Name="NpcTradeGoldSpentTextBlock"
                                               Text="Gold spent: 0"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6" />
                                    <TextBlock x:Name="NpcTradeTroopsTextBlock"
                                               Text="NPC Troops: 0"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6" />
                                    <TextBlock x:Name="NpcTradeBuildingsTextBlock"
                                               Text="NPC Buildings: 0"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontWeight="SemiBold"
