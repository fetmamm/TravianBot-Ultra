<Window x:Class="TbotUltra.Desktop.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TbotUltra.Desktop"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tbot Ultra"
        Height="740"
        Width="1180"
        MinHeight="640"
        MinWidth="980"
        ShowInTaskbar="True"
        Background="#F3F4F6">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="#E5E7EB" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Background" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#F3F4F6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ResourceLevelBadgeStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="MinWidth" Value="52" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMaxLevel}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Foreground" Value="#6B7280" />
                    <Setter Property="Background" Value="#E5E7EB" />
                    <Setter Property="BorderBrush" Value="#9CA3AF" />
                    <Setter Property="Opacity" Value="0.85" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ContinuousRunToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#9CA3AF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <Border x:Name="Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="12"
                                    BorderBrush="#6B7280"
                                    BorderThickness="1" />
                            <Ellipse x:Name="Thumb"
                                     Width="20"
                                     Height="20"
                                     Margin="2"
                                     Fill="#FFFFFF"
                                     Stroke="#E5E7EB"
                                     StrokeThickness="1"
                                     HorizontalAlignment="Left" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#16A34A" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#15803D" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="0.88" ScaleY="0.88" />
        </Grid.LayoutTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#EFEFEF" BorderBrush="#D1D5DB" BorderThickness="0,0,1,0">
            <Grid Margin="10,8,10,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Tbot Ultra" FontSize="26" FontWeight="SemiBold" Foreground="#111827" />
                    <TextBlock x:Name="VersionTextBlock" Text="Version: -" Foreground="#6B7280" Margin="0,2,0,0" />
                </StackPanel>

                <Border Grid.Row="1" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="7" Margin="0,0,0,6">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Account" Foreground="#6B7280" VerticalAlignment="Center" />
                            <Button x:Name="AccountManageButton"
                                    DockPanel.Dock="Right"
                                    Content="Manage"
                                    Height="22"
                                    Width="72"
                                    Padding="8,1"
                                    Margin="6,0,0,0"
                                    HorizontalAlignment="Right"
                                    Click="AccountsButton_Click" />
                        </DockPanel>
                        <ComboBox x:Name="AccountComboBox"
                                  Height="30"
                                  DisplayMemberPath="PickerName"
                                  SelectionChanged="AccountComboBox_SelectionChanged" />
                        <TextBlock x:Name="ActiveAccountInfoTextBlock"
                                   Margin="0,6,0,0"
                                   Foreground="#4B5563"
                                    Text="Account: - | Server: -" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="7" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="LoginButton"
                                Grid.Column="0"
                                Margin="0,0,3,0"
                                Content="Login"
                                Background="#030826"
                                Foreground="White"
                                BorderBrush="#030826"
                                Click="LoginButton_Click" />
                        <Button x:Name="LogoutButton"
                                Grid.Column="1"
                                Margin="3,0,0,0"
                                Content="Logout"
                                Click="LogoutButton_Click" />
                    </Grid>
                </Border>

                <Border Grid.Row="3" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="7" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="Village" Foreground="#6B7280" Margin="0,0,0,5" />
                        <ComboBox x:Name="VillageComboBox" Height="28">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NameWithCoords}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#111827" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCapital}" Value="True">
                                                        <Setter Property="Foreground" Value="#D97706" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="4">
                    <Button x:Name="DashboardNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Dashboard" Tag="dashboard" Click="SidebarNavButton_Click" />
                    <Button x:Name="ResourcesNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Resources" Tag="resources" Click="SidebarNavButton_Click" />
                    <Button x:Name="BuildingsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Building" Tag="buildings" Click="SidebarNavButton_Click" />
                    <Button x:Name="HeroNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Hero / Adventures" Tag="hero" Click="SidebarNavButton_Click" />
                    <Button x:Name="FarmingNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Farming" Tag="farming" Click="SidebarNavButton_Click" />
                    <Button x:Name="TroopsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Troops" Tag="troops" Click="SidebarNavButton_Click" />
                    <Button x:Name="QueueNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Queue" Tag="queue" Click="SidebarNavButton_Click" />
                    <Button x:Name="LogsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Logs" Tag="logs" Click="SidebarNavButton_Click" />
                    <Button x:Name="InboxNavButton" Style="{StaticResource SidebarNavButtonStyle}" Content="Messages / Reports" Tag="inbox" Click="SidebarNavButton_Click" />
                </StackPanel>

                <Border Grid.Row="5" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="7">
                    <StackPanel>
                        <Border x:Name="LoopStateBadge"
                                Background="#6B7280"
                                CornerRadius="10"
                                Padding="8,2,8,2"
                                Margin="0,0,0,6"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="LoopStateTextBlock"
                                       Text="State: idle"
                                       Foreground="White"
                                       FontWeight="SemiBold" />
                        </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Continuous run"
                                           VerticalAlignment="Center"
                                           Foreground="#374151"
                                           FontWeight="SemiBold"
                                           Margin="0,0,8,0" />
						        <ToggleButton x:Name="ContinuousRunToggleButton"
                                              Style="{StaticResource ContinuousRunToggleStyle}"
                                              ToolTip="When enabled, Start/Pause/Stop controls continuous running."
                                              Unchecked="ContinuousRunToggleButton_Unchecked" />
                            </StackPanel>

						    <Grid Margin="0,0,0,6">
							    <Grid.ColumnDefinitions>
								    <ColumnDefinition Width="*" />
								    <ColumnDefinition Width="Auto" />
							    </Grid.ColumnDefinitions>
							    <Button x:Name="StartLoopButton" Grid.Column="0" Content="Start bot" Background="#030826" Foreground="White" BorderBrush="#030826" Click="StartLoopButton_Click" />
							    <Button x:Name="StopBotButton" Grid.Column="1" Content="&#9632;" Width="30" Padding="0" Margin="6,0,0,0" Click="StopBotButton_Click" ToolTip="Stop bot" />
						    </Grid>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="SettingsButton"
                                    Grid.Column="0"
                                    Content="Settings"
                                    Click="SettingsButton_Click"
                                    Margin="0,0,6,0" />
                            <Button x:Name="SupportButton"
                                    Grid.Column="1"
                                    Content="&#xE715;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Width="30"
                                    Padding="0"
                                    Margin="6,0,0,0"
                                    ToolTip="Support"
                                    Click="SupportButton_Click" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="12,8,12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                <DockPanel>
                    <TextBlock x:Name="BrowserInfoTextBlock" Text="Browser: idle" Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Left" />
                    <TextBlock x:Name="TribeInfoTextBlock" Text="Tribe: -" Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Right" />
                    <TextBlock Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Right">
                        <Run Text="Plus: " /><Run x:Name="PlusInfoTextBlock" Text="-" />
                    </TextBlock>
                    <TextBlock Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Right">
                        <Run Text="Goldclub: " /><Run x:Name="GoldClubInfoTextBlock" Text="-" />
                    </TextBlock>
                    <TextBlock x:Name="ServerResourcesTextBlock" Text="Gold: - | Silver: -" Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Right" />
                    <TextBlock x:Name="CaptchaStatsTextBlock" Text="Captchas solved: 0/0" Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Right" />
                    <TextBlock x:Name="ClockTextBlock" Text="Time: -" Foreground="#4B5563" Margin="0,0,16,0" DockPanel.Dock="Left" />
                    <TextBlock x:Name="StatusTextBlock" Text="Ready." Visibility="Collapsed" />
                </DockPanel>
            </Border>

            <StatusBar Grid.Row="1" Margin="0,0,0,8" Background="#E5E7EB">
                <StatusBarItem>
                    <TextBlock Text="Status" FontWeight="SemiBold" />
                </StatusBarItem>
                <StatusBarItem>
                    <TextBlock x:Name="StatusMiniLogTextBlock" Text="Ready." Foreground="#1F2937" />
                </StatusBarItem>
            </StatusBar>

            <Border Grid.Row="2"
                    Margin="0,56,0,0"
                    Background="#F9FAFB"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <TabControl x:Name="MainTabControl" Background="Transparent" BorderThickness="0">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Style>
                    </TabControl.ItemContainerStyle>

                <TabItem x:Name="DashboardTabItem" Header="Dashboard">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="Dashboard" FontSize="32" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right" x:Name="ResetProgramButton" Height="32" Content="Reset program" Background="#FCD34D" Foreground="#1F2937" BorderBrush="#F59E0B" VerticalAlignment="Center" Margin="12,0,0,0" Click="ResetProgramButton_Click" />
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,10" Visibility="Collapsed">
                            <TextBlock x:Name="VillagesInfoTextBlock" Text="Villages: -" />
                            <TextBlock x:Name="LastScanInfoTextBlock" Text="Last scan: -" />
                        </Grid>

                        <DockPanel Grid.Row="2" Margin="0,0,0,8" LastChildFill="False">
                            <Button DockPanel.Dock="Right" x:Name="DashboardFunctionListButton" Height="32" Content="List" MinWidth="70" Click="DashboardFunctionListButton_Click" />
                        </DockPanel>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="320" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,0,10,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                        <TextBlock DockPanel.Dock="Left" Text="Automation Loop" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                                            <Ellipse x:Name="AutomationLoopRunStateDot" Width="8" Height="8" Fill="#9CA3AF" Margin="0,0,6,0" />
                                            <TextBlock x:Name="AutomationLoopRunStateTextBlock" Text="Idle" Foreground="#6B7280" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DockPanel>

                                    <ListBox x:Name="AutomationLoopListBox"
                                             Grid.Row="1"
                                             Margin="0,0,0,8"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             SelectionMode="Single"
                                             AllowDrop="True"
                                             PreviewMouseLeftButtonDown="AutomationLoopListBox_PreviewMouseLeftButtonDown"
                                             PreviewMouseMove="AutomationLoopListBox_PreviewMouseMove"
                                             DragOver="AutomationLoopListBox_DragOver"
                                             Drop="AutomationLoopListBox_Drop">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <local:VerticalFirstUniformGrid Columns="2" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,0,8,8" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Background" Value="Transparent" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="9" Padding="10" Background="#FFFFFF">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FFFFFF" />
                                                            <Setter Property="BorderBrush" Value="#D1D5DB" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                    <Setter Property="Background" Value="#F9FAFB" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                    <Setter Property="Background" Value="#DCFCE7" />
                                                                    <Setter Property="BorderBrush" Value="#16A34A" />
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <ToggleButton Grid.Column="0"
                                                                      Style="{StaticResource ContinuousRunToggleStyle}"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,10,0"
                                                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                                      Click="AutomationLoopToggleButton_Click" />

                                                        <Border Grid.Column="1" BorderBrush="#2563EB" BorderThickness="3,0,0,0" Padding="10,0,0,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="BorderBrush" Value="#2563EB" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="#16A34A" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                            <Setter Property="BorderBrush" Value="#D1D5DB" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="#111827" />
                                                                    <TextBlock Text="Running" Margin="8,0,0,0" Foreground="#16A34A" FontSize="12" FontWeight="SemiBold">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Description}" Foreground="#4B5563" FontSize="12" Margin="0,2,0,0" />
                                                            </StackPanel>
                                                        </Border>

                                                        <Border Grid.Column="2"
                                                                Width="28"
                                                                Height="28"
                                                                CornerRadius="14"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Center"
                                                                Background="#2563EB">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#2563EB" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                            <Setter Property="Background" Value="#16A34A" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Order}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <TextBlock Grid.Row="2"
                                               x:Name="AutomationLoopSummaryTextBlock"
                                               Text="Loop cycles through enabled tasks continuously."
                                               HorizontalAlignment="Center"
                                               Foreground="#4B5563" />
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="9" Padding="12">
                                <StackPanel Grid.IsSharedSizeScope="True">
                                    <TextBlock Text="Villages" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6" />
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="VillagePopColumn" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="VillageCoordsColumn" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="VillageFlagColumn" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Village" FontWeight="SemiBold" Foreground="#111827" />
                                        <TextBlock Grid.Column="1" Text="Pop" FontWeight="SemiBold" Foreground="#111827" Margin="8,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="Coords" FontWeight="SemiBold" Foreground="#111827" Margin="8,0,0,0" />
                                    </Grid>
                                    <ItemsControl x:Name="DashboardVillageList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="VillagePopColumn" />
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="VillageCoordsColumn" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="VillageFlagColumn" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#374151" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding PopText}" Foreground="#374151" FontSize="13" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="2" Text="{Binding CoordsText}" Foreground="#374151" FontSize="13" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="4" Text="{Binding CapitalText}" Foreground="#D97706" FontSize="13" FontWeight="SemiBold" Margin="8,0,0,0" HorizontalAlignment="Right" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem x:Name="ResourcesTabItem" Header="Resources">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="LoadResourcesButton" Content="↻" Width="42" FontSize="16" Click="LoadResourcesButton_Click" ToolTip="Refresh resources" />
                            <TextBlock Text="Target level" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox x:Name="ResourceTargetLevelComboBox" Width="90" Margin="0,0,8,0" />
                            <Button x:Name="UpgradeAllResourcesButton" Content="Upgrade all to level" Width="160" Click="UpgradeAllResourcesButton_Click" />
                        </StackPanel>
                        <Border Grid.Row="1" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Background="#FFFFFF" Padding="12">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <Grid HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Width="190" Margin="0,0,8,0">
                                    <TextBlock Text="Woodcutter" Foreground="#0F766E" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding WoodFields, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#E4F2F1" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="#134E4A"
                                                                Background="#A5E1DA"
                                                                BorderBrush="#74CCC2"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Width="190" Margin="0,0,8,0">
                                    <TextBlock Text="Clay Pit" Foreground="#DC4C1D" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding ClayFields, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FDECE5" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="#7C2D12"
                                                                Background="#F9C9AF"
                                                                BorderBrush="#F2A57E"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Width="190" Margin="0,0,8,0">
                                    <TextBlock Text="Iron Mine" Foreground="#334155" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding IronFields, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#EAF0F4" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="#1E293B"
                                                                Background="#B7C7D4"
                                                                BorderBrush="#92ABC0"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel x:Name="CroplandColumnPanel" Grid.Column="3" Width="190" Margin="0,0,0,0">
                                    <TextBlock Text="Cropland" Foreground="#C47F00" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl x:Name="CroplandItemsControl" ItemsSource="{Binding CroplandFields, ElementName=RootWindow}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="1" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FFF5DF" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        <Button Grid.Column="1"
                                                                Tag="{Binding}"
                                                                Content="{Binding LevelLabel}"
                                                                Style="{StaticResource ResourceLevelBadgeStyle}"
                                                                Foreground="#7C5C0B"
                                                                Background="#F7E3A3"
                                                                BorderBrush="#EACD73"
                                                                Click="ResourceLevelBadge_Click"
                                                                ToolTip="Click to queue +1 level upgrade." />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                            </ScrollViewer>
                        </Border>
                        <DataGrid x:Name="ResourcesDataGrid" Visibility="Collapsed" />
                        <TextBlock x:Name="ResourcesInfoTextBlock" Visibility="Collapsed" Text="Resources not loaded yet." />
                    </Grid>
                </TabItem>

                <TabItem x:Name="BuildingsTabItem" Header="Buildings">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="260" />
        </Grid.ColumnDefinitions>

        <!-- Vänster: slot-grid -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,4">
                            <TextBlock Text="Buildings" FontSize="24" FontWeight="SemiBold" Foreground="#111827" />
                <TextBlock Text="Manage your village buildings. Click a slot to view and manage building details."
                           Foreground="#6B7280" Margin="0,2,0,8" />
            </StackPanel>

            <!-- Load-knapp -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="LoadBuildingsButton" Content="Load buildings" Width="118" Height="28" Click="LoadBuildingsButton_Click" />
                <Button x:Name="UpgradeAllBuildingsToMaxButton" Content="Upgrade all to max" Width="136" Height="28" Margin="6,0,0,0" Click="UpgradeAllBuildingsToMaxButton_Click" />
				
				<!-- Dolda kontroller för bakåtkompatibilitet med code-behind -->
				<ComboBox x:Name="BuildingCategoryComboBox" Visibility="Collapsed" />
				<ComboBox x:Name="ConstructBuildingComboBox" Visibility="Collapsed" />
				<ComboBox x:Name="DemolishBuildingComboBox" Visibility="Collapsed" />
				<TextBox x:Name="ConstructSlotTextBox" Visibility="Collapsed" Text="19" />
				<TextBox x:Name="UpgradeSlotTextBox" Visibility="Collapsed" Text="19" />
				<TextBox x:Name="UpgradeTargetLevelTextBox" Visibility="Collapsed" Text="2" />
				<TextBox x:Name="DemolishTargetLevelTextBox" Visibility="Collapsed" Text="0" />
				<TextBlock x:Name="BuildingsInfoTextBlock" Visibility="Collapsed" />
            </StackPanel>

            <!-- Slot-grid -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="BuildingSlotsItemsControl"
                              ItemsSource="{Binding BuildingSlots, ElementName=RootWindow}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Margin="3"
									Background="#FFFFFF"
									BorderBrush="#D1D5DB"
									BorderThickness="1"
									CornerRadius="6">
								<Border.Style>
									<Style TargetType="Border">
										<Style.Triggers>
											<DataTrigger Binding="{Binding HasPendingUpgrade}" Value="True">
												<Setter Property="BorderBrush" Value="#D97706" />
												<Setter Property="Background" Value="#FFFBEB" />
											</DataTrigger>
											<DataTrigger Binding="{Binding HasPendingConstruct}" Value="True">
												<Setter Property="BorderBrush" Value="#16A34A" />
												<Setter Property="Background" Value="#F0FDF4" />
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Border.Style>
								<Button Background="Transparent"
										BorderThickness="0"
										Padding="5,4"
                                        MinHeight="60"
										Tag="{Binding}"
										Click="BuildingSlotCircleButton_Click"
										HorizontalContentAlignment="Stretch"
										VerticalContentAlignment="Stretch">
									<StackPanel>
										<TextBlock Text="{Binding SlotLabel}"
												   FontSize="11"
												   Foreground="#9CA3AF"
												   HorizontalAlignment="Left" />
										<TextBlock Text="{Binding NameLabel}"
												   FontSize="11"
												   FontWeight="SemiBold"
												   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="30"
												   Margin="0,2,0,0">
											<TextBlock.Style>
												<Style TargetType="TextBlock">
													<Setter Property="Foreground" Value="#111827" />
													<Style.Triggers>
														<DataTrigger Binding="{Binding IsOccupied}" Value="False">
															<Setter Property="Foreground" Value="#2563EB" />
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</TextBlock.Style>
										</TextBlock>
										<TextBlock Text="{Binding LevelStatusLabel}"
												   FontSize="11"
												   Margin="0,1,0,0">
											<TextBlock.Style>
												<Style TargetType="TextBlock">
													<Setter Property="Foreground" Value="#6B7280" />
													<Style.Triggers>
														<DataTrigger Binding="{Binding IsMaxLevel}" Value="True">
															<Setter Property="Foreground" Value="#D97706" />
														</DataTrigger>
														<DataTrigger Binding="{Binding IsDemolishing}" Value="True">
															<Setter Property="Foreground" Value="#DC2626" />
															<Setter Property="FontWeight" Value="SemiBold" />
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</TextBlock.Style>
										</TextBlock>
									</StackPanel>
								</Button>
							</Border>
						</DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</TabItem>

                <TabItem x:Name="HeroTabItem" Header="Hero / Adventures">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="#F3F4F6">
                        <StackPanel>
                            <!-- Header -->
                            <DockPanel Margin="2,2,2,12">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Hero / Adventures"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#111827" />
                                    <TextBlock Text="Configure hero behaviour and queue adventures."
                                               Foreground="#6B7280"
                                               FontSize="12"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </DockPanel>

                            <!-- Settings card -->
                            <Border Background="#FFFFFF"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="2,0,2,12">
                                <StackPanel>
                                    <TextBlock Text="Settings"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               Margin="0,0,0,10" />
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Hero min HP for adventure" Foreground="#374151" FontSize="12" />
                                            <TextBox x:Name="HeroMinHpTextBox"
                                                     Text="60"
                                                     Margin="0,4,12,0"
                                                     Padding="6,4"
                                                     BorderBrush="#E5E7EB" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                                            <CheckBox x:Name="HeroAutoReviveCheckBox" Content="Auto revive" IsChecked="True" Margin="0,0,0,6" />
                                            <CheckBox x:Name="HeroAutoAssignPointsCheckBox" Content="Auto assign attribute points" IsChecked="True" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Adventure pick order" Foreground="#374151" FontSize="12" Margin="0,8,0,4" />
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="HeroAdventureShortestRadio"
                                                     Content="Shortest adventure first"
                                                     GroupName="HeroAdventureOrder"
                                                     IsChecked="True"
                                                     Margin="0,0,16,0" />
                                        <RadioButton x:Name="HeroAdventureTopRadio"
                                                     Content="Top adventure first"
                                                     GroupName="HeroAdventureOrder" />
                                    </StackPanel>
                                    <TextBlock Text="Hide hero" Foreground="#374151" FontSize="12" Margin="0,12,0,4" />
                                    <StackPanel Orientation="Vertical">
                                        <RadioButton x:Name="HeroHideRadio"
                                                     Content="Hero will hide during an attack on their home village."
                                                     GroupName="HeroHideMode"
                                                     IsChecked="True"
                                                     Margin="0,0,0,4"
                                                     Checked="HeroHideModeRadio_Checked" />
                                        <RadioButton x:Name="HeroFightRadio"
                                                     Content="Your hero will always stay with the troops."
                                                     GroupName="HeroHideMode"
                                                     Checked="HeroHideModeRadio_Checked" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Attribute priority + Adventures side by side -->
                            <Grid Margin="2,0,2,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Attribute priority card -->
                                <Border Grid.Column="0"
                                        Background="#FFFFFF"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14"
                                        Margin="0,0,6,0">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="Attribute priority"
                                                       DockPanel.Dock="Left"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#111827"
                                                       VerticalAlignment="Center" />
                                            <Button x:Name="RefreshHeroStatsButton"
                                                    DockPanel.Dock="Right"
                                                    Content="Refresh hero stats"
                                                    Width="150"
                                                    Click="RefreshHeroStatsButton_Click"
                                                    Background="#FFFFFF"
                                                    BorderBrush="#E5E7EB" />
                                        </DockPanel>
                                        <TextBlock Text="Drag to reorder"
                                                   Foreground="#9CA3AF"
                                                   FontSize="11"
                                                   Margin="0,0,0,6" />
                                        <Border BorderBrush="#F3F4F6"
                                                BorderThickness="1"
                                                Background="#FAFBFC"
                                                CornerRadius="6"
                                                Padding="10"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <ListBox x:Name="HeroAttributePriorityItemsControl"
                                                         HorizontalAlignment="Stretch"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         AllowDrop="True"
                                                         PreviewMouseLeftButtonDown="HeroAttributePriorityItemsControl_PreviewMouseLeftButtonDown"
                                                         PreviewMouseMove="HeroAttributePriorityItemsControl_PreviewMouseMove"
                                                         Drop="HeroAttributePriorityItemsControl_Drop">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Padding" Value="0" />
                                                            <Setter Property="Margin" Value="0,0,0,4" />
                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#FFFFFF"
                                                                    BorderBrush="#E5E7EB"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    Padding="10,6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="28" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{Binding Order}"
                                                                               VerticalAlignment="Center"
                                                                               Foreground="#9CA3AF"
                                                                               FontWeight="SemiBold" />
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding Title}"
                                                                               VerticalAlignment="Center"
                                                                               Foreground="#111827" />
                                                                    <Border Grid.Column="2"
                                                                            Background="#F3F4F6"
                                                                            CornerRadius="4"
                                                                            Padding="6,2">
                                                                        <TextBlock Text="{Binding PointsText, StringFormat=Pts: {0}}"
                                                                                   Foreground="#374151"
                                                                                   FontSize="11" />
                                                                    </Border>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                                <TextBlock x:Name="HeroAttributesStatusTextBlock"
                                                           Text="Hero stats not loaded."
                                                           Foreground="#6B7280"
                                                           FontSize="12"
                                                           Margin="2,4,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Adventures card -->
                                <Border Grid.Column="1"
                                        Background="#FFFFFF"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14"
                                        Margin="6,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Adventures"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"
                                                   Margin="0,0,0,12" />
                                        <DockPanel Margin="0,0,0,10">
                                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                <Border Background="#F0FDF4"
                                                        BorderBrush="#BBF7D0"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Padding="10,6"
                                                        Margin="0,0,12,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Available:" Foreground="#166534" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                        <TextBlock x:Name="HeroAdventureCountTextBlock"
                                                                   Text="—"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="15"
                                                                   Foreground="#166534"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Border>
                                                <Button x:Name="RefreshAdventuresButton"
                                                        Content="Refresh adventures"
                                                        Width="160"
                                                        Click="RefreshAdventuresButton_Click"
                                                        Background="#FFFFFF"
                                                        BorderBrush="#E5E7EB" />
                                            </StackPanel>
                                        </DockPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="QueueHeroManageButton"
                                                    Content="Hero adventure"
                                                    Width="190"
                                                    Click="QueueHeroManageButton_Click"
                                                    Background="#030826"
                                                    Foreground="White"
                                                    BorderBrush="#030826" />
                                            <CheckBox x:Name="ContinuousAdventuresCheckBox"
                                                      Content="Continuous adventures"
                                                      VerticalAlignment="Center"
                                                      Margin="14,0,0,0"
                                                      ToolTip="Re-queue Hero adventure after each run until no adventures remain." />
                                        </StackPanel>
                                        <!-- Hidden but kept for code-behind compatibility. State is shown next to the Start bot button. -->
                                        <TextBlock x:Name="HeroAdventureStatusTextBlock"
                                                   Visibility="Collapsed"
                                                   Text="Hero adventure status: idle." />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="FarmingTabItem" Header="Farming">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Farming" FontSize="24" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,10" />
                        <Grid Grid.Row="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#FFFFFF"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,0,8,0">
                                    <Grid MaxWidth="560" HorizontalAlignment="Left">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="Farm List Management"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"
                                                   Margin="0,0,0,12" />

                                        <WrapPanel Grid.Row="1" Margin="0,0,0,12">
                                            <Button x:Name="AnalyzeFarmListsButton"
                                                    Content="Analyze Farmlists"
                                                    Background="#030826"
                                                    Foreground="White"
                                                    BorderBrush="#030826"
                                                    MinWidth="150"
                                                    Click="AnalyzeFarmListsButton_Click" />
                                            <Button x:Name="AddFarmsToListButton"
                                                    Content="Add Farms to List"
                                                    MinWidth="140"
                                                    Click="AddFarmsToListButton_Click" />
                                            <Button x:Name="CreateFarmListButton"
                                                    Content="Create Farmlist"
                                                    MinWidth="120"
                                                    Click="CreateFarmListButton_Click" />
                                        </WrapPanel>

                                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel>
                                                <TextBlock x:Name="FarmingStatusTextBlock"
                                                           Text="No farm lists loaded. Click Analyze Farmlists."
                                                           Foreground="#4B5563"
                                                           Margin="0,0,0,8" />

                                                <ItemsControl x:Name="FarmListsItemsControl">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="9" Padding="10" Margin="0,0,0,10" Background="#F9FAFB">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <ToggleButton Grid.Column="0"
                                                                                  Style="{StaticResource ContinuousRunToggleStyle}"
                                                                                  VerticalAlignment="Center"
                                                                                  Margin="0,0,10,0"
                                                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}" />

                                                                    <Border Grid.Column="1" BorderBrush="#2563EB" BorderThickness="3,0,0,0" Padding="10,0,0,0">
                                                                        <StackPanel VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#111827" />
                                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                                <TextBlock Text="{Binding FarmCountText}" Foreground="#4B5563" FontSize="12" Margin="0,0,8,0" />
                                                                                <ProgressBar Width="120"
                                                                                             Height="8"
                                                                                             VerticalAlignment="Center"
                                                                                             Minimum="0"
                                                                                             Maximum="100"
                                                                                             Value="{Binding FillPercent, Mode=OneWay}" />
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <Border Grid.Column="2"
                                                                            Margin="8,0,8,0"
                                                                            Padding="10,4"
                                                                            CornerRadius="8"
                                                                            VerticalAlignment="Center"
                                                                            BorderThickness="1">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="#DCFCE7" />
                                                                                <Setter Property="BorderBrush" Value="#22C55E" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasTimer}" Value="True">
                                                                                        <Setter Property="Background" Value="#FEF3C7" />
                                                                                        <Setter Property="BorderBrush" Value="#F59E0B" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="{Binding ReadyText}" />
                                                                                    <Setter Property="Foreground" Value="#15803D" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasTimer}" Value="True">
                                                                                            <Setter Property="Text" Value="{Binding TimerText}" />
                                                                                            <Setter Property="Foreground" Value="#B45309" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Border>

                                                                    <Button Grid.Column="3"
                                                                            Content="Send Now"
                                                                            MinWidth="90"
                                                                            Height="32"
                                                                            Background="#030826"
                                                                            Foreground="White"
                                                                            BorderBrush="#030826"
                                                                            VerticalAlignment="Center"
                                                                            Tag="{Binding}"
                                                                            IsEnabled="{Binding CanSendNow}"
                                                                            Click="FarmListSendNowButton_Click" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1"
                                        Background="#FFFFFF"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="8,0,0,0">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="Manual farming"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="#111827"
                                                       VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1"
                                                        HorizontalAlignment="Right">
                                                <TextBlock Text="Farmlist executions"
                                                           Foreground="#6B7280"
                                                           FontSize="12"
                                                           HorizontalAlignment="Right" />
                                                <TextBlock x:Name="ManualFarmingExecutionCountTextBlock"
                                                           Text="0"
                                                           Foreground="#111827"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Right" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="190" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Button x:Name="AnalyzeNatarsProfileButton"
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    Content="Analyze natars profile"
                                                    Width="170"
                                                    Margin="0,0,0,6"
                                                    Click="AnalyzeNatarsProfileButton_Click" />
                                            <Button x:Name="ShowNatarsListButton"
                                                    Grid.Row="1"
                                                    Grid.Column="0"
                                                    Content="Show natars list"
                                                    Width="170"
                                                    Margin="0,0,0,6"
                                                    Click="ShowNatarsListButton_Click" />
                                            <Button x:Name="StartManualFarmingButton"
                                                    Grid.Row="2"
                                                    Grid.Column="0"
                                                    Content="Start manual farming"
                                                    Width="170"
                                                    HorizontalAlignment="Center"
                                                    Click="StartManualFarmingButton_Click" />

                                            <StackPanel Grid.Row="0"
                                                        Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="10,0,0,6">
                                                <TextBlock Text="Analyzed:"
                                                           VerticalAlignment="Center"
                                                           Foreground="#374151"
                                                           Margin="0,0,6,0" />
                                                <Ellipse x:Name="NatarsProfileAnalyzedIndicator"
                                                         Width="14"
                                                         Height="14"
                                                         VerticalAlignment="Center"
                                                         Fill="#9CA3AF" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="2"
                                                        Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="10,0,0,0">
                                                <TextBlock x:Name="ManualFarmingStateTextBlock"
                                                           Text="State:"
                                                           Foreground="#6B7280"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Center" />
                                                <Ellipse x:Name="ManualFarmingStateDot"
                                                         Width="12"
                                                         Height="12"
                                                         VerticalAlignment="Center"
                                                         Fill="#9CA3AF" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem x:Name="TroopsTabItem" Header="Troops">
                    <Grid>
                        <Border Background="#FFFFFF"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="Troops"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           Margin="0,0,0,12" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="UpgradeTroopsButton"
                                            Content="Upgrade troops"
                                            Width="150"
                                            Click="UpgradeTroopsButton_Click" />
                                </StackPanel>
                                <TextBlock x:Name="TroopsInfoTextBlock"
                                           Foreground="#6B7280"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem x:Name="QueueTabItem" Header="Queue">
                    <Grid Background="#F3F4F6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <DockPanel Grid.Row="0" Margin="2,2,2,12">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Queue"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#111827" />
                                <TextBlock x:Name="QueueInfoTextBlock"
                                           Text="Queue loaded."
                                           Foreground="#6B7280"
                                           FontSize="12"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <Button x:Name="QueuePopoutButton"
                                    DockPanel.Dock="Right"
                                    Content="Pop out"
                                    Width="92"
                                    Click="QueuePopoutButton_Click"
                                    Background="#FFFFFF"
                                    BorderBrush="#E5E7EB" />
                            <Button x:Name="QueueClearButton"
                                    DockPanel.Dock="Right"
                                    Content="Clear queue"
                                    Width="100"
                                    Margin="0,0,8,0"
                                    Click="QueueClearButton_Click"
                                    Background="#FEE2E2"
                                    BorderBrush="#FCA5A5"
                                    Foreground="#991B1B" />
                            <TextBlock />
                        </DockPanel>

                        <!-- Build queue status bar (hidden — kept for code-behind compatibility) -->
                        <TextBlock x:Name="BuildQueueStatusTextBlock" Grid.Row="1" Visibility="Collapsed" />

                        <!-- Active queue card -->
                        <Border Grid.Row="2"
                                Background="#FFFFFF"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="2,0,2,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <Ellipse Width="8" Height="8" Fill="#16A34A" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Text="Active queue"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="QueueAddButton" Content="Add" Width="76" Click="QueueAddButton_Click" Background="#FFFFFF" BorderBrush="#E5E7EB" />
                                        <Button x:Name="QueueRemoveButton" Content="Remove" Width="76" Margin="6,0,0,0" Click="QueueRemoveButton_Click" Background="#FFFFFF" BorderBrush="#E5E7EB" />
                                        <Rectangle Width="1" Fill="#E5E7EB" Margin="10,3,10,3" />
                                        <Button x:Name="QueueMoveUpButton" Content="↑" Width="36" Click="QueueMoveUpButton_Click" Background="#FFFFFF" BorderBrush="#E5E7EB" ToolTip="Move up" />
                                        <Button x:Name="QueueMoveDownButton" Content="↓" Width="36" Margin="6,0,0,0" Click="QueueMoveDownButton_Click" Background="#FFFFFF" BorderBrush="#E5E7EB" ToolTip="Move down" />
                                        <Rectangle Width="1" Fill="#E5E7EB" Margin="10,3,10,3" />
                                        <Button x:Name="QueueRetryButton" Content="Retry" Width="68" Click="QueueRetryButton_Click" Background="#FFFFFF" BorderBrush="#E5E7EB" />
                                        <Button x:Name="QueueRefreshButton" Content="Refresh" Width="76" Margin="6,0,0,0" Click="QueueRefreshButton_Click" Background="#FFFFFF" BorderBrush="#E5E7EB" />
                                    </StackPanel>
                                </DockPanel>

                                <DataGrid x:Name="QueueDataGrid"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserReorderColumns="False"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#F3F4F6"
                                          RowBackground="#FFFFFF"
                                          AlternatingRowBackground="#FAFBFC"
                                          BorderBrush="#E5E7EB"
                                          BorderThickness="1"
                                          HeadersVisibility="Column"
                                          ColumnHeaderHeight="32"
                                          RowHeight="30"
                                          FontSize="12">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F9FAFB" />
                                            <Setter Property="Foreground" Value="#374151" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="FontSize" Value="11" />
                                            <Setter Property="Padding" Value="10,6" />
                                            <Setter Property="BorderBrush" Value="#E5E7EB" />
                                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="10,4" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Foreground" Value="#1F2937" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#EEF2FF" />
                                                    <Setter Property="Foreground" Value="#1F2937" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Task" Width="2.4*" Binding="{Binding DisplayName}" />
                                        <DataGridTextColumn Header="Status" Width="*" Binding="{Binding Status}" />
                                        <DataGridTextColumn Header="Retries" Width="0.7*" Binding="{Binding Retries}" />
                                        <DataGridTextColumn Header="Max" Width="0.6*" Binding="{Binding MaxRetries}" />
                                        <DataGridTextColumn Header="Next try" Width="1.5*" Binding="{Binding NextAttemptAtServer}" />
                                        <DataGridTextColumn Header="Created" Width="1.5*" Binding="{Binding CreatedAtServer}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!-- Spacing -->
                        <Border Grid.Row="3" Height="0" />

                        <!-- History card -->
                        <Border Grid.Row="4"
                                Background="#FFFFFF"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="2,0,2,2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                    <Ellipse Width="8" Height="8" Fill="#9CA3AF" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="History"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <DataGrid x:Name="QueueHistoryDataGrid"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserReorderColumns="False"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#F3F4F6"
                                          RowBackground="#FFFFFF"
                                          AlternatingRowBackground="#FAFBFC"
                                          BorderBrush="#E5E7EB"
                                          BorderThickness="1"
                                          HeadersVisibility="Column"
                                          ColumnHeaderHeight="32"
                                          RowHeight="30"
                                          FontSize="12">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F9FAFB" />
                                            <Setter Property="Foreground" Value="#374151" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="FontSize" Value="11" />
                                            <Setter Property="Padding" Value="10,6" />
                                            <Setter Property="BorderBrush" Value="#E5E7EB" />
                                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="10,4" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Foreground" Value="#4B5563" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#F3F4F6" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Completed task" Width="2.4*" Binding="{Binding DisplayName}" />
                                        <DataGridTextColumn Header="Status" Width="*" Binding="{Binding Status}" />
                                        <DataGridTextColumn Header="Retries" Width="0.7*" Binding="{Binding Retries}" />
                                        <DataGridTextColumn Header="Created" Width="1.5*" Binding="{Binding CreatedAtServer}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="5" Height="0" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="LogsTabItem" Header="Logs">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TabControl x:Name="TerminalAlarmTabControl" Grid.Row="0" Margin="0,0,0,8">
                            <TabItem Header="Log">
                                <Border Background="#020617" Padding="8">
                                    <ListBox x:Name="TerminalListBox"
                                             Background="#020617"
                                             Foreground="#93C5FD"
                                             BorderThickness="0"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             SelectionMode="Extended"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </TabItem>
                            <TabItem Header="Alarms">
                                <Border Background="#110D0D" Padding="8">
                                    <ListBox x:Name="AlarmListBox"
                                             Background="#110D0D"
                                             BorderThickness="0"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             SelectionMode="Extended"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#FCA5A5" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsAcknowledged}" Value="True">
                                                                    <Setter Property="Foreground" Value="#93C5FD" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </TabItem>
                        </TabControl>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="CopyFeedbackTextBlock"
                                       Text=""
                                       Foreground="#16A34A"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Visibility="Collapsed" />
                            <Button x:Name="PopoutLogsButton" Content="Pop out" Margin="0,0,8,0" Padding="10,4" Click="PopoutLogsButton_Click" />
                            <Button x:Name="CopyCurrentTabButton" Content="Copy" Margin="0,0,8,0" Padding="10,4" Click="CopyCurrentTabButton_Click" />
                            <Button x:Name="AcknowledgeAlarmButton" Content="Acknowledge alarms" Margin="0,0,8,0" Padding="10,4" Click="AcknowledgeAlarmButton_Click" />
                            <Button x:Name="ClearCurrentLogButton" Content="Clear" Padding="10,4" Click="ClearCurrentLogButton_Click" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem x:Name="InboxTabItem" Header="Inbox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Messages / Reports" FontSize="24" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,8" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Messages" FontSize="20" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6" />
                                    <TextBlock x:Name="MessageUnreadTextBlock" Text="Unread: -" Foreground="#374151" Margin="0,0,0,10" />
                                    <Button x:Name="MarkMessagesReadButton" Width="120" Margin="0" Content="Mark as read" Click="MarkMessagesReadButton_Click" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Reports" FontSize="20" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6" />
                                    <TextBlock x:Name="ReportsUnreadTextBlock" Text="Unread: -" Foreground="#374151" Margin="0,0,0,10" />
                                    <Button x:Name="MarkReportsReadButton" Width="120" Margin="0" Content="Mark as read" Click="MarkReportsReadButton_Click" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
                </TabControl>
            </Border>

        </Grid>

    </Grid>
</Window>




