<Window x:Class="TbotUltra.Desktop.ServerListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Server list"
        Height="460"
        Width="620"
        MinHeight="360"
        MinWidth="540"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Closing="ServerListWindow_Closing">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="ServerDataGrid"
                  Grid.Row="0"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Server name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="200" />
                <DataGridTextColumn Header="URL" Binding="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                <DataGridTextColumn Header="Type" Binding="{Binding ServerTypeLabel}" Width="80" IsReadOnly="True" />
                <DataGridTemplateColumn Header="" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Delete"
                                    Width="74"
                                    Click="DeleteRowButton_Click" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="100" Margin="0,0,8,0" Content="Add server" Click="AddServerButton_Click" />
            <Button Width="100" Margin="0,0,8,0" Content="Reset" Click="ResetButton_Click" />
            <Button Width="100" Margin="0,0,8,0" Content="Save" Click="SaveButton_Click" />
            <Button Width="100" Content="Cancel" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
