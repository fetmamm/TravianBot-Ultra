<Window x:Class="TbotUltra.Desktop.BuildingConstructChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose building"
        Height="700"
        Width="980"
        MinHeight="560"
        MinWidth="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#111827"
                   Margin="0,0,0,10" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Infrastructure" FontSize="14" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,8" />
                        <TextBlock Text="Available" FontWeight="SemiBold" Foreground="#16A34A" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="InfrastructureAvailablePanel" Margin="0,0,0,10" />
                        <TextBlock Text="Locked" FontWeight="SemiBold" Foreground="#D97706" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="InfrastructureLockedPanel" Margin="0,0,0,10" />
                        <TextBlock Text="Already built" FontWeight="SemiBold" Foreground="#2563EB" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="InfrastructureAlreadyBuiltPanel" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Army" FontSize="14" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,8" />
                        <TextBlock Text="Available" FontWeight="SemiBold" Foreground="#16A34A" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="ArmyAvailablePanel" Margin="0,0,0,10" />
                        <TextBlock Text="Locked" FontWeight="SemiBold" Foreground="#D97706" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="ArmyLockedPanel" Margin="0,0,0,10" />
                        <TextBlock Text="Already built" FontWeight="SemiBold" Foreground="#2563EB" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="ArmyAlreadyBuiltPanel" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Resources" FontSize="14" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,8" />
                        <TextBlock Text="Available" FontWeight="SemiBold" Foreground="#16A34A" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="ResourcesAvailablePanel" Margin="0,0,0,10" />
                        <TextBlock Text="Locked" FontWeight="SemiBold" Foreground="#D97706" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="ResourcesLockedPanel" Margin="0,0,0,10" />
                        <TextBlock Text="Already built" FontWeight="SemiBold" Foreground="#2563EB" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="ResourcesAlreadyBuiltPanel" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Unavailable" FontSize="14" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,8" />
                        <TextBlock Text="Not possible here" FontWeight="SemiBold" Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="UnavailablePanel" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="#F9FAFB"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="0,8,0,0">
            <StackPanel>
                <TextBlock x:Name="SelectedNameTextBlock"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Text="Select a building above" />
                <TextBlock x:Name="SelectedDetailsTextBlock"
                           Foreground="#6B7280"
                           FontSize="11"
                           Margin="0,2,0,6" />
                <DockPanel>
                    <TextBlock Text="Target level:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="TargetLevelComboBox"
                              Width="100"
                              IsEnabled="False"
                              VerticalAlignment="Center" />
                </DockPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="BuildMaxButton"
                    Width="110"
                    Content="Build max"
                    IsEnabled="False"
                    Background="#D97706"
                    Foreground="White"
                    BorderBrush="#D97706"
                    Margin="0,0,8,0"
                    Click="BuildMaxButton_Click" />
            <Button x:Name="BuildButton"
                    Width="110"
                    Content="Build"
                    IsEnabled="False"
                    Background="#030826"
                    Foreground="White"
                    BorderBrush="#030826"
                    Margin="0,0,8,0"
                    Click="BuildButton_Click" />
            <Button Width="100"
                    Content="Cancel"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
