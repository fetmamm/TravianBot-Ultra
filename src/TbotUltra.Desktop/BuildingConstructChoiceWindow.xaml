<Window x:Class="TbotUltra.Desktop.BuildingConstructChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Choose building"
        Height="700"
        Width="980"
        MinHeight="560"
        MinWidth="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,10" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Infrastructure" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        <TextBlock Text="Available" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="InfrastructureAvailablePanel" Margin="0,0,0,10" />
                        <TextBlock Text="Locked" FontWeight="SemiBold" Foreground="{DynamicResource CapitalBrush}" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="InfrastructureLockedPanel" Margin="0,0,0,10" />
                        <TextBlock Text="Already built" FontWeight="SemiBold" Foreground="{DynamicResource InfoBrush}" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="InfrastructureAlreadyBuiltPanel" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Army" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        <TextBlock Text="Available" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="ArmyAvailablePanel" Margin="0,0,0,10" />
                        <TextBlock Text="Locked" FontWeight="SemiBold" Foreground="{DynamicResource CapitalBrush}" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="ArmyLockedPanel" Margin="0,0,0,10" />
                        <TextBlock Text="Already built" FontWeight="SemiBold" Foreground="{DynamicResource InfoBrush}" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="ArmyAlreadyBuiltPanel" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Resources" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        <TextBlock Text="Available" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="ResourcesAvailablePanel" Margin="0,0,0,10" />
                        <TextBlock Text="Locked" FontWeight="SemiBold" Foreground="{DynamicResource CapitalBrush}" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="ResourcesLockedPanel" Margin="0,0,0,10" />
                        <TextBlock Text="Already built" FontWeight="SemiBold" Foreground="{DynamicResource InfoBrush}" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="ResourcesAlreadyBuiltPanel" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Unavailable" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        <TextBlock Text="Not possible here" FontWeight="SemiBold" Foreground="{DynamicResource BorderMutedBrush}" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel x:Name="UnavailablePanel" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="0,8,0,0">
            <StackPanel>
                <TextBlock x:Name="SelectedNameTextBlock"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Text="Select a building above" />
                <TextBlock x:Name="SelectedDetailsTextBlock"
                           Foreground="{DynamicResource TextSubtleBrush}"
                           FontSize="11"
                           Margin="0,2,0,6" />
                <DockPanel>
                    <TextBlock Text="Target level:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="TargetLevelComboBox"
                              Width="100"
                              IsEnabled="False"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Left" />
                </DockPanel>

                <!-- Cumulative build time + colored resource cost up to the selected level. -->
                <StackPanel x:Name="EstimatePanel"
                            Orientation="Horizontal"
                            Margin="0,8,0,0"
                            Visibility="Collapsed">
                    <TextBlock Text="Time "
                               Foreground="{DynamicResource TextSubtleBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="TimeTextBlock"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock x:Name="ConstructFasterTimeTextBlock"
                               Foreground="{DynamicResource ConstructFasterBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0" />
                    <TextBlock Text="Cost "
                               Foreground="{DynamicResource TextSubtleBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="WoodTextBlock" Text="-" Foreground="{DynamicResource WoodTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text=" | " Foreground="{DynamicResource TextSubtleBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="ClayTextBlock" Text="-" Foreground="{DynamicResource ClayTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text=" | " Foreground="{DynamicResource TextSubtleBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="IronTextBlock" Text="-" Foreground="{DynamicResource IronTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text=" | " Foreground="{DynamicResource TextSubtleBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="CropTextBlock" Text="-" Foreground="{DynamicResource CropTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="BuildMaxButton"
                    Width="110"
                    Content="Build max"
                    IsEnabled="False"
                    Background="{DynamicResource CapitalBrush}"
                    Foreground="White"
                    BorderBrush="{DynamicResource CapitalBrush}"
                    Margin="0,0,8,0"
                    Click="BuildMaxButton_Click" />
            <Button x:Name="BuildButton"
                    Width="110"
                    Content="Build"
                    IsEnabled="False"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    BorderBrush="{DynamicResource AccentBrush}"
                    Margin="0,0,8,0"
                    Click="BuildButton_Click" />
            <Button Width="100"
                    Content="Cancel"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
