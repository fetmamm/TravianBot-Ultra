<Window x:Class="TbotUltra.Desktop.SaveReportPngWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Save report as PNG"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Save report as PNG"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="1. Navigate to the report you want to save"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,8,0,0" />
            <TextBlock Text="2. Click the Save report button"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,3,0,0" />
            <TextBlock Text="3. This will generate a PNG of the report and save it in the Reports folder"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,3,0,0" />
            <TextBlock Text="4. If you are on the wrong page the program will tell you so"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,3,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <CheckBox x:Name="HideAttackerCheckBox"
                      Content="Hide attacker"
                      Margin="0,0,0,4" />
            <TextBlock Text="Blurs the attacker's player name, village and alliance."
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="22,0,0,10" />
            <CheckBox x:Name="HideDefenderCheckBox"
                      Content="Hide defender"
                      Margin="0,0,0,4" />
            <TextBlock Text="Blurs all defenders' player names, villages and alliances."
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="22,0,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,10">
            <Button x:Name="OpenReportsFolderButton"
                    Padding="10,4"
                    Content="Open reports folder"
                    ToolTip="Opens the folder where report PNG files are saved."
                    Click="OpenReportsFolderButton_Click" />
            <Button x:Name="SaveButton"
                    Width="110"
                    Margin="10,0,0,0"
                    Background="{DynamicResource AccentBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Content="Save report"
                    Click="SaveButton_Click" />
        </StackPanel>

        <Separator Grid.Row="3" Margin="0,0,0,12" />

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="4"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource InfoBrush}"
                   Margin="0,0,0,10" />

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="100"
                    Content="Close"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
