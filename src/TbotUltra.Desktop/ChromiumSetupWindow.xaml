<Window x:Class="TbotUltra.Desktop.ChromiumSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Browser setup"
        Height="250"
        Width="470"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Browser components missing"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,8" />

        <TextBlock x:Name="ExplanationTextBlock"
                   Grid.Row="1"
                   TextWrapping="Wrap"
                   LineHeight="18"
                   Foreground="{DynamicResource TextMutedBrush}"
                   Text="Tbot Ultra needs a browser component that is not installed yet. It downloads once and is reused after that." />

        <StackPanel Grid.Row="2" VerticalAlignment="Bottom" Margin="0,12,0,0">
            <TextBlock x:Name="StatusTextBlock"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,6" />
            <ProgressBar x:Name="DownloadProgressBar"
                         Visibility="Collapsed"
                         Height="6"
                         Minimum="0"
                         Maximum="100"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="{DynamicResource SurfaceBrush}"
                         BorderThickness="0" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button x:Name="NotNowButton"
                    Content="Not now"
                    Width="90"
                    Height="32"
                    IsCancel="True"
                    Click="NotNowButton_Click" />
            <Button x:Name="DownloadButton"
                    Content="Download"
                    Width="110"
                    Height="32"
                    Margin="0"
                    IsDefault="True"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="{DynamicResource OnAccentBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    Click="DownloadButton_Click" />
        </StackPanel>
    </Grid>
</Window>
