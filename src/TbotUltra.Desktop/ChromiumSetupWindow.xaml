<Window x:Class="TbotUltra.Desktop.ChromiumSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Browser setup"
        Height="205"
        Width="470"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <!-- Asks only. The download itself runs behind the shared busy overlay, so progress and cancelling
         look the same here as for every other long operation in the app. -->
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Browser components missing"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,8" />

        <TextBlock x:Name="ExplanationTextBlock"
                   Grid.Row="1"
                   TextWrapping="Wrap"
                   LineHeight="18"
                   Foreground="{DynamicResource TextMutedBrush}"
                   Text="Tbot Ultra needs a browser component that is not installed yet. It downloads once (about 190 MB) and is reused after that." />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button x:Name="NotNowButton"
                    Content="Cancel"
                    Width="100"
                    Height="32"
                    IsCancel="True"
                    Background="{DynamicResource DangerBgBrush}"
                    Foreground="{DynamicResource DangerTextBrush}"
                    BorderBrush="{DynamicResource DangerBorderBrush}"
                    Click="NotNowButton_Click" />
            <Button x:Name="DownloadButton"
                    Content="Download"
                    Width="110"
                    Height="32"
                    Margin="0"
                    IsDefault="True"
                    Background="{DynamicResource SuccessBgBrush}"
                    Foreground="{DynamicResource SuccessTextBrush}"
                    BorderBrush="{DynamicResource SuccessBorderBrush}"
                    Click="DownloadButton_Click" />
        </StackPanel>
    </Grid>
</Window>
