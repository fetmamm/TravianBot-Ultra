<Window x:Class="TbotUltra.Desktop.AddFarmsToListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        xmlns:views="clr-namespace:TbotUltra.Desktop.Views"
        Title="Add Farms to List"
        Height="560"
        Width="680"
        MinHeight="430"
        MinWidth="620"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid x:Name="ContentRoot" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Select target farm lists"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,10" />

            <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource SurfaceBrush}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ListBox x:Name="FarmListOptionsListBox" SelectionMode="Single">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8" Background="{DynamicResource SurfaceAltBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,10,0"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Checked="FarmListOptionCheckBox_Changed"
                                                  Unchecked="FarmListOptionCheckBox_Changed" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding CountText}" Foreground="{DynamicResource OnWarningBrush}" Margin="10,0,0,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding CapacityText}" Margin="10,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFull}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource UnreadBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="1"
                               x:Name="InfoTextBlock"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Text="Check one or more lists. They are processed one at a time." />

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="130" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Amount" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Border Grid.Column="1"
                                Width="14"
                                Height="14"
                                Margin="0,0,10,0"
                                CornerRadius="7"
                                Background="{DynamicResource ControlBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                VerticalAlignment="Center"
                                ToolTipService.InitialShowDelay="0">
                            <Border.ToolTip>
                                <ToolTip MaxWidth="360">
                                    <StackPanel Width="320">
                                        <TextBlock Text="Amount"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TooltipForegroundBrush}"
                                                   Margin="0,0,0,8" />
                                        <TextBlock TextWrapping="Wrap" Text="ALL: Add all checked Natars that are available in the saved Natars list." />
                                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="FILL: Add enough checked Natars to fill each selected farm list." />
                                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="Checked: Add every currently checked Natar from the saved Natars list." />
                                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="Custom: Add the number entered in the box to each selected list." />
                                    </StackPanel>
                                </ToolTip>
                            </Border.ToolTip>
                            <TextBlock Text="i"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <RadioButton x:Name="AllModeRadioButton" Content="ALL" Margin="0,0,10,0" Checked="AllModeRadioButton_Checked" />
                            <RadioButton x:Name="FillModeRadioButton" Content="FILL" Margin="0,0,10,0" Checked="FillModeRadioButton_Checked" />
                            <RadioButton x:Name="CheckedModeRadioButton" Content="Checked" Margin="0,0,10,0" Checked="CheckedModeRadioButton_Checked" />
                            <RadioButton x:Name="CustomModeRadioButton" Content="Custom" Margin="0,0,8,0" Checked="CustomModeRadioButton_Checked" />
                        </StackPanel>
                        <TextBox x:Name="CustomCountTextBox" Grid.Column="5" Width="120" TextChanged="CustomCountTextBox_TextChanged" />
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="130" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Troop" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox x:Name="TroopTypeComboBox"
                                  Grid.Column="1"
                                  SelectionChanged="TroopTypeComboBox_SelectionChanged" />

                        <TextBlock Grid.Column="3" Text="Count" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox x:Name="TroopCountTextBox"
                                 Grid.Column="4"
                                 TextChanged="TroopCountTextBox_TextChanged" />
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button x:Name="AddFarmsButton" Width="110" Margin="0,0,8,0" Content="Add farms" Click="AddFarmsButton_Click" />
                <Button x:Name="CancelButtonControl" Width="100" Content="Cancel" Click="CancelButton_Click" />
            </StackPanel>
        </Grid>

        <views:BusyOverlayControl x:Name="LoadingOverlay"
                                  IsBusy="True"
                                  Title="Loading"
                                  Text="Working… loading farm lists and Natars profile."
                                  Cancelled="LoadingOverlay_Cancelled" />
    </Grid>
</Window>
