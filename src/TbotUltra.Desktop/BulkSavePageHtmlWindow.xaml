<Window x:Class="TbotUltra.Desktop.BulkSavePageHtmlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TbotUltra.Desktop.Views"
        Title="Bulk save HTML"
        Height="520"
        Width="520"
        MinHeight="460"
        MinWidth="480"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Bulk save page HTML"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#111827"
                       Margin="0,0,0,8" />

            <TextBlock Grid.Row="1"
                       TextWrapping="Wrap"
                       Foreground="#374151"
                       Margin="0,0,0,12"
                       Text="Select pages to visit and save. Each selected row is opened in order and saved to the DOM folder using the page name." />

            <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,0,0,10">
                <TextBlock Text="File prefix"
                           Margin="0,0,0,4" />
                <TextBox x:Name="PrefixTextBox"
                         ToolTip="Optional text added before every saved file name, for example SS." />
            </StackPanel>

            <DataGrid x:Name="PagesGrid"
                      Grid.Row="3"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      ItemsSource="{Binding Pages}"
                      SelectionMode="Single"
                      Margin="0,0,0,10">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Save"
                                            Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                            Width="70" />
                    <DataGridTextColumn Header="Page"
                                        Binding="{Binding Page, UpdateSourceTrigger=PropertyChanged}"
                                        Width="2*" />
                    <DataGridTextColumn Header="Alias"
                                        Binding="{Binding Alias, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="4"
                        Orientation="Vertical"
                        HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,8">
                    <Button Padding="10,4"
                            Margin="0,0,8,0"
                            Content="Add"
                            Click="AddButton_Click" />
                    <Button Padding="10,4"
                            Margin="0,0,8,0"
                            Content="Remove"
                            Click="RemoveButton_Click" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="OpenFolderButton"
                            Padding="10,4"
                            Margin="0,0,8,0"
                            Content="Open folder"
                            ToolTip="Opens the folder where the HTML files are saved."
                            Click="OpenFolderButton_Click" />
                    <Button x:Name="ClearFolderButton"
                            Padding="10,4"
                            Content="Clear folder"
                            ToolTip="Deletes all files in the DOM folder (asks for confirmation first)."
                            Click="ClearFolderButton_Click" />
                    <TextBlock x:Name="StatusTextBlock"
                               VerticalAlignment="Center"
                               Foreground="#2563EB"
                               Margin="10,0,0,0" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="5"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button x:Name="SaveButton"
                        Width="100"
                        Margin="0,0,8,0"
                        Background="#030826"
                        BorderBrush="#030826"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Content="Bulk save HTML"
                        Click="SaveButton_Click" />
                <Button Width="100"
                        Content="Close"
                        Click="CloseButton_Click" />
            </StackPanel>
        </Grid>

        <views:BusyOverlayControl x:Name="LoadingOverlay"
                                  Title="Bulk saving HTML"
                                  Text="Saving HTML pages..."
                                  Cancelled="LoadingOverlay_Cancelled" />
    </Grid>
</Window>
