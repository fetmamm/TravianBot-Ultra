<Window x:Class="TbotUltra.Desktop.HeroResourceOverviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Hero resource settings"
        Width="980"
        MinHeight="300"
        Height="560"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Hero resources by village"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
                <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                Margin="8,2,0,0"
                                ToolTip="Enable hero inventory resources per village, choose which features may use them, and cap max resources used per resource." />
            </StackPanel>
            <TextBlock x:Name="SubtitleTextBlock"
                       Foreground="{DynamicResource TextSubtleBrush}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="14,12,14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="54" />
                            <ColumnDefinition Width="*" MinWidth="160" />
                            <ColumnDefinition Width="128" />
                            <ColumnDefinition Width="88" />
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="108" />
                            <ColumnDefinition Width="112" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="ON"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="VILLAGE"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="CONSTRUCTION"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                            Margin="4,0,0,0"
                                            ToolTip="Allows hero inventory resources for building and resource-field upgrades when short on resources." />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="SMITHY"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                            Margin="4,0,0,0"
                                            ToolTip="Allows hero inventory resources for troop upgrades in the Smithy when short on resources." />
                        </StackPanel>
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="BREWERY"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                            Margin="4,0,0,0"
                                            ToolTip="Allows hero inventory resources for Brewery celebrations when short on resources." />
                        </StackPanel>
                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="TOWN HALL"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                            Margin="4,0,0,0"
                                            ToolTip="Allows hero inventory resources for Town Hall celebrations when short on resources." />
                        </StackPanel>
                        <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="MAX LIMIT"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                            Margin="4,0,0,0"
                                            ToolTip="Maximum hero inventory resources that may be used per resource for one action in this village. Default 5000." />
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="14,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="*" MinWidth="160" />
                                            <ColumnDefinition Width="128" />
                                            <ColumnDefinition Width="88" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="108" />
                                            <ColumnDefinition Width="112" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Style="{DynamicResource ToggleSwitchBlueStyle}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  ToolTip="Enable hero inventory resources for this village."
                                                  IsChecked="{Binding IsHeroResourcesEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding VillageName}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,0,12,0" />

                                        <CheckBox Grid.Column="2"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  ToolTip="Allow hero resources for building and resource-field upgrades."
                                                  IsChecked="{Binding UseConstruction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox Grid.Column="3"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  ToolTip="Allow hero resources for Smithy troop upgrades."
                                                  IsChecked="{Binding UseSmithy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox Grid.Column="4"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  ToolTip="Allow hero resources for brewery celebrations."
                                                  IsChecked="{Binding UseBrewery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox Grid.Column="5"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  ToolTip="Allow hero resources for Town Hall celebrations."
                                                  IsChecked="{Binding UseTownHall, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="6"
                                                 Width="78"
                                                 Padding="6,4"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 Text="{Binding MaxUsePerResource, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 ToolTip="Max hero resources used per resource for one action in this village."
                                                 BorderBrush="{DynamicResource BorderSubtleBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Width="80"
                    Height="30"
                    Content="Cancel"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click" />
            <Button Width="120"
                    Height="30"
                    Content="Save &amp; close"
                    Click="SaveButton_Click"
                    Background="{DynamicResource PrimaryButtonBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    Foreground="{DynamicResource OnAccentBrush}" />
        </StackPanel>
    </Grid>
</Window>
