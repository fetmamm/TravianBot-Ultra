<Window x:Class="TbotUltra.Desktop.VillageSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TbotUltra.Desktop"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Village settings"
        Width="1320"
        Height="720"
        MinHeight="320"
        MinWidth="920"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
            <TextBlock Text="Village settings" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                            Margin="8,2,0,0"
                            ToolTip="Per-village automation. &quot;Auto&quot; turns the village on/off for the bot (off = skipped entirely). &quot;Hero res.&quot; selects which villages may use hero inventory resources. &quot;NPC&quot; selects which villages NPC trade may run in. New villages start with Construction on, Hero res. on, and everything else off; Auto is on only when the account has one village. Saved per account." />
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Settings">
        <DataGrid x:Name="VillageSettingsDataGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="Auto">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Auto" FontSize="11" VerticalAlignment="Center"
                                       ToolTipService.InitialShowDelay="100"
                                       ToolTip="Turns the village on/off for the bot. Off = the village is skipped entirely." />
                            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}" Margin="4,0,0,0"
                                            ToolTipService.InitialShowDelay="100"
                                            ToolTip="Turns the village on/off for the bot. Off = the village is skipped entirely." />
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox Style="{DynamicResource ToggleSwitchStyle}"
                                      IsChecked="{Binding IsEnabledForAutomation, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="2,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Binding="{Binding Name}" Width="Auto" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <!-- Gold for the capital, same as the Village overview on the dashboard. -->
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding KeyInfo.IsCapital}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource CapitalBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.Header>
                        <TextBlock Text="Village" FontSize="11" VerticalAlignment="Center" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <!-- Hidden by default: only special servers allow a different tribe per village, and the
                     window makes this visible when the villages actually differ (see constructor). -->
                <DataGridTextColumn x:Name="TribeColumn"
                                    Binding="{Binding TribeText}"
                                    Width="Auto"
                                    IsReadOnly="True"
                                    Visibility="Collapsed">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="Tribe" FontSize="11" VerticalAlignment="Center" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding PopText}" Width="Auto" IsReadOnly="True">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="Pop" FontSize="11" VerticalAlignment="Center" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTemplateColumn x:Name="NpcTradeColumn" Width="Auto">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="NPC" FontSize="11" VerticalAlignment="Center"
                                   ToolTipService.InitialShowDelay="100"
                                   ToolTip="Selects which villages NPC trade may run in. The NPC trade master toggle in Auto settings must also be on for it to run." />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox Style="{DynamicResource ToggleSwitchBlueStyle}"
                                      IsChecked="{Binding NpcTrade, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="2,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- One toggle column per automation group is generated in code-behind (BuildGroupColumns). -->
            </DataGrid.Columns>
        </DataGrid>
            </TabItem>

            <TabItem Header="Overview">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <StackPanel DockPanel.Dock="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Upcoming tasks" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                                Margin="8,2,0,0"
                                                ToolTip="Live projection of the next tasks the bot will run, in the order it will pick them across all villages. &quot;Ready&quot; means it can start now; a timer shows when a deferred task becomes eligible. It is a preview and updates as the queue changes." />
                            </StackPanel>
                            <TextBlock x:Name="OverviewRunningTaskTextBlock"
                                       Text="Running: Nothing running"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                        <TextBlock x:Name="OverviewUpdatedTextBlock"
                                   DockPanel.Dock="Right"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </DockPanel>

                    <!-- Auto columns + left align: the table hugs its content instead of stretching, so
                         Task/Group/Status stay compact. -->
                    <DataGrid x:Name="UpcomingTasksDataGrid"
                              Grid.Row="1"
                              Height="174"
                              Margin="0,0,0,10"
                              HorizontalAlignment="Left"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Width="Auto" Binding="{Binding Position}" />
                            <DataGridTextColumn Header="Task" Width="Auto" MaxWidth="340" Binding="{Binding Task}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="Wrap" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Village" Width="Auto" Binding="{Binding Village}" />
                            <DataGridTextColumn Header="Group" Width="Auto" Binding="{Binding Group}" />
                            <DataGridTemplateColumn Header="Status" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock local:OverviewStatusText.Text="{Binding Timing}"
                                                   VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Columns are built in code-behind (BuildOverviewColumns) so every status cell shares
                         the same color-coded template (Ready green / Waiting amber / Disabled muted) and
                         auto-sizes to its content (a column full of "Disabled" shrinks; active timers grow). -->
                    <DataGrid x:Name="VillageOverviewDataGrid"
                              Grid.Row="2"
                              HorizontalAlignment="Left"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              FrozenColumnCount="2"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap" />
                                <Setter Property="VerticalAlignment" Value="Top" />
                            </Style>
                        </DataGrid.Resources>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="100" Content="Save" Click="SaveAndCloseButton_Click" Margin="0,0,8,0"
                    Background="{DynamicResource SuccessBgBrush}"
                    BorderBrush="{DynamicResource SuccessBorderBrush}"
                    Foreground="{DynamicResource SuccessTextBrush}" />
            <Button Width="100" Content="Close" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
