<Window x:Class="TbotUltra.Desktop.VillageSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Village settings"
        Height="460"
        Width="1180"
        MinHeight="320"
        MinWidth="820"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
            <TextBlock Text="Village settings" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                            Margin="8,2,0,0"
                            ToolTip="Per-village automation. &quot;Auto&quot; turns the village on/off for the bot (off = skipped entirely). &quot;NPC&quot; selects which villages NPC trade may run in — the NPC trade master toggle in Auto settings must also be on. The automation-group columns mirror the dashboard cards per village. New villages start with Construction on and everything else off; Auto is on only when the account has one village. Saved per account." />
        </StackPanel>

        <DataGrid x:Name="VillageSettingsDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="Auto">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Auto" VerticalAlignment="Center" />
                            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}" Margin="5,0,0,0"
                                            ToolTip="Turns the village on/off for the bot. Off = the village is skipped entirely." />
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox Style="{DynamicResource ToggleSwitchStyle}"
                                      IsChecked="{Binding IsEnabledForAutomation, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="6,2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Binding="{Binding Name}" Width="Auto" IsReadOnly="True">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="Village" VerticalAlignment="Center" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding PopText}" Width="Auto" IsReadOnly="True">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="Pop" VerticalAlignment="Center" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTemplateColumn x:Name="NpcTradeColumn" Width="Auto">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="NPC" VerticalAlignment="Center" />
                            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}" Margin="5,0,0,0"
                                            ToolTip="Selects which villages NPC trade may run in. The NPC trade master toggle in Auto settings must also be on for it to run." />
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox Style="{DynamicResource ToggleSwitchBlueStyle}"
                                      IsChecked="{Binding NpcTrade, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="6,2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- One toggle column per automation group is generated in code-behind (BuildGroupColumns). -->
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="100" Content="Close" Click="CloseButton_Click" Margin="0,0,8,0" />
            <Button Width="140" Content="Save &amp; close" Click="SaveAndCloseButton_Click"
                    Background="{DynamicResource PrimaryButtonBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    Foreground="{DynamicResource OnAccentBrush}" />
        </StackPanel>
    </Grid>
</Window>
