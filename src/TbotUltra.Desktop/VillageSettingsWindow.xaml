<Window x:Class="TbotUltra.Desktop.VillageSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Village settings"
        Height="460"
        Width="720"
        MinHeight="320"
        MinWidth="600"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Village settings" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Per-village automation. &quot;Auto&quot; turns the village on/off for the bot (off = skipped entirely). &quot;NPC&quot; selects which villages NPC trade may run in — the NPC trade master toggle in Auto settings must also be on. Saved per account; capital on by default."
                       Foreground="{DynamicResource TextSubtleBrush}"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
        </StackPanel>

        <DataGrid x:Name="VillageSettingsDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Auto" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox Style="{DynamicResource ToggleSwitchStyle}"
                                      IsChecked="{Binding IsEnabledForAutomation, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="6,2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Village" Binding="{Binding Name}" Width="*" IsReadOnly="True" />
                <DataGridTextColumn Header="Pop" Binding="{Binding PopText}" Width="Auto" IsReadOnly="True" />
                <DataGridTextColumn Header="Coords" Binding="{Binding CoordsText}" Width="Auto" IsReadOnly="True" />
                <DataGridCheckBoxColumn Header="Hero res" Binding="{Binding HeroResources, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
                <DataGridCheckBoxColumn Header="NPC" Binding="{Binding NpcTrade, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
                <DataGridCheckBoxColumn Header="Build troops" Binding="{Binding BuildTroops, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
                <DataGridCheckBoxColumn Header="Upgrade troops" Binding="{Binding UpgradeTroops, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
                <DataGridCheckBoxColumn Header="Farming" Binding="{Binding Farming, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="100" Content="Close" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
