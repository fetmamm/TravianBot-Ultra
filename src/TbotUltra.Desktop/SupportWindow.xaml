<Window x:Class="TbotUltra.Desktop.SupportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Support"
        Height="430"
        Width="520"
        MinHeight="400"
        MinWidth="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Contact / Support" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Discord" Width="100" Margin="0,0,8,0" Click="DiscordButton_Click" />
            <Button Content="GitHub" Width="100" Click="GithubButton_Click" />
        </StackPanel>

        <Button Grid.Row="2" Content="Create diagnostics file" Width="170" Margin="0,0,0,12" HorizontalAlignment="Left" Click="DiagnosticsButton_Click" />

        <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center" Margin="0,0,8,8" />
                <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Email" VerticalAlignment="Center" Margin="0,0,8,8" />
                <TextBox x:Name="EmailTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Message" VerticalAlignment="Top" Margin="0,0,8,0" />
                <TextBox x:Name="MessageTextBox" Grid.Row="2" Grid.Column="1" Height="110" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Border>

        <TextBlock x:Name="InfoTextBlock" Grid.Row="4" TextWrapping="Wrap" Foreground="{DynamicResource IronTextBrush}" />

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Send" Width="100" Margin="0,0,8,0" Click="SendButton_Click" />
            <Button Content="Cancel" Width="100" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
