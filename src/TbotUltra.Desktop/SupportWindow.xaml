<Window x:Class="TbotUltra.Desktop.SupportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TbotUltra.Desktop.Views"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Support"
        Height="390"
        Width="460"
        MinHeight="350"
        MinWidth="420"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Contact / Support" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />

        <TextBlock Grid.Row="1"
                   Text="Reach out on Discord or report issues on GitHub."
                   Foreground="{DynamicResource TextSubtleBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <!-- Discord = blue, GitHub = green, both using the soft tinted fade of the Start bot button. -->
            <Button Content="Discord"
                    Width="110"
                    Height="30"
                    Margin="0,0,8,0"
                    Background="{DynamicResource InfoBgBrush}"
                    BorderBrush="{DynamicResource InfoBrush}"
                    Foreground="{DynamicResource InfoTextBrush}"
                    Click="DiscordButton_Click" />
            <Button Content="GitHub"
                    Width="110"
                    Height="30"
                    Margin="0,0,8,0"
                    Background="{DynamicResource SuccessBgBrush}"
                    BorderBrush="{DynamicResource SuccessBorderBrush}"
                    Foreground="{DynamicResource SuccessTextBrush}"
                    Click="GithubButton_Click" />
            <!-- Version: grey when up to date / unknown, amber when a newer release exists (set in code). -->
            <Button x:Name="VersionButton"
                    Content="Version"
                    Width="110"
                    Height="30"
                    Click="VersionButton_Click" />
        </StackPanel>

        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Diagnostics" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                    ToolTip="Creates a ZIP file with sanitized settings, all available logs, system information, and runtime diagnostics. Screenshots may still contain visible game data. Review the ZIP before sharing it." />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="DiagnosticsButton"
                            Content="Create diagnostics file"
                            Width="170"
                            Margin="0,0,8,0"
                            Background="{DynamicResource PurpleBgBrush}"
                            BorderBrush="{DynamicResource PurpleBorderBrush}"
                            Foreground="{DynamicResource PurpleTextBrush}"
                            Click="DiagnosticsButton_Click" />
                    <Button x:Name="OpenDiagnosticsFolderButton"
                            Content="Open diagnostics folder"
                            Width="180"
                            Click="OpenDiagnosticsFolderButton_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock x:Name="InfoTextBlock" Grid.Row="4" TextWrapping="Wrap" Foreground="{DynamicResource IronTextBrush}" />

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Close" Width="100" Click="CancelButton_Click" />
        </StackPanel>

        <views:BusyOverlayControl x:Name="DiagnosticsBusyOverlay"
                                  Grid.RowSpan="6"
                                  Panel.ZIndex="100"
                                  ShowCancel="True"
                                  Cancelled="DiagnosticsBusyOverlay_Cancelled" />
    </Grid>
</Window>
