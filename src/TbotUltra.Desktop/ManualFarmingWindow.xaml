<Window x:Class="TbotUltra.Desktop.ManualFarmingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Manual Farming"
        Height="470"
        Width="460"
        MinHeight="420"
        MinWidth="420"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Choose troop setup"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,10" />

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{DynamicResource SurfaceBrush}"
                Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Troop"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <ComboBox x:Name="TroopTypeComboBox"
                              Grid.Row="0"
                              Grid.Column="1"
                              SelectionChanged="TroopTypeComboBox_SelectionChanged" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Amount"
                               VerticalAlignment="Center"
                               Margin="0,14,10,0" />
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TroopCountTextBox"
                                 Grid.Column="0"
                                 Text="1"
                                 TextChanged="TroopCountTextBox_TextChanged" />
                        <TextBlock x:Name="EffectiveRangeTextBlock"
                                   Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSubtleBrush}"
                                   Text="1-1" />
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="Variation±:"
                               VerticalAlignment="Center"
                               Margin="0,14,10,0" />
                    <ComboBox x:Name="VarianceComboBox"
                              Grid.Row="2"
                              Grid.Column="1"
                              Width="55"
                              Margin="0,14,0,0"
                              HorizontalAlignment="Left"
                              SelectionChanged="VarianceComboBox_SelectionChanged" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Text="Type"
                               VerticalAlignment="Top"
                               Margin="0,14,10,0" />
                    <StackPanel Grid.Row="3"
                                Grid.Column="1"
                                Orientation="Vertical"
                                Margin="0,14,0,0">
                        <RadioButton x:Name="RaidRadioButton"
                                     Content="Raid"
                                     Margin="0,0,0,6"
                                     Checked="AttackTypeRadioButton_Checked" />
                        <RadioButton x:Name="NormalAttackRadioButton"
                                     Content="Normal attack"
                                     Checked="AttackTypeRadioButton_Checked" />
                    </StackPanel>

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Text="Targets"
                               VerticalAlignment="Top"
                               Margin="0,14,10,0"
                               ToolTip="Farm villages uses only villages named 'Natar farm village'. All villages uses every village found in the Natars profile list." />
                    <StackPanel Grid.Row="4"
                                Grid.Column="1"
                                Orientation="Vertical"
                                Margin="0,14,0,0">
                        <RadioButton x:Name="FarmVillagesRadioButton"
                                     Content="Farm villages"
                                     Margin="0,0,0,6"
                                     Checked="TargetSelectionRadioButton_Checked"
                                     ToolTip="Only villages named 'Natar farm village'." />
                        <RadioButton x:Name="AllVillagesRadioButton"
                                     Content="All villages"
                                     Checked="TargetSelectionRadioButton_Checked"
                                     ToolTip="Every village found in the Natars profile list." />
                    </StackPanel>

                    <TextBlock x:Name="InfoTextBlock"
                               Grid.Row="5"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               Margin="0,16,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="Select troop type and amount." />
                </Grid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="StartButton"
                    Width="100"
                    Margin="0,0,8,0"
                    Content="Start"
                    Click="StartButton_Click" />
            <Button Width="100"
                    Content="Cancel"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
