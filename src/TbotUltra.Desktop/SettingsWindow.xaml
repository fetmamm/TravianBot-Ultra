<Window x:Class="TbotUltra.Desktop.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="430"
        Width="500"
        MinHeight="400"
        MinWidth="460"
        WindowStartupLocation="CenterOwner"
        Closing="SettingsWindow_Closing">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Padding="12">
            <StackPanel>
                <TextBlock Text="Bot Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                <CheckBox x:Name="HeadlessCheckBox" Margin="0,0,0,8" Content="Headless" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox x:Name="HumanLikeCheckBox"
                              Content="Act more human" />
                    <Border Width="18"
                            Height="18"
                            Margin="8,0,0,0"
                            CornerRadius="9"
                            Background="#DBEAFE"
                            BorderBrush="#93C5FD"
                            BorderThickness="1"
                            ToolTipService.InitialShowDelay="0"
                            ToolTip="Adds a random 0.1-1.0s delay between each sent manual farm attack.">
                        <TextBlock Text="i"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#1D4ED8"
                                   FontWeight="SemiBold"
                                   FontSize="11" />
                    </Border>
                </StackPanel>
                <Separator Margin="0,0,0,10" />
                <CheckBox x:Name="AllowGoldSpendingCheckBox" Margin="0,0,0,8" Content="Allow gold spending" />
                <CheckBox x:Name="AllowSilverSpendingCheckBox" Margin="0,0,0,10" Content="Allow silver spending" />

                <TextBlock x:Name="GoldLimitTextBlock" Text="Gold limit: 100" Margin="0,0,0,4" />
                <Slider x:Name="GoldLimitSlider"
                        Width="150"
                        Minimum="0"
                        Maximum="200"
                        Value="100"
                        TickFrequency="10"
                        IsSnapToTickEnabled="True"
                        Margin="0,0,0,10"
                        ValueChanged="GoldLimitSlider_ValueChanged" />

                <TextBlock x:Name="SilverLimitTextBlock" Text="Silver limit: 100" Margin="0,0,0,4" />
                <Slider x:Name="SilverLimitSlider"
                        Width="150"
                        Minimum="0"
                        Maximum="1000"
                        Value="100"
                        TickFrequency="25"
                        IsSnapToTickEnabled="True"
                        Margin="0,0,0,0"
                        ValueChanged="SilverLimitSlider_ValueChanged" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="ResetButton" Width="100" Margin="0,0,8,0" Content="Reset" Click="ResetButton_Click" />
            <Button x:Name="SaveButton" Width="100" Margin="0,0,8,0" Content="Save" Click="SaveButton_Click" />
            <Button x:Name="CancelButtonControl" Width="100" Content="Cancel" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
