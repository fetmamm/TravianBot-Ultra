<Window x:Class="TbotUltra.Desktop.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TbotUltra.Desktop"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Settings"
        Height="720"
        Width="780"
        MinHeight="520"
        MinWidth="680"
        WindowStartupLocation="CenterOwner"
        Closing="SettingsWindow_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Badges.xaml" />
                <!-- Buttons.xaml is also merged app-wide in App.xaml, but this window is constructed
                     standalone in tests, where StaticResource lookups cannot reach App resources. -->
                <ResourceDictionary Source="Themes/Buttons.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Lightweight section divider: settings are grouped by spacing and hierarchy, not nested cards. -->
            <Style x:Key="SettingsGroupBox" TargetType="Border">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Padding" Value="0,0,0,16" />
                <Setter Property="Margin" Value="0,0,0,16" />
            </Style>
            <Style x:Key="SettingsCategoryCardStyle" TargetType="Border">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="Visibility" Value="Collapsed" />
            </Style>
            <Style x:Key="GeneralSettingsCategoryStyle" TargetType="Border" BasedOn="{StaticResource SettingsCategoryCardStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SelectedIndex, ElementName=SettingsCategoryTabControl}" Value="0">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="PacingSettingsCategoryStyle" TargetType="Border" BasedOn="{StaticResource SettingsCategoryCardStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SelectedIndex, ElementName=SettingsCategoryTabControl}" Value="1">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="ConstructionSettingsCategoryStyle" TargetType="Border" BasedOn="{StaticResource SettingsCategoryCardStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SelectedIndex, ElementName=SettingsCategoryTabControl}" Value="2">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="HeroSettingsCategoryStyle" TargetType="Border" BasedOn="{StaticResource SettingsCategoryCardStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SelectedIndex, ElementName=SettingsCategoryTabControl}" Value="3">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="FarmingSettingsCategoryStyle" TargetType="Border" BasedOn="{StaticResource SettingsCategoryCardStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SelectedIndex, ElementName=SettingsCategoryTabControl}" Value="4">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="TroopsSettingsCategoryStyle" TargetType="Border" BasedOn="{StaticResource SettingsCategoryCardStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SelectedIndex, ElementName=SettingsCategoryTabControl}" Value="5">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="NpcTradeSettingsCategoryStyle" TargetType="Border" BasedOn="{StaticResource SettingsCategoryCardStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SelectedIndex, ElementName=SettingsCategoryTabControl}" Value="7">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="CelebrationsSettingsCategoryStyle" TargetType="Border" BasedOn="{StaticResource SettingsCategoryCardStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SelectedIndex, ElementName=SettingsCategoryTabControl}" Value="6">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="SettingsCategoryTabStyle" TargetType="TabItem">
                <!-- Match the compact, square tab treatment used by Village settings. -->
                <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="TabSurface"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0,0,0,2"
                                    Margin="0,0,2,0"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter ContentSource="Header"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="TabSurface" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                    <Setter TargetName="TabSurface" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="False" />
                                        <Condition Property="IsMouseOver" Value="True" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="TabSurface" Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                </MultiTrigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="TabSurface" Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="Transparent" BorderThickness="0" Padding="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,0,4,12" VerticalAlignment="Center">
                    <TextBlock Text="Bot Settings"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource InkBrush}"
                               VerticalAlignment="Center" />
                    <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                    Margin="7,1,0,0"
                                    ToolTip="Configure execution, automation, and spending behavior." />
                </StackPanel>

                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1,1,1,0"
                        CornerRadius="8,8,0,0">
                    <TabControl x:Name="SettingsCategoryTabControl"
                                Height="44"
                                SelectedIndex="0"
                                Background="Transparent"
                                BorderThickness="0"
                                SelectionChanged="SettingsCategoryTabControl_SelectionChanged"
                                ItemContainerStyle="{StaticResource SettingsCategoryTabStyle}">
                        <TabItem Header="General" />
                        <TabItem Header="Pacing" />
                        <TabItem Header="Construction" />
                        <TabItem Header="Hero" />
                        <TabItem Header="Farming" />
                        <TabItem Header="Troops" />
                        <TabItem Header="Celebrations" />
                        <TabItem Header="NPC / Trade" />
                    </TabControl>
                </Border>

                <Border Grid.Row="2"
                        Padding="20,18"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1,0,1,1"
                        CornerRadius="0,0,8,8">
                    <ScrollViewer x:Name="SettingsContentScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,0,10,0">

                    <Border Style="{StaticResource GeneralSettingsCategoryStyle}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="0,0,0,22"
                            Margin="0,0,0,22">
                        <StackPanel>
                            <TextBlock Text="General"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,10" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="DontNotifyNewVersionCheckBox"
                                          Content="Dont notify for new version" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Suppresses the popup shown when a newer version is available. Updates can still be checked and installed manually from the version window." />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="QuickReloginCheckBox"
                                          Content="Quick re-login within 2 hours" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="When logging in less than 10 minutes after the last full login, skip the post-login analyzes (villages, hero, farm lists, brewery) and only confirm the session. Saved per account." />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="AutomaticallyCheckLanguageCheckBox"
                                          Content="Automatically check language" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Checks that Travian is set to English before automation parses pages. Turn off only if the language guard itself causes problems." />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="DetailedBrowserLoggingCheckBox"
                                          Content="Detailed browser logging (development only)"
                                          Checked="DetailedBrowserLoggingCheckBox_Changed"
                                          Unchecked="DetailedBrowserLoggingCheckBox_Changed" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Development only. Records detailed browser actions, navigation, reloads, refreshes, reads, waits, retries, and cache decisions. This can create large log files and slightly affect performance. Keep this OFF during normal use." />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                                <CheckBox x:Name="DailyServerResetOverrideCheckBox"
                                          Content="Daily server reset (manual)"
                                          VerticalAlignment="Center"
                                          Checked="DailyServerResetOverride_Changed"
                                          Unchecked="DailyServerResetOverride_Changed" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="The server-local whole hour when the game day resets. The bot auto-detects this from the daily quests dialog per account — the detected value is shown on the right. Leave the toggle OFF to use the detected value; turn it ON only to override it manually (e.g. if detection is wrong)." />
                                <ComboBox x:Name="DailyServerResetHourComboBox"
                                          Width="80"
                                          Margin="10,0,0,0"
                                          VerticalAlignment="Center" />
                                <TextBlock x:Name="DailyServerResetDetectedTextBlock"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PacingSettingsCategoryStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Bot behavior"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <Button x:Name="ResetPacingButton"
                                        Style="{StaticResource RefreshIconButtonStyle}"
                                        Margin="8,0,0,0"
                                        ToolTip="Reset pacing defaults"
                                        Click="ResetPacingButton_Click" />
                            </StackPanel>

                            <Border Style="{StaticResource SettingsGroupBox}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <CheckBox x:Name="SessionPacingEnabledCheckBox"
                                                  Content="Session pacing" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                        ToolTip="Limits how long the bot runs before it logs out, sleeps, and resumes automatically." />
                                    </StackPanel>
                                    <Grid Margin="18,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Min" FontWeight="SemiBold" Margin="0,2" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Max" FontWeight="SemiBold" Margin="6,2,0,2" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Run (min)" VerticalAlignment="Center" Margin="0,2" />
                                        <TextBox x:Name="SessionRunMinMinutesTextBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2" />
                                        <TextBox x:Name="SessionRunMaxMinutesTextBox" Grid.Row="1" Grid.Column="2" Height="24" Margin="6,2,0,2" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Sleep (min)" VerticalAlignment="Center" Margin="0,2" />
                                        <TextBox x:Name="SessionSleepMinMinutesTextBox" Grid.Row="2" Grid.Column="1" Height="24" Margin="0,2" />
                                        <TextBox x:Name="SessionSleepMaxMinutesTextBox" Grid.Row="2" Grid.Column="2" Height="24" Margin="6,2,0,2" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Daily max" VerticalAlignment="Center" Margin="0,2" />
                                        <ComboBox x:Name="SessionDailyMaxHoursComboBox" Grid.Row="3" Grid.Column="1" Height="24" Margin="0,2" />
                                        <ComboBox x:Name="SessionDailyMaxVariationComboBox" Grid.Row="3" Grid.Column="2" Height="24" Margin="6,2,0,2"
                                                  ToolTip="Daily max variation: randomizes the daily limit by this much each day (applies only to Daily max)." />
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="18,0,0,6">
                                        <TextBlock Text="Allowed hours" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                        ToolTip="Checked hours may run. Unchecked hours log out and stay stopped until the next checked hour." />
                                    </StackPanel>
                                    <local:VerticalFirstUniformGrid x:Name="SessionAllowedHoursGrid"
                                                                    Columns="6"
                                                                    Margin="18,0,0,0" />
                                    <StackPanel Orientation="Horizontal" Margin="18,12,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Daily variation" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                        ToolTip="Shifts each allowed-hours on/off boundary by ± this percent of an hour (e.g. 30% = ±18 min), so the bot does not start or stop at the exact same clock time every day. Set to 0 to keep exact hours." />
                                        <ComboBox x:Name="SessionHoursVariationComboBox" Width="110" Height="24" Margin="8,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsGroupBox}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <CheckBox x:Name="ActionPacingEnabledCheckBox"
                                                  Content="Action pacing" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                        ToolTip="Adds small randomized pauses around central bot actions such as tasks, page loads, farm sends, and loop passes." />
                                    </StackPanel>
                                    <Grid Margin="18,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="70" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Min s" FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Max s" FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Task" VerticalAlignment="Center" Margin="0,4" />
                                        <TextBox x:Name="ActionTaskMinTextBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                        <TextBox x:Name="ActionTaskMaxTextBox" Grid.Row="1" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Page load" VerticalAlignment="Center" Margin="0,4" />
                                        <TextBox x:Name="ActionPageLoadMinTextBox" Grid.Row="2" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                        <TextBox x:Name="ActionPageLoadMaxTextBox" Grid.Row="2" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Click" VerticalAlignment="Center" Margin="0,4" />
                                        <TextBox x:Name="ActionClickMinTextBox" Grid.Row="3" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                        <TextBox x:Name="ActionClickMaxTextBox" Grid.Row="3" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Loop" VerticalAlignment="Center" Margin="0,4" />
                                        <TextBox x:Name="ActionLoopMinTextBox" Grid.Row="4" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                        <TextBox x:Name="ActionLoopMaxTextBox" Grid.Row="4" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Farmlist" VerticalAlignment="Center" Margin="0,4" />
                                        <TextBox x:Name="FarmListStepDelayMinTextBox" Grid.Row="5" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                        <TextBox x:Name="FarmListStepDelayMaxTextBox" Grid.Row="5" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Margin="0,14,0,8">
                                        <TextBlock Text="Collect tasks delay" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                        ToolTip="Randomized delay between the reward clicks in the Auto collect tasks flow only, where many buttons are clicked in a row. Keeps that fast burst from looking robotic. Daily quests use the normal Click pacing instead, since they usually have a single button. Set both to 0 to disable." />
                                    </StackPanel>
                                    <Grid Margin="18,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="70" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Min s" FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Max s" FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Click/step" VerticalAlignment="Center" Margin="0,4" />
                                        <TextBox x:Name="CollectStepDelayMinTextBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                        <TextBox x:Name="CollectStepDelayMaxTextBox" Grid.Row="1" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsGroupBox}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <CheckBox x:Name="IdleBreakEnabledCheckBox"
                                                  Content="Idle break"
                                                  VerticalAlignment="Center" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}">
                                            <ContentControl.ToolTip>
                                                <ToolTip MaxWidth="320">
                                                    <TextBlock TextWrapping="Wrap"
                                                               Text="Occasionally pauses the loop as if you stepped away from the computer. Somewhere within the Every range a random pause of the Length range fires between tasks (never mid-action); when it ends the timer restarts. Shown in the log under the Pacing filter." />
                                                </ToolTip>
                                            </ContentControl.ToolTip>
                                        </ContentControl>
                                    </StackPanel>
                                    <Grid Margin="18,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="70" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Min" FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Max" FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Every (min)" VerticalAlignment="Center" Margin="0,4" />
                                        <TextBox x:Name="IdleBreakIntervalMinTextBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                        <TextBox x:Name="IdleBreakIntervalMaxTextBox" Grid.Row="1" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Length (min)" VerticalAlignment="Center" Margin="0,4" />
                                        <TextBox x:Name="IdleBreakDurationMinTextBox" Grid.Row="2" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                        <TextBox x:Name="IdleBreakDurationMaxTextBox" Grid.Row="2" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsGroupBox}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <CheckBox x:Name="IdleBrowseEnabledCheckBox"
                                                  Content="Idle browse"
                                                  VerticalAlignment="Center" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}">
                                            <ContentControl.ToolTip>
                                                <ToolTip MaxWidth="320">
                                                    <TextBlock TextWrapping="Wrap"
                                                               Text="Occasionally opens a non-functional page (map, statistics, reports, messages) and reads nothing, as if you were browsing around. Somewhere within the Every range one page is opened between tasks (never mid-action); then the timer restarts. Pick which pages may be visited on the right. Shown in the log under the Pacing filter." />
                                                </ToolTip>
                                            </ContentControl.ToolTip>
                                        </ContentControl>
                                    </StackPanel>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Min" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Max" FontWeight="SemiBold" />
                                    <TextBox x:Name="IdleBrowseIntervalMinTextBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                    <TextBox x:Name="IdleBrowseIntervalMaxTextBox" Grid.Row="1" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                    <Expander Grid.Row="1" Grid.Column="3" Header="Pages to visit" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Grid Margin="4,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                                <CheckBox x:Name="IdleBrowsePageMapCheckBox" Content="Map" Margin="0,2" />
                                                <CheckBox x:Name="IdleBrowsePageReportsCheckBox" Content="Reports" Margin="0,2" />
                                                <CheckBox x:Name="IdleBrowsePageMessagesCheckBox" Content="Messages" Margin="0,2" />
                                                <CheckBox x:Name="IdleBrowsePageStatisticsCheckBox" Content="Statistics - General" Margin="0,2" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <CheckBox x:Name="IdleBrowsePageStatisticsHeroCheckBox" Content="Statistics - Hero" Margin="0,2" />
                                                <CheckBox x:Name="IdleBrowsePageStatisticsTop10CheckBox" Content="Statistics - Top10" Margin="0,2" />
                                                <CheckBox x:Name="IdleBrowsePageStatisticsDefendersCheckBox" Content="Statistics - Defender" Margin="0,2" />
                                                <CheckBox x:Name="IdleBrowsePageStatisticsAttackersCheckBox" Content="Statistics - Attacker" Margin="0,2" />
                                            </StackPanel>
                                        </Grid>
                                    </Expander>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource SettingsGroupBox}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Refresh jitter" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                        ToolTip="Always on. The background dashboard resource refresh fires at a random interval in this range instead of a fixed 20s heartbeat. Fixed values, shown for reference." />
                                    </StackPanel>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Min s" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Max s" FontWeight="SemiBold" />
                                    <!-- Fixed, non-editable. Mirrors the jitter range in MainWindow's resource-refresh timer (15–35s). -->
                                    <TextBox Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2,6,2" Text="15" IsReadOnly="True" Focusable="False" Foreground="{DynamicResource TextMutedBrush}" />
                                    <TextBox Grid.Row="1" Grid.Column="2" Height="24" Margin="0,2,0,2" Text="35" IsReadOnly="True" Focusable="False" Foreground="{DynamicResource TextMutedBrush}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ConstructionSettingsCategoryStyle}">
                        <StackPanel>
                            <TextBlock Text="Construction"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,10" />

                            <Border Style="{StaticResource SettingsGroupBox}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Auto storage upgrade"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                    <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                    ToolTip="If a construction needs more warehouse/granary to upgrade, program will upgrade automatically. This setting changes how many levels ahead the program will upgrade storage facilities." />
                                    <ComboBox x:Name="StorageUpgradeLevelsAheadComboBox"
                                              Width="72"
                                              Margin="12,0,0,0"
                                              VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsGroupBox}"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                                        <CheckBox x:Name="ConstructionHumanizeCheckBox"
                                                  Content="Construction start delay"
                                                  FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                  VerticalAlignment="Center" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                        ToolTip="Wait a bit before starting the next construction instead of reacting the instant a slot frees. Shortly before a session-pacing sleep, delayed starts are pulled forward automatically so every build slot that can be filled is occupied when the sleep begins. Off means builds start immediately." />
                                    </StackPanel>

                                    <Grid HorizontalAlignment="Left">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="64" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Min" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="{DynamicResource TextSubtleBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Max" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="{DynamicResource TextSubtleBrush}" HorizontalAlignment="Center" />

                                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2">
                                            <TextBlock Text="Queue delay (%)" VerticalAlignment="Center" />
                                            <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                            ToolTip="When a build is already running and Plus allows another build to be queued, wait a random percentage of the running build's remaining time. Max delay is still respected." />
                                        </StackPanel>
                                        <TextBox x:Name="ConstructionHumanizeQueuePercentMinTextBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                        <TextBox x:Name="ConstructionHumanizeQueuePercentMaxTextBox" Grid.Row="1" Grid.Column="2" Height="24" Margin="0,2" />

                                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2">
                                            <TextBlock Text="Max delay (min)" VerticalAlignment="Center" />
                                            <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                            ToolTip="Absolute cap on the queue-delay percentage." />
                                        </StackPanel>
                                        <TextBox x:Name="ConstructionHumanizeMaxDelayTextBox" Grid.Row="2" Grid.Column="1" Height="24" Margin="0,2,6,2" />

                                        <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2">
                                            <TextBlock Text="No-Plus delay (min)" VerticalAlignment="Center" />
                                            <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                            ToolTip="When only one build slot is available, wait a random number of minutes in this range after a build finishes before starting the next." />
                                        </StackPanel>
                                        <TextBox x:Name="ConstructionHumanizeNoPlusMinTextBox" Grid.Row="3" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                        <TextBox x:Name="ConstructionHumanizeNoPlusMaxTextBox" Grid.Row="3" Grid.Column="2" Height="24" Margin="0,2" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GeneralSettingsCategoryStyle}">
                        <StackPanel>
                            <TextBlock Text="Automation"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,10" />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="After login"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        VerticalAlignment="Center" />

                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                Margin="6,0,0,0"
                                                ToolTip="Optional extra analyzing-functions to run after login.
                                                (This is optional)" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="PostLoginAnalyzeFarmlistsCheckBox"
                                        Content="Analyze farmlists" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Reads all configured farmlists and updates local data." />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="PostLoginAnalyzeHeroCheckBox"
                                        Content="Analyze hero attributes" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Reads the hero attribute values and updates local data." />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="PostLoginAnalyzeHeroInventoryCheckBox"
                                        Content="Analyze hero inventory" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Reads hero inventory resources and items." />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="PostLoginReadTroopTrainingQueueCheckBox"
                                        Content="Read troop training queue" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Reads current troop training queues from: &#10;Barracks &#10;Stable &#10;Workshop"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="PostLoginAnalyzeBreweryCheckBox"
                                        Content="Analyze brewery" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Reads brewery level and current bonus information/timer." />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="PostLoginAnalyzeNewVillagesCheckBox"
                                          Content="Analyze new village startup" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="After login, detects villages without cached status and reads their resource fields and buildings from dorf1 and dorf2. Enabled by default." />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HeroSettingsCategoryStyle}">
                        <StackPanel>
                            <TextBlock Text="Adventure settings" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Border Style="{StaticResource SettingsGroupBox}" Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <CheckBox Content="Restart delay (min)"
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              IsChecked="{Binding HeroAdventureRestartDelay.IsEnabled, Mode=TwoWay}" />
                                    <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                    ToolTip="Waits a random time before sending the hero after returning home or after an adventure becomes available." />
                                    <StackPanel Orientation="Horizontal"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                IsEnabled="{Binding HeroAdventureRestartDelay.IsEnabled}">
                                        <TextBox Width="56" Text="{Binding HeroAdventureRestartDelay.DelayMinMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="–" Margin="8,0" VerticalAlignment="Center" />
                                        <TextBox Width="56" Text="{Binding HeroAdventureRestartDelay.DelayMaxMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SettingsGroupBox}" Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Width="190" VerticalAlignment="Center">
                                        <TextBlock Text="Hero HP regen per day (%)"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                        ToolTip="Estimates when low Hero HP should be checked again. Live HP reads during jitter refresh always override this estimate and release the adventure immediately when HP is sufficient." />
                                    </StackPanel>
                                    <ComboBox x:Name="HeroHpRegenPerDayComboBox"
                                              Width="80"
                                              ItemsSource="{Binding HeroHpRegenOptions}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource FarmingSettingsCategoryStyle}">
                        <Grid MinHeight="300">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="44" Height="44" CornerRadius="22"
                                        HorizontalAlignment="Center"
                                        Background="{DynamicResource SuccessBgBrush}"
                                        BorderBrush="{DynamicResource SuccessBorderBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="F"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource SuccessTextBrush}" />
                                </Border>
                                <TextBlock Text="Farming settings"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,4"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="No settings in this category yet."
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource TroopsSettingsCategoryStyle}">
                        <StackPanel>
                            <TextBlock Text="Smithy upgrade troops" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Border Style="{StaticResource SettingsGroupBox}" Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <CheckBox Content="Restart delay (min)"
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              IsChecked="{Binding SmithyUpgradeRestartDelay.IsEnabled, Mode=TwoWay}" />
                                    <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                    ToolTip="Waits after a Smithy queue slot becomes free. An empty queue starts immediately and Travian Plus slots are filled together without a delay between them." />
                                    <StackPanel Orientation="Horizontal"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                IsEnabled="{Binding SmithyUpgradeRestartDelay.IsEnabled}">
                                        <TextBox Width="56" Text="{Binding SmithyUpgradeRestartDelay.DelayMinMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="–" Margin="8,0" VerticalAlignment="Center" />
                                        <TextBox Width="56" Text="{Binding SmithyUpgradeRestartDelay.DelayMaxMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CelebrationsSettingsCategoryStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Town hall settings"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Enable Town Hall celebrations per village and choose Small or Great. Great falls back to Small until the Town Hall reaches level 10." />
                            </StackPanel>

                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,9">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="180" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="ON" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" />
                                            <TextBlock Grid.Column="1" Text="VILLAGE" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" />
                                            <TextBlock Grid.Column="2" Text="MODE" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" />
                                        </Grid>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding TownHallRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="12,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="64" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="180" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Style="{DynamicResource ToggleSwitchStyle}"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  IsChecked="{Binding IsTownHallEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding VillageName}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   Margin="0,0,12,0" />
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <RadioButton Content="Small"
                                                                         Margin="0,0,16,0"
                                                                         IsChecked="{Binding IsSmall, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            <RadioButton Content="Great"
                                                                         IsChecked="{Binding IsBig, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No villages loaded."
                                               Margin="12"
                                               Foreground="{DynamicResource TextMutedBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TownHallRows.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsGroupBox}" Margin="0,0,0,18">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Celebration queue" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                        ToolTip="One runs one celebration at a time. Two keeps one running and queues a second with Travian Plus. Without Plus, one runs at a time." />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Run" Width="120" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                        <RadioButton Content="One" Margin="0,0,18,0" IsChecked="{Binding TownHallQueue.IsOne, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <RadioButton Content="Two (one queued)" IsChecked="{Binding TownHallQueue.IsTwo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                                        <CheckBox Content="Restart delay (min)" Foreground="{DynamicResource TextSecondaryBrush}" IsChecked="{Binding TownHallQueue.IsRestartDelayEnabled, Mode=TwoWay}" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                        ToolTip="Random waiting time after a Town Hall celebration finishes before the next celebration is started." />
                                        <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center" IsEnabled="{Binding TownHallQueue.IsRestartDelayEnabled}">
                                            <TextBox Width="56" Text="{Binding TownHallQueue.DelayMinMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="–" Margin="8,0" VerticalAlignment="Center" />
                                            <TextBox Width="56" Text="{Binding TownHallQueue.DelayMaxMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Brewery settings"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Border Style="{StaticResource SettingsGroupBox}" Margin="0,10,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <CheckBox Content="Restart delay (min)" Foreground="{DynamicResource TextSecondaryBrush}" IsChecked="{Binding BreweryRestartDelay.IsEnabled, Mode=TwoWay}" />
                                        <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                        ToolTip="Random waiting time after a Brewery celebration finishes before the next celebration is started." />
                                        <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center" IsEnabled="{Binding BreweryRestartDelay.IsEnabled}">
                                            <TextBox Width="56" Text="{Binding BreweryRestartDelay.DelayMinMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="–" Margin="8,0" VerticalAlignment="Center" />
                                            <TextBox Width="56" Text="{Binding BreweryRestartDelay.DelayMaxMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NpcTradeSettingsCategoryStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Silver spending"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <CheckBox x:Name="AllowSilverSpendingCheckBox" Content="Allow silver spending" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Not used by any automation yet — reserved for future auction/silver features. The bot only reads your silver amount for display today; nothing spends silver regardless of this setting." />
                            </StackPanel>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="48" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Minimum silver balance" VerticalAlignment="Center" />
                                    <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                    ToolTip="Minimum silver balance to keep. Silver spending must not reduce the balance below this value." />
                                </StackPanel>
                                <TextBox x:Name="SilverLimitTextBox" Grid.Column="1" Text="100" />
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Daily spending limit" VerticalAlignment="Center" />
                                    <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                    ToolTip="Maximum silver allowed to be spent each day. Resets at 00:00 server time." />
                                </StackPanel>
                                <TextBox x:Name="DailySilverSpendingLimitTextBox"
                                         Grid.Column="1"
                                         Text="10000"
                                         TextChanged="DailySpendingLimitTextBox_TextChanged" />
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <Border Height="30"
                                        MinWidth="70"
                                        Padding="9,3"
                                        Margin="0,0,6,0"
                                        Background="{DynamicResource SuccessBgBrush}"
                                        BorderBrush="{DynamicResource SuccessBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <TextBlock x:Name="DailySilverSpendingUsageTextBlock"
                                               Text="0 / 10000"
                                               Foreground="{DynamicResource SuccessTextBrush}"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <Button x:Name="ResetDailySilverLimitButton"
                                        Content="Reset daily limits"
                                        Click="ResetDailySilverLimitButton_Click" />
                            </StackPanel>

                            <Border Height="1"
                                    Background="{DynamicResource BorderSubtleBrush}"
                                    Margin="0,18,0,16" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Gold spending"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>
                            <CheckBox x:Name="AllowGoldSpendingCheckBox"
                                      Content="Allow gold spending"
                                      Margin="0,0,0,12"
                                      ToolTip="Allows gold-spending features such as NPC trade. Spending respects the daily gold limit below." />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="48" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Minimum gold balance" VerticalAlignment="Center" />
                                    <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                    ToolTip="Minimum gold balance to keep. Gold spending must not reduce the balance below this value." />
                                </StackPanel>
                                <TextBox x:Name="GoldLimitTextBox" Grid.Column="1" Text="100" />
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Daily spending limit" VerticalAlignment="Center" />
                                    <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                    ToolTip="Maximum gold allowed to be spent each day. Resets at 00:00 server time." />
                                </StackPanel>
                                <TextBox x:Name="DailyGoldSpendingLimitTextBox"
                                         Grid.Column="1"
                                         Text="20"
                                         TextChanged="DailySpendingLimitTextBox_TextChanged" />
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <Border Height="30"
                                        MinWidth="70"
                                        Padding="9,3"
                                        Margin="0,0,6,0"
                                        Background="{DynamicResource SuccessBgBrush}"
                                        BorderBrush="{DynamicResource SuccessBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <TextBlock x:Name="DailyGoldSpendingUsageTextBlock"
                                               Text="0 / 20"
                                               Foreground="{DynamicResource SuccessTextBrush}"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <Button x:Name="ResetDailyGoldLimitButton"
                                        Content="Reset daily limits"
                                        Click="ResetDailyGoldLimitButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="ResetSettingsButton"
                        MinWidth="106"
                        Height="32"
                        Padding="14,0"
                        Content="Reset settings"
                        FontWeight="SemiBold"
                        Background="{DynamicResource WarningBgBrush}"
                        Foreground="{DynamicResource WarningTextBrush}"
                        BorderBrush="{DynamicResource WarningBorderBrush}"
                        Click="ResetSettingsButton_Click" />
                <Button x:Name="SleepNowButton"
                        MinWidth="88"
                        Height="32"
                        Padding="14,0"
                        Margin="8,0,0,0"
                        Content="Sleep now"
                        FontWeight="SemiBold"
                        Background="{DynamicResource InfoBgBrush}"
                        Foreground="{DynamicResource InfoTextBrush}"
                        BorderBrush="{DynamicResource InfoBrush}"
                        ToolTip="Stop automation, log out, and sleep now for the configured sleep time."
                        Click="SleepNowButton_Click" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SaveButton"
                        MinWidth="88"
                        Height="32"
                        Padding="16,0"
                        Margin="0,0,8,0"
                        Content="Save"
                        FontWeight="SemiBold"
                        Background="{DynamicResource SuccessBgBrush}"
                        Foreground="{DynamicResource SuccessTextBrush}"
                        BorderBrush="{DynamicResource SuccessBorderBrush}"
                        Click="SaveButton_Click" />
                <Button x:Name="CancelButtonControl" Width="100" Content="Cancel" Click="CancelButton_Click" />
            </StackPanel>
