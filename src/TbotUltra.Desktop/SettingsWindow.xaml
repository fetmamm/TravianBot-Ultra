<Window x:Class="TbotUltra.Desktop.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="560"
        Width="560"
        MinHeight="520"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        Closing="SettingsWindow_Closing">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Bot Settings" FontSize="20" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,4" />
                    <TextBlock Text="Configure execution, automation, and spending behavior."
                               Foreground="#64748B"
                               Margin="0,0,0,14" />

                    <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="General"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Margin="0,0,0,10" />
                            <CheckBox x:Name="HeadlessCheckBox" Margin="0,0,0,8" Content="Headless" />
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="HumanLikeCheckBox"
                                          Content="Act more human" />
                                <Border Width="18"
                                        Height="18"
                                        Margin="8,0,0,0"
                                        CornerRadius="9"
                                        Background="#DBEAFE"
                                        BorderBrush="#93C5FD"
                                        BorderThickness="1"
                                        ToolTipService.InitialShowDelay="0"
                                        ToolTip="Adds a random 0.1-1.0s delay between each sent manual farm attack.">
                                    <TextBlock Text="i"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#1D4ED8"
                                               FontWeight="SemiBold"
                                               FontSize="11" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Automation"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Margin="0,0,0,10" />

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Queue wait threshold" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,4" />
                                    <TextBlock Text="Controls when long waits are deferred back to the smart queues."
                                               Foreground="#64748B"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <ComboBox x:Name="QueueWaitThresholdComboBox"
                                          Grid.Column="1"
                                          Width="150"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Top">
                                    <ComboBoxItem Content="2s" Tag="2" />
                                    <ComboBoxItem Content="5s" Tag="5" />
                                    <ComboBoxItem Content="10s" Tag="10" />
                                    <ComboBoxItem Content="20s" Tag="20" />
                                    <ComboBoxItem Content="Smart" Tag="smart" />
                                </ComboBox>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Delay between farm sends" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,4" />
                                    <TextBlock Text="Adds spacing between continuous farmlist sends."
                                               Foreground="#64748B"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <ComboBox x:Name="FarmDispatchDelayComboBox"
                                          Grid.Column="1"
                                          Width="150"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Top">
                                    <ComboBoxItem Content="1 min" Tag="1" />
                                    <ComboBoxItem Content="2 min" Tag="2" />
                                    <ComboBoxItem Content="3 min" Tag="3" />
                                    <ComboBoxItem Content="4 min" Tag="4" />
                                    <ComboBoxItem Content="5 min" Tag="5" />
                                </ComboBox>
                            </Grid>

                            <TextBlock Text="After login"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Margin="0,14,0,6" />
                            <TextBlock Text="Optional extra reads to run after login. Existing post-login actions are always kept."
                                       Foreground="#64748B"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <CheckBox x:Name="PostLoginAnalyzeFarmlistsCheckBox"
                                      Margin="0,0,0,8"
                                      Content="Analyze farmlists" />
                            <CheckBox x:Name="PostLoginAnalyzeHeroCheckBox"
                                      Margin="0,0,0,8"
                                      Content="Analyze hero" />
                            <CheckBox x:Name="PostLoginReadTroopTrainingQueueCheckBox"
                                      Margin="0,0,0,8"
                                      Content="Read troop training queue (Barracks, Stable, Workshop)" />
                            <CheckBox x:Name="PostLoginAnalyzeBreweryCheckBox"
                                      Content="Analyze brewery" />
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Spending"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Margin="0,0,0,10" />
                            <CheckBox x:Name="AllowGoldSpendingCheckBox" Margin="0,0,0,8" Content="Allow gold spending" />
                            <CheckBox x:Name="AllowSilverSpendingCheckBox" Margin="0,0,0,12" Content="Allow silver spending" />

                            <TextBlock x:Name="GoldLimitTextBlock" Text="Gold limit: 100" Margin="0,0,0,4" />
                            <Slider x:Name="GoldLimitSlider"
                                    Minimum="0"
                                    Maximum="200"
                                    Value="100"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    Margin="0,0,0,10"
                                    ValueChanged="GoldLimitSlider_ValueChanged" />

                            <TextBlock x:Name="SilverLimitTextBlock" Text="Silver limit: 100" Margin="0,0,0,4" />
                            <Slider x:Name="SilverLimitSlider"
                                    Minimum="0"
                                    Maximum="1000"
                                    Value="100"
                                    TickFrequency="25"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SilverLimitSlider_ValueChanged" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="ResetButton" Width="100" Margin="0,0,8,0" Content="Reset" Click="ResetButton_Click" />
            <Button x:Name="SaveButton" Width="100" Margin="0,0,8,0" Content="Save" Click="SaveButton_Click" />
            <Button x:Name="CancelButtonControl" Width="100" Content="Cancel" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
