<Window x:Class="TbotUltra.Desktop.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TbotUltra.Desktop"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Settings"
        Height="680"
        Width="640"
        MinHeight="520"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        Closing="SettingsWindow_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Badges.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource ToggleTrackBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Bot Settings" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource InkBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="Configure execution, automation, and spending behavior."
                               Foreground="{DynamicResource MutedSlateBrush}"
                               Margin="0,0,0,14" />

                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource SlateBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="General"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,10" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="DontNotifyNewVersionCheckBox"
                                          Content="Dont notify for new version" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Suppresses the popup shown when a newer version is available. Updates can still be checked and installed manually from the version window." />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="QuickReloginCheckBox"
                                          Content="Quick re-login within 10 min" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="When logging in less than 10 minutes after the last full login, skip the post-login analyzes (villages, hero, farm lists, brewery) and only confirm the session. Saved per account." />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="AutomaticallyCheckLanguageCheckBox"
                                          Content="Automatically check language" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Checks that Travian is set to English before automation parses pages. Turn off only if the language guard itself causes problems." />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource SlateBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Bot behavior"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <Button x:Name="ResetPacingButton"
                                        Width="26"
                                        Height="26"
                                        Padding="0"
                                        Margin="8,0,0,0"
                                        FontFamily="Segoe MDL2 Assets"
                                        Content="&#xE72C;"
                                        ToolTip="Reset pacing defaults"
                                        Click="ResetPacingButton_Click" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="SessionPacingEnabledCheckBox"
                                          Content="Session pacing" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Limits how long the bot runs before it logs out, sleeps, and resumes automatically." />
                            </StackPanel>
                            <Grid Margin="18,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Min" FontWeight="SemiBold" Margin="0,2" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Max" FontWeight="SemiBold" Margin="6,2,0,2" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Run (min)" VerticalAlignment="Center" Margin="0,2" />
                                <TextBox x:Name="SessionRunMinMinutesTextBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2" />
                                <TextBox x:Name="SessionRunMaxMinutesTextBox" Grid.Row="1" Grid.Column="2" Height="24" Margin="6,2,0,2" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Sleep (min)" VerticalAlignment="Center" Margin="0,2" />
                                <TextBox x:Name="SessionSleepMinMinutesTextBox" Grid.Row="2" Grid.Column="1" Height="24" Margin="0,2" />
                                <TextBox x:Name="SessionSleepMaxMinutesTextBox" Grid.Row="2" Grid.Column="2" Height="24" Margin="6,2,0,2" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Daily max" VerticalAlignment="Center" Margin="0,2" />
                                <ComboBox x:Name="SessionDailyMaxHoursComboBox" Grid.Row="3" Grid.Column="1" Height="24" Margin="0,2" />
                                <ComboBox x:Name="SessionDailyMaxVariationComboBox" Grid.Row="3" Grid.Column="2" Height="24" Margin="6,2,0,2"
                                          ToolTip="Daily max variation: randomizes the daily limit by this much each day (applies only to Daily max)." />
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="18,0,0,6">
                                <TextBlock Text="Allowed hours" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Checked hours may run. Unchecked hours log out and stay stopped until the next checked hour." />
                            </StackPanel>
                            <local:VerticalFirstUniformGrid x:Name="SessionAllowedHoursGrid"
                                                            Columns="6"
                                                            Margin="18,0,0,12" />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="ActionPacingEnabledCheckBox"
                                          Content="Action pacing" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Adds small randomized pauses around central bot actions such as tasks, page loads, farm sends, and loop passes." />
                            </StackPanel>
                            <Grid Margin="18,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Min s" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Max s" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Task" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox x:Name="ActionTaskMinTextBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                <TextBox x:Name="ActionTaskMaxTextBox" Grid.Row="1" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Page load" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox x:Name="ActionPageLoadMinTextBox" Grid.Row="2" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                <TextBox x:Name="ActionPageLoadMaxTextBox" Grid.Row="2" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Click" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox x:Name="ActionClickMinTextBox" Grid.Row="3" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                <TextBox x:Name="ActionClickMaxTextBox" Grid.Row="3" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Loop" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox x:Name="ActionLoopMinTextBox" Grid.Row="4" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                <TextBox x:Name="ActionLoopMaxTextBox" Grid.Row="4" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Farmlist" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox x:Name="FarmListStepDelayMinTextBox" Grid.Row="5" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                <TextBox x:Name="FarmListStepDelayMaxTextBox" Grid.Row="5" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,8">
                                <TextBlock Text="Collect tasks/daily delay" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Randomized delay between internal clicks/steps in the Auto collect tasks and Auto collect daily quests flows only. Keeps these fast bursts from looking robotic. Set both to 0 to disable." />
                            </StackPanel>
                            <Grid Margin="18,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Min s" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Max s" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Click/step" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox x:Name="CollectStepDelayMinTextBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                <TextBox x:Name="CollectStepDelayMaxTextBox" Grid.Row="1" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,8">
                                <CheckBox x:Name="IdleBreakEnabledCheckBox"
                                          Content="Idle break"
                                          VerticalAlignment="Center" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}">
                                    <ContentControl.ToolTip>
                                        <ToolTip MaxWidth="320">
                                            <TextBlock TextWrapping="Wrap"
                                                       Text="Occasionally pauses the loop as if you stepped away from the computer. Somewhere within the Every range a random pause of the Length range fires between tasks (never mid-action); when it ends the timer restarts. Shown in the log under the Pacing filter." />
                                        </ToolTip>
                                    </ContentControl.ToolTip>
                                </ContentControl>
                            </StackPanel>
                            <Grid Margin="18,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Min" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Max" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Every (min)" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox x:Name="IdleBreakIntervalMinTextBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                <TextBox x:Name="IdleBreakIntervalMaxTextBox" Grid.Row="1" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Length (min)" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox x:Name="IdleBreakDurationMinTextBox" Grid.Row="2" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                <TextBox x:Name="IdleBreakDurationMaxTextBox" Grid.Row="2" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,8">
                                <CheckBox x:Name="IdleBrowseEnabledCheckBox"
                                          Content="Idle browse"
                                          VerticalAlignment="Center" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}">
                                    <ContentControl.ToolTip>
                                        <ToolTip MaxWidth="320">
                                            <TextBlock TextWrapping="Wrap"
                                                       Text="Occasionally opens a non-functional page (map, statistics, reports, messages) and reads nothing, as if you were browsing around. Somewhere within the Every range one page is opened between tasks (never mid-action); then the timer restarts. Pick which pages may be visited below. Shown in the log under the Pacing filter." />
                                        </ToolTip>
                                    </ContentControl.ToolTip>
                                </ContentControl>
                            </StackPanel>
                            <Grid Margin="18,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Min" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Max" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Every (min)" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox x:Name="IdleBrowseIntervalMinTextBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                <TextBox x:Name="IdleBrowseIntervalMaxTextBox" Grid.Row="1" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                            </Grid>
                            <Expander Header="Pages to visit" Margin="18,6,0,0" Foreground="{DynamicResource TextPrimaryBrush}">
                                <StackPanel Margin="4,4,0,0">
                                    <CheckBox x:Name="IdleBrowsePageMapCheckBox" Content="Map" Margin="0,2" />
                                    <CheckBox x:Name="IdleBrowsePageStatisticsCheckBox" Content="Statistics" Margin="0,2" />
                                    <CheckBox x:Name="IdleBrowsePageReportsCheckBox" Content="Reports" Margin="0,2" />
                                    <CheckBox x:Name="IdleBrowsePageMessagesCheckBox" Content="Messages" Margin="0,2" />
                                </StackPanel>
                            </Expander>

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,8">
                                <TextBlock Text="Resource refresh jitter" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Always on. The background dashboard resource refresh fires at a random interval in this range instead of a fixed 20s heartbeat. Fixed values, shown for reference." />
                            </StackPanel>
                            <Grid Margin="18,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Min s" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Max s" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Interval (s)" VerticalAlignment="Center" Margin="0,4" />
                                <!-- Fixed, non-editable. Mirrors the jitter range in MainWindow's resource-refresh timer (15–35s). -->
                                <TextBox Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2,6,2" Text="15" IsReadOnly="True" Focusable="False" Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBox Grid.Row="1" Grid.Column="2" Height="24" Margin="0,2,0,2" Text="35" IsReadOnly="True" Focusable="False" Foreground="{DynamicResource TextMutedBrush}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource SlateBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Automation"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,10" />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="After login"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        VerticalAlignment="Center" />

                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                Margin="6,0,0,0"
                                                ToolTip="Optional extra analyzing-functions to run after login.
                                                (This is optional)" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="PostLoginAnalyzeFarmlistsCheckBox"
                                        Content="Analyze farmlists" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Reads all configured farmlists and updates local data." />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="PostLoginAnalyzeHeroCheckBox"
                                        Content="Analyze hero attributes" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Reads the hero attribute values and updates local data." />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="PostLoginAnalyzeHeroInventoryCheckBox"
                                        Content="Analyze hero inventory" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Reads hero inventory resources and items." />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="PostLoginReadTroopTrainingQueueCheckBox"
                                        Content="Read troop training queue" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Reads current troop training queues from: &#10;Barracks &#10;Stable &#10;Workshop"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="PostLoginAnalyzeBreweryCheckBox"
                                        Content="Analyze brewery" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Reads brewery level and current bonus information/timer." />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="PostLoginAnalyzeNewVillagesCheckBox"
                                          Content="Analyze new village startup" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="After login, detects villages without cached status and reads their resource fields and buildings from dorf1 and dorf2. Enabled by default." />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource SlateBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Spending"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,10" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <CheckBox x:Name="AllowSilverSpendingCheckBox" Content="Allow silver spending" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Not used by any automation yet — reserved for future auction/silver features. The bot only reads your silver amount for display today; nothing spends silver regardless of this setting." />
                            </StackPanel>

                            <TextBlock x:Name="SilverLimitTextBlock" Text="Silver limit: 100" Margin="0,0,0,4" />
                            <Slider x:Name="SilverLimitSlider"
                                    Minimum="0"
                                    Maximum="1000"
                                    Value="100"
                                    TickFrequency="25"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SilverLimitSlider_ValueChanged" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="ResetSettingsButton"
                        Width="140"
                        Height="32"
                        Content="Reset settings"
                        Background="{DynamicResource PrimaryButtonBrush}"
                        Foreground="{DynamicResource OnAccentBrush}"
                        BorderBrush="{DynamicResource PrimaryButtonBrush}"
                        Click="ResetSettingsButton_Click" />
                <Button x:Name="SleepNowButton"
                        Width="110"
                        Height="32"
                        Margin="8,0,0,0"
                        Content="Sleep now"
                        ToolTip="Stop automation, log out, and sleep now for the configured sleep time."
                        Click="SleepNowButton_Click" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SaveButton" Width="100" Margin="0,0,8,0" Content="Save" Click="SaveButton_Click" />
                <Button x:Name="CancelButtonControl" Width="100" Content="Cancel" Click="CancelButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
