<Window x:Class="TbotUltra.Desktop.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="680"
        Width="640"
        MinHeight="520"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        Closing="SettingsWindow_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Badges.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Bot Settings" FontSize="20" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,4" />
                    <TextBlock Text="Configure execution, automation, and spending behavior."
                               Foreground="#64748B"
                               Margin="0,0,0,14" />

                    <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="General"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Margin="0,0,0,10" />
                            <CheckBox x:Name="HeadlessCheckBox" Margin="0,0,0,8" Content="Headless" />
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Bot behavior"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           VerticalAlignment="Center" />
                                <Button x:Name="ResetPacingButton"
                                        Width="26"
                                        Height="26"
                                        Padding="0"
                                        Margin="8,0,0,0"
                                        FontFamily="Segoe MDL2 Assets"
                                        Content="&#xE72C;"
                                        ToolTip="Reset pacing defaults"
                                        Click="ResetPacingButton_Click" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="SessionPacingEnabledCheckBox"
                                          Content="Session pacing" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Limits how long the bot runs before it logs out, sleeps, and resumes automatically." />
                            </StackPanel>
                            <Grid Margin="18,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Max run (min)" VerticalAlignment="Center" Margin="0,2" />
                                <TextBox x:Name="SessionMaxRunMinutesTextBox" Grid.Row="0" Grid.Column="1" Height="24" Margin="0,2" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Sleep (min)" VerticalAlignment="Center" Margin="0,2" />
                                <TextBox x:Name="SessionSleepMinutesTextBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Variation %" VerticalAlignment="Center" Margin="0,2" />
                                <TextBox x:Name="SessionVariationPercentTextBox" Grid.Row="2" Grid.Column="1" Height="24" Margin="0,2" />
                            </Grid>

                            <Button x:Name="SleepNowButton"
                                    Content="Sleep now"
                                    HorizontalAlignment="Left"
                                    Padding="12,4"
                                    Margin="18,0,0,14"
                                    ToolTip="Stop automation, log out, and sleep now for the configured sleep time."
                                    Click="SleepNowButton_Click" />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="ActionPacingEnabledCheckBox"
                                          Content="Action pacing" />
                                <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                                ToolTip="Adds small randomized pauses around central bot actions such as tasks, page loads, farm sends, and loop passes." />
                            </StackPanel>
                            <Grid Margin="18,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Min s" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Max s" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Task" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox x:Name="ActionTaskMinTextBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                <TextBox x:Name="ActionTaskMaxTextBox" Grid.Row="1" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Page load" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox x:Name="ActionPageLoadMinTextBox" Grid.Row="2" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                <TextBox x:Name="ActionPageLoadMaxTextBox" Grid.Row="2" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Click" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox x:Name="ActionClickMinTextBox" Grid.Row="3" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                <TextBox x:Name="ActionClickMaxTextBox" Grid.Row="3" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Loop" VerticalAlignment="Center" Margin="0,4" />
                                <TextBox x:Name="ActionLoopMinTextBox" Grid.Row="4" Grid.Column="1" Height="24" Margin="0,2,6,2" />
                                <TextBox x:Name="ActionLoopMaxTextBox" Grid.Row="4" Grid.Column="2" Height="24" Margin="0,2,0,2" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Automation"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Margin="0,0,0,10" />

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Queue wait threshold" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,4" />
                                    <TextBlock Text="Controls when long waits are deferred back to the smart queues."
                                               Foreground="#64748B"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <ComboBox x:Name="QueueWaitThresholdComboBox"
                                          Grid.Column="1"
                                          Width="150"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Top">
                                    <ComboBoxItem Content="2s" Tag="2" />
                                    <ComboBoxItem Content="5s" Tag="5" />
                                    <ComboBoxItem Content="10s" Tag="10" />
                                    <ComboBoxItem Content="20s" Tag="20" />
                                    <ComboBoxItem Content="Smart" Tag="smart" />
                                </ComboBox>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Delay between farm sends" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,4" />
                                    <TextBlock Text="Adds spacing between continuous farmlist sends."
                                               Foreground="#64748B"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <ComboBox x:Name="FarmDispatchDelayComboBox"
                                          Grid.Column="1"
                                          Width="150"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Top">
                                    <ComboBoxItem Content="1 min" Tag="1" />
                                    <ComboBoxItem Content="2 min" Tag="2" />
                                    <ComboBoxItem Content="3 min" Tag="3" />
                                    <ComboBoxItem Content="4 min" Tag="4" />
                                    <ComboBoxItem Content="5 min" Tag="5" />
                                </ComboBox>
                            </Grid>

                            <TextBlock Text="After login"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Margin="0,14,0,6" />
                            <TextBlock Text="Optional extra reads to run after login. Existing post-login actions are always kept."
                                       Foreground="#64748B"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <CheckBox x:Name="PostLoginAnalyzeFarmlistsCheckBox"
                                      Margin="0,0,0,8"
                                      Content="Analyze farmlists" />
                            <CheckBox x:Name="PostLoginAnalyzeHeroCheckBox"
                                      Margin="0,0,0,8"
                                      Content="Analyze hero" />
                            <CheckBox x:Name="PostLoginReadTroopTrainingQueueCheckBox"
                                      Margin="0,0,0,8"
                                      Content="Read troop training queue (Barracks, Stable, Workshop)" />
                            <CheckBox x:Name="PostLoginAnalyzeBreweryCheckBox"
                                      Margin="0,0,0,8"
                                      Content="Analyze brewery" />
                            <CheckBox x:Name="PostLoginAnalyzeHeroInventoryCheckBox"
                                      Content="Analyze hero inventory" />
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Spending"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Margin="0,0,0,10" />
                            <CheckBox x:Name="AllowSilverSpendingCheckBox" Margin="0,0,0,12" Content="Allow silver spending" />

                            <TextBlock x:Name="SilverLimitTextBlock" Text="Silver limit: 100" Margin="0,0,0,4" />
                            <Slider x:Name="SilverLimitSlider"
                                    Minimum="0"
                                    Maximum="1000"
                                    Value="100"
                                    TickFrequency="25"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SilverLimitSlider_ValueChanged" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Button x:Name="ResetSettingsButton"
                    Width="140"
                    Height="32"
                    HorizontalAlignment="Left"
                    Content="Reset settings"
                    Background="#111827"
                    Foreground="#FFFFFF"
                    BorderBrush="#0F172A"
                    Click="ResetSettingsButton_Click" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SaveButton" Width="100" Margin="0,0,8,0" Content="Save" Click="SaveButton_Click" />
                <Button x:Name="CancelButtonControl" Width="100" Content="Cancel" Click="CancelButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
