<Window x:Class="TbotUltra.Desktop.BuildingTemplatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Building templates"
        Width="1060"
        Height="680"
        MinWidth="920"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Templates"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Templates}"
                         SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                         DisplayMemberPath="Name"
                         Background="{DynamicResource SurfaceAltBrush}"
                         BorderBrush="{DynamicResource BorderBrush}" />
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                    <Button Content="New"
                            Width="76"
                            Height="28"
                            Margin="0,0,6,0"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="White"
                            BorderBrush="{DynamicResource AccentBrush}"
                            Click="NewTemplateButton_Click" />
                    <Button Content="Delete"
                            Width="76"
                            Height="28"
                            Background="{DynamicResource DangerBgBrush}"
                            Foreground="{DynamicResource DangerTextBrush}"
                            BorderBrush="{DynamicResource DangerBorderBrush}"
                            Click="DeleteTemplateButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Name"
                                   Foreground="{DynamicResource TextSubtleBrush}"
                                   FontSize="11" />
                        <TextBox Text="{Binding SelectedTemplate.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="28"
                                 Margin="0,3,0,0"
                                 Background="{DynamicResource SurfaceAltBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                        <TextBlock Text="Created by tribe"
                                   Foreground="{DynamicResource TextSubtleBrush}"
                                   FontSize="11" />
                        <TextBlock Text="{Binding SelectedTemplate.CreatedByTribe}"
                                   FontWeight="SemiBold"
                                   Margin="0,7,0,0" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Add building"
                            Width="106"
                            Height="28"
                            Margin="0,0,6,0"
                            Click="AddBuildingRowButton_Click" />
                    <Button Content="Add resources"
                            Width="96"
                            Height="28"
                            Margin="0,0,6,0"
                            Click="AddAllResourcesRowButton_Click" />
                    <Button Content="Up"
                            Width="54"
                            Height="28"
                            Margin="0,0,6,0"
                            Click="MoveRowUpButton_Click" />
                    <Button Content="Down"
                            Width="62"
                            Height="28"
                            Margin="0,0,6,0"
                            Click="MoveRowDownButton_Click" />
                    <Button Content="Remove"
                            Width="78"
                            Height="28"
                            Background="{DynamicResource DangerBgBrush}"
                            Foreground="{DynamicResource DangerTextBrush}"
                            BorderBrush="{DynamicResource DangerBorderBrush}"
                            Click="RemoveRowButton_Click" />
                </StackPanel>

                <DataGrid Grid.Row="2"
                          x:Name="RowsGrid"
                          ItemsSource="{Binding Rows}"
                          SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="{DynamicResource SurfaceAltBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          RowBackground="{DynamicResource SurfaceAltBrush}"
                          AlternatingRowBackground="{DynamicResource SurfaceBrush}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="#" Width="42">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Index}" Margin="6,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Task" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.RowKinds, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding Kind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Building" Width="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding TargetOptionsView}"
                                              SelectedItem="{Binding Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ScrollViewer.CanContentScroll="False"
                                              VirtualizingPanel.IsVirtualizing="False"
                                              MaxDropDownHeight="360">
                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem"
                                                   BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                                <Setter Property="IsEnabled" Value="{Binding CanInvoke}" />
                                                <Setter Property="ToolTip" Value="{Binding AvailabilityReason}" />
                                                <EventSetter Event="PreviewMouseLeftButtonDown"
                                                             Handler="BuildingOption_PreviewMouseLeftButtonDown" />
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Availability}"
                                                                             Value="MissingRequirements">
                                                                    <Setter Property="Foreground" Value="{DynamicResource WarningTextBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Availability}"
                                                                             Value="Unavailable">
                                                                    <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                        <ComboBox.GroupStyle>
                                            <GroupStyle>
                                                <GroupStyle.HeaderTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextSubtleBrush}"
                                                                   Padding="6,6,6,2" />
                                                    </DataTemplate>
                                                </GroupStyle.HeaderTemplate>
                                            </GroupStyle>
                                        </ComboBox.GroupStyle>
                                    </ComboBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Slot" Width="82">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding SlotOptions}"
                                              SelectedItem="{Binding SlotText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding IsSlotSelectable}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Level" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.LevelOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding TargetLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Status" Width="*" Binding="{Binding Status}" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="3"
                        Margin="0,8,0,0"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Totals:"
                                   FontWeight="SemiBold"
                                   Margin="0,0,10,0" />
                        <TextBlock Grid.Column="1" Text="Cost" Margin="0,0,5,0" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding TotalWoodText}"
                                   Foreground="{DynamicResource WoodTextBrush}" />
                        <TextBlock Grid.Column="3" Text=" | " Foreground="{DynamicResource TextSubtleBrush}" />
                        <TextBlock Grid.Column="4"
                                   Text="{Binding TotalClayText}"
                                   Foreground="{DynamicResource ClayTextBrush}" />
                        <TextBlock Grid.Column="5" Text=" | " Foreground="{DynamicResource TextSubtleBrush}" />
                        <TextBlock Grid.Column="6"
                                   Text="{Binding TotalIronText}"
                                   Foreground="{DynamicResource IronTextBrush}" />
                        <TextBlock Grid.Column="7" Text=" | " Foreground="{DynamicResource TextSubtleBrush}" />
                        <TextBlock Grid.Column="8"
                                   Text="{Binding TotalCropText}"
                                   Foreground="{DynamicResource CropTextBrush}" />
                        <TextBlock Grid.Column="10"
                                   Text="{Binding TotalTimeText}"
                                   Margin="12,0,0,0" />
                        <TextBlock Grid.Column="11"
                                   Text="{Binding TotalConstructFasterTimeText}"
                                   Foreground="{DynamicResource ConstructFasterBrush}"
                                   Margin="12,0,0,0" />
                        <TextBlock Grid.Column="12"
                                   Text="{Binding ValidationSummaryText}"
                                   Foreground="{DynamicResource WarningBrush}"
                                   Margin="12,0,0,0" />
                    </Grid>
                </Border>

                <Grid Grid.Row="4" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource TextSubtleBrush}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Save"
                                Width="86"
                                Height="30"
                                Margin="0,0,8,0"
                                Click="SaveButton_Click" />
                        <Button Content="Queue template"
                                Width="118"
                                Height="30"
                                Margin="0,0,8,0"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White"
                                BorderBrush="{DynamicResource AccentBrush}"
                                Click="QueueTemplateButton_Click" />
                        <Button Content="Close"
                                Width="82"
                                Height="30"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
