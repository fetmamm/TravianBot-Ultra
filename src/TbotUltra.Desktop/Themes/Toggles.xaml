<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="AutomationToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <Border x:Name="Track"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                BorderBrush="{DynamicResource ToggleTrackBorderBrush}"
                                BorderThickness="1" />
                        <Ellipse x:Name="Thumb"
                                 Width="18"
                                 Height="18"
                                 Margin="2"
                                 Fill="{DynamicResource ThumbBrush}"
                                 Stroke="{DynamicResource ThumbStrokeBrush}"
                                 StrokeThickness="1"
                                 HorizontalAlignment="Left">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="4"
                                                  ShadowDepth="1"
                                                  Direction="270"
                                                  Opacity="0.14" />
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="Thumb" Property="Stroke" Value="{DynamicResource ThumbStrokeOnBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
                        </MultiTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource PressedTrackBrush}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsPressed" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentPressedBrush}" />
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentPressedBrush}" />
                        </MultiTrigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Track" Property="Opacity" Value="0.55" />
                            <Setter TargetName="Thumb" Property="Opacity" Value="0.75" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Reusable compact toggle switch rendered from a CheckBox, so existing checkboxes keep their
         Content label, IsChecked binding and Checked/Unchecked handlers — only the Style changes.
         Kept small (20px track) so it does not increase row height. -->
    <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Grid Width="36" Height="20" VerticalAlignment="Center">
                            <Border x:Name="Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10"
                                    BorderBrush="{DynamicResource ToggleTrackBorderBrush}"
                                    BorderThickness="1" />
                            <Ellipse x:Name="Thumb"
                                     Width="14"
                                     Height="14"
                                     Margin="3"
                                     Fill="{DynamicResource ThumbBrush}"
                                     Stroke="{DynamicResource ThumbStrokeBrush}"
                                     StrokeThickness="1"
                                     HorizontalAlignment="Left">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4"
                                                      ShadowDepth="1"
                                                      Direction="270"
                                                      Opacity="0.14" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ContentPresenter x:Name="Label"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="Thumb" Property="Stroke" Value="{DynamicResource ThumbStrokeOnBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
                        </MultiTrigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Track" Property="Opacity" Value="0.55" />
                            <Setter TargetName="Thumb" Property="Opacity" Value="0.75" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

