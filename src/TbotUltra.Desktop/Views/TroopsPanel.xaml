<UserControl x:Class="TbotUltra.Desktop.Views.TroopsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TbotUltra.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TroopTrainingViewModel}"
             d:DesignHeight="600"
             d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Troops"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#111827"
                   Margin="0,0,0,12" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Width="230">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#FFFFFF"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="Upgrade"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,0,0,8" />
                        <Button Content="Upgrade troops"
                                Width="150"
                                HorizontalAlignment="Left"
                                Click="UpgradeTroopsButton_Click" />
                        <TextBlock Text="Smithy upgrades stay separate from troop building."
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Background="#FFFFFF"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Celebration"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       VerticalAlignment="Center" />
                            <Border Width="14"
                                    Height="14"
                                    Margin="6,0,0,0"
                                    CornerRadius="7"
                                    Background="#E5E7EB"
                                    BorderBrush="#D1D5DB"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    ToolTipService.InitialShowDelay="0">
                                <Border.ToolTip>
                                    <ToolTip MaxWidth="340">
                                        <StackPanel Width="300">
                                            <TextBlock Text="Celebration"
                                                       FontWeight="SemiBold"
                                                       Foreground="#F9FAFB"
                                                       Margin="0,0,0,6" />
                                            <TextBlock TextWrapping="Wrap"
                                                       Text="Automatically starts brewery celebrations when available. This is only available for Teutons." />
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Text="i"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#4B5563"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Celebration status:"
                                       Foreground="#374151"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            <Border Grid.Column="2"
                                    Margin="8,0,0,0"
                                    MinWidth="84"
                                    Padding="10,4"
                                    CornerRadius="8"
                                    Background="{Binding AutoCelebrationBadgeBackground}"
                                    BorderBrush="{Binding AutoCelebrationBadgeBorderBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding AutoCelebrationTimerText}"
                                           Foreground="{Binding AutoCelebrationBadgeForeground}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />
                            </Border>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Brewery found:"
                                       Foreground="#374151"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            <Border Grid.Column="2"
                                    Margin="8,0,0,0"
                                    MinWidth="84"
                                    Padding="10,4"
                                    CornerRadius="8"
                                    Background="{Binding BreweryFoundBadgeBackground}"
                                    BorderBrush="{Binding BreweryFoundBadgeBorderBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding BreweryFoundIndicatorText}"
                                           Foreground="{Binding BreweryFoundBadgeForeground}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />
                            </Border>
                        </Grid>
                        <CheckBox Content="Auto celebration (Teutons only)"
                                  VerticalAlignment="Center"
                                  Margin="0,0,0,8"
                                  IsChecked="{Binding AutoCelebrationEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding IsAutoCelebrationCheckboxEnabled}" />
                        <Button x:Name="CheckCelebrationButton"
                                Content="Check celebration"
                                Width="150"
                                HorizontalAlignment="Left"
                                Click="CheckCelebrationButton_Click" />
                    </StackPanel>
                </Border>

            </Grid>

            <Border Grid.Column="2"
                    Background="#FFFFFF"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Build troops"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="16,0,0,0">
                            <Button Content="Build now"
                                    Width="92"
                                    Margin="0,0,8,0"
                                    Click="BuildTroopsNowButton_Click" />
                            <Button x:Name="RefreshTroopQueuesButton"
                                    Content="Refresh queues"
                                    Width="110"
                                    Click="RefreshTroopQueuesButton_Click" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding InfoText}"
                               Foreground="#6B7280"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />

                    <StackPanel Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Resources to check for % resources"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <Border Width="14"
                                    Height="14"
                                    Margin="6,0,0,0"
                                    CornerRadius="7"
                                    Background="#E5E7EB"
                                    BorderBrush="#D1D5DB"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    ToolTipService.InitialShowDelay="0">
                                <Border.ToolTip>
                                    <ToolTip MaxWidth="340">
                                        <StackPanel Width="300">
                                            <TextBlock Text="Resources to check"
                                                       FontWeight="SemiBold"
                                                       Foreground="#F9FAFB"
                                                       Margin="0,0,0,6" />
                                            <TextBlock TextWrapping="Wrap"
                                                       Text="Only selected resources are checked when Run trigger is set to % resources." />
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Text="i"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#4B5563"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="Wood"
                                      Margin="0,0,12,0"
                                      IsChecked="{Binding CheckWood, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="Clay"
                                      Margin="0,0,12,0"
                                      IsChecked="{Binding CheckClay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="Iron"
                                      Margin="0,0,12,0"
                                      IsChecked="{Binding CheckIron, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="Crop"
                                      IsChecked="{Binding CheckCrop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Fallback wait when no exact troop ETA exists"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <Border Width="14"
                                    Height="14"
                                    Margin="6,0,0,0"
                                    CornerRadius="7"
                                    Background="#E5E7EB"
                                    BorderBrush="#D1D5DB"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    ToolTipService.InitialShowDelay="0">
                                <Border.ToolTip>
                                    <ToolTip MaxWidth="340">
                                        <StackPanel Width="300">
                                            <TextBlock Text="Fallback wait"
                                                       FontWeight="SemiBold"
                                                       Foreground="#F9FAFB"
                                                       Margin="0,0,0,6" />
                                            <TextBlock TextWrapping="Wrap"
                                                       Text="Used when the bot cannot read an exact troop queue ETA. It waits this long before checking again." />
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Text="i"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#4B5563"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <ComboBox Width="120"
                                  HorizontalAlignment="Left"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding FallbackCooldownSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <ComboBoxItem Content="10s" Tag="10" />
                            <ComboBoxItem Content="30s" Tag="30" />
                            <ComboBoxItem Content="1 min" Tag="60" />
                            <ComboBoxItem Content="2 min" Tag="120" />
                            <ComboBoxItem Content="5 min" Tag="300" />
                            <ComboBoxItem Content="10 min" Tag="600" />
                        </ComboBox>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Buildings}"
                                  Margin="0,0,0,10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,8,0"
                                        Background="#FFFFFF">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center" />
                                        <Border Margin="0,8,0,0"
                                                HorizontalAlignment="Center"
                                                Width="96"
                                                Padding="8,4"
                                                CornerRadius="8"
                                                Background="{Binding QueueBadgeBackground}"
                                                BorderBrush="{Binding QueueBadgeBorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding QueueTimerText}"
                                                       Foreground="{Binding QueueBadgeForeground}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding Buildings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,10"
                                        Background="#F9FAFB">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"
                                                        Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="#111827" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="Troop"
                                                       Foreground="#6B7280"
                                                       FontSize="11"
                                                       Margin="8,4,0,0"
                                                       VerticalAlignment="Bottom" />
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        Margin="0,4,0,0"
                                                        VerticalAlignment="Bottom">
                                                <TextBlock Text="Max build queue"
                                                           Foreground="#6B7280"
                                                           FontSize="11"
                                                           VerticalAlignment="Center" />
                                                <Border Width="14"
                                                        Height="14"
                                                        Margin="6,0,0,0"
                                                        CornerRadius="7"
                                                        Background="#E5E7EB"
                                                        BorderBrush="#D1D5DB"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Center"
                                                        ToolTipService.InitialShowDelay="0">
                                                    <Border.ToolTip>
                                                        <ToolTip MaxWidth="340">
                                                            <StackPanel Width="300">
                                                                <TextBlock Text="Max build queue"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#F9FAFB"
                                                                           Margin="0,0,0,6" />
                                                                <TextBlock TextWrapping="Wrap"
                                                                           Text="Limits how much training time may already be queued for this troop building before the bot skips adding more troops." />
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                    <TextBlock Text="i"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="#4B5563"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="3"
                                                        Orientation="Horizontal"
                                                        Margin="0,4,0,0"
                                                        VerticalAlignment="Bottom">
                                                <TextBlock Text="Amount mode"
                                                           Foreground="#6B7280"
                                                           FontSize="11"
                                                           VerticalAlignment="Center" />
                                                <Border Width="14"
                                                        Height="14"
                                                        Margin="6,0,0,0"
                                                        CornerRadius="7"
                                                        Background="#E5E7EB"
                                                        BorderBrush="#D1D5DB"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Center"
                                                        ToolTipService.InitialShowDelay="0">
                                                    <Border.ToolTip>
                                                        <ToolTip MaxWidth="340">
                                                            <StackPanel Width="300">
                                                                <TextBlock Text="Amount mode"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#F9FAFB"
                                                                           Margin="0,0,0,6" />
                                                                <TextBlock TextWrapping="Wrap"
                                                                           Text="Maximum spends available resources on as many troops as possible. Keep resources reserves the selected percent before training." />
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                    <TextBlock Text="i"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="#4B5563"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4"
                                                        Orientation="Horizontal"
                                                        Margin="0,4,0,0"
                                                        VerticalAlignment="Bottom">
                                                <TextBlock Text="Keep %"
                                                           Foreground="#6B7280"
                                                           FontSize="11"
                                                           VerticalAlignment="Bottom" />
                                                <Border Width="14"
                                                        Height="14"
                                                        Margin="6,0,0,0"
                                                        CornerRadius="7"
                                                        Background="#E5E7EB"
                                                        BorderBrush="#D1D5DB"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Center"
                                                        ToolTipService.InitialShowDelay="0">
                                                    <Border.ToolTip>
                                                        <ToolTip MaxWidth="320">
                                                            <StackPanel Width="280">
                                                                <TextBlock Text="Keep %"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#F9FAFB"
                                                                           Margin="0,0,0,6" />
                                                                <TextBlock TextWrapping="Wrap"
                                                                           Text="Only used when Amount mode is set to Keep resources." />
                                                                <TextBlock Margin="0,6,0,0"
                                                                           TextWrapping="Wrap"
                                                                           Text="The bot keeps this percent of each resource in storage and only spends the remainder on troop training." />
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                    <TextBlock Text="i"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="#4B5563"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      Content="Build troops"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                            <ComboBox Grid.Column="1"
                                                      Margin="8,0,8,0"
                                                      ItemsSource="{Binding TroopOptions}"
                                                      SelectedItem="{Binding SelectedTroop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="120"
                                                      HorizontalAlignment="Left"
                                                      HorizontalContentAlignment="Left" />

                                            <ComboBox Grid.Column="2"
                                                      Margin="0,0,8,0"
                                                      Width="80"
                                                      HorizontalAlignment="Left"
                                                      HorizontalContentAlignment="Left"
                                                      SelectedValuePath="Tag"
                                                      SelectedValue="{Binding MaxQueueMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                <ComboBoxItem Content="1h" Tag="1" />
                                                <ComboBoxItem Content="2h" Tag="2" />
                                                <ComboBoxItem Content="3h" Tag="3" />
                                                <ComboBoxItem Content="5h" Tag="5" />
                                                <ComboBoxItem Content="10h" Tag="10" />
                                                <ComboBoxItem Content="20h" Tag="20" />
                                                <ComboBoxItem Content="50h" Tag="50" />
                                                <ComboBoxItem Content="100h" Tag="100" />
                                                <ComboBoxItem Content="No limit" Tag="no_limit" />
                                            </ComboBox>

                                            <ComboBox Grid.Column="3"
                                                      Margin="0,0,8,0"
                                                      Width="100"
                                                      HorizontalAlignment="Left"
                                                      HorizontalContentAlignment="Left"
                                                      SelectedValuePath="Tag"
                                                      SelectedValue="{Binding AmountMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                <ComboBoxItem Content="Maximum" Tag="maximum" />
                                                <ComboBoxItem Content="Keep resources" Tag="keep_resources" />
                                            </ComboBox>

                                            <ComboBox Grid.Column="4"
                                                      Width="80"
                                                      HorizontalAlignment="Left"
                                                      HorizontalContentAlignment="Left"
                                                      SelectedValuePath="Tag"
                                                      SelectedValue="{Binding KeepResourcesPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEnabled="{Binding UsesKeepResourcesMode}">
                                                <ComboBoxItem Content="0%" Tag="0" />
                                                <ComboBoxItem Content="5%" Tag="5" />
                                                <ComboBoxItem Content="10%" Tag="10" />
                                                <ComboBoxItem Content="15%" Tag="15" />
                                                <ComboBoxItem Content="20%" Tag="20" />
                                                <ComboBoxItem Content="25%" Tag="25" />
                                                <ComboBoxItem Content="30%" Tag="30" />
                                                <ComboBoxItem Content="40%" Tag="40" />
                                                <ComboBoxItem Content="50%" Tag="50" />
                                                <ComboBoxItem Content="60%" Tag="60" />
                                                <ComboBoxItem Content="70%" Tag="70" />
                                                <ComboBoxItem Content="80%" Tag="80" />
                                                <ComboBoxItem Content="90%" Tag="90" />
                                            </ComboBox>
                                        </Grid>

                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="Run trigger"
                                                           Foreground="#6B7280"
                                                           FontSize="11"
                                                           VerticalAlignment="Center" />
                                                <Border Width="14"
                                                        Height="14"
                                                        Margin="6,0,0,0"
                                                        CornerRadius="7"
                                                        Background="#E5E7EB"
                                                        BorderBrush="#D1D5DB"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Center"
                                                        ToolTipService.InitialShowDelay="0">
                                                    <Border.ToolTip>
                                                        <ToolTip MaxWidth="340">
                                                            <StackPanel Width="300">
                                                                <TextBlock Text="Run trigger"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#F9FAFB"
                                                                           Margin="0,0,0,6" />
                                                                <TextBlock TextWrapping="Wrap"
                                                                           Text="Min troops starts training when the current troop count drops below the value to the right." />
                                                                <TextBlock Margin="0,6,0,0"
                                                                           TextWrapping="Wrap"
                                                                           Text="% resources starts training when available resources reach the selected percent threshold." />
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                    <TextBlock Text="i"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="#4B5563"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center" />
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <RadioButton Content="Min troops"
                                                             Margin="0,0,12,0"
                                                             IsChecked="{Binding IsMinimumTroopsMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <RadioButton Content="% resources"
                                                             IsChecked="{Binding IsResourcePercentMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>

                                            <Grid Grid.Column="2">
                                                <TextBox Width="88"
                                                         Height="28"
                                                         HorizontalAlignment="Left"
                                                         VerticalAlignment="Center"
                                                         Text="{Binding MinimumTroopsText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding UsesMinimumTroopsMode}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>

                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding UsesResourcePercentMode}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                        </StackPanel.Style>
                                                    <Slider Width="170"
                                                            Minimum="0"
                                                            Maximum="100"
                                                            TickFrequency="1"
                                                            IsSnapToTickEnabled="True"
                                                            Value="{Binding MinimumResourcesPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Text="{Binding MinimumResourcesPercent, StringFormat={}{0}%}"
                                                               Margin="10,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="#374151"
                                                               FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
