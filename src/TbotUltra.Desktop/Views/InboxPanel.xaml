<UserControl x:Class="TbotUltra.Desktop.Views.InboxPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TbotUltra.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:InboxViewModel}"
             d:DesignHeight="320"
             d:DesignWidth="640">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Messages / Reports"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#111827"
                   Margin="0,0,0,8" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FFFFFF"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Messages"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Margin="0,0,0,6" />
                    <TextBlock Text="{Binding MessageUnreadText}"
                               Foreground="#374151"
                               Margin="0,0,0,10" />
                    <Button x:Name="MarkMessagesReadButton"
                            Width="120"
                            Margin="0"
                            Content="Mark as read"
                            Click="MarkMessagesReadButton_Click" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="#FFFFFF"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Reports"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Margin="0,0,0,6" />
                    <TextBlock Text="{Binding ReportsUnreadText}"
                               Foreground="#374151"
                               Margin="0,0,0,10" />
                    <Button x:Name="MarkReportsReadButton"
                            Width="120"
                            Margin="0"
                            Content="Mark as read"
                            Click="MarkReportsReadButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
