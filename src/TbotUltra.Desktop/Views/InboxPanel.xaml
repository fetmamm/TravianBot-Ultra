<UserControl x:Class="TbotUltra.Desktop.Views.InboxPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TbotUltra.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:InboxViewModel}"
             d:DesignHeight="320"
             d:DesignWidth="640">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Messages / Reports"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,8" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Messages"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,6" />
                    <TextBlock Text="{Binding MessageUnreadText}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,10" />
                    <CheckBox Content="Auto read messages"
                              IsChecked="{Binding AutoReadMessages, Mode=TwoWay}"
                              Click="AutoReadCheckBox_Click"
                              ToolTipService.InitialShowDelay="500"
                              Margin="0,0,0,10">
                        <CheckBox.ToolTip>
                            <ToolTip>
                                <TextBlock Text="Automatically opens Messages when unread messages are found, selects all visible messages, marks them as read, then follows Forward and repeats until no unread messages remain." />
                            </ToolTip>
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <Button x:Name="MarkMessagesReadButton"
                            Width="120"
                            HorizontalAlignment="Left"
                            Margin="0"
                            Content="Mark as read"
                            IsEnabled="{Binding ActionsEnabled}"
                            Click="MarkMessagesReadButton_Click"
                            ToolTipService.InitialShowDelay="500">
                        <Button.ToolTip>
                            <ToolTip>
                                <TextBlock Text="Opens Messages, selects all visible messages, marks them as read, then follows Forward and repeats until no unread messages remain." />
                            </ToolTip>
                        </Button.ToolTip>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Reports"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,6" />
                    <TextBlock Text="{Binding ReportsUnreadText}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,10" />
                    <CheckBox Content="Auto read reports"
                              IsChecked="{Binding AutoReadReports, Mode=TwoWay}"
                              Click="AutoReadCheckBox_Click"
                              ToolTipService.InitialShowDelay="500"
                              Margin="0,0,0,10">
                        <CheckBox.ToolTip>
                            <ToolTip>
                                <TextBlock Text="Automatically opens Reports when unread reports are found, selects all visible reports, and marks them as read." />
                            </ToolTip>
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <Button x:Name="MarkReportsReadButton"
                            Width="120"
                            HorizontalAlignment="Left"
                            Margin="0"
                            Content="Mark as read"
                            IsEnabled="{Binding ActionsEnabled}"
                            Click="MarkReportsReadButton_Click"
                            ToolTipService.InitialShowDelay="500">
                        <Button.ToolTip>
                            <ToolTip>
                                <TextBlock Text="Opens Reports, selects all visible reports, and marks them as read." />
                            </ToolTip>
                        </Button.ToolTip>
                    </Button>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <Button x:Name="SaveReportPngButton"
                                Width="140"
                                Content="Save report as PNG"
                                Click="SaveReportPngButton_Click" />
                        <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        ToolTipService.InitialShowDelay="500">
                            <ContentControl.ToolTip>
                                <ToolTip>
                                    <TextBlock Text="Saves the currently open combat report as a PNG image into the Reports folder. The bot must be paused and the report page must be open in the browser."
                                               TextWrapping="Wrap"
                                               MaxWidth="320" />
                                </ToolTip>
                            </ContentControl.ToolTip>
                        </ContentControl>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
