<UserControl x:Class="TbotUltra.Desktop.Views.NpcTradePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Grid Background="{DynamicResource AppBackgroundBrush}">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="16" />
        <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <StackPanel Grid.Column="0">
        <Border VerticalAlignment="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <StackPanel>
                <TextBlock Text="NPC Trade"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,12" />
                <TextBlock Text="Each NPC trade costs 3 gold. Allow gold spending must be enabled for NPC trade to run."
                           Foreground="{DynamicResource TextSubtleBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />
                <TextBlock x:Name="NpcTradeGoldSpentTextBlock"
                           Text="Gold spent: 0"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBlock x:Name="NpcTradeTroopsTextBlock"
                           Text="NPC Troops: 0"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBlock x:Name="NpcTradeBuildingsTextBlock"
                           Text="NPC Buildings: 0"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />
                <TextBlock Text="Troops"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,6" />
                <StackPanel Orientation="Horizontal">
                    <CheckBox Content="Enable NPC trade while building troops"
                              VerticalAlignment="Center"
                              IsChecked="{Binding NpcTradeEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Border Width="14"
                            Height="14"
                            Margin="6,0,0,0"
                            CornerRadius="7"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip MaxWidth="340">
                                <StackPanel Width="300">
                                    <TextBlock Text="NPC trade for troops"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TooltipForegroundBrush}"
                                               Margin="0,0,0,6" />
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Allows NPC trade while training troops when a selected resource reaches the configured threshold. Each completed NPC trade costs 3 gold and still respects the gold limit." />
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="i"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>
                </StackPanel>
                <TextBlock Text="Trade when a selected resource is at/above"
                           Foreground="{DynamicResource TextSubtleBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,8,0,4" />
                <ComboBox Width="100"
                          HorizontalAlignment="Left"
                          SelectedValuePath="Tag"
                          IsEnabled="{Binding NpcTradeEnabled}"
                          SelectedValue="{Binding NpcTradeThresholdPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBoxItem Content="50%" Tag="50" />
                    <ComboBoxItem Content="60%" Tag="60" />
                    <ComboBoxItem Content="70%" Tag="70" />
                    <ComboBoxItem Content="80%" Tag="80" />
                    <ComboBoxItem Content="90%" Tag="90" />
                    <ComboBoxItem Content="95%" Tag="95" />
                    <ComboBoxItem Content="100%" Tag="100" />
                </ComboBox>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                    <TextBlock Text="Analyze resources"
                               Foreground="{DynamicResource TextSubtleBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <Border Width="14"
                            Height="14"
                            Margin="6,0,0,0"
                            CornerRadius="7"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip MaxWidth="340">
                                <StackPanel Width="300">
                                    <TextBlock Text="Analyze resources"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TooltipForegroundBrush}"
                                               Margin="0,0,0,6" />
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Only selected resources can trigger NPC trade. The bot checks their storage percentage against the configured threshold." />
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="i"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>
                </StackPanel>
                <WrapPanel>
                    <CheckBox Content="Wood"
                              Width="90"
                              IsChecked="{Binding NpcTradeAnalyzeWood, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEnabled="{Binding NpcTradeEnabled}" />
                    <CheckBox Content="Clay"
                              Width="90"
                              IsChecked="{Binding NpcTradeAnalyzeClay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEnabled="{Binding NpcTradeEnabled}" />
                    <CheckBox Content="Iron"
                              Width="90"
                              Margin="0,6,0,0"
                              IsChecked="{Binding NpcTradeAnalyzeIron, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEnabled="{Binding NpcTradeEnabled}" />
                    <CheckBox Content="Crop"
                              Width="90"
                              Margin="0,6,0,0"
                              IsChecked="{Binding NpcTradeAnalyzeCrop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEnabled="{Binding NpcTradeEnabled}" />
                </WrapPanel>

                <Border Height="1"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        Margin="0,14,0,14" />

                <TextBlock Text="Buildings and resource fields"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,6" />
                <StackPanel Orientation="Horizontal">
                    <CheckBox Content="Enable NPC trade while upgrading buildings and resource fields"
                              VerticalAlignment="Center"
                              IsChecked="{Binding NpcTradeConstructionEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Border Width="14"
                            Height="14"
                            Margin="6,0,0,0"
                            CornerRadius="7"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip MaxWidth="340">
                                <StackPanel Width="300">
                                    <TextBlock Text="NPC trade for upgrades"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TooltipForegroundBrush}"
                                               Margin="0,0,0,6" />
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Allows NPC trade only when a building or resource field upgrade page says there are not enough resources. Each completed NPC trade costs 3 gold and still respects the gold limit." />
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="i"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <CheckBox Content="NPC build time limit"
                              VerticalAlignment="Center"
                              IsChecked="{Binding NpcTradeBuildTimeLimitEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEnabled="{Binding NpcTradeConstructionEnabled}" />
                    <ComboBox Width="90"
                              Margin="10,0,0,0"
                              SelectedValuePath="Tag"
                              IsEnabled="{Binding NpcTradeBuildTimeLimitEnabled}"
                              SelectedValue="{Binding NpcTradeBuildTimeLimitSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBoxItem Content="30s" Tag="30" />
                        <ComboBoxItem Content="1min" Tag="60" />
                        <ComboBoxItem Content="5min" Tag="300" />
                        <ComboBoxItem Content="20min" Tag="1200" />
                        <ComboBoxItem Content="1h" Tag="3600" />
                    </ComboBox>
                    <Border Width="14"
                            Height="14"
                            Margin="6,0,0,0"
                            CornerRadius="7"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip MaxWidth="340">
                                <StackPanel Width="300">
                                    <TextBlock Text="NPC build time limit"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TooltipForegroundBrush}"
                                               Margin="0,0,0,6" />
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Skips NPC trade when missing resources will be available within the selected time limit." />
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="i"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Margin="0,16,0,0"
                VerticalAlignment="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Gold"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,12" />
                <TextBlock Text="{Binding GoldLimitText}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,4" />
                <Slider Minimum="0"
                        Maximum="1000"
                        TickFrequency="10"
                        IsSnapToTickEnabled="True"
                        Width="140"
                        HorizontalAlignment="Left"
                        Value="{Binding GoldLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Border>

    </StackPanel>

    <StackPanel Grid.Column="2">
        <Border VerticalAlignment="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Resource Trading"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Target village"
                               Foreground="{DynamicResource TextSubtleBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <Border Width="14"
                            Height="14"
                            Margin="6,0,0,0"
                            CornerRadius="7"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip MaxWidth="340">
                                <StackPanel Width="300">
                                    <TextBlock Text="Target village"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TooltipForegroundBrush}"
                                               Margin="0,0,0,6" />
                                    <TextBlock TextWrapping="Wrap"
                                               Text="This village receives resources from the selected source villages. It is greyed out in the source list because a village cannot send resources to itself." />
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="i"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>
                </StackPanel>
                <ComboBox x:Name="ResourceTransferTargetVillageComboBox"
                          DisplayMemberPath="DisplayName"
                          Height="28"
                          Margin="0,0,0,10"
                          SelectionChanged="ResourceTransferSetting_SelectionChanged" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Source villages"
                               Foreground="{DynamicResource TextSubtleBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <Border Width="14"
                            Height="14"
                            Margin="6,0,0,0"
                            CornerRadius="7"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip MaxWidth="340">
                                <StackPanel Width="300">
                                    <TextBlock Text="Source villages"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TooltipForegroundBrush}"
                                               Margin="0,0,0,6" />
                                    <TextBlock TextWrapping="Wrap"
                                               Text="These villages can send resources to the selected target." />
                                    <TextBlock Margin="0,5,0,0"
                                               TextWrapping="Wrap"
                                               Text="The selected target is greyed out here because a village cannot send resources to itself." />
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="i"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>
                </StackPanel>
                <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        MaxHeight="150"
                        Margin="0,0,0,10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ResourceTransferSourceVillagesItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsEnabled="{Binding CanSelectAsSource}"
                                                  IsChecked="{Binding IsSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </CheckBox>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center">
                                            <TextBlock Foreground="{Binding WoodPercentBrush}" FontSize="11" FontWeight="Bold" Text="{Binding WoodPercentText}" />
                                            <TextBlock Foreground="{DynamicResource BorderMutedBrush}" FontSize="11" Margin="5,0" Text="|" />
                                            <TextBlock Foreground="{Binding ClayPercentBrush}" FontSize="11" FontWeight="Bold" Text="{Binding ClayPercentText}" />
                                            <TextBlock Foreground="{DynamicResource BorderMutedBrush}" FontSize="11" Margin="5,0" Text="|" />
                                            <TextBlock Foreground="{Binding IronPercentBrush}" FontSize="11" FontWeight="Bold" Text="{Binding IronPercentText}" />
                                            <TextBlock Foreground="{DynamicResource BorderMutedBrush}" FontSize="11" Margin="5,0" Text="|" />
                                            <TextBlock Foreground="{Binding CropPercentBrush}" FontSize="11" FontWeight="Bold" Text="{Binding CropPercentText}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding SourceStatusText}"
                                                   Foreground="{DynamicResource BorderMutedBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Send from"
                                       Foreground="{DynamicResource TextSubtleBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            <Border Width="14"
                                    Height="14"
                                    Margin="6,0,0,0"
                                    CornerRadius="7"
                                    Background="{DynamicResource ControlBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    ToolTipService.InitialShowDelay="0">
                                <Border.ToolTip>
                                    <ToolTip MaxWidth="320">
                                        <StackPanel Width="280">
                                            <TextBlock Text="Send from"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TooltipForegroundBrush}"
                                                       Margin="0,0,0,6" />
                                            <TextBlock TextWrapping="Wrap"
                                                       Text="Source storage percent required before this resource can be sent." />
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Text="i"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <ComboBox x:Name="ResourceTransferSourceThresholdComboBox"
                                  SelectedValuePath="Tag"
                                  SelectionChanged="ResourceTransferSetting_SelectionChanged">
                            <ComboBoxItem Content="0%" Tag="0" />
                            <ComboBoxItem Content="5%" Tag="5" />
                            <ComboBoxItem Content="10%" Tag="10" />
                            <ComboBoxItem Content="20%" Tag="20" />
                            <ComboBoxItem Content="30%" Tag="30" />
                            <ComboBoxItem Content="40%" Tag="40" />
                            <ComboBoxItem Content="50%" Tag="50" />
                            <ComboBoxItem Content="60%" Tag="60" />
                            <ComboBoxItem Content="70%" Tag="70" />
                            <ComboBoxItem Content="80%" Tag="80" />
                            <ComboBoxItem Content="90%" Tag="90" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Keep"
                                       Foreground="{DynamicResource TextSubtleBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            <Border Width="14"
                                    Height="14"
                                    Margin="6,0,0,0"
                                    CornerRadius="7"
                                    Background="{DynamicResource ControlBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    ToolTipService.InitialShowDelay="0">
                                <Border.ToolTip>
                                    <ToolTip MaxWidth="320">
                                        <StackPanel Width="280">
                                            <TextBlock Text="Keep"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TooltipForegroundBrush}"
                                                       Margin="0,0,0,6" />
                                            <TextBlock TextWrapping="Wrap"
                                                       Text="Source storage percent left behind after sending." />
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Text="i"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <ComboBox x:Name="ResourceTransferSourceKeepComboBox"
                                  SelectedValuePath="Tag"
                                  SelectionChanged="ResourceTransferSetting_SelectionChanged">
                            <ComboBoxItem Content="0%" Tag="0" />
                            <ComboBoxItem Content="5%" Tag="5" />
                            <ComboBoxItem Content="10%" Tag="10" />
                            <ComboBoxItem Content="20%" Tag="20" />
                            <ComboBoxItem Content="30%" Tag="30" />
                            <ComboBoxItem Content="40%" Tag="40" />
                            <ComboBoxItem Content="50%" Tag="50" />
                            <ComboBoxItem Content="60%" Tag="60" />
                            <ComboBoxItem Content="70%" Tag="70" />
                            <ComboBoxItem Content="80%" Tag="80" />
                            <ComboBoxItem Content="90%" Tag="90" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Fill target"
                                       Foreground="{DynamicResource TextSubtleBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            <Border Width="14"
                                    Height="14"
                                    Margin="6,0,0,0"
                                    CornerRadius="7"
                                    Background="{DynamicResource ControlBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    ToolTipService.InitialShowDelay="0">
                                <Border.ToolTip>
                                    <ToolTip MaxWidth="320">
                                        <StackPanel Width="280">
                                            <TextBlock Text="Fill target"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TooltipForegroundBrush}"
                                                       Margin="0,0,0,6" />
                                            <TextBlock TextWrapping="Wrap"
                                                       Text="Maximum target storage percent to fill to." />
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Text="i"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <ComboBox x:Name="ResourceTransferTargetFillComboBox"
                                  SelectedValuePath="Tag"
                                  SelectionChanged="ResourceTransferSetting_SelectionChanged">
                            <ComboBoxItem Content="0%" Tag="0" />
                            <ComboBoxItem Content="10%" Tag="10" />
                            <ComboBoxItem Content="20%" Tag="20" />
                            <ComboBoxItem Content="30%" Tag="30" />
                            <ComboBoxItem Content="40%" Tag="40" />
                            <ComboBoxItem Content="50%" Tag="50" />
                            <ComboBoxItem Content="60%" Tag="60" />
                            <ComboBoxItem Content="70%" Tag="70" />
                            <ComboBoxItem Content="80%" Tag="80" />
                            <ComboBoxItem Content="90%" Tag="90" />
                            <ComboBoxItem Content="100%" Tag="100" />
                        </ComboBox>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Resources"
                               Foreground="{DynamicResource TextSubtleBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <Border Width="14"
                            Height="14"
                            Margin="6,0,0,0"
                            CornerRadius="7"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip MaxWidth="340">
                                <StackPanel Width="300">
                                    <TextBlock Text="Resources"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TooltipForegroundBrush}"
                                               Margin="0,0,0,6" />
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Only selected resource types can be sent. A resource is still skipped if the source has no surplus or the target is already full enough." />
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="i"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>
                </StackPanel>
                <WrapPanel Margin="0,0,0,12">
                    <CheckBox x:Name="ResourceTransferWoodCheckBox" Content="Wood" Width="90" Checked="ResourceTransferSetting_Changed" Unchecked="ResourceTransferSetting_Changed" />
                    <CheckBox x:Name="ResourceTransferClayCheckBox" Content="Clay" Width="90" Checked="ResourceTransferSetting_Changed" Unchecked="ResourceTransferSetting_Changed" />
                    <CheckBox x:Name="ResourceTransferIronCheckBox" Content="Iron" Width="90" Checked="ResourceTransferSetting_Changed" Unchecked="ResourceTransferSetting_Changed" />
                    <CheckBox x:Name="ResourceTransferCropCheckBox" Content="Crop" Width="90" Checked="ResourceTransferSetting_Changed" Unchecked="ResourceTransferSetting_Changed" />
                </WrapPanel>
                <TextBlock x:Name="ResourceTransferStatusTextBlock"
                           Text="Requires at least 2 villages."
                           Foreground="{DynamicResource WarningTextBrush}"
                           FontSize="12"
                           Margin="0,0,0,8"
                           TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="ResourceTransferQueueNowButton"
                            Content="Queue now"
                            Padding="10,4"
                            Click="QueueResourceTransferNowButton_Click" />
                    <Button x:Name="ResourceTransferScanVillagesButton"
                            Content="Scan villages"
                            Padding="10,4"
                            Margin="8,0,0,0"
                            Click="ResourceTransferScanVillagesButton_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Margin="0,16,0,0"
                VerticalAlignment="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Town Hall settings"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <ContentControl Style="{StaticResource SettingInfoIconStyle}"
                                    Margin="8,2,0,0"
                                    VerticalAlignment="Center"
                                    ToolTip="Configure Town Hall celebrations per village in the overview." />
                </StackPanel>
                <Button x:Name="TownHallSettingsButton"
                        Content="Town Hall overview"
                        MinWidth="170"
                        HorizontalAlignment="Left"
                        Click="TownHallSettingsButton_Click" />
            </StackPanel>
        </Border>
    </StackPanel>
</Grid>
</UserControl>
