<UserControl x:Class="TbotUltra.Desktop.Views.BuildingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="760">
    <UserControl.Resources>
        <CollectionViewSource x:Key="BuildingTopSlotsView"
                              Source="{Binding BuildingsVm.BuildingSlots, RelativeSource={RelativeSource AncestorType=Window}}"
                              Filter="BuildingTopSlotsView_Filter" />
        <CollectionViewSource x:Key="BuildingRemainingSlotsView"
                              Source="{Binding BuildingsVm.BuildingSlots, RelativeSource={RelativeSource AncestorType=Window}}"
                              Filter="BuildingRemainingSlotsView_Filter" />

        <DataTemplate x:Key="BuildingSlotButtonTemplate">
            <Button Margin="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Padding="8,7"
                    Width="110"
                    MinHeight="72"
                    Tag="{Binding}"
                    Click="BuildingSlotCircleButton_Click"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SlotCardBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding HasPendingUpgrade}" Value="True">
                                <Setter TargetName="SlotCardBorder" Property="BorderBrush" Value="{DynamicResource CapitalBrush}" />
                                <Setter TargetName="SlotCardBorder" Property="Background" Value="{DynamicResource SlotSelectedBgBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasPendingConstruct}" Value="True">
                                <Setter TargetName="SlotCardBorder" Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                <Setter TargetName="SlotCardBorder" Property="Background" Value="{DynamicResource HeroAdvBgBrush}" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SlotCardBorder" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                <Setter TargetName="SlotCardBorder" Property="BorderBrush" Value="{DynamicResource TerminalFgBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SlotCardBorder" Property="Background" Value="{DynamicResource InfoBgBrush}" />
                                <Setter TargetName="SlotCardBorder" Property="BorderBrush" Value="{DynamicResource SlotSelectedBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel>
                    <TextBlock Text="{Binding SlotLabel}"
                               FontSize="11"
                               Foreground="{DynamicResource BorderMutedBrush}"
                               HorizontalAlignment="Left" />
                    <TextBlock Text="{Binding NameLabel}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="32"
                               Margin="0,3,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOccupied}" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource InfoBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding LevelStatusLabel}"
                               FontSize="11"
                               Margin="0,3,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMaxLevel}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource CapitalBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDemolishing}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource UnreadBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="260" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,4">
                <TextBlock Text="Buildings" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="Manage your village buildings. Click a slot to view and manage building details."
                           Foreground="{DynamicResource TextSubtleBrush}" Margin="0,2,0,8" />
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Load buildings"
                        Width="118"
                        Height="28"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        BorderBrush="{DynamicResource AccentBrush}"
                        Click="LoadBuildingsButton_Click"
                        ToolTip="Read the current buildings from the village and refresh the buildings list with their slots and levels." />
                <Button Content="Upgrade all to max"
                        Width="136"
                        Height="28"
                        Margin="6,0,0,0"
                        Background="{DynamicResource WarningButtonBgBrush}"
                        Foreground="{DynamicResource OnWarningBrush}"
                        BorderBrush="{DynamicResource WarningBorderBrush}"
                        ToolTip="Queues upgrades for all buildings until each one reaches its maximum level."
                        Click="UpgradeAllBuildingsToMaxButton_Click" />
            </StackPanel>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Source={StaticResource BuildingTopSlotsView}}"
                                  ItemTemplate="{StaticResource BuildingSlotButtonTemplate}"
                                  Width="448"
                                  HorizontalAlignment="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <Border Height="10" Background="Transparent" />

                    <ItemsControl ItemsSource="{Binding Source={StaticResource BuildingRemainingSlotsView}}"
                                  ItemTemplate="{StaticResource BuildingSlotButtonTemplate}"
                                  Width="448"
                                  HorizontalAlignment="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Right column: construction settings, split into two cards (placements + timing). -->
        <StackPanel Grid.Column="1" VerticalAlignment="Top">
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9"
                    Padding="14,12">
                <StackPanel>
                    <TextBlock Text="Construction settings"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Recommended placements for these buildings (optional):"
                               Foreground="{DynamicResource TextSubtleBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,4,0,8" />
                    <ItemsControl>
                        <ItemsControl.Items>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Slot 22" Width="52" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="Barracks" FontSize="12" Foreground="{DynamicResource TextSubtleBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Slot 29" Width="52" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="Stable" FontSize="12" Foreground="{DynamicResource TextSubtleBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Slot 31" Width="52" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="Marketplace" FontSize="12" Foreground="{DynamicResource TextSubtleBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Slot 21" Width="52" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="Workshop" FontSize="12" Foreground="{DynamicResource TextSubtleBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Slot 11" Width="52" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="Hospital" FontSize="12" Foreground="{DynamicResource TextSubtleBrush}" />
                            </StackPanel>
                        </ItemsControl.Items>
                    </ItemsControl>
                    <Button Content="Building templates"
                            Height="30"
                            Margin="0,8,0,0"
                            Background="{DynamicResource PrimaryButtonBrush}"
                            Foreground="{DynamicResource OnAccentBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            FontWeight="SemiBold"
                            ToolTip="Create, save, and queue reusable building templates for the selected village."
                            Click="BuildingTemplatesButton_Click" />
                </StackPanel>
            </Border>

            <!-- Human-like pause before starting the next construction + pre-sleep fill. -->
            <Border Margin="0,10,0,0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9"
                    Padding="14,12">
                <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <CheckBox x:Name="ConstructionHumanizeCheckBox"
                              Style="{DynamicResource ToggleSwitchBlueStyle}"
                              VerticalAlignment="Center"
                              IsChecked="True"
                              Checked="ConstructionHumanizeSetting_Changed"
                              Unchecked="ConstructionHumanizeSetting_Changed" />
                    <TextBlock Text="Construction start delay"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                    <ContentControl Style="{StaticResource SettingInfoIconStyle}">
                        <ContentControl.ToolTip>
                            <ToolTip MaxWidth="320">
                                <TextBlock TextWrapping="Wrap"
                                           Text="Wait a bit before starting the next construction instead of reacting the instant a slot frees. Shortly before a session-pacing sleep, delayed starts are pulled forward automatically so every build slot that can be filled is occupied when the sleep begins. Off = builds start immediately, as before." />
                            </ToolTip>
                        </ContentControl.ToolTip>
                    </ContentControl>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="58" />
                        <ColumnDefinition Width="58" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Min" FontWeight="SemiBold" FontSize="11"
                               Foreground="{DynamicResource TextSubtleBrush}" HorizontalAlignment="Center" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Max" FontWeight="SemiBold" FontSize="11"
                               Foreground="{DynamicResource TextSubtleBrush}" HorizontalAlignment="Center" Margin="6,0,0,0" />

                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2">
                        <TextBlock Text="Queue delay (%)" VerticalAlignment="Center"
                                   FontSize="11" Foreground="{DynamicResource TextSubtleBrush}" />
                        <ContentControl Style="{StaticResource SettingInfoIconStyle}">
                            <ContentControl.ToolTip>
                                <ToolTip MaxWidth="320">
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Applies when a build is already running and the next one is placed in the Travian queue (needs Plus). Waits a random percentage of the running build's remaining time — kept under 100% so the queued build is placed before the current one finishes, losing no progress. Capped by Max delay." />
                                </ToolTip>
                            </ContentControl.ToolTip>
                        </ContentControl>
                    </StackPanel>
                    <TextBox x:Name="ConstructionHumanizeQueuePercentMinTextBox" Grid.Row="1" Grid.Column="1" Height="24"
                             Margin="0,2" LostFocus="ConstructionHumanizeSetting_Changed" />
                    <TextBox x:Name="ConstructionHumanizeQueuePercentMaxTextBox" Grid.Row="1" Grid.Column="2" Height="24"
                             Margin="6,2,0,2" LostFocus="ConstructionHumanizeSetting_Changed" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Max delay (min)" VerticalAlignment="Center"
                               FontSize="11" Foreground="{DynamicResource TextSubtleBrush}" Margin="0,2"
                               ToolTip="Absolute cap on the queue-delay percentage." />
                    <TextBox x:Name="ConstructionHumanizeMaxDelayTextBox" Grid.Row="2" Grid.Column="1" Height="24"
                             Margin="0,2" LostFocus="ConstructionHumanizeSetting_Changed" />

                    <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2">
                        <TextBlock Text="No-Plus delay (min)" VerticalAlignment="Center"
                                   FontSize="11" Foreground="{DynamicResource TextSubtleBrush}" />
                        <ContentControl Style="{StaticResource SettingInfoIconStyle}">
                            <ContentControl.ToolTip>
                                <ToolTip MaxWidth="320">
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Used when there is only one build slot (no Plus): the next build can only start once the current one finishes, so there is no running timer to take a percentage of. Waits a random number of minutes in this range after a build finishes before starting the next." />
                                </ToolTip>
                            </ContentControl.ToolTip>
                        </ContentControl>
                    </StackPanel>
                    <TextBox x:Name="ConstructionHumanizeNoPlusMinTextBox" Grid.Row="3" Grid.Column="1" Height="24"
                             Margin="0,2" LostFocus="ConstructionHumanizeSetting_Changed" />
                    <TextBox x:Name="ConstructionHumanizeNoPlusMaxTextBox" Grid.Row="3" Grid.Column="2" Height="24"
                             Margin="6,2,0,2" LostFocus="ConstructionHumanizeSetting_Changed" />
                </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
