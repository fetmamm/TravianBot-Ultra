<UserControl x:Class="TbotUltra.Desktop.Views.BusyOverlayControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="RootControl"
             mc:Ignorable="d"
             Visibility="Collapsed"
             d:DesignHeight="240"
             d:DesignWidth="480">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <!-- Dark scrim captures all clicks so the only available action during the operation is Cancel. -->
    <Border Background="#CC111827">
        <Border Background="White"
                CornerRadius="10"
                Padding="30,26"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="440">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding Title, ElementName=RootControl}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" />
                <ProgressBar IsIndeterminate="True" Width="260" Height="6" Margin="0,0,0,14" />
                <TextBlock Text="{Binding Text, ElementName=RootControl}"
                           FontSize="13"
                           Foreground="#374151"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="360"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,18" />
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Width="120"
                        HorizontalAlignment="Center"
                        IsEnabled="{Binding CancelEnabled, ElementName=RootControl}"
                        Visibility="{Binding ShowCancel, ElementName=RootControl, Converter={StaticResource BoolToVisibility}}"
                        Click="CancelButton_Click" />
            </StackPanel>
        </Border>
    </Border>
</UserControl>
