<UserControl x:Class="TbotUltra.Desktop.Views.ReinforcementsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Grid Background="{DynamicResource AppBackgroundBrush}">
    <Border VerticalAlignment="Stretch"
            HorizontalAlignment="Stretch"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Reinforcements"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <Border Width="14"
                            Height="14"
                            Margin="8,3,0,0"
                            CornerRadius="7"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Top"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip MaxWidth="360">
                                <StackPanel Width="320">
                                    <TextBlock Text="Reinforcements"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TooltipForegroundBrush}"
                                               Margin="0,0,0,6" />
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Sends selected troops from chosen source villages to the selected target village as reinforcements." />
                                    <TextBlock Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               Text="Use the Troops button on each source village when different villages should send different troop types or amounts." />
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="i"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>
                </StackPanel>
                <TextBlock Grid.Row="1"
                           Text="Target village"
                           Foreground="{DynamicResource TextSubtleBrush}"
                           FontSize="12"
                           Margin="0,0,0,4" />
                <ComboBox Grid.Row="2"
                          x:Name="ReinforcementTargetVillageComboBox"
                          Height="30"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="ReinforcementSetting_SelectionChanged" />

                <Grid Grid.Row="3" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Source villages"
                               Foreground="{DynamicResource TextSubtleBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <Button x:Name="ReinforcementMarkAllTroopsButton"
                            Grid.Column="1"
                            Content="Mark all"
                            Padding="8,2"
                            Click="MarkAllReinforcementTroopsButton_Click" />
                    </Grid>
                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        MinHeight="160">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ReinforcementSourceVillagesItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding CanSelectAsSource}"
                                                  VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1"
                                                    Margin="8,0,8,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding TroopSummaryText}"
                                                       Foreground="{DynamicResource TextSubtleBrush}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Content="Troops"
                                                Padding="8,2"
                                                Tag="{Binding}"
                                                Click="ChooseReinforcementVillageTroopsButton_Click" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding SourceStatusText}"
                                                   Foreground="{DynamicResource BorderMutedBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
                </Grid>
                <TextBlock Grid.Row="4"
                           x:Name="ReinforcementTroopsSummaryTextBlock"
                           Text="No troops selected."
                           Foreground="{DynamicResource TextSubtleBrush}"
                           FontSize="12"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap" />
            </Grid>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Send troop settings"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,12" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="92" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="128" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Min (min)"
                               Foreground="{DynamicResource TextSubtleBrush}"
                               FontSize="12"
                               Margin="0,0,0,4" />
                    <TextBox Grid.Row="1"
                             Grid.Column="0"
                             x:Name="ReinforcementSendMinMinutesTextBox"
                             Height="28"
                             VerticalContentAlignment="Center"
                             LostFocus="ReinforcementSetting_TextChanged" />
                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Text="Max (min)"
                               Foreground="{DynamicResource TextSubtleBrush}"
                               FontSize="12"
                               Margin="0,0,0,4" />
                    <TextBox Grid.Row="1"
                             Grid.Column="2"
                             x:Name="ReinforcementSendMaxMinutesTextBox"
                             Height="28"
                             VerticalContentAlignment="Center"
                             LostFocus="ReinforcementSetting_TextChanged" />
                </Grid>
                <TextBlock x:Name="ReinforcementTroopsDetailTextBlock"
                           Text=""
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />
                <TextBlock x:Name="ReinforcementStatusTextBlock"
                           Text=""
                           Foreground="{DynamicResource WarningTextBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />
                <Button x:Name="ReinforcementQueueNowButton"
                        Content="Queue now"
                        Padding="10,4"
                        HorizontalAlignment="Left"
                        Margin="0,12,0,0"
                        Click="QueueReinforcementsNowButton_Click" />

                <Border Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,18,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Catapult waves"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Border Width="14"
                                    Height="14"
                                    CornerRadius="7"
                                    Background="{DynamicResource ControlBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    Margin="8,5,0,0"
                                    VerticalAlignment="Center"
                                    ToolTipService.InitialShowDelay="0">
                                <Border.ToolTip>
                                    <ToolTip MaxWidth="360">
                                        <StackPanel Width="320">
                                            <TextBlock Text="Catapult waves"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TooltipForegroundBrush}"
                                                       Margin="0,0,0,6" />
                                            <TextBlock TextWrapping="Wrap"
                                                       Text="Reads available troops from Rally Point, prepares one first attack and multiple attack waves. Catapult targets use Random automatically when catapults are included." />
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Text="i"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <Button x:Name="StartCatapultWavesButton"
                                Content="Start catapult waves"
                                Width="180"
                                HorizontalAlignment="Left"
                                IsEnabled="False"
                                ToolTip="Temporarily disabled — feature under review."
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White"
                                BorderBrush="{DynamicResource AccentBrush}"
                                Click="StartCatapultWavesButton_Click" />
                        <TextBlock x:Name="CatapultWavesStatusTextBlock"
                                   Text="No catapult waves running."
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Grid>
</UserControl>

