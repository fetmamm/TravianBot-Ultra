<UserControl x:Class="TbotUltra.Desktop.Views.HeroPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TbotUltra.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:HeroViewModel}"
             d:DesignHeight="600"
             d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="#F3F4F6">
        <StackPanel>
            <!-- Header -->
            <DockPanel Margin="2,2,2,12">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Hero / Adventures"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#111827" />
                    <TextBlock Text="Configure hero behaviour and queue adventures."
                               Foreground="#6B7280"
                               FontSize="12"
                               Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>

            <!-- Settings card -->
            <Border Background="#FFFFFF"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="2,0,2,12">
                <StackPanel>
                    <TextBlock Text="Settings"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Margin="0,0,0,10" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="210" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Hero min HP for adventure" Foreground="#374151" FontSize="12" />
                            <TextBox Text="{Binding MinHpForAdventure, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,12,0"
                                     Padding="6,4"
                                     BorderBrush="#E5E7EB" />
                            <TextBlock Text="Hero HP regen per day (%)" Foreground="#374151" FontSize="12" Margin="0,8,0,0" />
                            <ComboBox ItemsSource="{Binding HeroHpRegenOptions}"
                                      SelectedItem="{Binding HeroHpRegenPerDayPercent}"
                                      Margin="0,4,12,0"
                                      Padding="6,4" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="10,0,0,0">
                            <TextBlock Text="Automation"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       FontSize="12"
                                       Margin="0,0,0,8" />
                            <CheckBox Content="Auto revive" IsChecked="{Binding AutoRevive}" Margin="0,0,0,6" />
                            <CheckBox Content="Auto assign attribute points" IsChecked="{Binding AutoAssignPoints}" Margin="0,0,0,6" />
                            <CheckBox Content="Auto use ointments" IsChecked="{Binding AutoUseOintments}" Margin="0,0,0,6" />
                            <CheckBox Content="Manage hero defence"
                                      IsChecked="{Binding HideModeControlEnabled}" />
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Adventure pick order"
                                           Foreground="#374151"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Border Width="14"
                                        Height="14"
                                        Margin="6,0,0,0"
                                        CornerRadius="7"
                                        Background="#E5E7EB"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTipService.InitialShowDelay="0">
                                    <Border.ToolTip>
                                        <ToolTip MaxWidth="340">
                                            <StackPanel Width="300">
                                                <TextBlock Text="Adventure pick order"
                                                           FontWeight="SemiBold"
                                                           Foreground="#F9FAFB"
                                                           Margin="0,0,0,6" />
                                                <TextBlock TextWrapping="Wrap"
                                                           Text="Shortest adventure first queues the nearest adventure. Top adventure first queues the first adventure shown in the Travian list." />
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="i"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#4B5563"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center" />
                                </Border>
                            </StackPanel>
                            <Border Background="#FFFFFF"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10">
                                <StackPanel Orientation="Vertical">
                                    <RadioButton Content="Shortest adventure first"
                                                 GroupName="HeroAdventureOrder"
                                                 IsChecked="{Binding IsAdventurePickShortest}"
                                                 Margin="0,0,0,4" />
                                    <RadioButton Content="Top adventure first"
                                                 GroupName="HeroAdventureOrder"
                                                 IsChecked="{Binding IsAdventurePickTop}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Hero defense"
                                           Foreground="#374151"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Border Width="14"
                                        Height="14"
                                        Margin="6,0,0,0"
                                        CornerRadius="7"
                                        Background="#E5E7EB"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTipService.InitialShowDelay="0">
                                    <Border.ToolTip>
                                        <ToolTip MaxWidth="340">
                                            <StackPanel Width="300">
                                                <TextBlock Text="Hero defense"
                                                           FontWeight="SemiBold"
                                                           Foreground="#F9FAFB"
                                                           Margin="0,0,0,6" />
                                                <TextBlock TextWrapping="Wrap"
                                                           Text="Controls whether the hero hides during an attack on the home village or stays and fights with the troops." />
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="i"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#4B5563"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center" />
                                </Border>
                            </StackPanel>
                            <Border BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10"
                                    Opacity="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HideModeControlEnabled}" Value="False">
                                                <Setter Property="Background" Value="#F3F4F6" />
                                                <Setter Property="Opacity" Value="0.62" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Vertical"
                                            IsEnabled="{Binding HideModeControlEnabled}">
                                    <RadioButton Content="Hero will hide during an attack on their home village."
                                                 GroupName="HeroHideMode"
                                                 IsChecked="{Binding IsHideModeHide}"
                                                 Margin="0,0,0,4"
                                                 Checked="HeroHideModeRadio_Checked" />
                                    <RadioButton Content="Your hero will stay with the troops."
                                                 GroupName="HeroHideMode"
                                                 IsChecked="{Binding IsHideModeFight}"
                                                 Checked="HeroHideModeRadio_Checked" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Attribute priority + Adventures side by side -->
            <Grid Margin="2,0,2,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Attribute priority card -->
                <Border Grid.Column="0"
                        Background="#FFFFFF"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,6,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <TextBlock Text="Attribute priority"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           VerticalAlignment="Center" />
                                <Border Width="14"
                                        Height="14"
                                        Margin="6,0,0,0"
                                        CornerRadius="7"
                                        Background="#E5E7EB"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTipService.InitialShowDelay="0">
                                    <Border.ToolTip>
                                        <ToolTip MaxWidth="340">
                                            <StackPanel Width="300">
                                                <TextBlock Text="Attribute priority"
                                                           FontWeight="SemiBold"
                                                           Foreground="#F9FAFB"
                                                           Margin="0,0,0,6" />
                                                <TextBlock TextWrapping="Wrap"
                                                           Text="When auto assign attribute points is enabled, points are assigned in this order. Drag attributes to change priority." />
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="i"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#4B5563"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center" />
                                </Border>
                            </StackPanel>
                            <Button x:Name="RefreshHeroStatsButton"
                                    DockPanel.Dock="Right"
                                    Content="Refresh hero stats"
                                    Width="150"
                                    Click="RefreshHeroStatsButton_Click"
                                    Background="#FFFFFF"
                                    BorderBrush="#E5E7EB" />
                        </DockPanel>
                        <TextBlock Text="Drag to reorder"
                                   Foreground="#9CA3AF"
                                   FontSize="11"
                                   Margin="0,0,0,6" />
                        <Border BorderBrush="#F3F4F6"
                                BorderThickness="1"
                                Background="#FAFBFC"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <ListBox x:Name="HeroAttributePriorityItemsControl"
                                         HorizontalAlignment="Stretch"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         AllowDrop="True"
                                         ItemsSource="{Binding AttributePriorityItems}"
                                         PreviewMouseLeftButtonDown="HeroAttributePriorityItemsControl_PreviewMouseLeftButtonDown"
                                         PreviewMouseMove="HeroAttributePriorityItemsControl_PreviewMouseMove"
                                         Drop="HeroAttributePriorityItemsControl_Drop">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,0,4" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FFFFFF"
                                                    BorderBrush="#E5E7EB"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="28" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Order}"
                                                               VerticalAlignment="Center"
                                                               Foreground="#9CA3AF"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Title}"
                                                               VerticalAlignment="Center"
                                                               Foreground="#111827" />
                                                    <Border Grid.Column="2"
                                                            Background="#F3F4F6"
                                                            CornerRadius="4"
                                                            Padding="6,2">
                                                        <TextBlock Text="{Binding PointsText, StringFormat=Pts: {0}}"
                                                                   Foreground="#374151"
                                                                   FontSize="11" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="{Binding AttributesStatusText}"
                                           Foreground="#6B7280"
                                           FontSize="12"
                                           Margin="2,4,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Adventures card -->
                <Border Grid.Column="1"
                        Background="#FFFFFF"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Adventures"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,0,0,12" />
                        <DockPanel Margin="0,0,0,10">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <Border Background="#F0FDF4"
                                        BorderBrush="#BBF7D0"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,6"
                                        Margin="0,0,12,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F0FDF4" />
                                            <Setter Property="BorderBrush" Value="#BBF7D0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AdventureCountText}" Value="0">
                                                    <Setter Property="Background" Value="#F3F4F6" />
                                                    <Setter Property="BorderBrush" Value="#D1D5DB" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Available:" VerticalAlignment="Center" Margin="0,0,6,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#166534" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AdventureCountText}" Value="0">
                                                            <Setter Property="Foreground" Value="#6B7280" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding AdventureCountText}"
                                                   FontWeight="SemiBold"
                                                   FontSize="15"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#166534" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AdventureCountText}" Value="0">
                                                            <Setter Property="Foreground" Value="#6B7280" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <Button x:Name="RefreshAdventuresButton"
                                        Content="Refresh adventures"
                                        Width="160"
                                        Click="RefreshAdventuresButton_Click"
                                        Background="#FFFFFF"
                                        BorderBrush="#E5E7EB" />
                            </StackPanel>
                        </DockPanel>
                        <TextBlock Text="{Binding HeroStatusText}"
                                   Foreground="#111827"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Start adventure"
                                    Width="190"
                                    Click="QueueHeroManageButton_Click"
                                    Background="#030826"
                                    Foreground="White"
                                    BorderBrush="#030826" />
                        </StackPanel>
                        <TextBlock Text="{Binding AdventureStatusText}"
                                   Foreground="#6B7280"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
