<UserControl x:Class="TbotUltra.Desktop.Views.HeroPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TbotUltra.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:HeroViewModel}"
             d:DesignHeight="600"
             d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="{DynamicResource AppBackgroundBrush}">
        <StackPanel>
            <!-- Header -->
            <DockPanel Margin="2,2,2,12">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Hero / Adventures"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Configure hero behaviour and queue adventures."
                               Foreground="{DynamicResource TextSubtleBrush}"
                               FontSize="12"
                               Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>

            <!-- Settings card -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="2,0,2,12">
                <StackPanel>
                    <TextBlock Text="Settings"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,10" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="210" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="230" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Hero min HP for adventure" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                            <TextBox Text="{Binding MinHpForAdventure, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,12,0"
                                     Padding="6,4"
                                     BorderBrush="{DynamicResource BorderSubtleBrush}" />
                            <TextBlock Text="Hero HP regen per day (%)" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,8,0,0" />
                            <ComboBox ItemsSource="{Binding HeroHpRegenOptions}"
                                      SelectedItem="{Binding HeroHpRegenPerDayPercent}"
                                      Margin="0,4,12,0"
                                      Padding="6,4" />
                        </StackPanel>
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="Automation"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="12"
                                       Margin="0,0,0,8" />
                            <Border Grid.Row="1"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10">
                                <StackPanel>
                                    <CheckBox Content="Auto revive" IsChecked="{Binding AutoRevive}" Margin="0,0,0,6" />
                                    <CheckBox Content="Auto assign attribute points" IsChecked="{Binding AutoAssignPoints}" Margin="0,0,0,6" />
                                    <CheckBox Content="Auto use ointments" IsChecked="{Binding AutoUseOintments}" Margin="0,0,0,6" />
                                    <CheckBox Content="Manage hero defence"
                                              IsChecked="{Binding HideModeControlEnabled}"
                                              Margin="0,0,0,6" />
                                    <CheckBox Content="Increase adventures to hard"
                                              IsChecked="{Binding IncreaseAdventuresToHard}"
                                              Margin="0,0,0,6"
                                              ToolTip="When on, the adventure function first watches the bonus video to raise the next adventure's danger to hard (Official Travian only). Skipped automatically if it is already active." />
                                    <CheckBox Content="Reduce adventure time 25%"
                                              IsChecked="{Binding ReduceAdventureTime}"
                                              ToolTip="When on, the adventure function also watches the bonus video to reduce the next adventure's duration by 25% (after the increase-danger step). Official Travian only. Skipped automatically if it is already active." />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Border Grid.Column="4"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10">
                            <StackPanel>
                                <TextBlock Text="Adventures"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="12"
                                           Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,6"
                                            Margin="0,0,10,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource HeroAdvBgBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource HeroAdvBorderBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AdventureCountText}" Value="0">
                                                        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Available:"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessTextStrongBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AdventureCountText}" Value="0">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding AdventureCountText}"
                                                       FontWeight="SemiBold"
                                                       FontSize="15"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessTextStrongBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AdventureCountText}" Value="0">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <Button x:Name="RefreshAdventuresButton"
                                            Content="Refresh"
                                            Width="90"
                                            Click="RefreshAdventuresButton_Click"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderSubtleBrush}" />
                                </StackPanel>
                                <Button Content="Start adventure"
                                        HorizontalAlignment="Left"
                                        Width="150"
                                        Click="QueueHeroManageButton_Click"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="White"
                                        BorderBrush="{DynamicResource AccentBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Adventure pick order"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Border Width="14"
                                        Height="14"
                                        Margin="6,0,0,0"
                                        CornerRadius="7"
                                        Background="{DynamicResource ControlBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTipService.InitialShowDelay="0">
                                    <Border.ToolTip>
                                        <ToolTip MaxWidth="340">
                                            <StackPanel Width="300">
                                                <TextBlock Text="Adventure pick order"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TooltipForegroundBrush}"
                                                           Margin="0,0,0,6" />
                                                <TextBlock TextWrapping="Wrap"
                                                           Text="Shortest adventure first queues the nearest adventure. Top adventure first queues the first adventure shown in the Travian list." />
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="i"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center" />
                                </Border>
                            </StackPanel>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10">
                                <StackPanel Orientation="Vertical">
                                    <RadioButton Content="Shortest adventure first"
                                                 GroupName="HeroAdventureOrder"
                                                 IsChecked="{Binding IsAdventurePickShortest}"
                                                 Margin="0,0,0,4" />
                                    <RadioButton Content="Top adventure first"
                                                 GroupName="HeroAdventureOrder"
                                                 IsChecked="{Binding IsAdventurePickTop}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Hero defense"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Border Width="14"
                                        Height="14"
                                        Margin="6,0,0,0"
                                        CornerRadius="7"
                                        Background="{DynamicResource ControlBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTipService.InitialShowDelay="0">
                                    <Border.ToolTip>
                                        <ToolTip MaxWidth="340">
                                            <StackPanel Width="300">
                                                <TextBlock Text="Hero defense"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TooltipForegroundBrush}"
                                                           Margin="0,0,0,6" />
                                                <TextBlock TextWrapping="Wrap"
                                                           Text="Controls whether the hero hides during an attack on the home village or stays and fights with the troops." />
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="i"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center" />
                                </Border>
                            </StackPanel>
                            <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10"
                                    Opacity="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HideModeControlEnabled}" Value="False">
                                                <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
                                                <Setter Property="Opacity" Value="0.62" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Vertical"
                                            IsEnabled="{Binding HideModeControlEnabled}">
                                    <RadioButton Content="Hero will hide during an attack on their home village."
                                                 GroupName="HeroHideMode"
                                                 IsChecked="{Binding IsHideModeHide}"
                                                 Margin="0,0,0,4"
                                                 Checked="HeroHideModeRadio_Checked" />
                                    <RadioButton Content="Your hero will stay with the troops."
                                                 GroupName="HeroHideMode"
                                                 IsChecked="{Binding IsHideModeFight}"
                                                 Checked="HeroHideModeRadio_Checked" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Attribute priority + Hero inventory side by side -->
            <Grid Margin="2,0,2,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Attribute priority card -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,6,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <TextBlock Text="Attribute priority"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <Border Width="14"
                                        Height="14"
                                        Margin="6,0,0,0"
                                        CornerRadius="7"
                                        Background="{DynamicResource ControlBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTipService.InitialShowDelay="0">
                                    <Border.ToolTip>
                                        <ToolTip MaxWidth="340">
                                            <StackPanel Width="300">
                                                <TextBlock Text="Attribute priority"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TooltipForegroundBrush}"
                                                           Margin="0,0,0,6" />
                                                <TextBlock TextWrapping="Wrap"
                                                           Text="When auto assign attribute points is enabled, points are assigned in this order. Drag attributes to change priority." />
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="i"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center" />
                                </Border>
                            </StackPanel>
                            <Button x:Name="RefreshHeroStatsButton"
                                    DockPanel.Dock="Right"
                                    Content="Refresh hero stats"
                                    Width="150"
                                    Click="RefreshHeroStatsButton_Click"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}" />
                        </DockPanel>
                        <TextBlock Text="Drag to reorder"
                                   Foreground="{DynamicResource BorderMutedBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,6" />
                        <Border BorderBrush="{DynamicResource AppBackgroundBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource RowAltBackgroundBrush}"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <ListBox x:Name="HeroAttributePriorityItemsControl"
                                         HorizontalAlignment="Stretch"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         AllowDrop="True"
                                         ItemsSource="{Binding AttributePriorityItems}"
                                         PreviewMouseLeftButtonDown="HeroAttributePriorityItemsControl_PreviewMouseLeftButtonDown"
                                         PreviewMouseMove="HeroAttributePriorityItemsControl_PreviewMouseMove"
                                         Drop="HeroAttributePriorityItemsControl_Drop">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,0,4" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="28" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Order}"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource BorderMutedBrush}"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Title}"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                                    <Border Grid.Column="2"
                                                            Background="{DynamicResource AppBackgroundBrush}"
                                                            CornerRadius="4"
                                                            Padding="6,2">
                                                        <TextBlock Text="{Binding PointsText, StringFormat=Pts: {0}}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="11" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="{Binding AttributesStatusText}"
                                           Foreground="{DynamicResource TextSubtleBrush}"
                                           FontSize="12"
                                           Margin="2,4,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Hero inventory card (placed where Adventures used to be). -->
                <Border Grid.Column="1"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="6,0,0,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="Hero inventory"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                            <Button x:Name="RefreshHeroInventoryButton"
                                    DockPanel.Dock="Right"
                                    Content="Refresh hero inventory"
                                    Width="170"
                                    HorizontalAlignment="Right"
                                    Click="RefreshHeroInventoryButton_Click"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}" />
                        </DockPanel>

                        <!-- Reuse the resource colors and card treatment from the Storage UI. -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Margin="0,0,8,0" Padding="8" CornerRadius="8"
                                    Background="{DynamicResource WoodCardBgBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Wood" Foreground="{DynamicResource WoodTextBrush}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding HeroInventoryWood}" Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Margin="0,0,8,0" Padding="8" CornerRadius="8"
                                    Background="{DynamicResource ClayCardBgBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Clay" Foreground="{DynamicResource ClayTextBrush}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding HeroInventoryClay}" Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Margin="0,0,8,0" Padding="8" CornerRadius="8"
                                    Background="{DynamicResource IronCardBgBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Iron" Foreground="{DynamicResource IronTextBrush}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding HeroInventoryIron}" Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Padding="8" CornerRadius="8"
                                    Background="{DynamicResource CropCardBgBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Crop" Foreground="{DynamicResource CropTextBrush}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding HeroInventoryCrop}" Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Text="{Binding HeroInventoryStatusText}"
                                   Foreground="{DynamicResource TextSubtleBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />

                        <!-- Per-resource cap on how much may be pulled from the hero inventory for a
                             single construction top-up. When the needed amount for any resource exceeds
                             the limit, the transfer is skipped and the build waits until the village has
                             accumulated enough that the hero share fits the limit. -->
                        <Border BorderBrush="{DynamicResource AppBackgroundBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource RowAltBackgroundBrush}"
                                CornerRadius="6"
                                Padding="10">
                            <StackPanel>
                                <CheckBox Content="Max use limit"
                                          IsChecked="{Binding HeroResourceMaxUseEnabled}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          VerticalContentAlignment="Center" />
                                <TextBlock Text="Max resources used from the hero inventory per resource, per building."
                                           Foreground="{DynamicResource TextSubtleBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                            IsEnabled="{Binding HeroResourceMaxUseEnabled}">
                                    <TextBlock Text="Limit"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBox Width="100"
                                             Padding="6,4"
                                             Text="{Binding HeroResourceMaxUsePerResource, UpdateSourceTrigger=LostFocus}"
                                             BorderBrush="{DynamicResource BorderSubtleBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Per-consumer gates: which automation features may pull from the hero inventory
                             when they run short on resources. The master hero-resource toggle (Auto settings)
                             still applies on top of these. -->
                        <Border BorderBrush="{DynamicResource AppBackgroundBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource RowAltBackgroundBrush}"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,8,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Hero resources settings"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                                    Margin="6,2,0,0"
                                                    ToolTip="Pick which features may top up from the hero inventory when short on resources." />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <CheckBox Content="Construction"
                                              IsChecked="{Binding HeroResourceUseConstruction}"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              VerticalContentAlignment="Center" />
                                    <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                                    Margin="6,2,0,0"
                                                    ToolTip="Top up from the hero inventory for building and resource-field upgrades when the village runs short." />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <CheckBox Content="Smithy"
                                              IsChecked="{Binding HeroResourceUseSmithy}"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              VerticalContentAlignment="Center" />
                                    <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                                    Margin="6,2,0,0"
                                                    ToolTip="Top up from the hero inventory for troop upgrades in the Smithy when short on resources." />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox Content="Brewery"
                                              IsChecked="{Binding HeroResourceUseBrewery}"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              VerticalContentAlignment="Center" />
                                    <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                                    Margin="6,2,0,0"
                                                    ToolTip="Top up from the hero inventory to start a brewery celebration when short on resources." />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
