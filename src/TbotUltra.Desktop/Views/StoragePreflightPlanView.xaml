<UserControl x:Class="TbotUltra.Desktop.Views.StoragePreflightPlanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="470">
    <StackPanel>
        <TextBlock Text="{Binding Description}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="13"
                   LineHeight="19" />

        <StackPanel Orientation="Horizontal" Margin="0,14,0,10">
            <Border Padding="8,4"
                    CornerRadius="5"
                    Background="{DynamicResource SuccessBgBrush}"
                    BorderBrush="{DynamicResource SuccessBorderBrush}"
                    BorderThickness="1">
                <TextBlock Text="CONSTRUCT"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SuccessTextBrush}" />
            </Border>
            <Border Padding="8,4"
                    Margin="8,0,0,0"
                    CornerRadius="5"
                    Background="{DynamicResource InfoBgBrush}"
                    BorderBrush="{DynamicResource InfoBrush}"
                    BorderThickness="1">
                <TextBlock Text="UPGRADE"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource InfoTextBrush}" />
            </Border>
        </StackPanel>

        <ScrollViewer MaxHeight="410"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Stages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,6,10"
                                Padding="12"
                                CornerRadius="8"
                                Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Padding="8,4"
                                            CornerRadius="5"
                                            Background="{DynamicResource WarningBgBrush}"
                                            BorderBrush="{DynamicResource WarningBorderBrush}"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding Badge}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource WarningTextBrush}" />
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding Heading}"
                                               TextWrapping="Wrap"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Actions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,6"
                                                    Padding="10,8"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="82" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            Padding="7,3"
                                                            CornerRadius="4"
                                                            BorderThickness="1">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{DynamicResource InfoBgBrush}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource InfoBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Construct">
                                                                        <Setter Property="Background" Value="{DynamicResource SuccessBgBrush}" />
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBorderBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Label}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource InfoTextBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="Construct">
                                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessTextBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Margin="8,0,12,0">
                                                        <TextBlock Text="{Binding Building}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                                        <TextBlock Text="{Binding Details}"
                                                                   Margin="0,2,0,0"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="CAPACITY"
                                                                   HorizontalAlignment="Right"
                                                                   FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextSubtleBrush}" />
                                                        <TextBlock Text="{Binding Capacity}"
                                                                   Margin="0,2,0,0"
                                                                   HorizontalAlignment="Right"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding Requirement}"
                                           Margin="2,3,0,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource WarningTextBrush}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </StackPanel>
</UserControl>
