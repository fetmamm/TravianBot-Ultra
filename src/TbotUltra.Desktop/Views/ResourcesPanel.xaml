<UserControl x:Class="TbotUltra.Desktop.Views.ResourcesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Resources" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
            <StackPanel Orientation="Horizontal">
                <Button x:Name="LoadResourcesButton" Style="{StaticResource RefreshIconButtonStyle}" Margin="0,0,6,0" Click="LoadResourcesButton_Click" ToolTip="Refresh resources" IsEnabled="{Binding ActionsEnabled}" />
                <TextBlock Text="Target level" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox Width="90" Margin="0,0,8,0" ItemsSource="{Binding TargetLevelOptions}" SelectedItem="{Binding SelectedTargetLevel}" IsEnabled="{Binding ActionsEnabled}" />
                <Button Content="Upgrade all to level" Width="160" Background="{DynamicResource AccentBrush}" Foreground="White" BorderBrush="{DynamicResource AccentBrush}" Click="UpgradeAllResourcesButton_Click" IsEnabled="{Binding ActionsEnabled}"
                        ToolTip="Queue upgrades for every resource field up to the target level selected on the left, following the chosen Build order (Lowest level first or Smart)." />
                <Button Content="Upgrade to max" Width="140" Margin="8,0,0,0" Background="{DynamicResource WarningButtonBgBrush}" Foreground="{DynamicResource OnWarningBrush}" BorderBrush="{DynamicResource WarningBorderBrush}" Click="UpgradeAllResourcesToMaxButton_Click" IsEnabled="{Binding ActionsEnabled}"
                        ToolTip="Queue upgrades for every resource field up to its maximum level, following the chosen Build order (Lowest level first or Smart)." />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                <TextBlock Text="Build order:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,8,0" />
                <Border Width="14" Height="14" Margin="0,0,14,0" CornerRadius="7" Background="{DynamicResource ControlBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" VerticalAlignment="Center" ToolTipService.InitialShowDelay="0">
                    <Border.ToolTip>
                        <ToolTip MaxWidth="340">
                            <StackPanel Width="300">
                                <TextBlock Text="Build order" FontWeight="SemiBold" Foreground="{DynamicResource TooltipForegroundBrush}" Margin="0,0,0,6" />
                                <TextBlock TextWrapping="Wrap" Text="Lowest level first upgrades the resource field with the lowest level so fields rise evenly." />
                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="Smart prioritizes the resource you currently have the least of in storage and re-evaluates after each pass." />
                            </StackPanel>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock Text="i" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
                </Border>
                <RadioButton Content="Smart" GroupName="ResourceBuildStrategy" VerticalAlignment="Center" Margin="0,0,16,0"
                             IsChecked="{Binding IsBuildSmart}" Click="ResourceBuildStrategyRadio_Click"
                             ToolTip="When using 'Upgrade all', prioritize fields that produce the resource you currently have the least of in storage (wood/clay/iron/crop), re-evaluated each pass to balance your stockpile." />
                <RadioButton Content="Lowest level first" GroupName="ResourceBuildStrategy" VerticalAlignment="Center"
                             IsChecked="{Binding IsBuildLowestFirst}" Click="ResourceBuildStrategyRadio_Click"
                             ToolTip="When using 'Upgrade all', always upgrade the resource field with the lowest level first, so all fields rise evenly toward the target level." />
            </StackPanel>
            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,12,0,0">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Production" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding StorageBars}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="4" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,8,0" Padding="8" CornerRadius="6" Background="{Binding TrackBrush}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ProductionText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Background="{DynamicResource SurfaceBrush}" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <Grid HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Width="190" Margin="0,0,8,0">
                        <TextBlock Text="Woodcutter" Foreground="{DynamicResource WoodTextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding WoodFields}">
                            <ItemsControl.ItemTemplate><DataTemplate><Border Background="{DynamicResource WoodCardBgBrush}" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock VerticalAlignment="Center" Text="{Binding Name}" /><Button Grid.Column="1" Tag="{Binding}" Content="{Binding LevelLabel}" Style="{StaticResource ResourceLevelBadgeStyle}" Foreground="{DynamicResource WoodBadgeTextBrush}" Background="{DynamicResource WoodBadgeBgBrush}" BorderBrush="{DynamicResource WoodBadgeBorderBrush}" Click="ResourceLevelBadge_Click" ToolTip="Click to queue +1 level upgrade." /></Grid></Border></DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Width="190" Margin="0,0,8,0">
                        <TextBlock Text="Clay Pit" Foreground="{DynamicResource ClayTextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding ClayFields}">
                            <ItemsControl.ItemTemplate><DataTemplate><Border Background="{DynamicResource ClayCardBgBrush}" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock VerticalAlignment="Center" Text="{Binding Name}" /><Button Grid.Column="1" Tag="{Binding}" Content="{Binding LevelLabel}" Style="{StaticResource ResourceLevelBadgeStyle}" Foreground="{DynamicResource ClayBadgeTextBrush}" Background="{DynamicResource ClayBadgeBgBrush}" BorderBrush="{DynamicResource ClayBadgeBorderBrush}" Click="ResourceLevelBadge_Click" ToolTip="Click to queue +1 level upgrade." /></Grid></Border></DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Width="190" Margin="0,0,8,0">
                        <TextBlock Text="Iron Mine" Foreground="{DynamicResource IronTextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding IronFields}">
                            <ItemsControl.ItemTemplate><DataTemplate><Border Background="{DynamicResource IronCardBgBrush}" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock VerticalAlignment="Center" Text="{Binding Name}" /><Button Grid.Column="1" Tag="{Binding}" Content="{Binding LevelLabel}" Style="{StaticResource ResourceLevelBadgeStyle}" Foreground="{DynamicResource IronBadgeTextBrush}" Background="{DynamicResource IronBadgeBgBrush}" BorderBrush="{DynamicResource IronBadgeBorderBrush}" Click="ResourceLevelBadge_Click" ToolTip="Click to queue +1 level upgrade." /></Grid></Border></DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <StackPanel x:Name="CroplandColumnPanel" Grid.Column="3" Width="190">
                        <TextBlock Text="Cropland" Foreground="{DynamicResource CropTextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ItemsControl x:Name="CroplandItemsControl" ItemsSource="{Binding CroplandFields}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="1" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate><DataTemplate><Border Background="{DynamicResource CropCardBgBrush}" CornerRadius="6" Padding="8" Margin="0,0,0,6" Width="170"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock VerticalAlignment="Center" Text="{Binding Name}" /><Button Grid.Column="1" Tag="{Binding}" Content="{Binding LevelLabel}" Style="{StaticResource ResourceLevelBadgeStyle}" Foreground="{DynamicResource CropBadgeTextBrush}" Background="{DynamicResource CropBadgeBgBrush}" BorderBrush="{DynamicResource CropBadgeBorderBrush}" Click="ResourceLevelBadge_Click" ToolTip="Click to queue +1 level upgrade." /></Grid></Border></DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
        <TextBlock Visibility="Collapsed" Text="{Binding InfoText}" />
    </Grid>
</UserControl>
