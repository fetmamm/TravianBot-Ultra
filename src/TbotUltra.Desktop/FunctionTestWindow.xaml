<Window x:Class="TbotUltra.Desktop.FunctionTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Test functions"
        Height="180"
        Width="320"
        MinHeight="180"
        MinWidth="300"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Button x:Name="TestResourceProductionButton"
                Grid.Row="0"
                HorizontalAlignment="Left"
                Padding="10,4"
                Content="Read production/h"
                ToolTip="ReadCurrentPageResourceProductionPerHourAsync"
                ToolTipService.InitialShowDelay="0"
                Click="TestResourceProductionButton_Click" />

        <TextBlock Grid.Row="1"
                   Margin="0,10,0,0"
                   Text="Manual test functions for the current browser page."
                   TextWrapping="Wrap"
                   Foreground="DimGray" />
    </Grid>
</Window>
