<Window x:Class="TbotUltra.Desktop.ProxyLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TbotUltra.Desktop.Views"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Proxy list"
        Height="500"
        Width="820"
        MinHeight="380"
        MinWidth="700"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Closing="ProxyLibraryWindow_Closing">
    <Grid>
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="0,0,0,4"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SlateTextBrush}"
                       Text="Saved proxies are global. Assigning a proxy locks it to one account; Used by tracks accounts that have saved it." />
            <TextBlock x:Name="ActiveProxyTextBlock"
                       Grid.Row="1"
                       Margin="0,0,0,8"
                       TextWrapping="Wrap"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource InfoTextBrush}" />

            <DataGrid x:Name="ProxyDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  SelectionMode="Single">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource InfoBgBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Active" Binding="{Binding ActiveText}" IsReadOnly="True" Width="70" />
                <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                <DataGridTextColumn Header="Proxy" Binding="{Binding HostPort}" IsReadOnly="True" Width="150" />
                <DataGridTextColumn Header="Type" Binding="{Binding Scheme}" IsReadOnly="True" Width="80" />
                <DataGridTextColumn Header="Country" Binding="{Binding Country}" IsReadOnly="True" Width="110" />
                <DataGridTextColumn Header="Latency" Binding="{Binding LatencyText}" IsReadOnly="True" Width="80" />
                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" IsReadOnly="True" Width="90" />
                <DataGridTemplateColumn Header="Assigned to" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.AccountChoices, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding AssignedAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="False" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Used by" Binding="{Binding UsedByText}" IsReadOnly="True" Width="*" />
                <DataGridTemplateColumn Width="90">
                    <DataGridTemplateColumn.Header>
                        <Button Content="Delete all"
                                Width="78"
                                Height="22"
                                Padding="0"
                                Background="{DynamicResource DangerBgBrush}"
                                BorderBrush="{DynamicResource DangerBorderBrush}"
                                Foreground="{DynamicResource DangerTextBrush}"
                                Click="DeleteAllButton_Click" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Delete"
                                    Width="66"
                                    Height="26"
                                    Margin="0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource DangerBgBrush}"
                                    BorderBrush="{DynamicResource DangerBorderBrush}"
                                    Foreground="{DynamicResource DangerTextBrush}"
                                    Click="DeleteRowButton_Click" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

            <DockPanel Grid.Row="3" Margin="0,12,0,0">
                <Button DockPanel.Dock="Left"
                        Width="110"
                        Content="Check proxies"
                        Click="CheckProxiesButton_Click" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Width="100" Margin="0,0,8,0" Content="Add proxy" Click="AddProxyButton_Click" />
                    <Button Width="100" Margin="0,0,8,0" Content="Save" Click="SaveButton_Click" />
                    <Button Width="100" Content="Close" Click="CloseButton_Click" />
                </StackPanel>
            </DockPanel>
        </Grid>

        <views:BusyOverlayControl x:Name="BusyOverlay"
                                  Title="Checking proxies"
                                  Text="Preparing..."
                                  Cancelled="BusyOverlay_Cancelled" />
    </Grid>
</Window>
