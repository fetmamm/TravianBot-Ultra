<Window x:Class="TbotUltra.Desktop.ProxyLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TbotUltra.Desktop.Views"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Proxy list"
        Height="500"
        Width="1040"
        MinHeight="380"
        MinWidth="920"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Closing="ProxyLibraryWindow_Closing">
    <Grid>
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="0,0,0,4"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SlateTextBrush}"
                       Text="Saved proxies are global. Assigning a proxy locks it to one account; Used by tracks accounts that have saved it." />
            <TextBlock x:Name="ActiveProxyTextBlock"
                       Grid.Row="1"
                       Margin="0,0,0,8"
                       TextWrapping="Wrap"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource InfoTextBrush}" />

            <DataGrid x:Name="ProxyDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="230">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessTextBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Proxy" IsReadOnly="True" Width="190">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding HostPort}" VerticalAlignment="Center">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <TextBlock>
                                            <Run Text="IP: " /><Run Text="{Binding Host}" /><LineBreak />
                                            <Run Text="Port: " /><Run Text="{Binding Port}" /><LineBreak />
                                            <Run Text="Type: " /><Run Text="{Binding Scheme}" /><LineBreak />
                                            <Run Text="Country: " /><Run Text="{Binding CountryDisplay}" />
                                        </TextBlock>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Latency" Binding="{Binding LatencyText}" IsReadOnly="True" Width="80" />
                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" IsReadOnly="True" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsWorking}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessTextBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsWorking}" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsWorking}" Value="{x:Null}">
                                    <Setter Property="Foreground" Value="{DynamicResource WarningTextBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Assigned to"
                                        SortMemberPath="AssignedAccount"
                                        CanUserSort="True"
                                        Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.AccountChoices, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding AssignedAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="False" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Used by" Binding="{Binding UsedByText}" IsReadOnly="True" Width="*" />
                <DataGridTemplateColumn Width="90">
                    <DataGridTemplateColumn.Header>
                        <Button Content="Delete all"
                                Width="78"
                                Height="22"
                                Padding="0"
                                Background="{DynamicResource DangerBgBrush}"
                                BorderBrush="{DynamicResource DangerBorderBrush}"
                                Foreground="{DynamicResource DangerTextBrush}"
                                Click="DeleteAllButton_Click" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Delete"
                                    Width="66"
                                    Height="26"
                                    Margin="0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource DangerBgBrush}"
                                    BorderBrush="{DynamicResource DangerBorderBrush}"
                                    Foreground="{DynamicResource DangerTextBrush}"
                                    Click="DeleteRowButton_Click" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

            <DockPanel Grid.Row="3" Margin="0,12,0,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Width="110"
                            Content="Check proxies"
                            Click="CheckProxiesButton_Click" />
                    <Button Width="142"
                            Margin="8,0,0,0"
                            Content="Delete failed proxies"
                            Background="{DynamicResource DangerBgBrush}"
                            BorderBrush="{DynamicResource DangerBorderBrush}"
                            Foreground="{DynamicResource DangerTextBrush}"
                            Click="DeleteFailedProxiesButton_Click" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Width="100" Margin="0,0,8,0" Content="Add proxy" Click="AddProxyButton_Click" />
                    <Button Width="100" Margin="0,0,8,0" Content="Save" Click="SaveButton_Click" />
                    <Button Width="100" Content="Close" Click="CloseButton_Click" />
                </StackPanel>
            </DockPanel>
        </Grid>

        <views:BusyOverlayControl x:Name="BusyOverlay"
                                  Title="Checking proxies"
                                  Text="Preparing..."
                                  Cancelled="BusyOverlay_Cancelled" />
    </Grid>
</Window>
