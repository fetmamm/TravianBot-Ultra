<Window x:Class="TbotUltra.Desktop.TroopTrainingOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Training options"
        Width="960"
        MinHeight="360"
        Height="560"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6" VerticalAlignment="Center">
            <TextBlock Text="Troop training by village"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                            Margin="8,2,0,0"
                            ToolTip="Quick per-village controls for which training buildings are active and which troop each one builds. Other troop settings stay unchanged." />
        </StackPanel>

        <TextBlock x:Name="SubtitleTextBlock"
                   Grid.Row="1"
                   Foreground="{DynamicResource TextSubtleBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10" />

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,0,8,6"
                Margin="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="240" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Village"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSubtleBrush}" />
                <TextBlock Grid.Column="1"
                           Text="Barracks"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSubtleBrush}" />
                <TextBlock Grid.Column="2"
                           Text="Stable"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSubtleBrush}" />
                <TextBlock Grid.Column="3"
                           Text="Workshop"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSubtleBrush}" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Padding="0,0,4,0">
            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8,8">
                            <Grid MinWidth="910">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="240" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding VillageName}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,0,12,0" />

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,0,14,0">
                                    <CheckBox Width="22"
                                              VerticalAlignment="Center"
                                              ToolTip="Enable Barracks training for this village."
                                              IsChecked="{Binding Barracks.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Width="180"
                                              ItemsSource="{Binding Barracks.TroopOptions}"
                                              SelectedItem="{Binding Barracks.SelectedTroop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding Barracks.IsEnabled}"
                                              HorizontalContentAlignment="Left" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,0,14,0">
                                    <CheckBox Width="22"
                                              VerticalAlignment="Center"
                                              ToolTip="Enable Stable training for this village."
                                              IsChecked="{Binding Stable.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Width="180"
                                              ItemsSource="{Binding Stable.TroopOptions}"
                                              SelectedItem="{Binding Stable.SelectedTroop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding Stable.IsEnabled}"
                                              HorizontalContentAlignment="Left" />
                                </StackPanel>

                                <StackPanel Grid.Column="3"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <CheckBox Width="22"
                                              VerticalAlignment="Center"
                                              ToolTip="Enable Workshop training for this village."
                                              IsChecked="{Binding Workshop.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Width="180"
                                              ItemsSource="{Binding Workshop.TroopOptions}"
                                              SelectedItem="{Binding Workshop.SelectedTroop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding Workshop.IsEnabled}"
                                              HorizontalContentAlignment="Left" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="72"
                    Height="28"
                    Content="Cancel"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click" />
            <Button Width="110"
                    Height="28"
                    Content="Save &amp; close"
                    Click="SaveButton_Click"
                    Background="{DynamicResource PrimaryButtonBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    Foreground="{DynamicResource OnAccentBrush}" />
        </StackPanel>
    </Grid>
</Window>
