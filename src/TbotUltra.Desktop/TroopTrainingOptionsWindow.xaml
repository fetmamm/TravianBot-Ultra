<Window x:Class="TbotUltra.Desktop.TroopTrainingOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Training options"
        Width="760"
        MinHeight="320"
        MaxHeight="760"
        SizeToContent="Height"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6" VerticalAlignment="Center">
            <TextBlock Text="Build troops"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                            Margin="8,2,0,0"
                            ToolTip="Per-building troop training for the village shown below. Use &quot;Sync to all villages&quot; to copy these settings to every village. A village without its own settings uses the global troop config." />
        </StackPanel>

        <TextBlock x:Name="SubtitleTextBlock"
                   Grid.Row="1"
                   Foreground="{DynamicResource TextSubtleBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10" />

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0,0,4,0">
            <StackPanel>
                <StackPanel Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Resources to check for % resources"
                                   Foreground="{DynamicResource TextSubtleBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                        <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                        Margin="6,0,0,0"
                                        ToolTip="Only selected resources are checked when Run trigger is set to % resources." />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Content="Wood"
                                  Margin="0,0,12,0"
                                  IsChecked="{Binding CheckWood, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Content="Clay"
                                  Margin="0,0,12,0"
                                  IsChecked="{Binding CheckClay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Content="Iron"
                                  Margin="0,0,12,0"
                                  IsChecked="{Binding CheckIron, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Content="Crop"
                                  IsChecked="{Binding CheckCrop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Fallback wait when no exact troop ETA exists"
                                   Foreground="{DynamicResource TextSubtleBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                        <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                        Margin="6,0,0,0"
                                        ToolTip="Used when the bot cannot read an exact troop queue ETA. It waits this long before checking again." />
                    </StackPanel>
                    <ComboBox Width="120"
                              HorizontalAlignment="Left"
                              SelectedValuePath="Tag"
                              SelectedValue="{Binding FallbackCooldownSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBoxItem Content="10s" Tag="10" />
                        <ComboBoxItem Content="30s" Tag="30" />
                        <ComboBoxItem Content="1 min" Tag="60" />
                        <ComboBoxItem Content="2 min" Tag="120" />
                        <ComboBoxItem Content="5 min" Tag="300" />
                        <ComboBoxItem Content="10 min" Tag="600" />
                    </ComboBox>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Buildings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,0,10"
                                    Background="{DynamicResource SurfaceAltBrush}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="Troop"
                                                   Foreground="{DynamicResource TextSubtleBrush}"
                                                   FontSize="11"
                                                   Margin="8,4,0,0"
                                                   VerticalAlignment="Bottom" />
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Bottom">
                                            <TextBlock Text="Max build queue"
                                                       Foreground="{DynamicResource TextSubtleBrush}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center" />
                                            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                                            Margin="6,0,0,0"
                                                            ToolTip="Limits how much training time may already be queued for this building before the bot skips adding more troops." />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Bottom">
                                            <TextBlock Text="Amount mode"
                                                       Foreground="{DynamicResource TextSubtleBrush}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center" />
                                            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                                            Margin="6,0,0,0"
                                                            ToolTip="Maximum spends available resources on as many troops as possible. Keep resources reserves the selected percent before training." />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Bottom">
                                            <TextBlock Text="Keep %"
                                                       Foreground="{DynamicResource TextSubtleBrush}"
                                                       FontSize="11"
                                                       VerticalAlignment="Bottom" />
                                            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                                            Margin="6,0,0,0"
                                                            ToolTip="Only used when Amount mode is Keep resources. The bot keeps this percent of each resource and spends the rest on training." />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  Content="Build troops"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <ComboBox Grid.Column="1"
                                                  Margin="8,0,8,0"
                                                  ItemsSource="{Binding TroopOptions}"
                                                  SelectedItem="{Binding SelectedTroop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Width="120"
                                                  HorizontalAlignment="Left"
                                                  HorizontalContentAlignment="Left" />

                                        <ComboBox Grid.Column="2"
                                                  Margin="0,0,8,0"
                                                  Width="80"
                                                  HorizontalAlignment="Left"
                                                  HorizontalContentAlignment="Left"
                                                  SelectedValuePath="Tag"
                                                  SelectedValue="{Binding MaxQueueMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBoxItem Content="1h" Tag="1" />
                                            <ComboBoxItem Content="2h" Tag="2" />
                                            <ComboBoxItem Content="3h" Tag="3" />
                                            <ComboBoxItem Content="5h" Tag="5" />
                                            <ComboBoxItem Content="10h" Tag="10" />
                                            <ComboBoxItem Content="20h" Tag="20" />
                                            <ComboBoxItem Content="50h" Tag="50" />
                                            <ComboBoxItem Content="100h" Tag="100" />
                                            <ComboBoxItem Content="No limit" Tag="no_limit" />
                                        </ComboBox>

                                        <ComboBox Grid.Column="3"
                                                  Margin="0,0,8,0"
                                                  Width="100"
                                                  HorizontalAlignment="Left"
                                                  HorizontalContentAlignment="Left"
                                                  SelectedValuePath="Tag"
                                                  SelectedValue="{Binding AmountMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBoxItem Content="Maximum" Tag="maximum" />
                                            <ComboBoxItem Content="Keep resources" Tag="keep_resources" />
                                        </ComboBox>

                                        <ComboBox Grid.Column="4"
                                                  Width="80"
                                                  HorizontalAlignment="Left"
                                                  HorizontalContentAlignment="Left"
                                                  SelectedValuePath="Tag"
                                                  SelectedValue="{Binding KeepResourcesPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding UsesKeepResourcesMode}">
                                            <ComboBoxItem Content="0%" Tag="0" />
                                            <ComboBoxItem Content="5%" Tag="5" />
                                            <ComboBoxItem Content="10%" Tag="10" />
                                            <ComboBoxItem Content="15%" Tag="15" />
                                            <ComboBoxItem Content="20%" Tag="20" />
                                            <ComboBoxItem Content="25%" Tag="25" />
                                            <ComboBoxItem Content="30%" Tag="30" />
                                            <ComboBoxItem Content="40%" Tag="40" />
                                            <ComboBoxItem Content="50%" Tag="50" />
                                            <ComboBoxItem Content="60%" Tag="60" />
                                            <ComboBoxItem Content="70%" Tag="70" />
                                            <ComboBoxItem Content="80%" Tag="80" />
                                            <ComboBoxItem Content="90%" Tag="90" />
                                        </ComboBox>
                                    </Grid>

                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Run trigger"
                                                       Foreground="{DynamicResource TextSubtleBrush}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center" />
                                            <ContentControl Style="{DynamicResource InfoTooltipIconStyle}"
                                                            Margin="6,0,0,0"
                                                            ToolTip="Min troops trains when the troop count drops below the value. % resources trains when resources reach the selected percent." />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <RadioButton Content="Min troops"
                                                         Margin="0,0,12,0"
                                                         IsChecked="{Binding IsMinimumTroopsMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <RadioButton Content="% resources"
                                                         IsChecked="{Binding IsResourcePercentMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <Grid Grid.Column="2">
                                            <TextBox Width="88"
                                                     Height="28"
                                                     HorizontalAlignment="Left"
                                                     VerticalAlignment="Center"
                                                     Text="{Binding MinimumTroopsText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UsesMinimumTroopsMode}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>

                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UsesResourcePercentMode}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Slider Width="170"
                                                        Minimum="0"
                                                        Maximum="100"
                                                        TickFrequency="1"
                                                        IsSnapToTickEnabled="True"
                                                        Value="{Binding MinimumResourcesPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="{Binding MinimumResourcesPercent, StringFormat={}{0}%}"
                                                           Margin="10,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="72"
                    Height="28"
                    Content="Cancel"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click" />
            <Button Width="150"
                    Height="28"
                    Content="Sync to all villages"
                    Margin="0,0,8,0"
                    Click="SyncToAllButton_Click" />
            <Button Width="110"
                    Height="28"
                    Content="Save &amp; close"
                    Click="SaveButton_Click"
                    Background="{DynamicResource PrimaryButtonBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    Foreground="{DynamicResource OnAccentBrush}" />
        </StackPanel>
    </Grid>
</Window>
