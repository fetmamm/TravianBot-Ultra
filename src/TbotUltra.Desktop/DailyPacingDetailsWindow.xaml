<Window x:Class="TbotUltra.Desktop.DailyPacingDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Daily details"
        Width="780"
        Height="520"
        MinWidth="680"
        MinHeight="420"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Online time today" Foreground="{DynamicResource TextSubtleBrush}" FontSize="11" />
                    <TextBlock x:Name="OnlineTodayTextBlock" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="Waiting today" Foreground="{DynamicResource TextSubtleBrush}" FontSize="11" />
                    <TextBlock x:Name="WaitingTodayTextBlock" Foreground="{DynamicResource WarningBrush}" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="12,0,0,0">
                    <TextBlock Text="Time left" Foreground="{DynamicResource TextSubtleBrush}" FontSize="11" />
                    <TextBlock x:Name="TimeLeftTextBlock" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="12,0,0,0">
                    <TextBlock Text="Daily limit" Foreground="{DynamicResource TextSubtleBrush}" FontSize="11" />
                    <TextBlock x:Name="DailyLimitTextBlock" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="4" Margin="12,0,0,0">
                    <TextBlock Text="Week total" Foreground="{DynamicResource TextSubtleBrush}" FontSize="11" />
                    <TextBlock x:Name="WeekTotalTextBlock" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="5" Margin="12,0,0,0">
                    <TextBlock Text="Account total" Foreground="{DynamicResource TextSubtleBrush}" FontSize="11" />
                    <TextBlock x:Name="AccountTotalTextBlock" Foreground="{DynamicResource SuccessTextBrush}" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Online">
                <DataGrid x:Name="WeekDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Margin="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*" />
                        <DataGridTextColumn Header="Online" Binding="{Binding Online}" Width="*" />
                        <DataGridTextColumn Header="Waiting" Binding="{Binding Waiting}" Width="*" />
                        <DataGridTextColumn Header="Limit" Binding="{Binding Limit}" Width="*" />
                        <DataGridTextColumn Header="Usage" Binding="{Binding Usage}" Width="1.4*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Graph">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Margin="0,4,0,0">
                    <Canvas x:Name="ChartCanvas"
                            Background="Transparent"
                            ClipToBounds="True"
                            SizeChanged="ChartCanvas_SizeChanged" />
                </Border>
            </TabItem>

            <TabItem Header="Tasks">
                <DataGrid x:Name="TaskDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Margin="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Task" Binding="{Binding Task}" Width="2*" />
                        <DataGridTextColumn Header="Runs" Binding="{Binding Runs}" Width="*" />
                        <DataGridTextColumn Header="Last run" Binding="{Binding LastRun}" Width="1.4*" />
                        <DataGridTextColumn Header="Peak hour" Binding="{Binding PeakHour}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Timeline">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Margin="0,4,0,0">
                    <DockPanel>
                        <!-- Legend pinned outside the scroll area so it is always visible without scrolling. -->
                        <StackPanel DockPanel.Dock="Bottom"
                                    Orientation="Horizontal"
                                    Margin="4,8,0,0">
                            <Rectangle Width="10" Height="10" RadiusX="2" RadiusY="2"
                                       Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="Task" Foreground="{DynamicResource TextSubtleBrush}"
                                       FontSize="10" Margin="5,0,16,0" VerticalAlignment="Center" />
                            <Rectangle Width="10" Height="10" RadiusX="2" RadiusY="2"
                                       Fill="{DynamicResource WarningBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="Waiting" Foreground="{DynamicResource TextSubtleBrush}"
                                       FontSize="10" Margin="5,0,16,0" VerticalAlignment="Center" />
                            <Rectangle Width="10" Height="10" RadiusX="2" RadiusY="2"
                                       Fill="{DynamicResource InfoBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="Sleeping" Foreground="{DynamicResource TextSubtleBrush}"
                                       FontSize="10" Margin="5,0,16,0" VerticalAlignment="Center" />
                            <Rectangle Width="10" Height="10" RadiusX="2" RadiusY="2" Opacity="0.45"
                                       Fill="{DynamicResource BorderBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="Offline" Foreground="{DynamicResource TextSubtleBrush}"
                                       FontSize="10" Margin="5,0,16,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <Canvas x:Name="TimelineCanvas"
                                    Background="Transparent"
                                    ClipToBounds="True"
                                    SizeChanged="TimelineCanvas_SizeChanged" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </TabItem>
        </TabControl>

        <Button Grid.Row="2"
                Content="Close"
                Width="90"
                Height="30"
                HorizontalAlignment="Right"
                Margin="0,14,0,0"
                Click="CloseButton_Click" />
    </Grid>
</Window>
