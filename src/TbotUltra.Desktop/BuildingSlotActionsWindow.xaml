<Window x:Class="TbotUltra.Desktop.BuildingSlotActionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Building slot actions"
        Width="260"
        SizeToContent="Height"
        MinHeight="280"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,6" />

        <TextBlock x:Name="SubtitleTextBlock"
                   Grid.Row="1"
                   Foreground="{DynamicResource TextSubtleBrush}"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap" />

        <!-- Next-level estimate: build time + colored resource cost. Hidden when unavailable. -->
        <Border x:Name="NextLevelEstimateBorder"
                Grid.Row="2"
                Margin="0,0,0,12"
                Padding="8,6"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="NextLevelTitleTextBlock"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Time "
                               Foreground="{DynamicResource TextSubtleBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="NextLevelTimeTextBlock"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="NextLevelConstructFasterTimeTextBlock"
                               Foreground="{DynamicResource ConstructFasterBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <TextBlock x:Name="NextLevelWoodTextBlock" Text="-" Foreground="{DynamicResource WoodTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text=" | " Foreground="{DynamicResource TextSubtleBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="NextLevelClayTextBlock" Text="-" Foreground="{DynamicResource ClayTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text=" | " Foreground="{DynamicResource TextSubtleBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="NextLevelIronTextBlock" Text="-" Foreground="{DynamicResource IronTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text=" | " Foreground="{DynamicResource TextSubtleBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="NextLevelCropTextBlock" Text="-" Foreground="{DynamicResource CropTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3">
            <Button x:Name="BuildBuildingButton"
                    Content="Build building"
                    Height="28"
                    Margin="0,0,0,6"
                    Click="BuildBuildingButton_Click" />
            <Button x:Name="UpgradeButton"
                    Content="Upgrade to..."
                    Height="28"
                    Margin="0,0,0,6"
                    Click="UpgradeButton_Click" />
            <Button x:Name="UpgradeOneLevelButton"
                    Content="Upgrade one level"
                    Height="28"
                    Margin="0,0,0,6"
                    Click="UpgradeOneLevelButton_Click" />
            <Button x:Name="UpgradeToMaxButton"
                    Content="Upgrade to max"
                    Height="28"
                    Margin="0,0,0,6"
                    Background="{DynamicResource WarningButtonBgBrush}"
                    Foreground="{DynamicResource OnWarningBrush}"
                    BorderBrush="{DynamicResource WarningBorderBrush}"
                    Click="UpgradeToMaxButton_Click" />
            <Button x:Name="DemolishButton"
                    Content="Demolish"
                    Height="28"
                    Margin="0,0,0,3"
                    Click="DemolishButton_Click" />
            <TextBlock x:Name="DemolishRequirementTextBlock"
                       Foreground="{DynamicResource BurntOrangeTextBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="2,0,0,6"
                       Visibility="Collapsed" />
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="88"
                    Height="28"
                    Content="Cancel"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
