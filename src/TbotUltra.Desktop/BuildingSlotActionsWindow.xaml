<Window x:Class="TbotUltra.Desktop.BuildingSlotActionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Building slot actions"
        Width="260"
        SizeToContent="Height"
        MinHeight="280"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#111827"
                   Margin="0,0,0,6" />

        <TextBlock x:Name="SubtitleTextBlock"
                   Grid.Row="1"
                   Foreground="#6B7280"
                   Margin="0,0,0,12"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="2">
            <Button x:Name="BuildBuildingButton"
                    Content="Build building"
                    Height="28"
                    Margin="0,0,0,6"
                    Click="BuildBuildingButton_Click" />
            <Button x:Name="UpgradeButton"
                    Content="Upgrade to..."
                    Height="28"
                    Margin="0,0,0,6"
                    Click="UpgradeButton_Click" />
            <Button x:Name="UpgradeOneLevelButton"
                    Content="Upgrade one level"
                    Height="28"
                    Margin="0,0,0,6"
                    Click="UpgradeOneLevelButton_Click" />
            <Button x:Name="UpgradeToMaxButton"
                    Content="Upgrade to max"
                    Height="28"
                    Margin="0,0,0,6"
                    Click="UpgradeToMaxButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#FCD34D" />
                        <Setter Property="Foreground" Value="#1F2937" />
                        <Setter Property="BorderBrush" Value="#F59E0B" />
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6B7280" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button x:Name="DemolishButton"
                    Content="Demolish"
                    Height="28"
                    Margin="0,0,0,3"
                    Click="DemolishButton_Click" />
            <TextBlock x:Name="DemolishRequirementTextBlock"
                       Foreground="#C2410C"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="2,0,0,6"
                       Visibility="Collapsed" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="88"
                    Height="28"
                    Content="Cancel"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
