<Window x:Class="TbotUltra.Desktop.ProxyScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Proxy schedule"
        Width="1050"
        Height="560"
        MinWidth="900"
        MinHeight="520"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="210" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                <TextBlock Text="Proxy rotation" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ContentControl Style="{DynamicResource InfoTooltipIconStyle}" Margin="7,1,0,0"
                                ToolTip="Allowed hours from Settings are shown first. Add one row per proxy and check the hours that proxy should use." />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <TextBlock Text="Variation (%)" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox x:Name="VariationTextBox" Width="48" Margin="8,0,0,0" TextChanged="VariationTextBox_TextChanged" />
                <ContentControl Style="{DynamicResource InfoTooltipIconStyle}" Margin="7,1,0,0"
                                ToolTip="Schedule variation can be 0–49%. 30% means each boundary can move by up to ±18 minutes." />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,8">
                    <Button Content="Add proxy" Width="100" DockPanel.Dock="Left"
                            Background="{DynamicResource SuccessBrush}"
                            BorderBrush="{DynamicResource SuccessBrush}"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Click="AddProxyButton_Click" />
                    <TextBlock Text="Checked hours are active. Each hour may belong to only one proxy for the same day group."
                               Margin="12,4,0,0" Foreground="{DynamicResource SlateTextBrush}" />
                </DockPanel>
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="TimelineGrid" />
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="0,12,0,0" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5"
                Background="{DynamicResource ControlBackgroundBrush}">
            <TextBlock x:Name="ValidationTextBlock" Text="Add proxies and press Validate setup." TextWrapping="Wrap" />
        </Border>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button x:Name="ValidateButton" Content="Validate setup" Width="120" Click="ValidateButton_Click" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Proxy list" Width="100" Margin="0,0,8,0" Click="ProxyListButton_Click" />
                <Button x:Name="SaveButton" Content="Save" Width="100"
                        Background="{DynamicResource SuccessBrush}"
                        BorderBrush="{DynamicResource SuccessBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Click="SaveButton_Click" />
                <Button Content="Cancel" Width="90" Margin="8,0,0,0" Click="CancelButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
