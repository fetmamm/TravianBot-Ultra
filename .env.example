# Copy this file to .env and fill in your own accounts.
# Do not commit .env to GitHub.

TBOT_ACTIVE_ACCOUNT=main
TBOT_ACCOUNTS=main

TBOT_MAIN_USERNAME=your_username_or_email
TBOT_MAIN_PASSWORD=your_password

# Example for a second account:
# TBOT_ACCOUNTS=main,alt
# TBOT_ALT_USERNAME=another_username_or_email
# TBOT_ALT_PASSWORD=another_password

